{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3.0",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "amphp/http-client": "4.2.1",
        "doctrine/annotations": "^2.0",
        "doctrine/doctrine-bundle": "^2.4",
        "doctrine/doctrine-migrations-bundle": "^3.1",
        "doctrine/orm": "^2.14",
        "easycorp/easyadmin-bundle": "4.*.*",
        "knplabs/knp-paginator-bundle": "6.*.*",
        "phpdocumentor/reflection-docblock": "^5.3",
        "phpstan/phpdoc-parser": "^1.19",
        "symfony/asset": "7.*.*",
        "symfony/asset-mapper": "7.*.*",
        "symfony/console": "7.*.*",
        "symfony/doctrine-messenger": "7.*.*",
        "symfony/dotenv": "7.*.*",
        "symfony/expression-language": "7.*.*",
        "symfony/flex": "^1.17|^2",
        "symfony/form": "7.*.*",
        "symfony/framework-bundle": "7.*.*",
        "symfony/http-client": "7.*.*",
        "symfony/intl": "7.*.*",
        "symfony/mailer": "7.*.*",
        "symfony/mime": "7.*.*",
        "symfony/monolog-bundle": "^3.0",
        "symfony/notifier": "7.*.*",
        "symfony/process": "7.*.*",
        "symfony/property-access": "7.*.*",
        "symfony/property-info": "7.*.*",
        "symfony/rate-limiter": "7.*.*",
        "symfony/runtime": "7.*.*",
        "symfony/security-bundle": "7.*.*",
        "symfony/serializer": "7.*.*",
        "symfony/stimulus-bundle": "^2.13",
        "symfony/string": "7.*.*",
        "symfony/translation": "7.*.*",
        "symfony/twig-bundle": "7.*.*",
        "symfony/ux-live-component": "^2.13",
        "symfony/ux-toggle-password": "^2.13",
        "symfony/ux-turbo": "^2.13",
        "symfony/ux-twig-component": "^2.13",
        "symfony/validator": "7.*.*",
        "symfony/web-link": "7.*.*",
        "symfony/yaml": "7.*.*",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/twig": "^2.12|^3.0",
        "vich/uploader-bundle": "2.*.*"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "check-cs": "vendor/bin/ecs check --ansi",
        "fix-cs": "vendor/bin/ecs check --fix --ansi",
        "rector-dry": "vendor/bin/rector process --dry-run",
        "rector" : "vendor/bin/rector process",
        "phpstan": "php -d memory_limit=256M vendor/bin/phpstan analyze"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.*.*"
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.4",
        "phpunit/phpunit": "^9.5",
        "rector/rector": "^1.0",
        "symfony/apache-pack": "^1.0",
        "symfony/browser-kit": "7.*.*",
        "symfony/css-selector": "7.*.*",
        "symfony/debug-bundle": "7.*.*",
        "symfony/maker-bundle": "^1.52",
        "symfony/stopwatch": "7.*.*",
        "symfony/web-profiler-bundle": "7.*.*",
        "symplify/easy-coding-standard": "^12.0"
    }
}
