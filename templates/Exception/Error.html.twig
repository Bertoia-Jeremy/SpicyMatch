{% extends 'base.html.twig' %}

{% block title %}SpicyMatch — Erreur{% endblock %}

{% block body %}
<section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <div class="bg-white border border-stone-200 rounded-2xl p-10">
        <div class="w-16 h-16 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-triangle-exclamation text-red-500 text-2xl"></i>
        </div>
        <h1 class="text-3xl font-bold text-stone-900 mb-3">Une erreur est survenue</h1>
        {% if codeError is defined %}
            <p class="text-stone-400 text-sm mb-2">Code d'erreur : <code class="bg-stone-100 px-2 py-0.5 rounded text-stone-600">{{ codeError }}</code></p>
        {% endif %}
        <p class="text-stone-500 mb-8">Si le problème persiste, merci de contacter l'administrateur.</p>
        <div class="flex gap-3 justify-center">
            <a href="{{ path('home') }}" class="btn-pill-primary">
                <i class="fa-solid fa-house"></i> Accueil
            </a>
            <a href="{{ path('new_contact') }}" class="btn-pill-outline">
                <i class="fa-solid fa-envelope"></i> Signaler
            </a>
        </div>
    </div>
</section>
{% endblock %}
