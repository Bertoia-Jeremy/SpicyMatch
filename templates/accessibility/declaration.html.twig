{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.a11y_decl.title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-stone-800 mb-6">{{ 'ui.a11y_decl.title'|trans }}</h1>

    <p class="text-stone-700 leading-relaxed mb-8">{{ 'ui.a11y_decl.intro'|trans }}</p>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.a11y_decl.status_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.a11y_decl.status_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.a11y_decl.tests_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.a11y_decl.tests_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.a11y_decl.feedback_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">
            {{ 'ui.a11y_decl.feedback_text'|trans }}
            <a href="{{ path('new_contact') }}" class="text-saffron-800 hover:text-saffron-700 font-medium underline">{{ 'ui.common.contact'|trans }}</a>.
        </p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.a11y_decl.recourse_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.a11y_decl.recourse_text'|trans }}</p>
    </section>

    <p class="text-sm text-stone-600">{{ 'ui.a11y_decl.date_text'|trans }}</p>
</div>
{% endblock %}
