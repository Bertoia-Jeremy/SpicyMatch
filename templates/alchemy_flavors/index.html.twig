{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.catalog.flavors_page_title'|trans }}{% endblock %}

{% block body %}
{% import 'macros/buttons.html.twig' as buttons %}

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
        <span class="tag-primary mb-4 inline-block">{{ 'ui.catalog.flavors_tag'|trans }}</span>
        <h1 class="text-4xl font-bold text-stone-900 mb-3">{{ 'ui.catalog.flavors_title'|trans }}</h1>
        <p class="text-stone-500 text-lg max-w-2xl mx-auto">{{ 'ui.catalog.flavors_page_intro'|trans }}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for flavor in alchemyFlavors %}
            <article class="card-warm p-6 flex flex-col h-full">
                <div class="w-12 h-12 rounded-xl bg-turmeric-100 flex items-center justify-center mb-4">
                    <i class="fa-solid fa-flask-vial text-turmeric-600" aria-hidden="true"></i>
                </div>
                <h2 class="text-xl font-bold text-stone-900 mb-2">{{ flavor.name }}</h2>
                {% if flavor.description %}
                    <p class="text-stone-500 text-sm line-clamp-3 mb-6 flex-1">{{ flavor.description }}</p>
                {% else %}
                    <p class="text-stone-400 text-sm italic mb-6 flex-1">{{ 'ui.catalog.no_description'|trans }}</p>
                {% endif %}

                {{ buttons.button('ui.catalog.explore_flavor'|trans, {
                    href: path('view_alchemy_flavors', {id: flavor.id}),
                    variant: 'outline',
                    size: 'sm',
                    icon: 'fa-solid fa-arrow-right',
                    icon_pos: 'right'
                }) }}
            </article>
        {% else %}
            <div class="col-span-full text-center py-12">
                <p class="text-stone-400">{{ 'ui.catalog.no_flavor'|trans }}</p>
            </div>
        {% endfor %}
    </div>
</section>
{% endblock %}
