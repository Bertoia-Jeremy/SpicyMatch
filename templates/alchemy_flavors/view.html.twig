{% extends 'base.html.twig' %}

{% block title %}SpicyMatch — {{ alchemyFlavor.name }}{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <div class="mb-8">
        <a href="{{ path('index_alchemy_flavors') }}" class="text-stone-500 hover:text-saffron-700 text-sm transition-colors">
            <i class="fa-solid fa-arrow-left mr-1"></i> Saveurs d'alchimie
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
        <div>
            <span class="tag-primary mb-3 inline-block">Saveur</span>
            <h1 class="text-4xl font-bold text-stone-900 mb-4">{{ alchemyFlavor.name }}</h1>
            <p class="text-stone-600 text-lg leading-relaxed">{{ alchemyFlavor.description }}</p>
        </div>

        {% if alchemyFlavor.cooking %}
        <div class="bg-white border border-stone-200 rounded-2xl p-6">
            <h2 class="text-xl font-bold text-stone-900 mb-4">
                <i class="fa-solid fa-fire-flame-curved text-saffron-600 mr-2"></i>Conseils cuisine
            </h2>
            <p class="text-stone-600 text-sm leading-relaxed">{{ alchemyFlavor.cooking }}</p>
            {% if alchemyFlavor.informations %}
                <p class="text-stone-500 text-sm mt-3">{{ alchemyFlavor.informations }}</p>
            {% endif %}
        </div>
        {% endif %}
    </div>

</div>
{% endblock %}
