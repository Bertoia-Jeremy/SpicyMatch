{% extends 'base.html.twig' %}

{% block title %}SpicyMatch — Groupes aromatiques{% endblock %}

{% block body %}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
        <span class="tag-primary mb-4 inline-block">Catalogue</span>
        <h1 class="text-4xl font-bold text-stone-900 mb-3">Groupes aromatiques</h1>
        <p class="text-stone-500 text-lg max-w-xl mx-auto">Les grandes familles d'arômes qui rassemblent les épices par affinité gustative.</p>
    </div>

    <div class="bg-white border border-stone-200 rounded-2xl p-8 text-center">
        <i class="fa-solid fa-layer-group text-4xl text-saffron-400 mb-4"></i>
        <p class="text-stone-500">Le catalogue des groupes aromatiques arrive bientôt.</p>
        <a href="{{ path('index_spices') }}" class="btn-pill-outline mt-6 inline-flex">
            <i class="fa-solid fa-arrow-left"></i> Voir les épices
        </a>
    </div>
</section>
{% endblock %}
