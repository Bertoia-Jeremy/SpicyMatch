<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        {% block metas %}{% endblock %}
        <title>{% block title %}SpicyMatch{% endblock %}</title>
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
        {% endblock %}
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>

    <body>
        {% block header %}
            {% if is_granted('ROLE_USER') %}
                {% include '/components/_navbar.html.twig' %}
            {% endif %}
        {% endblock %}

        {% block body %}
        {% endblock %}

        {% block footer %}
            {% if is_granted('ROLE_USER') %}
                {% include '/components/_footer.html.twig' %}
            {% endif %}
        {% endblock %}
    </body>
</html>
