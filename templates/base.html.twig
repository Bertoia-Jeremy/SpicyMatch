<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        {% block metas %}{% endblock %}
        <title>{% block title %}SpicyMatch{% endblock %}</title>
        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous">
            <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
        {% endblock %}
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>

    <body class="bg-cream min-h-screen flex flex-col">
        {% block header %}
            {% include '/components/_navbar.html.twig' %}
        {% endblock %}

        <main class="flex-1">
            {% block body %}
            {% endblock %}
        </main>

        {% block footer %}
            {% include '/components/_footer.html.twig' %}
        {% endblock %}
    </body>
</html>
