<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="motion-safe:scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="description" content="{% block meta_description %}{{ 'ui.meta.description'|trans }}{% endblock %}">
        <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">

        {# SEO i18n : canonical + alternates hreflang (uniquement sur les routes localisées /{_locale}) #}
        {% set _route = app.request.attributes.get('_route') %}
        {% set _params = app.request.attributes.get('_route_params')|default({}) %}
        {% if _route and _params._locale is defined %}
            {% set _hreflangSlugs = hreflang_slugs|default(null) %}
            <link rel="canonical" href="{{ url(_route, _params) }}">
            {% for _loc in ['fr', 'en', 'es'] %}
                {% set _altParams = _params|merge({'_locale': _loc}) %}
                {% if _hreflangSlugs and _params.slug is defined %}{% set _altParams = _altParams|merge({'slug': _hreflangSlugs[_loc]}) %}{% endif %}
                <link rel="alternate" hreflang="{{ _loc }}" href="{{ url(_route, _altParams) }}">
            {% endfor %}
            <link rel="alternate" hreflang="x-default" href="{{ url(_route, _params|merge({'_locale': 'fr'})|merge(_hreflangSlugs and _params.slug is defined ? {'slug': _hreflangSlugs.fr} : {})) }}">
        {% endif %}
        {% block metas %}{% endblock %}
        <title>{% block title %}{{ 'ui.meta.default_title'|trans }}{% endblock %}</title>

        <link rel="preload" as="style"
              data-async-css="fontawesome"
              href="{{ asset('lib/fontawesome/css/all.min.css') }}">
        <noscript>
            <link rel="stylesheet" href="{{ asset('lib/fontawesome/css/all.min.css') }}">
        </noscript>

        <script nonce="{{ csp_nonce('script') }}">
            // Swap preload → stylesheet pour éviter render-blocking sans casser CSP
            document.querySelectorAll('link[data-async-css]').forEach(l => l.rel = 'stylesheet');
        </script>

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
        {% endblock %}

        {# Dictionnaire i18n pour le JavaScript (lu par assets/i18n.js). JSON inerte = pas de nonce CSP requis. #}
        {# Tout le domaine `js` exposé en un bloc (lu par assets/i18n.js). Pas de
           liste manuelle = pas de drift ; JSON durci (HEX) = pas de breakout <script>. #}
        <script type="application/json" id="js-i18n">{{ js_i18n_json() }}</script>

        {% block javascripts %}
            {{ importmap('app', { nonce: csp_nonce('script') }) }}
        {% endblock %}
    </head>

    <body class="bg-cream text-stone-900 font-sans selection:bg-saffron-200 selection:text-saffron-900 overflow-x-hidden">

        {# Skip link — accessibilité clavier / lecteurs d'écran #}
        <a href="#main-content"
           class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-200 focus:px-4 focus:py-2 focus:bg-saffron-700 focus:text-cream focus:rounded-full focus:text-sm focus:font-semibold focus:shadow-lg">
            {{ 'ui.common.skip_to_content'|trans }}
        </a>

        {% include 'components/_navbar.html.twig' %}

        <main id="main-content" class="min-h-screen">
            {% block body %}{% endblock %}
        </main>

        {% include 'components/_footer.html.twig' %}

        {# {% include 'components/_cookie_consent.html.twig' %} #}

        {# Toast flash global — écoute l'événement "toast" sur window #}
        <div x-data="notificationHost"
             @toast.window="onToast($event)"
             class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex flex-col items-center gap-2 pointer-events-none"
             aria-live="polite" aria-atomic="false" role="status">
            <template x-for="t in toasts" :key="t.id">
                <div x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     x-transition:leave="transition ease-in duration-150"
                     x-transition:leave-start="opacity-100 translate-y-0"
                     x-transition:leave-end="opacity-0 translate-y-2"
                     class="bg-stone-800 text-white text-sm font-medium px-4 py-2.5 rounded-full shadow-lg flex items-center gap-2 pointer-events-auto">
                    <i :class="t.icon" class="text-xs" aria-hidden="true"></i>
                    <span x-text="t.message"></span>
                </div>
            </template>
        </div>

        {# Gamification toast container — Turbo Streams prepend here #}
        <div id="gamification-toasts"
             class="fixed bottom-6 right-6 z-50 flex flex-col-reverse pointer-events-none w-80"
             aria-live="polite" aria-atomic="false" role="status">
        </div>

        {% include 'components/_account_created_modal.html.twig' %}

        {# Onboarding — nouveaux utilisateurs uniquement (géré côté client via localStorage) #}
        {% include 'components/_onboarding.html.twig' %}

    </body>
</html>
