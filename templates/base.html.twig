<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="description" content="{% block meta_description %}SpicyMatch — Créez des mélanges d'épices parfaits grâce à l'analyse moléculaire des composés aromatiques.{% endblock %}">
        <link rel="icon" href="{{ asset('favicon.ico') }}" type="image/x-icon">
        {% block metas %}{% endblock %}
        <title>{% block title %}SpicyMatch — L'Alchimie Culinaire{% endblock %}</title>

        {# Fonts : preload non-blocking pour éviter render-blocking #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="preload" as="style"
              href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap"
              onload="this.onload=null;this.rel='stylesheet'">
        <noscript>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap">
        </noscript>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/fontawesome.min.css" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/solid.min.css" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/regular.min.css" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/brands.min.css" crossorigin="anonymous">

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>

    <body class="bg-cream text-stone-900 font-sans selection:bg-saffron-200 selection:text-saffron-900 overflow-x-hidden">

        {# Skip link — accessibilité clavier / lecteurs d'écran #}
        <a href="#main-content"
           class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-200 focus:px-4 focus:py-2 focus:bg-saffron-700 focus:text-cream focus:rounded-full focus:text-sm focus:font-semibold focus:shadow-lg">
            Aller au contenu principal
        </a>

        {% include 'components/_navbar.html.twig' %}

        <main id="main-content" class="min-h-screen">
            {% block body %}{% endblock %}
        </main>

        {% include 'components/_footer.html.twig' %}

        {% include 'components/_cookie_consent.html.twig' %}

        {# Gamification toast container — Turbo Streams prepend here #}
        <div id="gamification-toasts"
             class="fixed bottom-6 right-6 z-50 flex flex-col-reverse pointer-events-none w-80">
        </div>

    </body>
</html>
