<div class="container mx-auto">
    <div class="alert alert-{{ type }} bg-{{ type }}-100 border border-{{ type }}-400 text-{{ type }}-700 px-4 py-3 rounded relative w-3/4 mx-auto text-center">
        {{ this.message }}
    </div>
</div>

