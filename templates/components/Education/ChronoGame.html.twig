{% import 'components/Education/_game_header.html.twig' as game_header %}
<div {{ attributes }}>
  <div aria-live="polite" class="sr-only">
    {%- if this.isFinished %}{{ 'ui.game.time_up'|trans }}
    {%- elseif this.questionsAnswered > 0 %}
      {%- if this.lastAnswerCorrect %}{{ 'ui.game.correct_points'|trans({'%points%': this.lastPointsEarned}) }}
      {%- else %}{{ 'ui.game.it_was'|trans({'%name%': this.lastCorrectName}) }}
      {%- endif %}
    {%- endif %}
  </div>

  {% if this.streak >= 4 %}{% set streakBonus = '+3' %}
  {% elseif this.streak >= 3 %}{% set streakBonus = '+2' %}
  {% elseif this.streak >= 2 %}{% set streakBonus = '+1' %}
  {% else %}{% set streakBonus = '' %}{% endif %}
  {% set streakPill = this.streak >= 2 ? ' <span class="tag-primary text-xs"><i class="fa-solid fa-fire mr-1" aria-hidden="true"></i>' ~ this.streak ~ ' ' ~ streakBonus ~ '</span>' : '' %}
  {{ game_header.header(
      icon = 'fa-solid fa-fire-flame-curved',
      title = 'enum.game_mode.chrono.label'|trans,
      subtitle = 'ui.game.chrono_subtitle'|trans,
      scoreLabel = ('ui.edu.pts'|trans({'%score%': this.totalScore})) ~ streakPill,
      quitUrl = path('education_briefing', { mode: 'chrono', difficulty: this.difficulty }),
  ) }}

  {% if this.isFinished %}
    {{ game_header.game_over_summary(
        circleLabel = this.totalScore,
        title = 'ui.game.time_up'|trans,
        paragraphHtml = 'ui.game.time_up_summary'|trans({'%correct%': this.correctCount, '%answered%': this.questionsAnswered, '%score%': this.totalScore}),
        buttonLabel = 'ui.game.see_results'|trans,
        buttonAction = 'finish',
        variant = this.correctCount >= 5 ? 'success' : 'failure',
    ) }}

  {% else %}
    {# Timer — Stimulus-driven (CSP-friendly, no inline JS). data-live-ignore
       prevents morphdom from re-running connect() on every LC re-render. #}
    <div data-live-ignore
         data-controller="game-timer"
         data-game-timer-expires-at-value="{{ this.startedAt + this.timeLimit }}"
         data-game-timer-total-seconds-value="{{ this.timeLimit }}"
         data-game-timer-danger-threshold-value="10"
         data-game-timer-warning-threshold-value="30"
         class="mb-8">
      <button data-game-timer-target="timeoutButton"
              data-action="live#action"
              data-live-action-param="timeout"
              class="hidden" aria-hidden="true"></button>
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm text-stone-500">
          <i class="fa-solid fa-clock mr-1" aria-hidden="true"></i>{{ 'ui.game.time_remaining'|trans }}
        </span>
        <span data-game-timer-target="label"
              class="text-sm font-semibold text-stone-700"></span>
        <span data-game-timer-target="announcer" aria-live="polite" class="sr-only"></span>
      </div>
      <div class="w-full bg-stone-200 rounded-full h-3">
        <div data-game-timer-target="bar"
             class="h-3 rounded-full transition-all duration-1000 bg-saffron-500"></div>
      </div>
    </div>

    {# Stats row #}
    <div class="flex items-center justify-center gap-6 mb-6 text-sm text-stone-600">
      <span><i class="fa-solid fa-check text-turmeric-600 mr-1" aria-hidden="true"></i>{{ this.correctCount }}</span>
      <span><i class="fa-solid fa-question text-stone-400 mr-1" aria-hidden="true"></i>{{ this.questionsAnswered }}</span>
      {% if this.streak >= 2 %}
        <span class="text-saffron-700 font-semibold"><i class="fa-solid fa-fire mr-1" aria-hidden="true"></i>{{ this.streak }} {{ streakBonus }}</span>
      {% endif %}
    </div>

    {# Last answer feedback (inline) #}
    {% if this.questionsAnswered > 0 %}
      <div class="mb-6 text-center text-sm">
        {% if this.lastAnswerCorrect %}
          <span class="text-green-600 font-medium">
            <i class="fa-solid fa-check-circle mr-1" aria-hidden="true"></i>{{ 'ui.game.correct_points'|trans({'%points%': this.lastPointsEarned}) }}
          </span>
        {% else %}
          <span class="text-red-600 font-medium">
            <i class="fa-solid fa-times-circle mr-1" aria-hidden="true"></i>{{ 'ui.game.it_was'|trans({'%name%': this.lastCorrectName}) }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {# Spice card info (without name) #}
    <div class="bg-white border border-stone-200 rounded-2xl p-6 mb-6">
      <p class="text-xs text-stone-500 uppercase tracking-wide mb-3">{{ 'ui.game.which_spice'|trans }}</p>

      {% if this.currentCard.file is defined and this.currentCard.file %}
        <div class="flex justify-center mb-4">
          <img src="{{ asset('uploads/spices/' ~ this.currentCard.file) }}"
               alt="{{ 'ui.game.mystery_spice_alt'|trans }}"
               class="w-20 h-20 rounded-xl object-cover border border-stone-200">
        </div>
      {% endif %}

      {% if this.currentCard.description is defined and this.currentCard.description %}
        <p class="text-sm text-stone-600 mb-3">{{ this.currentCard.description }}</p>
      {% endif %}

      <div class="space-y-2 text-sm">
        {% if this.currentCard.aromaticGroup is defined and this.currentCard.aromaticGroup.name is defined %}
          <div class="flex items-center gap-2">
            <span class="text-stone-500">{{ 'ui.game.family'|trans }}</span>
            <span class="flex items-center gap-1.5">
              {% if this.currentCard.aromaticGroup.color is defined and this.currentCard.aromaticGroup.color %}
                <span class="w-3 h-3 rounded-full inline-block" style="background-color: {{ this.currentCard.aromaticGroup.color }}"></span>
              {% endif %}
              {{ this.currentCard.aromaticGroup.name }}
            </span>
          </div>
        {% endif %}

        {% if this.currentCard.spicyType is defined and this.currentCard.spicyType %}
          <div><span class="text-stone-500">{{ 'ui.game.type'|trans }}</span> {{ this.currentCard.spicyType }}</div>
        {% endif %}

        {% if this.currentCard.alchemyFlavors is defined and this.currentCard.alchemyFlavors|length > 0 %}
          <div>
            <span class="text-stone-500">{{ 'ui.game.flavors'|trans }}</span>
            {% for flavor in this.currentCard.alchemyFlavors %}
              <span class="tag-secondary text-xs">{{ flavor }}</span>
            {% endfor %}
          </div>
        {% endif %}

        {% if this.currentCard.mainCompounds is defined and this.currentCard.mainCompounds|length > 0 %}
          <div>
            <span class="text-stone-500">{{ 'ui.game.main_compounds'|trans }}</span>
            {{ this.currentCard.mainCompounds|join(', ') }}
          </div>
        {% endif %}

        {% if this.currentCard.secondaryCompounds is defined and this.currentCard.secondaryCompounds|length > 0 %}
          <div>
            <span class="text-stone-500">{{ 'ui.game.secondary_compounds'|trans }}</span>
            {{ this.currentCard.secondaryCompounds|join(', ') }}
          </div>
        {% endif %}

        {% if this.currentCard.cookingTips is defined and this.currentCard.cookingTips|length > 0 %}
          <div>
            <span class="text-stone-500">{{ 'ui.game.tip'|trans }}</span>
            {{ this.currentCard.cookingTips[0].title ?? this.currentCard.cookingTips[0].cookingStep ?? '' }}
          </div>
        {% endif %}
      </div>
    </div>

    {# Name options — answerOnce Alpine pour anti double-clic #}
    {% if this.isInCooldown %}
      <div class="mb-3 text-center text-xs text-stone-400 animate-pulse">
        <i class="fa-solid fa-hourglass-half mr-1" aria-hidden="true"></i>{{ 'ui.game.prepare_next'|trans }}
      </div>
    {% endif %}
    <div class="grid grid-cols-2 gap-3" x-data="answerOnce">
      {% for name in this.nameOptions %}
        <button type="button"
                data-action="live#action"
                data-live-action-param="answer"
                data-live-spice-name-param="{{ name|e('html_attr') }}"
                data-loading="action(answer)|addAttribute(disabled)"
                @click="pick()"
                :disabled="isAnswered()"
                class="px-4 py-3 rounded-xl border border-stone-200 bg-white hover:bg-cream hover:border-saffron-300 transition-all text-center font-medium text-stone-800 disabled:opacity-75 focus:outline-none focus-visible:ring-2 focus-visible:ring-saffron-600/30">
          {{ name }}
        </button>
      {% endfor %}
    </div>
  {% endif %}
</div>
