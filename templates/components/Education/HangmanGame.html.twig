{% import 'components/Education/_game_header.html.twig' as game_header %}
<div {{ attributes }}>
  {{ game_header.header(
      icon = 'fa-solid fa-temperature-three-quarters',
      title = 'Cuisson en Cours',
      subtitle = 'Devine le nom de l\'épice lettre par lettre',
      current = this.questionNumber,
      total = this.totalQuestions,
      scoreLabel = this.correctCount ~ ' <i class="fa-solid fa-check text-xs text-green-600"></i>  ' ~ this.incorrectCount ~ ' <i class="fa-solid fa-xmark text-xs text-paprika-500"></i>',
      quitUrl = path('education_briefing', { mode: 'hangman', difficulty: this.difficulty }),
  ) }}


  <div id="hangman-game-area" class="flex flex-col lg:flex-row gap-8 items-center">
    {# Sonde de cuisson — thermomètre avec zones textuées #}
    <div class="flex-shrink-0">
      {% if this.errorsCount >= 6 %}
        {% set zoneLabel = 'CRAMÉ !' %}{% set zoneColor = '#7c2d12' %}{% set bulbColor = '#3f1505' %}
      {% elseif this.errorsCount >= 5 %}
        {% set zoneLabel = 'Brûlant !' %}{% set zoneColor = '#dc2626' %}{% set bulbColor = '#dc2626' %}
      {% elseif this.errorsCount >= 4 %}
        {% set zoneLabel = 'Trop cuit' %}{% set zoneColor = '#ea580c' %}{% set bulbColor = '#ea580c' %}
      {% elseif this.errorsCount >= 3 %}
        {% set zoneLabel = 'Bien cuit' %}{% set zoneColor = '#d97706' %}{% set bulbColor = '#d97706' %}
      {% elseif this.errorsCount >= 2 %}
        {% set zoneLabel = 'À point' %}{% set zoneColor = '#16a34a' %}{% set bulbColor = '#16a34a' %}
      {% elseif this.errorsCount >= 1 %}
        {% set zoneLabel = 'Tiède' %}{% set zoneColor = '#0ea5e9' %}{% set bulbColor = '#0ea5e9' %}
      {% else %}
        {% set zoneLabel = 'Cru' %}{% set zoneColor = '#94a3b8' %}{% set bulbColor = '#94a3b8' %}
      {% endif %}

      <svg viewBox="0 0 200 250" class="w-40 h-48" aria-hidden="true">

        {# ── FOUR ─────────────────────────────────────────────────── #}

        {# Pieds #}
        <rect x="32" y="230" width="16" height="14" rx="3" fill="#a8a29e"/>
        <rect x="152" y="230" width="16" height="14" rx="3" fill="#a8a29e"/>

        {# Corps + bandeau #}
        <rect x="10" y="20" width="180" height="214" rx="10" fill="#e7e5e4" stroke="#a8a29e" stroke-width="2"/>
        <rect x="10" y="20" width="180" height="44" rx="10" fill="#d6d3d1"/>
        <line x1="10" y1="64" x2="190" y2="64" stroke="#a8a29e" stroke-width="1.5"/>

        {# Molettes #}
        <circle cx="45" cy="42" r="9" fill="#f5f5f4" stroke="#78716c" stroke-width="1.5"/>
        <circle cx="100" cy="42" r="9" fill="#f5f5f4" stroke="#78716c" stroke-width="1.5"/>
        <circle cx="155" cy="42" r="9" fill="#f5f5f4" stroke="#78716c" stroke-width="1.5"/>

        {# Porte + grande vitre #}
        <rect x="20" y="72" width="160" height="152" rx="8" fill="#d6d3d1" stroke="#a8a29e" stroke-width="1.5"/>
        <rect x="30" y="82" width="140" height="108" rx="5" fill="#1c1917" stroke="#78716c" stroke-width="1.5"/>

        {# Fumée (≥ 5 erreurs) #}
        {% if this.errorsCount >= 5 %}
          <path d="M 65 20 Q 60 10 65 2" stroke="#78716c" stroke-width="2" fill="none" opacity="0.5" stroke-linecap="round"/>
          <path d="M 100 20 Q 104 10 100 2" stroke="#78716c" stroke-width="2" fill="none" opacity="0.4" stroke-linecap="round"/>
          <path d="M 135 20 Q 140 10 135 2" stroke="#78716c" stroke-width="2" fill="none" opacity="0.5" stroke-linecap="round"/>
        {% endif %}

        {# ── PLAT (couleur progressive, dans la vitre) ─────────────── #}
        {% if this.errorsCount >= 6 %}{% set dishFill = '#0c0a09' %}
        {% elseif this.errorsCount >= 5 %}{% set dishFill = '#3f1505' %}
        {% elseif this.errorsCount >= 4 %}{% set dishFill = '#7c2d12' %}
        {% elseif this.errorsCount >= 3 %}{% set dishFill = '#92400e' %}
        {% elseif this.errorsCount >= 2 %}{% set dishFill = '#d97706' %}
        {% elseif this.errorsCount >= 1 %}{% set dishFill = '#fbbf24' %}
        {% else %}{% set dishFill = '#fef9c7' %}{% endif %}

        <circle cx="80" cy="136" r="30" fill="{{ dishFill }}"/>
        {% if this.errorsCount >= 3 %}
          <circle cx="68" cy="128" r="5" fill="#431407" opacity="0.75"/>
          <circle cx="89" cy="144" r="4" fill="#431407" opacity="0.75"/>
        {% endif %}
        {% if this.errorsCount >= 5 %}
          <circle cx="80" cy="130" r="7" fill="#111" opacity="0.9"/>
        {% endif %}

        {# ── SONDE — tige allant du plat au thermomètre ────────────── #}
        <line x1="92" y1="122" x2="130" y2="122" stroke="#d6d3d1" stroke-width="2.5" stroke-linecap="round"/>
        <circle cx="92" cy="122" r="4" fill="#a8a29e"/>

        {# ── THERMOMÈTRE VERTICAL (dans la vitre, côté droit) ──────── #}

        {# Tube extérieur #}
        <rect x="130" y="86" width="20" height="90" rx="10" fill="#0c0a09" stroke="#4b5563" stroke-width="1.5"/>

        {# 6 bandes de zones (toujours visibles) — du bas au haut : cru → cramé #}
        <rect x="132" y="160" width="16" height="14" fill="#60a5fa"/>
        <rect x="132" y="146" width="16" height="14" fill="#16a34a"/>
        <rect x="132" y="132" width="16" height="14" fill="#d97706"/>
        <rect x="132" y="118" width="16" height="14" fill="#ea580c"/>
        <rect x="132" y="104" width="16" height="14" fill="#dc2626"/>
        <rect x="132" y="90"  width="16" height="14" fill="#3f1505"/>

        {# Overlay sombre masquant les zones non atteintes (se réduit avec les erreurs) #}
        {% if this.errorsCount < 6 %}
          {% set darkH = (6 - this.errorsCount) * 14 %}
          <rect x="132" y="90" width="16" height="{{ darkH }}" fill="#0c0a09" opacity="0.9" rx="1"/>
        {% endif %}

        {# Bulbe coloré en bas du tube #}
        <circle cx="140" cy="182" r="10" fill="{{ bulbColor }}" stroke="#4b5563" stroke-width="1.5"/>

        {# ── LABEL ZONE — texte sur la porte du four ──────────────── #}
        <text x="82" y="214"
              font-family="sans-serif"
              font-size="14"
              font-weight="bold"
              text-anchor="middle"
              fill="{{ zoneColor }}">{{ zoneLabel }}</text>

        {# Poignée #}
        <rect x="60" y="222" width="80" height="7" rx="3.5" fill="#a8a29e" stroke="#78716c" stroke-width="1"/>

      </svg>
    </div>

    <div class="flex-1 w-full">
      {# Errors counter + hint #}
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-stone-500">
          Erreurs : <span class="{{ this.errorsCount > this.maxErrors * 0.6 ? 'text-paprika-600 font-semibold' : 'text-stone-700' }}">{{ this.errorsCount }}/{{ this.maxErrors }}</span>
        </p>
        {% if this.hint %}
          <p class="text-sm text-saffron-600"><i class="fa-solid fa-lightbulb mr-1"></i>{{ this.hint }}</p>
        {% endif %}
      </div>

      {# Word display — masked during play, revealed with color on feedback #}
      <div class="text-center mb-6">
        {% if this.showFeedback %}
          <p class="text-3xl font-mono tracking-[0.5em] font-bold mb-3
            {{ this.wordSolved ? 'text-green-700' : 'text-paprika-700' }} break-all">
            {{ this.revealedWord }}
          </p>
          <div class="py-2 px-4 rounded-xl inline-block text-sm
            {{ this.wordSolved ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' }}">
            <i class="fa-solid {{ this.wordSolved ? 'fa-circle-check' : 'fa-circle-xmark' }} mr-2"></i>
            <span class="font-semibold">
              {{ this.wordSolved ? 'Trouvé !' : 'Perdu...' }}
            </span>
          </div>
        {% else %}
          <p class="text-3xl font-mono tracking-[0.5em] font-bold text-stone-800 break-all">
            {% for char in this.maskedWord|split('') %}
              {% if char == '_' %}
                <span class="inline-block w-6 border-b-2 border-stone-400 mx-0.5">&nbsp;</span>
              {% elseif char == ' ' %}
                <span class="inline-block w-4">&nbsp;</span>
              {% else %}
                <span class="inline-block mx-0.5">{{ char }}</span>
              {% endif %}
            {% endfor %}
          </p>
        {% endif %}
      </div>

      {# Keyboard — optimistic UI: pending tracked in Alpine state, reset via MutationObserver on data-word-num change #}
      <div class="flex flex-wrap justify-center gap-2 mb-4"
           x-data="hangmanKeyboard()"
           data-word-num="{{ this.questionNumber }}">
        {% set alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ' %}
        {% for letter in alphabet|split('') %}
          {% set isGuessed = letter in this.guessedLetters %}
          {% set isDisabled = isGuessed or this.showFeedback %}
          <button type="button"
                  {% if not this.showFeedback %}
                    data-action="live#action"
                    data-live-action-param="guessLetter"
                    data-live-letter-param="{{ letter }}"
                    @click="guess('{{ letter }}')"
                  {% endif %}
                  {{ isDisabled ? 'disabled' : '' }}
                  :class="isPending('{{ letter }}') ? 'opacity-40 pointer-events-none' : ''"
                  class="w-10 h-10 sm:w-12 sm:h-12 rounded-lg text-sm font-semibold transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-saffron-600/30
                    {{ isDisabled ? 'bg-stone-200 text-stone-400 cursor-not-allowed' : 'bg-white border border-stone-300 text-stone-700 hover:bg-saffron-100 hover:border-saffron-400 hover:text-saffron-700' }}">
            {{ letter }}
          </button>
        {% endfor %}
      </div>

      {# Next word button — only visible during feedback #}
      {% if this.showFeedback %}
        <button data-action="live#action"
                data-live-action-param="nextWord"
                class="btn-pill-primary w-full">
          {% if this.questionNumber >= this.totalQuestions %}
            <i class="fa-solid fa-flag-checkered mr-2"></i>Terminer
          {% else %}
            <i class="fa-solid fa-arrow-right mr-2"></i>Mot suivant
          {% endif %}
        </button>
      {% endif %}
    </div>
  </div>
</div>
