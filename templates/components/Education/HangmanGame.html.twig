{% import 'components/Education/_game_header.html.twig' as game_header %}
<div {{ attributes }}>
  {{ game_header.header(
      icon = 'fa-solid fa-temperature-three-quarters',
      title = 'Cuisson en Cours',
      subtitle = 'Devine le nom de l\'épice lettre par lettre',
      current = this.questionNumber,
      total = this.totalQuestions,
      scoreLabel = this.correctCount ~ ' <i class="fa-solid fa-check text-xs"></i>',
  ) }}

  {% if this.isFinished %}
    {{ game_header.game_over_summary(
        circleLabel = this.correctCount ~ '/' ~ this.questionNumber,
        title = 'Partie terminée !',
        paragraphHtml = 'Tu as trouvé ' ~ this.correctCount ~ ' mot' ~ (this.correctCount > 1 ? 's' : '') ~ ' sur ' ~ this.questionNumber ~ '.',
        buttonLabel = 'Voir les résultats',
        buttonAction = 'finish',
        variant = this.correctCount >= (this.totalQuestions * 0.5) ? 'success' : 'failure',
    ) }}

  {% elseif this.showFeedback %}
    {# Word result feedback #}
    <div class="text-center py-12">
      {% if this.wordSolved %}
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-turmeric-100 flex items-center justify-center">
          <i class="fa-solid fa-circle-check text-turmeric-600 text-3xl"></i>
        </div>
        <h3 class="text-lg font-bold text-turmeric-700 mb-2">Trouvé !</h3>
      {% else %}
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-paprika-100 flex items-center justify-center">
          <i class="fa-solid fa-circle-xmark text-paprika-500 text-3xl"></i>
        </div>
        <h3 class="text-lg font-bold text-paprika-700 mb-2">Perdu</h3>
      {% endif %}
      <p class="text-stone-600 mb-2 text-xl font-mono tracking-widest">{{ this.revealedWord }}</p>

      <button data-action="live#action"
              data-live-action-param="nextWord"
              class="btn-pill-primary mt-6">
        {% if this.questionNumber >= this.totalQuestions %}
          <i class="fa-solid fa-flag-checkered mr-2"></i>Terminer
        {% else %}
          <i class="fa-solid fa-arrow-right mr-2"></i>Mot suivant
        {% endif %}
      </button>
    </div>

  {% else %}
    {# Timer — Stimulus-driven. data-live-ignore prevents morphdom from re-connecting. #}
    {% if this.expiresAt > 0 %}
      <div data-live-ignore
           data-controller="game-timer"
           data-game-timer-expires-at-value="{{ this.expiresAt }}"
           data-game-timer-total-seconds-value="{{ this.timeLimit }}"
           data-game-timer-danger-threshold-value="5"
           data-game-timer-warning-threshold-value="15"
           class="mb-6">
        <button data-game-timer-target="timeoutButton"
                data-action="live#action"
                data-live-action-param="timeout"
                class="hidden" aria-hidden="true"></button>
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-stone-500"><i class="fa-solid fa-clock mr-1"></i>Temps restant</span>
          <span data-game-timer-target="label"
                aria-live="polite"
                class="text-xs font-semibold text-stone-700"></span>
        </div>
        <div class="w-full bg-stone-200 rounded-full h-2">
          <div data-game-timer-target="bar"
               class="h-2 rounded-full transition-all duration-1000 bg-saffron-500"></div>
        </div>
      </div>
    {% endif %}

    {# Active word #}
    <div class="flex flex-col lg:flex-row gap-8 items-center">
      {# Hangman SVG #}
      <div class="flex-shrink-0">
        <svg viewBox="0 0 200 250" class="w-40 h-48 text-stone-700">
          {# Base structure — always visible #}
          <line x1="20" y1="230" x2="180" y2="230" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <line x1="60" y1="230" x2="60" y2="20" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <line x1="60" y1="20" x2="140" y2="20" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <line x1="140" y1="20" x2="140" y2="50" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>

          {# Head #}
          {% if this.errorsCount >= 1 %}
            <circle cx="140" cy="70" r="20" fill="none" stroke="currentColor" stroke-width="3"/>
          {% endif %}

          {# Body #}
          {% if this.errorsCount >= 2 %}
            <line x1="140" y1="90" x2="140" y2="150" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          {% endif %}

          {# Left arm #}
          {% if this.errorsCount >= 3 %}
            <line x1="140" y1="110" x2="110" y2="135" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          {% endif %}

          {# Right arm #}
          {% if this.errorsCount >= 4 %}
            <line x1="140" y1="110" x2="170" y2="135" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          {% endif %}

          {# Left leg #}
          {% if this.errorsCount >= 5 %}
            <line x1="140" y1="150" x2="110" y2="190" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          {% endif %}

          {# Right leg #}
          {% if this.errorsCount >= 6 %}
            <line x1="140" y1="150" x2="170" y2="190" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          {% endif %}

          {# Left foot #}
          {% if this.errorsCount >= 7 %}
            <line x1="110" y1="190" x2="100" y2="200" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          {% endif %}

          {# Right foot #}
          {% if this.errorsCount >= 8 %}
            <line x1="170" y1="190" x2="180" y2="200" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          {% endif %}
        </svg>
      </div>

      <div class="flex-1 w-full">
        {# Errors counter #}
        <div class="flex items-center justify-between mb-4">
          <p class="text-sm text-stone-500">
            Erreurs : <span class="{{ this.errorsCount > this.maxErrors * 0.6 ? 'text-paprika-600 font-semibold' : 'text-stone-700' }}">{{ this.errorsCount }}/{{ this.maxErrors }}</span>
          </p>
          {% if this.hint %}
            <p class="text-sm text-saffron-600"><i class="fa-solid fa-lightbulb mr-1"></i>{{ this.hint }}</p>
          {% endif %}
        </div>

        {# Masked word display #}
        <div class="text-center mb-8">
          <p class="text-3xl font-mono tracking-[0.5em] font-bold text-stone-800 break-all">
            {% for char in this.maskedWord|split('') %}
              {% if char == '_' %}
                <span class="inline-block w-6 border-b-2 border-stone-400 mx-0.5">&nbsp;</span>
              {% elseif char == ' ' %}
                <span class="inline-block w-4">&nbsp;</span>
              {% else %}
                <span class="inline-block mx-0.5">{{ char }}</span>
              {% endif %}
            {% endfor %}
          </p>
        </div>

        {# Keyboard — data-loading disables the individual letter while its action is in flight,
           so the rest of the keyboard stays usable (unlike a global Alpine submitting flag). #}
        <div class="flex flex-wrap justify-center gap-1.5">
          {% set alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ' %}
          {% for letter in alphabet|split('') %}
            {% set isGuessed = letter in this.guessedLetters %}
            <button type="button"
                    data-action="live#action"
                    data-live-action-param="guessLetter"
                    data-live-letter-param="{{ letter }}"
                    data-loading="action(guessLetter)|addAttribute(disabled)"
                    {{ isGuessed ? 'disabled' : '' }}
                    class="w-9 h-9 rounded-lg text-sm font-semibold transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-saffron-600/30
                      {{ isGuessed ? 'bg-stone-200 text-stone-400 cursor-not-allowed' : 'bg-white border border-stone-300 text-stone-700 hover:bg-saffron-100 hover:border-saffron-400 hover:text-saffron-700' }}">
              {{ letter }}
            </button>
          {% endfor %}
        </div>

      </div>
    </div>
  {% endif %}
</div>
