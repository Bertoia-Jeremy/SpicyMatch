{% import 'components/Education/_game_header.html.twig' as game_header %}
<div {{ attributes }}>
  {{ game_header.header(
      icon = 'fa-solid fa-ban',
      title = 'Hors Saison',
      subtitle = this.isInverted ? 'Trouve le compatible' : 'Trouve l\'intrus',
      current = this.questionNumber,
      total = this.totalQuestions,
      scoreLabel = this.correctCount ~ ' <i class="fa-solid fa-check text-xs"></i>',
  ) }}

  {% if this.isFinished %}
    {{ game_header.game_over_summary(
        circleLabel = this.correctCount ~ '/' ~ this.answers|length,
        title = 'Partie terminée !',
        paragraphHtml = 'Tu as trouvé ' ~ this.correctCount ~ ' bonne' ~ (this.correctCount > 1 ? 's' : '') ~ ' réponse' ~ (this.correctCount > 1 ? 's' : '') ~ ' sur ' ~ this.answers|length ~ ' questions.',
        buttonLabel = 'Voir les résultats',
        buttonAction = 'finish',
        variant = this.correctCount >= (this.totalQuestions * 0.5) ? 'success' : 'failure',
    ) }}

    {# Answer history dots — Intrus-specific detail below the summary. #}
    <div class="flex justify-center gap-1.5 -mt-6 mb-8">
      {% for answer in this.answers %}
        <div class="w-3 h-3 rounded-full {{ answer.correct ? 'bg-turmeric-400' : 'bg-paprika-400' }}"></div>
      {% endfor %}
    </div>

  {% elseif this.showFeedback %}
    {# Feedback between questions #}
    <div class="text-center py-12">
      {% if this.lastAnswerCorrect %}
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-turmeric-100 flex items-center justify-center">
          <i class="fa-solid fa-circle-check text-turmeric-600 text-3xl"></i>
        </div>
        <h3 class="text-lg font-bold text-turmeric-700 mb-2">Bonne réponse !</h3>
      {% else %}
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-paprika-100 flex items-center justify-center">
          <i class="fa-solid fa-circle-xmark text-paprika-500 text-3xl"></i>
        </div>
        <h3 class="text-lg font-bold text-paprika-700 mb-2">Mauvaise réponse</h3>
        <p class="text-stone-600 mb-2">
          La bonne réponse était <strong>{{ this.lastCorrectAnswerName }}</strong>
        </p>
      {% endif %}

      <button data-action="live#action"
              data-live-action-param="next"
              class="btn-pill-primary mt-6">
        {% if this.questionNumber >= this.totalQuestions %}
          <i class="fa-solid fa-flag-checkered mr-2"></i>Terminer
        {% else %}
          <i class="fa-solid fa-arrow-right mr-2"></i>Question suivante
        {% endif %}
      </button>
    </div>

  {% else %}
    {# Active question #}
    <div class="text-center mb-8">
      <p class="text-sm text-stone-500 mb-1">Épice de référence</p>
      <p class="text-xl font-bold text-stone-800 mb-3">{{ this.baseSpiceName }}</p>
      <p class="text-stone-700 text-lg">{{ this.prompt }}</p>
    </div>

    {% import 'components/Education/_option_card.html.twig' as option_card %}
    <div class="grid grid-cols-2 gap-4" x-data="submitOnceGrid">
      {% for option in this.options %}
        {{ option_card.option(option, 'answer', 'spiceId', 'md', false) }}
      {% endfor %}
    </div>
  {% endif %}
</div>
