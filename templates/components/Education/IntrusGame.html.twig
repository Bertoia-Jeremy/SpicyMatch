{% import 'components/Education/_game_header.html.twig' as game_header %}
<div {{ attributes }}>
  {{ game_header.header(
      icon = 'fa-solid fa-ban',
      title = 'Hors Saison',
      subtitle = this.isInverted ? 'Trouve le compatible' : 'Trouve l\'intrus',
      current = this.questionNumber,
      total = this.totalQuestions,
      scoreLabel = this.correctCount ~ ' <i class="fa-solid fa-check text-xs text-green-600"></i>  ' ~ this.incorrectCount ~ ' <i class="fa-solid fa-xmark text-xs text-paprika-500"></i>',
      quitUrl = path('education_briefing', { mode: 'intrus', difficulty: this.difficulty }),
  ) }}

  {# Question context — always visible #}
  <div class="text-center mb-8 min-h-[5rem]">
    {% if this.baseSpiceName %}
      <p class="text-sm text-stone-500 mb-1">Épice de référence</p>
      <p class="text-xl font-bold text-stone-800 mb-3">{{ this.baseSpiceName }}</p>
    {% endif %}
    <p class="text-stone-700 text-lg">{{ this.prompt }}</p>
  </div>

  {% if this.showFeedback %}
    {# Feedback mode — options non-interactive, colorées vert/rouge #}
    <div class="grid grid-cols-2 gap-4 mb-6">
      {% for option in this.options %}
        {% set isCorrect = option.name == this.lastCorrectAnswerName %}
        {% set isWrongSelected = option.id == this.lastSelectedId and not this.lastAnswerCorrect %}
        <div class="relative p-4 rounded-xl border-2 text-left
          {% if isCorrect %}border-green-500 bg-green-50
          {% elseif isWrongSelected %}border-red-500 bg-red-50
          {% else %}border-stone-200 bg-white{% endif %}">
          <div class="flex items-center gap-3">
            {% if option.file %}
              <img src="{{ asset('uploads/spices/' ~ option.file) }}"
                   alt="{{ option.name }}"
                   class="w-12 h-12 rounded-lg object-cover">
            {% else %}
              <div class="w-12 h-12 rounded-lg flex items-center justify-center"
                   style="background-color: {{ option.color ?? '#f5f5f4' }}20">
                <i class="fa-solid fa-seedling" style="color: {{ option.color ?? '#78716c' }}"></i>
              </div>
            {% endif %}
            <div>
              <p class="font-semibold text-base text-stone-800">{{ option.name }}</p>
              {% if option.groupName is defined and option.groupName %}
                <p class="text-xs text-stone-500">{{ option.groupName }}</p>
              {% elseif option.color is defined and option.color %}
                <div class="w-3 h-3 rounded-full mt-1" style="background-color: {{ option.color }}"></div>
              {% endif %}
            </div>
          </div>
          {% if isCorrect %}
            <div class="absolute top-2 right-2">
              <i class="fa-solid fa-check text-green-600"></i>
            </div>
          {% elseif isWrongSelected %}
            <div class="absolute top-2 right-2">
              <i class="fa-solid fa-xmark text-red-500"></i>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="text-center mb-6 py-3 rounded-xl
      {{ this.lastAnswerCorrect ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' }}">
      <i class="fa-solid {{ this.lastAnswerCorrect ? 'fa-circle-check' : 'fa-circle-xmark' }} mr-2"></i>
      <span class="font-semibold">{{ this.lastAnswerCorrect ? 'Bonne réponse !' : 'Mauvaise réponse' }}</span>
    </div>

    <button data-action="live#action"
            data-live-action-param="next"
            class="btn-pill-primary w-full">
      {% if this.questionNumber >= this.totalQuestions %}
        <i class="fa-solid fa-flag-checkered mr-2"></i>Terminer
      {% else %}
        <i class="fa-solid fa-arrow-right mr-2"></i>Question suivante
      {% endif %}
    </button>

  {% else %}
    {# Active question #}
    {% import 'components/Education/_option_card.html.twig' as option_card %}
    <div class="grid grid-cols-2 gap-4" x-data="submitOnceGrid">
      {% for option in this.options %}
        {{ option_card.option(option, 'answer', 'spice-id', 'md', false) }}
      {% endfor %}
    </div>
  {% endif %}
</div>
