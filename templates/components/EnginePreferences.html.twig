<div {{ attributes }} class="space-y-6">
    {% if oav_context_enabled %}
    <div>
        <label class="block text-sm font-medium text-stone-700 mb-2">{{ 'ui.lab.prefs.default_matrix'|trans }}</label>
        <p class="text-xs text-stone-500 mb-3">{{ 'ui.lab.prefs.default_matrix_hint'|trans }}</p>
        <div class="flex flex-wrap gap-2">
            {% for m in this.matrices %}
                <button type="button"
                        data-action="live#action"
                        data-live-action-param="selectMatrix"
                        data-live-value-param="{{ m.value }}"
                        class="px-4 py-2 rounded-full text-sm font-medium border transition-colors
                               {{ matrix == m.value
                                  ? 'bg-saffron-600 text-white border-saffron-600'
                                  : 'bg-stone-100 text-stone-700 border-stone-200 hover:bg-stone-200' }}">
                    {{ m.label|trans }}
                </button>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <div>
        <label class="block text-sm font-medium text-stone-700 mb-2">
            {{ 'ui.lab.prefs.excluded_spices'|trans }}
            <span class="ml-1 text-xs text-stone-400">({{ this.excludedSpices|length }})</span>
        </label>

        {% if this.excludedSpices is empty %}
            <p class="text-xs text-stone-400 italic mb-3">{{ 'ui.lab.prefs.excluded_empty'|trans }}</p>
        {% else %}
            <div class="flex flex-wrap gap-2 mb-3">
                {% for spice in this.excludedSpices %}
                    <span class="tag-secondary inline-flex items-center gap-1.5">
                        {{ spice.getLocalizedName(app.request.locale) }}
                        <button type="button"
                                data-action="live#action"
                                data-live-action-param="toggleSpice"
                                data-live-id-param="{{ spice.id }}"
                                aria-label="{{ 'ui.lab.prefs.remove_exclusion'|trans }}"
                                class="hover:text-paprika-700">
                            <i class="fa-solid fa-xmark text-xs" aria-hidden="true"></i>
                        </button>
                    </span>
                {% endfor %}
            </div>
        {% endif %}

        <input type="text" data-model="search"
               placeholder="{{ 'ui.lab.prefs.search_spice'|trans }}"
               class="w-full rounded-lg border border-stone-200 px-3 py-2 text-sm focus:ring-2 focus:ring-saffron-600/30 focus:border-saffron-400">

        {% if search != '' %}
            <div class="mt-2 max-h-48 overflow-y-auto border border-stone-100 rounded-lg divide-y divide-stone-100">
                {% for spice in this.selectableSpices|slice(0, 12) %}
                    <button type="button"
                            data-action="live#action"
                            data-live-action-param="toggleSpice"
                            data-live-id-param="{{ spice.id }}"
                            class="w-full text-left px-3 py-2 text-sm text-stone-700 hover:bg-saffron-50">
                        {{ spice.getLocalizedName(app.request.locale) }}
                    </button>
                {% else %}
                    <p class="px-3 py-2 text-xs text-stone-400">{{ 'ui.lab.prefs.no_match'|trans }}</p>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
