<div {{ attributes }} class="relative">
    <input
        class="w-56 pl-4 {{ this.query ? 'pr-8' : 'pr-4' }} py-1.5 border border-spice-border rounded-full bg-white/80 text-stone-700
               placeholder-stone-400 text-sm backdrop-blur-sm
               focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-600/40
               transition-colors"
        type="text" placeholder="Rechercher..." aria-label="Rechercher"
        value="{{ this.query }}"
        data-model="query" data-action="live#update"
        @keydown.enter.prevent="window.location.href = '{{ path('search_results') }}?q=' + encodeURIComponent($el.value)"
    >
    {% if this.query %}
        <button type="button"
                data-action="live#action"
                data-live-action-param="clearQuery"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-stone-400 hover:text-stone-600 transition-colors"
                aria-label="Effacer la recherche">
            <i class="fa-solid fa-xmark text-xs"></i>
        </button>
    {% endif %}
    {% if this.query|length >= 2 %}
        <div class="absolute top-full left-0 right-0 mt-1 bg-white rounded-xl shadow-xl border border-spice-border z-50 overflow-hidden">
            {% if this.results is defined and this.results is not empty %}
                {% for result in this.results %}
                    {% if result.type == 'spice' %}
                        <a href="{{ path('view_spice', {id: result.id}) }}"
                           class="block px-4 py-2.5 text-sm text-stone-700 hover:bg-spice-surface hover:text-saffron-700 border-b border-stone-100 last:border-0 transition-colors">
                            {{ result.name }}
                            <span class="text-xs text-saffron-600 ml-1">Épice</span>
                        </a>
                    {% else %}
                        <a href="{{ path('view_aromatic_compound', {id: result.id}) }}"
                           class="block px-4 py-2.5 text-sm text-stone-700 hover:bg-spice-surface hover:text-saffron-700 border-b border-stone-100 last:border-0 transition-colors">
                            {{ result.name }}
                            <span class="text-xs text-turmeric-600 ml-1">Composé</span>
                        </a>
                    {% endif %}
                {% endfor %}
                <a href="{{ path('search_results') }}?q={{ this.query|url_encode }}"
                   class="flex items-center justify-center gap-1.5 px-4 py-2 text-xs text-stone-400 hover:text-saffron-700 hover:bg-stone-50 border-t border-stone-100 transition-colors">
                    <i class="fa-solid fa-magnifying-glass text-[10px]"></i>Voir tous les résultats
                </a>
            {% else %}
                <div class="px-4 py-4 text-center">
                    <p class="text-sm text-stone-400">Aucun résultat pour <span class="text-stone-600 font-medium">« {{ this.query }} »</span></p>
                    <a href="{{ path('search_results') }}?q={{ this.query|url_encode }}"
                       class="inline-flex items-center gap-1 mt-2 text-xs text-saffron-600 hover:underline">
                        <i class="fa-solid fa-arrow-right text-[10px]"></i>Page de recherche complète
                    </a>
                </div>
            {% endif %}
        </div>
    {% endif %}
</div>
