{% import "components/_macro_card_spicy_match.html.twig" as macroCardSpicyMatch %}
{% import 'macros/buttons.html.twig' as buttons %}

<div class="w-full px-4" {{ attributes }}>
    {# Quick View Modal accessible partout dans le Lab #}
    {% include 'components/_spice_modal.html.twig' %}

    {% set compatibleSpices = this.results.compatibleSpices %}
    {% set selectedSpices = this.results.selectedSpices %}

    {% if selectedSpices is empty %}
        <div class="w-full text-center py-6 mb-4">
            <div class="inline-flex flex-col items-center gap-2 text-stone-400">
                <i class="fa-solid fa-hand-pointer text-3xl text-saffron-400/60"></i>
                <p class="text-sm font-medium">Sélectionnez vos épices ci-dessous pour commencer</p>
                <i class="fa-solid fa-chevron-down text-xs animate-bounce text-saffron-500/50"></i>
            </div>
        </div>
    {% endif %}

    {% if selectedSpices is not empty %}
        <form class="flex flex-wrap justify-around items-center" data-model="spices">
            <div class="bg-white border border-stone-200 rounded-2xl w-full p-4 mb-6">
                <h2 class="text-saffron-700 font-display font-semibold text-lg mb-3 p-2">Épices sélectionnées</h2>
                <div class="flex justify-center items-center flex-wrap">
                    {% for groupName, spices in selectedSpices %}
                        <div class="flex flex-col mx-0">
                            <div class="my-3">
                                <h4 class="text-center {{ this.selectedAromaticGroup == groupName ? 'font-bold text-xl' : '' }}" style="color: {{ spices.0.color ?? '#888' }}" data-action="live#action" data-live-action-param="selectAromaticGroup" data-group-name="{{ groupName }}">{{ groupName }}</h4>
                                <div class="w-full h-[5px]" style="background-color: {{ spices.0.color ?? '#888' }}; opacity: 0.5"></div>
                            </div>
                            <div class="flex justify-center items-center flex-wrap">
                                {% for spice in spices %}
                                    {{ macroCardSpicyMatch.cardSpicyMatch(spice, true) }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="mt-4 space-y-2">
                    {{ buttons.button('Ajouter un groupe de mélange', {
                        variant: 'outline',
                        icon: 'fa-solid fa-plus text-xs',
                        attr: {
                            'class': 'w-full justify-center disabled:opacity-50 disabled:cursor-not-allowed',
                            'data-action': 'live#action',
                            'data-live-action-param': 'addGroup',
                            'data-haptic': 'light',
                            'disabled': not this.canAddMoreGroups ? 'disabled' : null
                        }
                    }) }}
                    {{ buttons.button('Étape suivante', {
                        variant: 'primary',
                        icon_pos: 'right',
                        icon: 'fa-solid fa-arrow-right text-xs',
                        attr: {
                            'class': 'w-full justify-center',
                            'data-action': 'live#action',
                            'data-live-action-param': 'nextStep',
                            'data-haptic': 'nudge'
                        }
                    }) }}
                </div>
            </div>
        </form>
    {% endif %}

    <form class="flex flex-wrap justify-around items-center" data-model="spices">
        {% if compatibleSpices is not empty %}
            {% for spice in compatibleSpices %}
                {{ macroCardSpicyMatch.cardSpicyMatch(spice, false, spice.score ?? null) }}
            {% endfor %}
        {% else %}
            <div class="w-full bg-spice-surface border border-spice-border text-stone-700 px-4 py-3 rounded-xl text-center text-sm">
                <i class="fa-solid fa-circle-info text-saffron-500 mr-1.5"></i>Aucune épice supplémentaire n'est compatible avec votre sélection.
            </div>
        {% endif %}
    </form>
</div>
