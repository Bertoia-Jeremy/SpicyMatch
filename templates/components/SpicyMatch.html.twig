{% import "components/_macro_card_spicy_match.html.twig" as macroCardSpicyMatch %}
{% import 'macros/buttons.html.twig' as buttons %}
{% import 'macros/filters.html.twig' as filters %}

<div class="w-full px-4" {{ attributes }}>
    {% set compatibleSpices = this.results.compatibleSpices %}
    {% set selectedSpices = this.results.selectedSpices %}
    {% set filterCount = (this.filterAgId ? 1 : 0) + (this.filterStId ? 1 : 0) + (this.search ? 1 : 0) %}

    {# ── Toggle Auto / Manuel ── #}
    <div class="flex items-center justify-end mb-4">
        <div class="inline-flex rounded-full bg-stone-100 p-0.5 border border-stone-200/60" data-tour="mode-toggle">
            <label class="cursor-pointer">
                <input type="radio" name="mode" value="auto" data-model="mode"
                       {{ this.mode == 'auto' ? 'checked' : '' }} class="sr-only peer">
                <span class="peer-checked:bg-white peer-checked:text-saffron-700 peer-checked:shadow-sm
                             px-3 py-1 rounded-full text-xs font-medium text-stone-500 transition-all">
                    <i class="fa-solid fa-wand-magic-sparkles mr-1 text-[10px]"></i>Auto
                </span>
            </label>
            <label class="cursor-pointer">
                <input type="radio" name="mode" value="manual" data-model="mode"
                       {{ this.mode == 'manual' ? 'checked' : '' }} class="sr-only peer">
                <span class="peer-checked:bg-white peer-checked:text-stone-700 peer-checked:shadow-sm
                             px-3 py-1 rounded-full text-xs font-medium text-stone-500 transition-all">
                    <i class="fa-solid fa-hand mr-1 text-[10px]"></i>Manuel
                </span>
            </label>
        </div>
    </div>

    {# ── Barre de filtres + recherche ── #}
    <div class="flex flex-wrap items-end gap-4 sm:gap-6 mb-6">

        {# Filtre Groupe Aromatique #}
        {% set ag_content %}
            <div class="flex flex-col gap-2">
                {% for group in this.aromaticGroups %}
                    <label class="flex items-center gap-3 cursor-pointer group/item">
                        <input type="radio"
                               name="filterAgId"
                               value="{{ group.id }}"
                               data-model="filterAgId"
                               {{ this.filterAgId == group.id ? 'checked' : '' }}
                               class="size-4 border-stone-300 text-saffron-600 focus:ring-saffron-600/20 cursor-pointer">
                        <span class="text-sm font-medium text-stone-700 group-hover/item:text-saffron-700 transition-colors">
                            {{ group.name }}
                        </span>
                    </label>
                {% endfor %}
            </div>
        {% endset %}
        {{ filters.filter_dropdown('Groupe Aromatique', ag_content, {
            count: this.filterAgId ? 1 : 0,
            reset_click: "$dispatch('live:action', {action: 'resetFilters'})"
        }) }}

        {# Filtre Type d'Épice #}
        {% set st_content %}
            <div class="flex flex-col gap-2">
                {% for type in this.spicyTypes %}
                    <label class="flex items-center gap-3 cursor-pointer group/item">
                        <input type="radio"
                               name="filterStId"
                               value="{{ type.id }}"
                               data-model="filterStId"
                               {{ this.filterStId == type.id ? 'checked' : '' }}
                               class="size-4 border-stone-300 text-saffron-600 focus:ring-saffron-600/20 cursor-pointer">
                        <span class="text-sm font-medium text-stone-700 group-hover/item:text-saffron-700 transition-colors">
                            {{ type.name }}
                        </span>
                    </label>
                {% endfor %}
            </div>
        {% endset %}
        {{ filters.filter_dropdown("Type d'Épice", st_content, {
            count: this.filterStId ? 1 : 0,
            reset_click: "$dispatch('live:action', {action: 'resetFilters'})"
        }) }}

        {# Barre de recherche #}
        <div class="relative flex-1 min-w-45">
            <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-stone-400 text-xs pointer-events-none"></i>
            <input
                type="text"
                data-model="search"
                data-tour="lab-search"
                placeholder="Rechercher une épice…"
                value="{{ this.search }}"
                class="w-full pl-8 {{ this.search ? 'pr-8' : 'pr-3' }} py-2 bg-white border border-spice-border rounded-xl text-sm text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-saffron-600/30 focus:border-saffron-400 transition">
            {% if this.search %}
                <button type="button"
                        data-action="live#action"
                        data-live-action-param="clearSearch"
                        class="absolute right-2.5 top-1/2 -translate-y-1/2 text-stone-400 hover:text-stone-600 transition-colors"
                        aria-label="Effacer la recherche">
                    <i class="fa-solid fa-xmark text-xs"></i>
                </button>
            {% endif %}
        </div>

        {# Reset global #}
        {% if filterCount > 0 %}
            <button type="button"
                    data-action="live#action"
                    data-live-action-param="resetFilters"
                    class="pb-1.5 text-xs font-bold uppercase tracking-widest text-stone-400 hover:text-paprika-700 transition-colors">
                Effacer tout
            </button>
        {% endif %}
    </div>

    {# Compteur #}
    <p class="text-xs text-stone-400 text-right -mt-4 mb-4">
        {{ compatibleSpices|length }} épice{{ compatibleSpices|length != 1 ? 's' : '' }} disponible{{ compatibleSpices|length != 1 ? 's' : '' }}
    </p>

    {% if selectedSpices is empty %}
        <div class="w-full text-center py-6 mb-4">
            <div class="inline-flex flex-col items-center gap-2 text-stone-400">
                <i class="fa-solid fa-hand-pointer text-3xl text-saffron-400/60"></i>
                <p class="text-sm font-medium">Sélectionnez vos épices ci-dessous pour commencer</p>
                <i class="fa-solid fa-chevron-down text-xs animate-bounce text-saffron-500/50"></i>
            </div>
        </div>
    {% endif %}

    {% if selectedSpices is not empty %}
        <form class="flex flex-wrap justify-around items-center" data-model="spices">
            <div class="bg-white border border-stone-200 rounded-2xl w-full p-4 mb-6">
                <h2 class="text-saffron-700 font-display font-semibold text-lg mb-3 p-2">Épices sélectionnées</h2>
                <div class="flex justify-center items-center flex-wrap">
                    {% for groupName, spices in selectedSpices %}
                        <div class="flex flex-col mx-0">
                            <div class="my-3">
                                <h4 class="text-center {{ this.selectedAromaticGroup == groupName ? 'font-bold text-xl' : '' }}" style="color: {{ spices.0.color ?? '#888' }}" data-action="live#action" data-live-action-param="selectAromaticGroup" data-group-name="{{ groupName }}">{{ groupName }}</h4>
                                <div class="w-full h-[5px]" style="background-color: {{ spices.0.color ?? '#888' }}; opacity: 0.5"></div>
                            </div>
                            <div class="flex justify-center items-center flex-wrap">
                                {% for spice in spices %}
                                    {{ macroCardSpicyMatch.cardSpicyMatch(spice, true) }}
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

                <div class="mt-4 space-y-2">
                    {{ buttons.button('Ajouter un groupe de mélange', {
                        variant: 'outline',
                        icon: 'fa-solid fa-plus text-xs',
                        attr: {
                            'class': 'w-full justify-center disabled:opacity-50 disabled:cursor-not-allowed',
                            'data-action': 'live#action',
                            'data-live-action-param': 'addGroup',
                            'data-haptic': 'light',
                            'disabled': not this.canAddMoreGroups ? 'disabled' : null
                        }
                    }) }}
                    {{ buttons.button('Étape suivante', {
                        variant: 'primary',
                        icon_pos: 'right',
                        icon: 'fa-solid fa-arrow-right text-xs',
                        attr: {
                            'class': 'w-full justify-center',
                            'data-action': 'live#action',
                            'data-live-action-param': 'nextStep',
                            'data-haptic': 'nudge'
                        }
                    }) }}
                </div>
            </div>
        </form>
    {% endif %}


    <form class="flex flex-wrap justify-around items-center" data-model="spices">
        {% if compatibleSpices is not empty %}
            {% for spice in compatibleSpices %}
                {{ macroCardSpicyMatch.cardSpicyMatch(spice, false, spice.score ?? null) }}
            {% endfor %}
        {% else %}
            <div class="w-full bg-spice-surface border border-spice-border text-stone-700 px-4 py-3 rounded-xl text-center text-sm">
                <i class="fa-solid fa-circle-info text-saffron-500 mr-1.5"></i>
                {% if this.search %}
                    Aucune épice ne correspond à « {{ this.search }} ».
                {% else %}
                    Aucune épice supplémentaire n'est compatible avec votre sélection.
                {% endif %}
            </div>
        {% endif %}
    </form>
</div>
