{% import "components/_macro_card_spicy_match.html.twig" as macroCardSpicyMatch %}
{% import 'macros/buttons.html.twig' as buttons %}
{% import 'macros/filters.html.twig' as filters %}

<div class="w-full" {{ attributes }}>
    {% set compatibleSpices = this.results.compatibleSpices %}
    {% set selectedSpices = this.results.selectedSpices %}
    {% set filterCount = (this.filterAgId ? 1 : 0) + (this.filterStId ? 1 : 0) + (this.search ? 1 : 0) %}

    {# Pré-calculs floatbar #}
    {% set selectedCount = 0 %}
    {% for gName, spices in selectedSpices %}
        {% set selectedCount = selectedCount + spices|length %}
    {% endfor %}

    {% set firstThree = [] %}
    {% for gName, spices in selectedSpices %}
        {% for sp in spices %}
            {% if firstThree|length < 3 %}
                {% set firstThree = firstThree|merge([sp]) %}
            {% endif %}
        {% endfor %}
    {% endfor %}

    {# ── Layout 2 colonnes : main + sidebar ── #}
    <div class="grid xl:grid-cols-[1fr_300px] gap-6">

        {# ────────────── COLONNE PRINCIPALE ────────────── #}
        <div class="min-w-0">

            {# Barre de filtres + recherche + toggle — inline comme le design #}
            <div class="flex flex-wrap items-center gap-2 mb-2 pb-4 border-b border-spice-border">

                {# Filtre Groupe Aromatique #}
                {% set ag_content %}
                    <div class="flex flex-col gap-2">
                        {% for group in this.aromaticGroups %}
                            <label class="flex items-center gap-3 cursor-pointer group/item">
                                <input type="radio"
                                       name="filterAgId"
                                       value="{{ group.id }}"
                                       data-model="filterAgId"
                                       {{ this.filterAgId == group.id ? 'checked' : '' }}
                                       class="size-4 border-stone-300 text-saffron-600 focus:ring-saffron-600/20 cursor-pointer">
                                <span class="text-sm font-medium text-stone-700 group-hover/item:text-saffron-700 transition-colors">
                                    {{ group.name }}
                                </span>
                            </label>
                        {% endfor %}
                    </div>
                {% endset %}
                <div data-tour="lab-aromatic-filter">
                    {{ filters.filter_dropdown('ui.filters.aromatic_group'|trans, ag_content, {
                        count: this.filterAgId ? 1 : 0,
                        reset_click: "$dispatch('live:action', {action: 'resetFilters'})",
                        style: 'pill'
                    }) }}
                </div>

                {# ── Sélecteur de cuisson (Étape 3E-2) ─────────────────────── #}
                {% set cooking_content %}
                    <div class="flex flex-col gap-4" x-data="{ advanced: {{ this.hasCustomCulinaryContext and (this.fatRatio > 0 or this.cookingTimeMin > 0) ? 'true' : 'false' }} }">
                        {# Question d'amorce #}
                        <p class="text-xs text-stone-500 leading-snug">
                            {{ 'ui.lab.cooking_question_html'|trans|raw }}
                        </p>

                        {# Trois grands modes culinaires (UX-6 ARIA labels + UX-2 contraste +800) #}
                        <div class="grid grid-cols-3 gap-2" role="group" aria-label="{{ 'ui.lab.culinary_context_aria'|trans }}">
                            <button type="button"
                                    data-action="live#action"
                                    data-live-action-param="setCookingPreset"
                                    data-live-preset-param="dry"
                                    aria-label="{{ 'ui.lab.preset_dry_aria'|trans }}"
                                    aria-pressed="{{ this.matrix == 'air' and this.cookingTimeMin == 0 and this.fatRatio == 0 ? 'true' : 'false' }}"
                                    class="flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl border text-center transition
                                           focus-visible:ring-2 focus-visible:ring-saffron-600 focus-visible:outline-none
                                           {{ this.matrix == 'air' and this.cookingTimeMin == 0 and this.fatRatio == 0
                                                ? 'border-saffron-500 bg-saffron-100 text-saffron-800 shadow-sm'
                                                : 'border-stone-200 bg-white text-stone-600 hover:border-saffron-200 hover:bg-saffron-50/40' }}">
                                <i class="fa-solid fa-wind text-base" aria-hidden="true"></i>
                                <span class="text-[12px] font-semibold">{{ 'ui.lab.preset_dry'|trans }}</span>
                                <span class="text-[9px] text-stone-400 uppercase tracking-wider">{{ 'ui.lab.preset_air'|trans }}</span>
                            </button>

                            <button type="button"
                                    data-action="live#action"
                                    data-live-action-param="setCookingPreset"
                                    data-live-preset-param="broth"
                                    aria-label="{{ 'ui.lab.preset_broth_aria'|trans }}"
                                    aria-pressed="{{ this.matrix == 'water' and this.fatRatio == 0 and this.cookingTimeMin > 0 ? 'true' : 'false' }}"
                                    class="flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl border text-center transition
                                           focus-visible:ring-2 focus-visible:ring-saffron-600 focus-visible:outline-none
                                           {{ this.matrix == 'water' and this.fatRatio == 0 and this.cookingTimeMin > 0
                                                ? 'border-saffron-500 bg-saffron-100 text-saffron-800 shadow-sm'
                                                : 'border-stone-200 bg-white text-stone-600 hover:border-saffron-200 hover:bg-saffron-50/40' }}">
                                <i class="fa-solid fa-glass-water text-base" aria-hidden="true"></i>
                                <span class="text-[12px] font-semibold">{{ 'ui.lab.preset_broth'|trans }}</span>
                                <span class="text-[9px] text-stone-400 uppercase tracking-wider">{{ 'ui.lab.preset_water'|trans }}</span>
                            </button>

                            <button type="button"
                                    data-action="live#action"
                                    data-live-action-param="setCookingPreset"
                                    data-live-preset-param="saute"
                                    aria-label="{{ 'ui.lab.preset_saute_aria'|trans }}"
                                    aria-pressed="{{ this.matrix == 'oil' and this.fatRatio >= 1 ? 'true' : 'false' }}"
                                    class="flex flex-col items-center gap-1.5 py-3 px-2 rounded-xl border text-center transition
                                           focus-visible:ring-2 focus-visible:ring-saffron-600 focus-visible:outline-none
                                           {{ this.matrix == 'oil' and this.fatRatio >= 1
                                                ? 'border-saffron-500 bg-saffron-100 text-saffron-800 shadow-sm'
                                                : 'border-stone-200 bg-white text-stone-600 hover:border-saffron-200 hover:bg-saffron-50/40' }}">
                                <i class="fa-solid fa-fire-flame-curved text-base" aria-hidden="true"></i>
                                <span class="text-[12px] font-semibold">{{ 'ui.lab.preset_saute'|trans }}</span>
                                <span class="text-[9px] text-stone-400 uppercase tracking-wider">{{ 'ui.lab.preset_oil'|trans }}</span>
                            </button>
                        </div>

                        {# Avancé : sliders fine-tuning #}
                        <button type="button"
                                @click="advanced = !advanced"
                                class="flex items-center justify-between text-[11px] font-mono uppercase tracking-widest
                                       text-stone-400 hover:text-saffron-600 transition-colors">
                            <span>{{ 'ui.lab.advanced'|trans }}</span>
                            <i class="fa-solid fa-chevron-down text-[9px] transition-transform" :class="{ 'rotate-180': advanced }"></i>
                        </button>

                        <div x-show="advanced" x-cloak class="flex flex-col gap-3">
                            {# Matrice ODT (override manuel) #}
                            <div>
                                <div class="flex items-baseline justify-between mb-1.5">
                                    <label class="text-[11px] font-mono uppercase tracking-widest text-stone-500">{{ 'ui.lab.odt_matrix'|trans }}</label>
                                    <span class="text-[11px] text-stone-400">{{ this.matrix }}</span>
                                </div>
                                <div class="inline-flex w-full rounded-full bg-stone-50 p-0.5 border border-stone-200">
                                    {% for m in ['air', 'water', 'oil'] %}
                                        <label class="cursor-pointer flex-1">
                                            <input type="radio" name="matrix" value="{{ m }}" data-model="matrix"
                                                   {{ this.matrix == m ? 'checked' : '' }} class="sr-only peer">
                                            <span class="peer-checked:bg-white peer-checked:text-saffron-700 peer-checked:shadow-sm
                                                         block px-2 py-1 rounded-full text-[11px] font-semibold text-center text-stone-500 transition-all">
                                                {{ m }}
                                            </span>
                                        </label>
                                    {% endfor %}
                                </div>
                            </div>

                            {# Fraction grasse #}
                            <div>
                                <div class="flex items-baseline justify-between mb-1">
                                    <label for="fatRatio" class="text-[11px] font-mono uppercase tracking-widest text-stone-500">{{ 'ui.lab.fat_ratio'|trans }}</label>
                                    <span class="text-[11px] text-stone-700 font-semibold tabular-nums">{{ (this.fatRatio * 100)|round }}&nbsp;%</span>
                                </div>
                                <input id="fatRatio" type="range" min="0" max="1" step="0.05"
                                       value="{{ this.fatRatio }}"
                                       data-model="debounce(400)|fatRatio"
                                       class="w-full accent-saffron-600">
                            </div>

                            {# Cuisson #}
                            <div>
                                <div class="flex items-baseline justify-between mb-1">
                                    <label for="cookingTimeMin" class="text-[11px] font-mono uppercase tracking-widest text-stone-500">{{ 'ui.lab.cooking_time'|trans }}</label>
                                    <span class="text-[11px] text-stone-700 font-semibold tabular-nums">{{ this.cookingTimeMin }}&nbsp;min</span>
                                </div>
                                <input id="cookingTimeMin" type="range" min="0" max="120" step="5"
                                       value="{{ this.cookingTimeMin }}"
                                       data-model="debounce(400)|cookingTimeMin"
                                       class="w-full accent-saffron-600">
                            </div>

                            {# Température #}
                            <div>
                                <div class="flex items-baseline justify-between mb-1">
                                    <label for="temperatureCelsius" class="text-[11px] font-mono uppercase tracking-widest text-stone-500">{{ 'ui.lab.temperature'|trans }}</label>
                                    <span class="text-[11px] text-stone-700 font-semibold tabular-nums">{{ this.temperatureCelsius }}&nbsp;°C</span>
                                </div>
                                <input id="temperatureCelsius" type="range" min="20" max="220" step="5"
                                       value="{{ this.temperatureCelsius }}"
                                       data-model="debounce(400)|temperatureCelsius"
                                       class="w-full accent-saffron-600">
                            </div>
                        </div>
                    </div>
                {% endset %}

                {# UX-1 : libellé explicite "Mode : X" pour rendre l'action et l'état visibles. #}
                <div title="{{ 'ui.lab.mode_tooltip'|trans }}">
                    {{ filters.filter_dropdown('ui.lab.mode_prefix'|trans({'%label%': this.culinaryLabel}), cooking_content, {
                        count: this.hasCustomCulinaryContext ? 1 : 0,
                        reset_click: "$dispatch('live:action', {action: 'resetCulinaryContext'})",
                        style: 'pill'
                    }) }}
                </div>

                {# Filtre Type d'Épice #}
                {% set st_content %}
                    <div class="flex flex-col gap-2">
                        {% for type in this.spicyTypes %}
                            <label class="flex items-center gap-3 cursor-pointer group/item">
                                <input type="radio"
                                       name="filterStId"
                                       value="{{ type.id }}"
                                       data-model="filterStId"
                                       {{ this.filterStId == type.id ? 'checked' : '' }}
                                       class="size-4 border-stone-300 text-saffron-600 focus:ring-saffron-600/20 cursor-pointer">
                                <span class="text-sm font-medium text-stone-700 group-hover/item:text-saffron-700 transition-colors">
                                    {{ type.name }}
                                </span>
                            </label>
                        {% endfor %}
                    </div>
                {% endset %}
                {{ filters.filter_dropdown('ui.filters.spice_type'|trans, st_content, {
                    count: this.filterStId ? 1 : 0,
                    reset_click: "$dispatch('live:action', {action: 'resetFilters'})",
                    style: 'pill'
                }) }}

                {# Barre de recherche #}
                <div class="relative flex-1 min-w-44">
                    <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-stone-400 text-xs pointer-events-none"></i>
                    <input
                        type="text"
                        data-model="debounce(300)|search"
                        data-tour="lab-search"
                        placeholder="{{ 'ui.lab.search_spice'|trans }}"
                        value="{{ this.search }}"
                        class="w-full pl-8 {{ this.search ? 'pr-8' : 'pr-3' }} py-2 bg-white border border-spice-border rounded-xl text-sm text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-saffron-600/30 focus:border-saffron-400 transition">
                    {% if this.search %}
                        <button type="button"
                                data-action="live#action"
                                data-live-action-param="clearSearch"
                                class="absolute right-2 top-1/2 -translate-y-1/2 size-5 flex items-center justify-center rounded-full text-stone-400 hover:text-stone-600 hover:bg-stone-100 transition-colors"
                                aria-label="{{ 'ui.lab.clear_search'|trans }}">
                            <i class="fa-solid fa-xmark text-sm"></i>
                        </button>
                    {% endif %}
                </div>

                {# Reset global — uniquement quand un filtre dropdown est actif (la croix gère la recherche) #}
                {% if this.filterAgId or this.filterStId %}
                    <button type="button"
                            data-action="live#action"
                            data-live-action-param="resetFilters"
                            class="pb-1.5 text-xs font-bold uppercase tracking-widest text-stone-400 hover:text-paprika-700 transition-colors whitespace-nowrap">
                        {{ 'ui.lab.clear_all'|trans }}
                    </button>
                {% endif %}

                {# Toggle Auto / Manuel — inline dans la toolbar #}
                <div class="inline-flex rounded-full bg-cream p-0.5 border border-spice-border shadow-sm ml-auto"
                     data-tour="mode-toggle">
                    <label class="cursor-pointer">
                        <input type="radio" name="mode" value="auto" data-model="mode"
                               {{ this.mode == 'auto' ? 'checked' : '' }} class="sr-only peer">
                        <span class="peer-checked:bg-white peer-checked:text-saffron-700 peer-checked:shadow-sm
                                     px-3 py-1.5 rounded-full text-xs font-semibold text-stone-500 transition-all inline-flex items-center gap-1.5">
                            <i class="fa-solid fa-wand-magic-sparkles text-[10px]"></i>{{ 'ui.lab.auto'|trans }}
                        </span>
                    </label>
                    <label class="cursor-pointer">
                        <input type="radio" name="mode" value="manual" data-model="mode"
                               {{ this.mode == 'manual' ? 'checked' : '' }} class="sr-only peer">
                        <span class="peer-checked:bg-white peer-checked:text-stone-700 peer-checked:shadow-sm
                                     px-3 py-1.5 rounded-full text-xs font-semibold text-stone-500 transition-all inline-flex items-center gap-1.5">
                            <i class="fa-solid fa-hand text-[10px]"></i>{{ 'ui.lab.manual'|trans }}
                        </span>
                    </label>
                </div>

                {# Meta compteur #}
                <span class="font-mono text-[11px] text-stone-400 whitespace-nowrap">
                    {{ 'ui.lab.spices_count'|trans({'%count%': compatibleSpices|length}) }}
                </span>
            </div>

            {# ── Grille épices plate.
                 UX-3 feedback debounce : data-loading="addClass(opacity-60)" donne un signal
                 visuel immédiat (50–100 ms) pendant que le serveur recalcule les scores. ── #}
            <form data-model="spices" data-loading="addClass(opacity-60)">
                {% if compatibleSpices is not empty %}
                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 transition-opacity duration-150">
                        {% for spice in compatibleSpices %}
                            {{ macroCardSpicyMatch.cardSpicyMatch(spice, false, spice.score ?? null) }}
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="w-full bg-spice-surface border border-spice-border text-stone-700 px-4 py-4 rounded-xl text-center text-sm">
                        <i class="fa-solid fa-circle-info text-saffron-500 mr-1.5"></i>
                        {% if this.search %}
                            {{ 'ui.lab.no_match'|trans({'%query%': this.search}) }}
                        {% else %}
                            {{ 'ui.lab.no_more_compatible'|trans }}
                        {% endif %}
                    </div>
                {% endif %}
            </form>

        </div>{# fin colonne principale #}

        {# ────────────── WORKSPACE SIDEBAR (xl+) ────────────── #}
        <aside class="hidden xl:block">
            <div class="workspace">

                {# Entête #}
                <div class="flex items-baseline justify-between pb-3 border-b border-spice-border">
                    <h3 class="font-display text-lg font-medium text-stone-800">{{ 'ui.lab.my_blend'|trans }}</h3>
                    <span class="group-count">{{ selectedCount }}</span>
                </div>

                {# Liste des épices sélectionnées #}
                <div class="workspace-list flex flex-col gap-2">
                    {% if selectedCount == 0 %}
                        <div class="ws-empty">
                            <i class="fa-solid fa-mortar-pestle text-3xl text-stone-300"></i>
                            <p class="text-sm leading-snug text-stone-400">
                                {{ 'ui.lab.empty_html'|trans|raw }}
                            </p>
                        </div>
                    {% else %}
                        {% for gName, spices in selectedSpices %}
                            {# En-tête groupe dans sidebar #}
                            <div class="flex items-center gap-2 px-1 pt-1">
                                <span class="size-2 rounded-full flex-none"
                                      style="background: {{ spices.0.color ?? '#888' }}"></span>
                                <span class="font-mono text-[9.5px] uppercase tracking-widest text-stone-400 truncate flex-1">
                                    {{ gName }}
                                </span>
                                <span class="font-mono text-[10px] text-stone-400 tabular-nums">{{ spices|length }}</span>
                            </div>
                            {% for spice in spices %}
                                {% set wsImg = spice.file ? asset('uploads/spices/' ~ spice.file) : null %}
                                <div class="ws-item">
                                    <div class="ws-thumb">
                                        {% if wsImg %}
                                            <img src="{{ wsImg }}" alt="{{ spice.name }}" loading="lazy">
                                        {% else %}
                                            <div class="w-full h-full flex items-center justify-center text-stone-300">
                                                <i class="fa-solid fa-seedling text-sm"></i>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="font-display text-sm font-medium text-stone-800 truncate leading-tight">
                                            {{ spice.name }}
                                        </p>
                                        <p class="text-[10px] font-mono uppercase tracking-wide text-stone-400 truncate">
                                            {{ gName }}
                                        </p>
                                    </div>
                                    {# Checkbox cachée (checked) — unchecking la retire du modèle LC #}
                                    <input type="checkbox"
                                           class="sr-only"
                                           data-model="spices.selectedSpices"
                                           value="{{ spice.id }}"
                                           checked>
                                    <button type="button"
                                            @click.prevent="$el.previousElementSibling.click()"
                                            class="size-6 rounded-md flex items-center justify-center shrink-0
                                                   text-stone-400 hover:bg-stone-100 hover:text-saffron-600 transition-colors"
                                            aria-label="{{ 'ui.lab.remove'|trans({'%name%': spice.name}) }}">
                                        <i class="fa-solid fa-xmark text-xs"></i>
                                    </button>
                                </div>
                            {% endfor %}
                        {% endfor %}
                    {% endif %}
                </div>

                {# CTAs #}
                <div class="flex flex-col gap-2 pt-1 border-t border-spice-border">
                    {% if selectedCount > 0 %}
                        <button type="button"
                                data-action="live#action"
                                data-live-action-param="clearSelection"
                                class="inline-flex items-center justify-center gap-2 w-full px-4 py-2 rounded-xl
                                       text-sm font-semibold border border-spice-border text-stone-500
                                       hover:border-paprika-300 hover:text-paprika-700 hover:bg-paprika-50/50 transition-colors">
                            <i class="fa-solid fa-trash-can text-xs"></i>{{ 'ui.lab.clear_selection'|trans }}
                        </button>
                    {% endif %}
                    <button type="button"
                            data-action="live#action"
                            data-live-action-param="nextStep"
                            data-haptic="nudge"
                            {% if selectedCount == 0 %}disabled{% endif %}
                            class="inline-flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-xl
                                   text-sm font-semibold bg-saffron-600 text-white shadow-sm
                                   hover:bg-saffron-700 transition-colors
                                   disabled:opacity-40 disabled:cursor-not-allowed">
                        {{ 'ui.lab.compose'|trans }}<i class="fa-solid fa-arrow-right text-xs"></i>
                    </button>
                </div>

                {# Badge qualité des données (Levier 4) — honnêteté sur la fiabilité du score.
                   Affiché dès qu'une sélection existe ; alerte visuelle si non production-grade. #}
                {% set dataConfidence = this.dataConfidence %}
                {% if dataConfidence is not null %}
                    {% set isProd = dataConfidence.isProductionGrade %}
                    <div class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg text-[11px] border
                                {{ isProd ? 'bg-emerald-50 border-emerald-200' : 'bg-stone-100 border-stone-300' }}">
                        <i class="fa-solid {{ isProd ? 'fa-circle-check text-emerald-600' : 'fa-flask-vial text-stone-500' }} shrink-0"
                           aria-hidden="true"></i>
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold {{ isProd ? 'text-emerald-800' : 'text-stone-700' }}">
                                {{ 'ui.lab.data'|trans({'%label%': dataConfidence.label|trans}) }} <span class="font-mono opacity-70">[{{ dataConfidence.tier }}]</span>
                            </p>
                            {% if not isProd %}
                                <p class="text-stone-500">{{ 'ui.lab.scores_indicative'|trans }}</p>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}

                {# Tip footer #}
                {% if selectedCount > 0 %}
                    <p class="text-[11px] text-stone-400 leading-relaxed flex gap-1.5 pt-1">
                        <i class="fa-solid fa-circle-info text-saffron-400 mt-0.5 shrink-0"></i>
                        {{ 'ui.lab.tip_mode_html'|trans({'%count%': selectedCount, '%mode%': this.mode == 'auto' ? 'ui.lab.auto'|trans : 'ui.lab.manual'|trans})|raw }}
                    </p>
                {% endif %}

                {# Indicateur contexte culinaire — visible dès qu'on quitte les defaults.
                   UX-2 contraste WCAG : bg-saffron-100 + text-saffron-800/900 (ratio ≥ 4.5:1). #}
                {% if this.hasCustomCulinaryContext %}
                    <div class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg bg-saffron-100 border border-saffron-300 text-[11px]">
                        <i class="fa-solid fa-fire text-saffron-700 shrink-0" aria-hidden="true"></i>
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-saffron-900 truncate">{{ this.culinaryLabel }}</p>
                            <p class="text-saffron-800 tabular-nums">
                                {{ this.matrix }}
                                {%- if this.fatRatio > 0 %} · {{ (this.fatRatio * 100)|round }} % gras{% endif -%}
                                {%- if this.cookingTimeMin > 0 %} · {{ this.cookingTimeMin }} min @ {{ this.temperatureCelsius }} °C{% endif -%}
                            </p>
                        </div>
                        <button type="button"
                                data-action="live#action"
                                data-live-action-param="resetCulinaryContext"
                                aria-label="{{ 'ui.lab.reset_culinary_aria'|trans }}"
                                class="shrink-0 size-5 rounded-md flex items-center justify-center text-saffron-700 hover:bg-saffron-200 hover:text-saffron-900 transition-colors focus-visible:ring-2 focus-visible:ring-saffron-600 focus-visible:outline-none">
                            <i class="fa-solid fa-xmark text-[10px]" aria-hidden="true"></i>
                        </button>
                    </div>
                {% endif %}

            </div>
        </aside>

    </div>{# fin grid 2 colonnes #}

    {# ── FLOATBAR mobile (<xl) ── #}
    <div class="floatbar">
        {% if selectedCount == 0 %}
            <div class="flex items-center gap-2 text-stone-400 text-sm flex-1">
                <i class="fa-solid fa-hand-pointer text-saffron-400"></i>
                {{ 'ui.lab.select_spices'|trans }}
            </div>
            <button type="button"
                    disabled
                    class="inline-flex items-center gap-2 h-10 px-4 rounded-xl
                           text-sm font-semibold bg-stone-200 text-stone-400 cursor-not-allowed shrink-0">
                {{ 'ui.lab.compose_short'|trans }} <i class="fa-solid fa-arrow-right text-xs"></i>
            </button>
        {% else %}
            <div class="flex items-center gap-3 flex-1 min-w-0">
                {# Avatars épices #}
                <div class="flex">
                    {% for sp in firstThree %}
                        {% set fbImg = sp.file ? asset('uploads/spices/' ~ sp.file) : null %}
                        <div class="size-8 rounded-full border-2 border-white overflow-hidden bg-spice-surface {{ not loop.first ? '-ml-2' : '' }}">
                            {% if fbImg %}
                                <img src="{{ fbImg }}" alt="{{ sp.name }}" class="w-full h-full object-cover">
                            {% else %}
                                <div class="w-full h-full grid place-items-center text-stone-300 text-xs">
                                    <i class="fa-solid fa-seedling"></i>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                    {% if selectedCount > 3 %}
                        <div class="size-8 rounded-full border-2 border-white -ml-2
                                    bg-spice-surface flex items-center justify-center
                                    font-mono text-[10px] text-stone-500 shrink-0">
                            +{{ selectedCount - 3 }}
                        </div>
                    {% endif %}
                </div>
                <div class="min-w-0">
                    <p class="font-display text-sm font-medium text-stone-800 leading-tight">
                        {{ 'ui.lab.spices_count'|trans({'%count%': selectedCount}) }}
                    </p>
                    <p class="font-mono text-[10px] uppercase tracking-wide text-stone-400">{{ 'ui.lab.selected'|trans }}</p>
                </div>
            </div>
            <button type="button"
                    data-action="live#action"
                    data-live-action-param="nextStep"
                    data-haptic="nudge"
                    class="inline-flex items-center gap-2 h-10 px-4 rounded-xl
                           text-sm font-semibold bg-saffron-600 text-white shadow-sm
                           hover:bg-saffron-700 transition-colors shrink-0">
                {{ 'ui.lab.compose_short'|trans }} <i class="fa-solid fa-arrow-right text-xs"></i>
            </button>
        {% endif %}
    </div>

</div>
