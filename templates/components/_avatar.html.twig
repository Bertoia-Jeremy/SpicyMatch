{#
  Composant avatar — l'avatar EST le badge équipé (rareté + icône).
  Variables :
    - equippedBadge (UserAchievement|null) : badge équipé, null → avatar par défaut
    - sizeClass     (string)               : classes Tailwind taille/texte (défaut : 'w-16 h-16 text-2xl')
    - borderClass   (string)               : classes de bordure (défaut : 'border-2 border-saffron-400/30')
    - level         (int|null)             : niveau à afficher en badge overlay (défaut : null — pas de badge)
  Usage :
    {% include 'components/_avatar.html.twig' with { equippedBadge: progression.equippedBadge, level: progression.level } %}
#}
{% set sizeClass = sizeClass ?? 'w-16 h-16 text-2xl' %}
{% set borderClass = borderClass ?? 'border-2 border-saffron-400/30' %}
{% set level = level ?? null %}

<div class="relative inline-flex shrink-0">
    {% if equippedBadge is defined and equippedBadge %}
        {% set colors = rarity_colors(equippedBadge.achievement.rarity) %}
        <div class="{{ sizeClass }} rounded-full flex items-center justify-center shrink-0"
             style="background-color: {{ colors.bg }}; box-shadow: 0 0 0 2px white, 0 0 0 4px {{ colors.ring }}">
            <i class="{{ equippedBadge.achievement.icon }}" style="color: {{ colors.text }}"></i>
        </div>
    {% else %}
        <div class="{{ sizeClass }} {{ borderClass }} rounded-full flex items-center justify-center shrink-0 bg-saffron-50">
            <i class="fa-solid fa-user text-saffron-700" aria-hidden="true"></i>
        </div>
    {% endif %}

    {% if level %}
        <span class="absolute -bottom-1 -right-1 px-1.5 py-0.5 text-xs font-bold bg-turmeric-400 text-stone-900 rounded-full leading-none ring-2 ring-white">
            {{ level }}
        </span>
    {% endif %}
</div>
