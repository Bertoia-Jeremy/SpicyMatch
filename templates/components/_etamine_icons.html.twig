{#
  Dispatcher d'icônes SVG pour les tuiles méthode (L'Étamine).
  Paramètre attendu : name (string) — titre de la méthode de préparation.
  Mapping par correspondance de sous-chaîne (lowercase).
#}
{% set n = name|lower %}

{% if 'mortier' in n or 'pilon' in n %}
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M4 11h16M5 11c0 4 3 7 7 7s7-3 7-7M9 7l2-3m3 3l-2-3M16 6l1-2" stroke="#9A4720" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>

{% elseif 'torr' in n or 'flamm' in n or 'grillé' in n or 'grille' in n %}
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M4 14h14a3 3 0 0 0 0-6h-1M4 14c0 2 1.5 4 4 4h6c2.5 0 4-2 4-4M19 11h2M10 5c0 1.5 2 2 2 4M14 4c0 2 2 2 2 4" stroke="#9A4720" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>

{% elseif 'infus' in n or 'thé' in n or 'the' in n or 'mug' in n or 'chaud' in n %}
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M5 11h12v2a5 5 0 0 1-5 5h-2a5 5 0 0 1-5-5v-2zm12 1h2a2 2 0 0 1 0 4h-1M9 3c0 2-2 2-2 4m4-4c0 2-2 2-2 4" stroke="#9A4720" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>

{% elseif 'moulin' in n or 'moulue' in n or 'moulu' in n or 'poudre' in n %}
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M8 4h8l-1 4H9L8 4zm-1 4h10l1 4H6l1-4zm0 4h10v3a4 4 0 0 1-4 4h-2a4 4 0 0 1-4-4v-3z" stroke="#9A4720" stroke-width="1.5" stroke-linejoin="round"/>
  </svg>

{% elseif 'couteau' in n or 'cisel' in n or 'ciseau' in n or 'hacher' in n or 'haché' in n %}
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M3 17l13-13 4 4-9 9-8 4 0-4zm6 0l8-8" stroke="#9A4720" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>

{% elseif 'huile' in n or 'émuls' in n or 'emuls' in n or 'tempér' in n or 'temper' in n or 'tadka' in n %}
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M12 3s7 8 7 13a7 7 0 1 1-14 0c0-5 7-13 7-13zM9 14a3 3 0 0 0 3 3" stroke="#9A4720" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>

{% else %}
  {# Fallback : feuille #}
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M17 8C8 10 5.9 16.17 3.82 19.68A1 1 0 0 0 4.93 21C9 19 12 17 12 17s0 2-2 4c5-3 9.73-8.17 8-13-1-3-3-5-8-5C4 3 3 7 3 9c0 4 4 6 4 6s1-8 10-7z" stroke="#9A4720" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{% endif %}
