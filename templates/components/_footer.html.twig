<footer class="relative" role="contentinfo"
        style="background: var(--color-parchment); border-top: 1px solid rgba(184,134,74,0.3)">

    <div class="max-w-7xl mx-auto px-6 py-14 lg:py-20">

        {# Ornement centré #}
        <div class="flex items-center gap-4 mb-14">
            <div class="flex-1 h-px"
                 style="background: linear-gradient(90deg, transparent, rgba(184,134,74,0.35))"></div>
            <span class="font-mono text-[9px] tracking-[0.4em] uppercase"
                  style="color: rgba(184,134,74,0.65)">✦ MAISON · EST. 2024 ✦</span>
            <div class="flex-1 h-px"
                 style="background: linear-gradient(270deg, transparent, rgba(184,134,74,0.35))"></div>
        </div>

        {# ── Grille 4 colonnes ────────────────────────────────────────── #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">

            {# Col 1 : Marque #}
            <div class="space-y-6">
                <a href="{{ path('home') }}" class="group flex items-center gap-3 no-underline">
                    <div class="size-11 rounded-full flex items-center justify-center shrink-0 transition-transform group-hover:scale-105"
                         style="background: radial-gradient(circle at 38% 35%, #D14A38, #9C2E22, #5C1A12);
                                box-shadow: 0 2px 12px rgba(176,57,43,0.3)">
                        <i class="fa-solid fa-mortar-pestle text-[15px]" style="color: var(--color-parchment)"></i>
                    </div>
                    <div class="leading-none">
                        <div class="font-mono text-[9px] tracking-[0.2em] uppercase"
                             style="color: rgba(184,134,74,0.7)">MAISON</div>
                        <div class="font-display text-[22px] font-medium leading-none"
                             style="color: var(--color-ink-deep)">
                            Spicy <em class="not-italic italic" style="color: #B91C1C">Match</em>
                        </div>
                    </div>
                </a>
                <p class="text-sm leading-relaxed max-w-xs"
                   style="color: rgba(42,24,16,0.5)">
                    L'alchimie aromatique au service de vos recettes. Découvrez des accords invisibles et sublimez vos créations culinaires.
                </p>
                <div class="flex items-center gap-3">
                    <a href="#" aria-label="Instagram"
                       class="size-9 rounded-full flex items-center justify-center transition-colors hover:border-copper"
                       style="border: 1px solid rgba(184,134,74,0.35); color: rgba(42,24,16,0.45)">
                        <i class="fa-brands fa-instagram text-sm" aria-hidden="true"></i>
                    </a>
                    <a href="#" aria-label="Pinterest"
                       class="size-9 rounded-full flex items-center justify-center transition-colors hover:border-copper"
                       style="border: 1px solid rgba(184,134,74,0.35); color: rgba(42,24,16,0.45)">
                        <i class="fa-brands fa-pinterest-p text-sm" aria-hidden="true"></i>
                    </a>
                </div>
            </div>

            {# Col 2 : Navigation #}
            <div>
                <h3 class="font-display italic text-[14px] mb-7 flex items-center gap-3"
                    style="color: var(--color-copper)">
                    <span class="block h-px w-5" style="background: var(--color-copper)"></span>
                    Navigation
                </h3>
                <ul class="space-y-4 list-none p-0">
                    <li><a href="{{ path('home') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        Accueil
                    </a></li>
                    <li><a href="{{ path('index_spices') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        Catalogue des épices
                    </a></li>
                    <li><a href="{{ path('index_spicy_match') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        Le Lab — Mélanges
                    </a></li>
                    <li><a href="{{ path('new_contact') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        Aide & Contact
                    </a></li>
                </ul>
            </div>

            {# Col 3 : L'Académie #}
            <div>
                <h3 class="font-display italic text-[14px] mb-7 flex items-center gap-3"
                    style="color: var(--color-copper)">
                    <span class="block h-px w-5" style="background: var(--color-copper)"></span>
                    L'Académie
                </h3>
                <ul class="space-y-4 list-none p-0">
                    <li><a href="{{ path('education_index') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        L'Académie des saveurs
                    </a></li>
                    <li><a href="{{ path('index_aromatic_compound') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        Composés aromatiques
                    </a></li>
                    <li><a href="{{ path('index_aromatic_groups') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        Groupes de saveurs
                    </a></li>
                    <li><a href="{{ path('index_spicy_type') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        Classification
                    </a></li>
                </ul>
            </div>

            {# Col 4 : L'Atelier #}
            <div>
                <h3 class="font-display italic text-[14px] mb-7 flex items-center gap-3"
                    style="color: var(--color-copper)">
                    <span class="block h-px w-5" style="background: var(--color-copper)"></span>
                    L'Atelier
                </h3>
                {% if is_granted('ROLE_USER') %}
                    <ul class="space-y-4 list-none p-0">
                        <li><a href="{{ path('profile_user') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            Mon Profil de Chef
                        </a></li>
                        <li><a href="{{ path('history_user') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            Mes Mélanges
                        </a></li>
                        <li><a href="{{ path('configuration_user') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            Configuration
                        </a></li>
                        <li><a href="{{ path('app_logout') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            Se déconnecter
                        </a></li>
                    </ul>
                {% else %}
                    <p class="text-xs italic leading-relaxed mb-6"
                       style="color: rgba(42,24,16,0.45)">
                        Rejoignez notre brigade de passionnés et explorez l'alchimie des saveurs.
                    </p>
                    <a href="{{ path('index_register') }}"
                       class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold transition-opacity hover:opacity-90"
                       style="background: var(--color-paprika-700); color: var(--color-parchment); border: 1.5px solid transparent">
                        Rejoindre la brigade
                        <i class="fa-solid fa-arrow-right text-xs"></i>
                    </a>
                {% endif %}
            </div>

        </div>

        {# ── Barre inférieure ─────────────────────────────────────────── #}
        <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
             style="border-top: 1px solid rgba(184,134,74,0.25)">
            <div class="font-mono text-[10px] tracking-[0.2em] uppercase"
                 style="color: rgba(42,24,16,0.38)">
                &copy; {{ "now"|date("Y") }} SpicyMatch —
                <em class="font-display not-italic italic text-[12px] normal-case tracking-normal"
                   style="color: var(--color-copper)">L'Art de l'Alchimie Culinaire</em>
            </div>
            <div class="flex items-center gap-6 font-mono text-[10px] uppercase tracking-widest">
                <a href="#" class="footer-link transition-colors">Mentions Légales</a>
                <a href="#" class="footer-link transition-colors">Confidentialité</a>
                <a href="{{ path('new_contact') }}" class="footer-link transition-colors">Contact</a>
            </div>
        </div>

    </div>

    {# ── Scroll to top ─────────────────────────────────────────────── #}
    <div x-data="scrollTop" class="fixed bottom-8 right-8 z-40">
        <button x-show="visible" x-cloak
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-4 scale-90"
                x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                x-transition:leave="transition ease-in duration-200"
                x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                x-transition:leave-end="opacity-0 translate-y-4 scale-90"
                @click="scrollUp"
                aria-label="Retour en haut de la page"
                class="size-12 rounded-full flex items-center justify-center transition-all duration-300 group cursor-pointer"
                style="background: var(--color-ink-deep);
                       border: 1px solid rgba(184,134,74,0.3);
                       color: var(--color-parchment);
                       box-shadow: 0 4px 20px rgba(42,24,16,0.25)">
            <i class="fa-solid fa-arrow-up text-sm transition-transform group-hover:-translate-y-0.5"></i>
        </button>
    </div>

</footer>
