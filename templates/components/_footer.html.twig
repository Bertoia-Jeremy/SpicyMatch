<footer class="bg-paprika-900 mt-auto" role="contentinfo">

    {# ── Corps principal ── #}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-10 lg:py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

            {# Col 1 : Logo + slogan + CTA + socials #}
            <div class="sm:col-span-2 lg:col-span-1 flex flex-col gap-8 lg:pt-2">

                <a href="{{ path('home') }}"
                   class="inline-flex items-center gap-2 font-display text-xl font-bold text-cream tracking-tight">
                    <i class="fa-solid fa-fire text-turmeric-400"></i>
                    Spicy<span class="italic text-turmeric-400">Match</span>
                </a>

                <p class="text-cream/60 text-sm leading-relaxed max-w-xs -mt-4">
                    Le moteur d'association aromatique basé sur la science des composés. Composez avec précision.
                </p>

                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="{{ path('index_spicy_match') }}"
                       class="inline-flex items-center justify-center gap-2 bg-turmeric-500 hover:bg-turmeric-400
                              text-stone-900 font-semibold rounded-full px-5 py-2.5 text-sm transition-colors">
                        <i class="fa-solid fa-wand-magic-sparkles text-xs"></i>
                        Créer un mélange
                    </a>
                    <a href="{{ path('new_contact') }}"
                       class="inline-flex items-center justify-center gap-2 border border-cream/20 text-cream/80
                              hover:border-cream/40 hover:text-cream rounded-full px-5 py-2.5 text-sm transition-colors">
                        Contact
                    </a>
                </div>

                <div class="flex items-center gap-2.5 -mt-2">
                    <span class="text-cream/50 text-xs uppercase tracking-widest font-semibold">Suivre</span>
                    <a href="#" aria-label="Instagram SpicyMatch"
                       class="inline-flex items-center justify-center w-8 h-8 rounded-full
                              bg-cream/5 border border-cream/10 text-cream/40
                              hover:text-cream hover:border-cream/30 transition-colors text-xs">
                        <i class="fa-brands fa-instagram"></i>
                    </a>
                    <a href="#" aria-label="X / Twitter SpicyMatch"
                       class="inline-flex items-center justify-center w-8 h-8 rounded-full
                              bg-cream/5 border border-cream/10 text-cream/40
                              hover:text-cream hover:border-cream/30 transition-colors text-xs">
                        <i class="fa-brands fa-x-twitter"></i>
                    </a>
                    <a href="#" aria-label="Pinterest SpicyMatch"
                       class="inline-flex items-center justify-center w-8 h-8 rounded-full
                              bg-cream/5 border border-cream/10 text-cream/40
                              hover:text-cream hover:border-cream/30 transition-colors text-xs">
                        <i class="fa-brands fa-pinterest-p"></i>
                    </a>
                </div>
            </div>

            {# Col 2 : Navigation #}
            <div class="lg:pt-2">
                <h5 class="text-cream font-semibold text-xs uppercase tracking-widest mb-5">Navigation</h5>
                <ul class="space-y-3.5">
                    <li>
                        <a href="{{ path('home') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Accueil</a>
                    </li>
                    <li>
                        <a href="{{ path('index_spicy_match') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Créer un mélange</a>
                    </li>
                    <li>
                        <a href="{{ path('index_spices') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Toutes les épices</a>
                    </li>
                    <li>
                        <a href="{{ path('new_contact') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Nous contacter</a>
                    </li>
                    {% if not is_granted("ROLE_USER") %}
                        <li>
                            <a href="{{ path('index_register') }}"
                               class="text-turmeric-400 hover:text-turmeric-300 text-sm transition-colors font-medium">
                                Créer un compte &rarr;
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>

            {# Col 3 : Explorer #}
            <div class="lg:pt-2">
                <h5 class="text-cream font-semibold text-xs uppercase tracking-widest mb-5">Explorer</h5>
                <ul class="space-y-3.5">
                    <li>
                        <a href="{{ path('index_aromatic_compound') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Composés aromatiques</a>
                    </li>
                    <li>
                        <a href="{{ path('index_aromatic_groups') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Groupes aromatiques</a>
                    </li>
                    <li>
                        <a href="{{ path('index_spicy_type') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Types d'épices</a>
                    </li>
                    <li>
                        <a href="{{ path('index_alchemy_flavors') }}"
                           class="text-cream/60 hover:text-cream text-sm transition-colors">Saveurs</a>
                    </li>
                </ul>
            </div>

            {# Col 4 : Newsletter card (style Chamina — bloc distinct) #}
            <div x-data="{ sent: false, email: '', rgpd: false, error: '' }" class="lg:pt-2">

                <div class="bg-cream/10 border border-cream/15 rounded-2xl p-6 flex flex-col gap-4">

                    <div class="flex items-center gap-3">
                        <span class="inline-flex items-center justify-center w-10 h-10 rounded-full
                                     bg-turmeric-500/20 text-turmeric-400 text-lg shrink-0">
                            <i class="fa-solid fa-fire"></i>
                        </span>
                        <div>
                            <p class="text-cream font-semibold text-sm leading-snug">
                                Épicez votre boîte mail
                            </p>
                            <p class="text-cream/50 text-xs mt-0.5">Nouveautés & recettes aromatiques</p>
                        </div>
                    </div>

                    {# Formulaire #}
                    <form x-show="!sent"
                          @submit.prevent="
                            if (!email) { error = 'Veuillez renseigner votre email.'; return; }
                            if (!rgpd)  { error = 'Vous devez accepter la politique de confidentialité.'; return; }
                            error = '';
                            sent = true;
                          "
                          class="flex flex-col gap-3"
                          novalidate>

                        <div class="relative">
                            <label for="footer-newsletter-email" class="sr-only">Adresse email</label>
                            <input id="footer-newsletter-email"
                                   type="email"
                                   x-model="email"
                                   placeholder="Votre adresse mail"
                                   class="w-full bg-white/10 border border-cream/15 text-cream placeholder-cream/30
                                          rounded-full pl-4 pr-10 py-2.5 text-sm
                                          focus:outline-none focus:ring-1 focus:ring-turmeric-400
                                          transition-colors">
                            <button type="submit"
                                    aria-label="S'abonner"
                                    class="absolute right-1 top-1/2 -translate-y-1/2
                                           w-8 h-8 rounded-full bg-turmeric-500 hover:bg-turmeric-400
                                           text-stone-900 flex items-center justify-center transition-colors text-xs">
                                <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>

                        {# RGPD #}
                        <label class="flex items-start gap-2.5 cursor-pointer group">
                            <input type="checkbox"
                                   x-model="rgpd"
                                   class="mt-0.5 shrink-0 accent-turmeric-500">
                            <span class="text-cream/50 text-xs leading-relaxed group-hover:text-cream/70 transition-colors">
                                J'accepte de recevoir la newsletter SpicyMatch.
                                <a href="{{ path('new_contact') }}" class="underline hover:text-cream">
                                    Politique de confidentialité
                                </a>
                            </span>
                        </label>

                        {# Erreur inline #}
                        <p x-show="error" x-text="error"
                           class="text-paprika-300 text-xs -mt-1"
                           role="alert"></p>

                    </form>

                    {# Confirmation #}
                    <div x-show="sent" x-cloak class="flex items-center gap-3 py-2">
                        <i class="fa-solid fa-circle-check text-turmeric-400 text-lg"></i>
                        <p class="text-cream/80 text-sm">Merci ! Vous êtes inscrit.</p>
                    </div>

                </div>
            </div>

        </div>
    </div>

    {# ── Bas de page ── #}
    <div class="border-t border-cream/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ul class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 py-7 text-sm text-cream/40">
                <li>
                    <span>© {{ "now"|date("Y") }} SpicyMatch</span>
                </li>
                <li>
                    <a href="{{ path('new_contact') }}" class="hover:text-cream/70 transition-colors">Mentions légales</a>
                </li>
                <li>
                    <a href="{{ path('new_contact') }}" class="hover:text-cream/70 transition-colors">CGU</a>
                </li>
                <li>
                    <a href="{{ path('new_contact') }}" class="hover:text-cream/70 transition-colors">Politique de confidentialité</a>
                </li>
                <li class="ml-auto hidden sm:flex items-center gap-1.5">
                    <i class="fa-solid fa-fire text-turmeric-400 text-xs"></i>
                    <span>Fait avec passion pour les épices</span>
                </li>
            </ul>
        </div>
    </div>

</footer>

{# ── Back to top (flottant, Alpine) ── #}
<div x-data="{ visible: false }"
     x-init="window.addEventListener('scroll', () => { visible = window.scrollY > 400 })"
     class="fixed bottom-6 right-6 z-40">
    <button x-show="visible"
            x-cloak
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 translate-y-2"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-2"
            @click="window.scrollTo({ top: 0, behavior: 'smooth' })"
            aria-label="Retour en haut de page"
            class="w-10 h-10 rounded-full bg-saffron-700 hover:bg-saffron-600
                   text-white shadow-lg hover:shadow-xl
                   flex items-center justify-center
                   transition-all duration-200 cursor-pointer">
        <i class="fa-solid fa-chevron-up text-xs"></i>
    </button>
</div>
