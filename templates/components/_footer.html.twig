<footer class="relative" role="contentinfo"
        style="background: var(--color-parchment); border-top: 1px solid rgba(184,134,74,0.3)">

    <div class="max-w-7xl mx-auto px-6 py-14 lg:py-20">

        {# Ornement centré #}
        <div class="flex items-center gap-4 mb-14">
            <div class="flex-1 h-px"
                 style="background: linear-gradient(90deg, transparent, rgba(184,134,74,0.35))"></div>
            <div class="flex-1 h-px"
                 style="background: linear-gradient(270deg, transparent, rgba(184,134,74,0.35))"></div>
        </div>

        {# ── Grille 4 colonnes ────────────────────────────────────────── #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">

            {# Col 1 : Marque #}
            <div class="space-y-6">
                <a href="{{ path('home') }}" class="group flex items-center gap-3 no-underline">
                    <svg class="size-11 shrink-0 transition-transform group-hover:scale-105" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <circle cx="200" cy="200" r="150" fill="none" stroke="#C46E1F" stroke-width="2.4" stroke-dasharray="2 9" stroke-linecap="round" opacity="0.85"/>
                        <circle cx="200" cy="200" r="150" fill="none" stroke="#C46E1F" stroke-width="6"
                                stroke-dasharray="518.36 9999" stroke-linecap="round"
                                transform="rotate(-90 200 200)"/>
                        <g stroke="#0A0907" stroke-width="4" fill="none">
                            <line x1="200" y1="150" x2="243" y2="175"/>
                            <line x1="243" y1="175" x2="243" y2="225"/>
                            <line x1="243" y1="225" x2="200" y2="250"/>
                            <line x1="200" y1="250" x2="157" y2="225"/>
                            <line x1="157" y1="225" x2="157" y2="175"/>
                            <line x1="157" y1="175" x2="200" y2="150"/>
                        </g>
                        <g stroke="#C46E1F" stroke-width="6" fill="none" stroke-linecap="round">
                            <path d="M 200 150 Q 210 100 200 50"/>
                            <path d="M 243 225 Q 295 245 330 275"/>
                            <path d="M 157 225 Q 105 245 70 275"/>
                        </g>
                        <g fill="#C46E1F">
                            <circle cx="200" cy="50" r="11"/>
                            <circle cx="330" cy="275" r="11"/>
                            <circle cx="70" cy="275" r="11"/>
                        </g>
                        <g fill="#0A0907">
                            <circle cx="243" cy="175" r="5"/>
                            <circle cx="200" cy="250" r="5"/>
                            <circle cx="157" cy="175" r="5"/>
                            <circle cx="200" cy="150" r="6"/>
                            <circle cx="243" cy="225" r="6"/>
                            <circle cx="157" cy="225" r="6"/>
                        </g>
                    </svg>
                    <div class="leading-none">
                        <div class="font-display text-[22px] font-medium leading-none"
                             style="color: var(--color-ink-deep)">
                            Spicy <em class="not-italic italic" style="color: #B91C1C">Match</em>
                        </div>
                    </div>
                </a>
                <p class="text-sm leading-relaxed max-w-xs"
                   style="color: rgba(42,24,16,0.65)">
                    {{ 'ui.footer.tagline'|trans }}
                </p>
            </div>

            {# Col 2 : Navigation #}
            <div>
                <h2 class="font-display italic text-[14px] mb-7 flex items-center gap-3"
                    style="color: var(--color-copper-text)">
                    <span class="block h-px w-5" style="background: var(--color-copper)"></span>
                    {{ 'ui.footer.navigation'|trans }}
                </h2>
                <ul class="space-y-4 list-none p-0">
                    <li><a href="{{ path('home') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.common.home'|trans }}
                    </a></li>
                    <li><a href="{{ path('index_spices') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.footer.catalog'|trans }}
                    </a></li>
                    <li><a href="{{ path('index_spicy_match') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.footer.lab_blends'|trans }}
                    </a></li>
                    <li><a href="{{ path('new_contact') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.footer.help_contact'|trans }}
                    </a></li>
                </ul>
            </div>

            {# Col 3 : L'Académie #}
            <div>
                <h2 class="font-display italic text-[14px] mb-7 flex items-center gap-3"
                    style="color: var(--color-copper-text)">
                    <span class="block h-px w-5" style="background: var(--color-copper)"></span>
                    {{ 'ui.common.academy'|trans }}
                </h2>
                <ul class="space-y-4 list-none p-0">
                    <li><a href="{{ path('education_index') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.footer.academy_flavors'|trans }}
                    </a></li>
                    <li><a href="{{ path('index_aromatic_compound') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.footer.aromatic_compounds'|trans }}
                    </a></li>
                    <li><a href="{{ path('index_aromatic_groups') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.footer.flavor_groups'|trans }}
                    </a></li>
                    <li><a href="{{ path('index_spicy_type') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                        <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                        {{ 'ui.footer.classification'|trans }}
                    </a></li>
                </ul>
            </div>

            {# Col 4 : L'Atelier #}
            <div>
                <h2 class="font-display italic text-[14px] mb-7 flex items-center gap-3"
                    style="color: var(--color-copper-text)">
                    <span class="block h-px w-5" style="background: var(--color-copper)"></span>
                    {{ 'ui.footer.atelier'|trans }}
                </h2>
                {% if is_granted('ROLE_USER') %}
                    <ul class="space-y-4 list-none p-0">
                        <li><a href="{{ path('profile_user', {tab: 'dashboard'}) }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            {{ 'ui.profile.menu.dashboard'|trans }}
                        </a></li>
                        <li><a href="{{ path('profile_user', {tab: 'grimoire'}) }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            {{ 'ui.profile.menu.grimoire'|trans }}
                        </a></li>
                        <li><a href="{{ path('profile_user', {tab: 'history'}) }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            {{ 'ui.profile.menu.history'|trans }}
                        </a></li>
                        <li><a href="{{ path('profile_user', {tab: 'lab'}) }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            {{ 'ui.profile.menu.lab'|trans }}
                        </a></li>
                        <li><a href="{{ path('app_logout') }}" class="footer-link group inline-flex items-center gap-2 text-sm transition-colors">
                            <span class="footer-link-dash block h-px w-3 shrink-0 transition-all duration-300 group-hover:w-6" style="background: var(--color-copper)"></span>
                            {{ 'ui.common.logout'|trans }}
                        </a></li>
                    </ul>
                {% else %}
                    <p class="text-xs italic leading-relaxed mb-6"
                       style="color: rgba(42,24,16,0.65)">
                        {{ 'ui.footer.join_text'|trans }}
                    </p>
                    <twig:Button
                        label="{{ 'ui.footer.join_cta'|trans }}"
                        href="{{ path('index_register') }}"
                        variant="primary"
                        icon="fa-solid fa-arrow-right"
                        iconPos="right"
                    />
                {% endif %}
            </div>

        </div>

        {# ── Barre inférieure ─────────────────────────────────────────── #}
        <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4"
             style="border-top: 1px solid rgba(184,134,74,0.25)">
            <div class="font-mono text-[10px] tracking-[0.2em] uppercase"
                 style="color: rgba(42,24,16,0.65)">
                &copy; {{ "now"|date("Y") }} SpicyMatch —
                <em class="font-display not-italic italic text-[12px] normal-case tracking-normal"
                   style="color: var(--color-copper-text)">{{ 'ui.footer.copyright_tagline'|trans }}</em>
            </div>
            <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-mono text-[10px] uppercase tracking-widest">
                <a href="{{ path('legal_notice') }}" class="footer-link transition-colors">{{ 'ui.footer.legal'|trans }}</a>
                <a href="{{ path('privacy_policy') }}" class="footer-link transition-colors">{{ 'ui.footer.privacy'|trans }}</a>
                <a href="{{ path('accessibility_declaration') }}" class="footer-link transition-colors">{{ 'ui.footer.accessibility'|trans }}</a>
                <a href="{{ path('new_contact') }}" class="footer-link transition-colors">{{ 'ui.common.contact'|trans }}</a>
            </div>
        </div>

    </div>

    {# ── Scroll to top ─────────────────────────────────────────────── #}
    <div x-data="scrollTop" class="fixed bottom-8 right-8 z-40">
        <button x-show="visible" x-cloak
                x-transition:enter="transition ease-out duration-300"
                x-transition:enter-start="opacity-0 translate-y-4 scale-90"
                x-transition:enter-end="opacity-100 translate-y-0 scale-100"
                x-transition:leave="transition ease-in duration-200"
                x-transition:leave-start="opacity-100 translate-y-0 scale-100"
                x-transition:leave-end="opacity-0 translate-y-4 scale-90"
                @click="scrollUp"
                aria-label="{{ 'ui.footer.scroll_top'|trans }}"
                class="size-12 rounded-full flex items-center justify-center transition-all duration-300 group cursor-pointer"
                style="background: var(--color-ink-deep);
                       border: 1px solid rgba(184,134,74,0.3);
                       color: var(--color-parchment);
                       box-shadow: 0 4px 20px rgba(42,24,16,0.25)">
            <i class="fa-solid fa-arrow-up text-sm transition-transform group-hover:-translate-y-0.5" aria-hidden="true"></i>
        </button>
    </div>

</footer>
