{# templates/components/_macro_card_spice.html.twig #}

{% macro cardSpice(spice, options = {}) %}
    {# Gestion hybride Entité (objet) vs LiveComponent (tableau associatif) #}
    {% if spice is iterable %}
        {# C'est un tableau (retourné par getResults() dans SpicyMatch) #}
        {% set spiceId = spice.id %}
        {% set spiceSlug = spice.slug|default(spice.id) %}
        {% set spiceName = spice.name %}
        {% set spiceDescription = spice.description|default(null) %}
        {% set color = spice.color|default('#78716C') %}
        {% set groupName = spice.groupName|default(null) %}
        {% set typeName = spice.typeName|default(null) %}
        {% set imageUrl = spice.file ? asset('uploads/spices/' ~ spice.file) : null %}
    {% else %}
        {# Entité Spices #}
        {% set loc = app.request.locale %}
        {% set spiceId = spice.id %}
        {% set spiceSlug = spice.getLocalizedSlug(loc) %}
        {% set spiceName = spice.getLocalizedName(loc) %}
        {% set spiceDescription = spice.getLocalizedDescription(loc) %}
        {% set color = spice.aromaticGroups ? spice.aromaticGroups.color : '#78716C' %}
        {% set groupName = spice.aromaticGroups ? spice.aromaticGroups.getLocalizedName(loc) : null %}
        {% set typeName = spice.spicyType ? spice.spicyType.name : null %}
        {% set imageUrl = vich_uploader_asset(spice, 'imageFile') %}
    {% endif %}

    {# Options #}
    {% set isSelection = options.isSelection|default(false) %}
    {% set score = options.score|default(null) %}
    {% set compact = options.compact|default(false) %}
    {% set showQuickView = options.showQuickView|default(true) %}
    {% set model = options.model|default(null) %}
    {% set labStyle = options.labStyle|default(false) %}

    {# Mode "Chef de Partie" : neutralise les couleurs de groupe aromatique. #}
    {% set effectiveMonochrome = options.monochrome ?? (isMonochrome ?? false) %}
    {% if effectiveMonochrome %}
        {% set color = '#78716C' %}
    {% endif %}

    <article x-data class="card-warm flex flex-col overflow-hidden h-full group relative">

        {# ── Zone 1 : Image ── #}
        {% if labStyle and model %}
            {# Lab style: toute la zone image est un label pour la checkbox de sélection #}
            <label for="spice_{{ spiceId }}"
                   class="relative overflow-hidden aspect-square bg-stone-100 block cursor-pointer"
                   @click.stop>
        {% elseif showQuickView %}
            <button type="button"
                    class="relative overflow-hidden aspect-square bg-stone-100 cursor-pointer block w-full p-0 border-0
                           focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-saffron-600 focus-visible:ring-inset"
                    aria-label="{{ 'ui.catalog.preview'|trans }} — {{ spiceName }}"
                    @click.prevent.stop="$dispatch('open-spice-modal', { url: '{{ path('quick_view_spice', { slug: spiceSlug }) }}', fullUrl: '{{ path('view_spice', { slug: spiceSlug }) }}' })">
        {% else %}
            <div class="relative overflow-hidden aspect-square bg-stone-100">
        {% endif %}

            {% set imgAlt = (showQuickView and not (labStyle and model)) ? '' : spiceName %}
            {% if imageUrl %}
                <img src="{{ imageUrl|imagine_filter('spice_card') }}"
                     srcset="{{ imageUrl|imagine_filter('spice_card') }} 1x, {{ imageUrl|imagine_filter('spice_card_2x') }} 2x"
                     alt="{{ imgAlt }}" loading="lazy" decoding="async" width="400" height="400"
                     class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
            {% else %}
                <span class="absolute inset-0 flex items-center justify-center text-stone-300" aria-hidden="true">
                    <i class="fa-solid fa-seedling text-4xl"></i>
                </span>
            {% endif %}

            {% if labStyle %}
                {# Group chip top-left (sur l'image) #}
                {% if groupName and not effectiveMonochrome %}
                    <span class="absolute top-2.5 left-2.5 z-10 inline-flex items-center gap-1.5
                                 bg-white/90 backdrop-blur-sm rounded-full px-2 py-1
                                 text-[10px] font-semibold uppercase tracking-wide leading-none pointer-events-none"
                          style="color: {{ color }}">
                        <span class="size-2.5 rounded-full flex-none" style="background: {{ color }}"></span>
                        {{ groupName }}
                    </span>
                {% endif %}

                {# Checkmark top-right : checkbox sr-only + visuel peer #}
                {% if model %}
                    <span class="absolute top-2.5 right-2.5 z-10 inline-flex">
                        <input type="checkbox"
                               id="spice_{{ spiceId }}"
                               data-model="{{ model }}"
                               value="{{ spiceId }}"
                               {% if isSelection %}checked{% endif %}
                               class="sr-only peer"
                               @click.stop>
                        <span class="flex size-6 items-center justify-center rounded-lg
                                     bg-white/90 backdrop-blur-sm border border-stone-200 shadow-sm
                                     peer-checked:bg-saffron-600 peer-checked:border-saffron-600
                                     peer-focus-visible:ring-2 peer-focus-visible:ring-saffron-600 peer-focus-visible:ring-offset-1
                                     transition-all duration-200 cursor-pointer"
                              @click.stop="$el.previousElementSibling.click()">
                            <i class="fa-solid fa-check text-[10px] text-white opacity-0
                                      peer-checked:opacity-100 transition-opacity" aria-hidden="true"></i>
                        </span>
                    </span>
                {% endif %}

            {% else %}
                {# Catalog style: overlay quick view #}
                {% if showQuickView %}
                    <span class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-300"
                          style="background: linear-gradient(to top, {{ color }}CC 0%, transparent 60%)" aria-hidden="true">
                        <span class="bg-white/95 text-stone-800 text-[10px] font-bold px-3 py-2 rounded-full shadow-lg translate-y-2 group-hover:translate-y-0 group-focus-within:translate-y-0 transition-all duration-300 uppercase tracking-wider">
                            <i class="fa-solid fa-magnifying-glass mr-1" aria-hidden="true"></i>{{ 'ui.catalog.preview'|trans }}
                        </span>
                    </span>
                {% endif %}

                {# Score badge (catalog style) #}
                {% if score is not null %}
                    <span class="absolute top-2 right-2 bg-white/95 backdrop-blur-sm px-2 py-1 rounded-lg shadow-sm border border-stone-100 flex flex-col items-center min-w-[40px]">
                        <span class="text-[10px] font-bold text-saffron-600 leading-none">{{ score }}%</span>
                        <span class="text-[8px] text-stone-400 uppercase font-bold tracking-tighter">{{ 'ui.catalog.match_label'|trans }}</span>
                    </span>
                {% endif %}
            {% endif %}

            {# Barre couleur groupe (commune aux deux styles) #}
            <span class="absolute bottom-0 left-0 right-0 h-0.5 block" style="background-color: {{ color }}"></span>

        {% if labStyle and model %}
            </label>
        {% elseif showQuickView %}
            </button>
        {% else %}
            </div>
        {% endif %}

        {# ── Zone 2 : Contenu ── #}
        {% if labStyle %}
            {# Lab style: nom + type + score + lien détail #}
            <div class="flex flex-col flex-1 p-3 gap-1">
                <h3 title="{{ spiceName }}" class="font-bold text-stone-900 text-sm leading-snug line-clamp-2 group-hover:text-saffron-700 transition-colors duration-200">
                    {{ spiceName }}
                </h3>

                <div class="flex flex-col gap-1.5 mt-auto">
                    {% if typeName %}
                        <p class="font-mono text-[9.5px] uppercase tracking-widest text-stone-400 truncate leading-none">
                            {{ typeName }}
                        </p>
                    {% endif %}

                    {% if score is not null %}
                        <div class="w-full pt-0.5">
                            <div class="flex items-center justify-between mb-0.5">
                                <span class="text-[9px] font-mono uppercase tracking-wide text-stone-400">{{ 'ui.catalog.compat'|trans }}</span>
                                <span class="text-[10px] font-bold text-saffron-600">{{ score }}%</span>
                            </div>
                            <div class="h-1 w-full bg-stone-100 rounded-full overflow-hidden">
                                <div class="h-full bg-saffron-500 transition-all duration-1000" style="width: {{ score }}%"></div>
                            </div>
                        </div>
                    {% endif %}

                    <button type="button"
                            class="flex items-center justify-between gap-2 pt-2 w-full
                                   border-t border-dashed border-spice-border
                                   text-[11px] font-semibold text-saffron-600
                                   hover:text-saffron-700 transition-colors group/link"
                            @click.stop="$dispatch('open-spice-modal', {
                                url: '{{ path('quick_view_spice', {slug: spiceSlug}) }}',
                                fullUrl: '{{ path('view_spice', {slug: spiceSlug}) }}'
                            })">
                        <span>{{ 'ui.catalog.see_details'|trans }}</span>
                        <i class="fa-solid fa-arrow-right text-[9px] transition-transform group-hover/link:translate-x-0.5" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        {% else %}
            {% set linkToSheet = showQuickView and not model %}
            {% set contentTag = model ? 'label' : (linkToSheet ? 'a' : 'div') %}
            <{{ contentTag }}
                {% if model %}for="spice_{{ spiceId }}"{% endif %}
                {% if linkToSheet %}href="{{ path('view_spice', { slug: spiceSlug }) }}" aria-label="{{ 'ui.catalog.see_sheet'|trans }} — {{ spiceName }}"{% endif %}
                class="flex flex-col flex-1 p-3 gap-1.5 {{ model or linkToSheet ? 'cursor-pointer hover:bg-stone-50/50 transition-colors' : '' }}{{ linkToSheet ? ' focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-saffron-600 focus-visible:ring-inset' : '' }}"
                @click.stop>

                <div class="flex items-start justify-between gap-2">
                    {% set headingTag = contentTag == 'label' ? 'span' : 'h3' %}
                    <{{ headingTag }}{% if headingTag == 'span' %} role="heading" aria-level="3"{% endif %} title="{{ spiceName }}" class="block font-bold text-stone-900 text-sm leading-snug line-clamp-2 group-hover:text-saffron-700 transition-colors duration-200">
                        {{ spiceName }}
                    </{{ headingTag }}>

                    {% if model %}
                        <div class="shrink-0 pt-0.5">
                            <input type="checkbox"
                                   id="spice_{{ spiceId }}"
                                   data-model="{{ model }}"
                                   value="{{ spiceId }}"
                                   {% if isSelection %}checked{% endif %}
                                   @click.stop
                                   class="size-4 rounded border-stone-300 text-saffron-600 focus:ring-saffron-500/20 transition-all cursor-pointer">
                        </div>
                    {% endif %}
                </div>

                {% if groupName and not effectiveMonochrome %}
                    <span class="inline-flex items-center gap-1 self-start text-[9px] font-bold px-2 py-0.5 rounded-full leading-none uppercase tracking-wide"
                          style="background-color: {{ color }}15; color: {{ color }}; border: 1px solid {{ color }}30">
                        {{ groupName }}
                    </span>
                {% elseif groupName %}
                    <span aria-label="{{ 'ui.catalog.hidden_group'|trans }}" class="inline-flex items-center gap-1 self-start text-[9px] font-bold px-2 py-0.5 rounded-full leading-none uppercase tracking-wide bg-stone-100 text-stone-500 border border-stone-200">
                        <span aria-hidden="true">???</span>
                    </span>
                {% endif %}

                {% if score is not null %}
                    <div class="w-full mt-auto pt-2">
                        <div class="h-1 w-full bg-stone-100 rounded-full overflow-hidden">
                            <div class="h-full bg-saffron-500 transition-all duration-1000" style="width: {{ score }}%"></div>
                        </div>
                    </div>
                {% endif %}

                {% if linkToSheet %}
                    <span class="{{ score is null ? 'mt-auto ' : '' }}pt-1.5 inline-flex items-center gap-1 text-[11px] font-medium text-stone-400 group-hover:text-saffron-600 transition-colors">
                        {{ 'ui.catalog.see_sheet'|trans }}
                        <i class="fa-solid fa-arrow-right text-[9px] transition-transform group-hover:translate-x-0.5" aria-hidden="true"></i>
                    </span>
                {% endif %}
            </{{ contentTag }}>
        {% endif %}

    </article>
{% endmacro %}
