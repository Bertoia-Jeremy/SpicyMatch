{% macro cardSpice(spice) %}
    {% set color = spice.aromaticGroups.color %}

    <div class="w-64 h-80 rounded-lg overflow-hidden shadow-lg m-4 bg-cover bg-center relative" style="background-image: url({{ vich_uploader_asset(spice, 'imageFile') }})">
        <div class="absolute inset-0 bg-black bg-opacity-50 hover:bg-opacity-25 transition-all duration-300">
            <div class="p-4 text-white flex flex-col justify-end h-full">
                <h3 class="text-2xl font-bold">{{ spice.name }}</h3>
                <p class="text-sm mt-2 h-16 overflow-y-auto">{{ spice.description }}</p>
            </div>
        </div>
    </div>
{% endmacro %}