{% macro cardSpicyMatch(spice, littleCard) %}
{% import "components/_macro_card_little_spice.html.twig" as macroCardSpice %}

    <div class="flex flex-col items-center m-2">
        <label for="spice_{{ spice.id }}" class="cursor-pointer">
            {{ macroCardSpice.cardLittleSpice(spice, littleCard) }}
        </label>
        <input id="spice_{{ spice.id }}" type="checkbox" data-model="spices.selectedSpices" value="{{ spice.id }}" class="mt-2 h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500">
    </div>

{% endmacro %}