{% macro cardSpicyMatch(spice, isSelection, score) %}
    {% import "components/_macro_card_spice.html.twig" as macroCardSpice %}

    <div class="m-2 w-[160px] sm:w-[180px]">
        {{ macroCardSpice.cardSpice(spice, {
            isSelection: isSelection,
            score: score,
            compact: true,
            model: 'spices.selectedSpices',
            showQuickView: true
        }) }}
    </div>
{% endmacro %}
