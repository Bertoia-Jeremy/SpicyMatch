{# ─── SVG Macros ──────────────────────────────────────────────────────────── #}

{% macro herbierLogo(sizeClass) %}
    {% set sizeClass = sizeClass|default('size-10') %}
    <svg class="{{ sizeClass }}" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        {# Halo pointillé de fond #}
        <circle cx="200" cy="200" r="150" fill="none" stroke="#C46E1F" stroke-width="2.4" stroke-dasharray="2 9" stroke-linecap="round" opacity="0.85"/>
        {# Arc fixe à 60% (565.49 = 0.6 × 2π × 150) #}
        <circle cx="200" cy="200" r="150" fill="none" stroke="#C46E1F" stroke-width="6"
                stroke-dasharray="518.36 9999" stroke-linecap="round"
                transform="rotate(-90 200 200)"/>
        {# Hexagone moléculaire #}
        <g stroke="#0A0907" stroke-width="4" fill="none">
            <line x1="200" y1="150" x2="243" y2="175"/>
            <line x1="243" y1="175" x2="243" y2="225"/>
            <line x1="243" y1="225" x2="200" y2="250"/>
            <line x1="200" y1="250" x2="157" y2="225"/>
            <line x1="157" y1="225" x2="157" y2="175"/>
            <line x1="157" y1="175" x2="200" y2="150"/>
        </g>
        {# Étamines — branches courbées #}
        <g stroke="#C46E1F" stroke-width="6" fill="none" stroke-linecap="round">
            <path d="M 200 150 Q 210 100 200 50"/>
            <path d="M 243 225 Q 295 245 330 275"/>
            <path d="M 157 225 Q 105 245 70 275"/>
        </g>
        {# Anthères — extrémités des étamines #}
        <g fill="#C46E1F">
            <circle cx="200" cy="50" r="11"/>
            <circle cx="330" cy="275" r="11"/>
            <circle cx="70" cy="275" r="11"/>
        </g>
        {# Sommets hexagonaux #}
        <g fill="#0A0907">
            <circle cx="243" cy="175" r="5"/>
            <circle cx="200" cy="250" r="5"/>
            <circle cx="157" cy="175" r="5"/>
            <circle cx="200" cy="150" r="6"/>
            <circle cx="243" cy="225" r="6"/>
            <circle cx="157" cy="225" r="6"/>
        </g>
    </svg>
{% endmacro %}

{% macro toqueIcon(sizeClass) %}
    {% set sizeClass = sizeClass|default('w-6 h-6') %}
    <svg class="{{ sizeClass }}" viewBox="0 0 32 32" fill="none" stroke="#0A0907" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M 9 11 C 5 10, 4 4, 9 4 C 11 1.5, 14 1.5, 16 3.5 C 18 1.5, 21 1.5, 23 4 C 28 4, 27 10, 23 11"/>
        <path d="M 9 11 L 9 22"/>
        <path d="M 23 11 L 23 22"/>
        <rect x="7" y="22" width="18" height="5" rx="0.6"/>
        <path d="M 12.5 11 L 12.5 22" opacity="0.5"/>
        <path d="M 19.5 11 L 19.5 22" opacity="0.5"/>
        <circle cx="16" cy="24.5" r="1.1" fill="#C46E1F" stroke="none"/>
    </svg>
{% endmacro %}

{# XP gauge — calculé une seule fois, réutilisé par le chip desktop et la grade card mobile #}
{% if is_granted('ROLE_USER') and app.user.progression %}
    {% set _lvl      = app.user.progression.level %}
    {% set _grade    = _lvl < 20 ? 'ui.grade.commis'|trans : (_lvl < 50 ? 'ui.grade.chef_partie'|trans : (_lvl < 80 ? 'ui.grade.saucier'|trans : 'ui.grade.chef_executif'|trans)) %}
    {% set _xp       = app.user.progression.xp %}
    {% set _minXp    = ((_lvl - 1) ** 1.3 * 100)|round %}
    {% set _maxXp    = (_lvl ** 1.3 * 100)|round %}
    {% set _rawPct   = _maxXp > _minXp ? (_xp - _minXp) / (_maxXp - _minXp) * 100 : 0 %}
    {% set _gaugePct = min(100, max(0, _rawPct)) %}
    {% set _streak   = app.user.progression.currentReadingStreak %}
{% endif %}

<div x-data="navMenu">

{# ════════════════════════════════════════════════════════════════════
   BARRE PRINCIPALE (sticky h-20 z-50)
   ════════════════════════════════════════════════════════════════════ #}
<nav class="nav-bar h-20 sticky top-0 z-50" aria-label="{{ 'ui.navbar.main_nav'|trans }}">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex items-center justify-between gap-3">

        {# ── LEFT : Toque ──────────────────────────────────────────────── #}

        {# Desktop (≥ lg) : toque + label #}
        <button type="button"
                @click="toggle()"
                :class="toqueClass()"
                :style="toqueColor()"
                :aria-expanded="open"
                aria-controls="nav-overlay"
                aria-label="{{ 'ui.navbar.main_menu'|trans }}"
                class="toque-btn hidden lg:inline-flex shrink-0">
            {{ _self.toqueIcon('w-[26px] h-[26px]') }}
            <div class="flex flex-col leading-none select-none">
                <span x-text="toqueLabel()"
                      class="font-mono text-[9px] tracking-[0.3em] uppercase"
                      style="color: var(--color-copper-text)"></span>
                <span class="font-display italic text-[17px] mt-0.5"
                      style="color: var(--color-ink-deep)">{{ 'ui.navbar.menu'|trans }}</span>
            </div>
        </button>

        {# Mobile (< lg) : toque compact #}
        <button type="button"
                @click="mobileToggle()"
                :class="mobileToqueClass()"
                :style="mobileToqueColor()"
                :aria-expanded="mobileOpen"
                aria-controls="nav-sheet"
                aria-label="{{ 'ui.navbar.main_menu'|trans }}"
                class="toque-btn lg:hidden shrink-0">
            {{ _self.toqueIcon('w-[22px] h-[22px]') }}
            <span x-text="mobileToqueLabel()"
                  class="font-display italic text-[15px]"
                  style="color: var(--color-ink-deep)"></span>
        </button>

        {# ── CENTER : Wax Seal + Wordmark ──────────────────────────────── #}
        <a href="{{ path('home') }}"
           class="flex items-center gap-3 group transition-transform duration-300 hover:scale-[1.02] mx-auto lg:mx-0">
            {{ _self.herbierLogo('size-9 lg:size-12') }}
            <div class="hidden lg:block leading-none">
                <div class="font-display text-[26px] font-medium leading-none"
                     style="color: var(--color-ink-deep)">
                    Spicy <em class="not-italic italic" style="color: var(--color-paprika-700)">Match</em>
                </div>
            </div>
        </a>

        {# ── RIGHT : Cluster utilitaires ───────────────────────────────── #}
        <div class="flex items-center gap-2 shrink-0">

            {# Mortar → Le Lab #}
            <a href="{{ path('index_spicy_match') }}"
               class="mortar-btn size-11 rounded-full flex items-center justify-center"
               aria-label="{{ 'ui.navbar.create_blend'|trans }}"
               title="{{ 'ui.navbar.lab_title'|trans }}">
                <i class="fa-solid fa-mortar-pestle text-sm" style="color: var(--color-ink-deep)" aria-hidden="true"></i>
            </a>

            {# Grade chip / avatar / login ───────────────────────────── #}
            {% if is_granted('ROLE_USER') and app.user.progression %}

                {# Desktop : grade chip complet #}
                <div class="hidden lg:flex items-center gap-2.5 pl-2 pr-4 py-1.5 rounded-full border"
                     style="border-color: rgba(184,134,74,0.4); background: rgba(255,250,235,0.6);">
                    {{ _self.herbierLogo('size-8') }}
                    <div class="flex flex-col leading-none min-w-0">
                        <span class="font-display text-[15px] font-medium truncate max-w-[100px]"
                              style="color: var(--color-ink-deep)">{{ app.user.username }}</span>
                        <span class="font-display italic text-[11px]"
                              style="color: var(--color-paprika-700)">{{ _grade }}</span>
                        <div class="rounded-full mt-1 overflow-hidden" style="width: 80px; height: 2px; background: rgba(184,134,74,0.2);">
                            <div class="gauge-bar h-full rounded-full" style="width: {{ _gaugePct }}%"></div>
                        </div>
                    </div>
                </div>

            {% elseif is_granted('ROLE_USER') %}
                <a href="{{ path('profile_user') }}"
                   class="hidden lg:inline-flex items-center px-4 py-2 rounded-full border text-sm font-medium transition-colors"
                   style="border-color: rgba(184,134,74,0.4); color: var(--color-ink-deep); background: rgba(255,250,235,0.6);">
                    {{ app.user.username }}
                </a>

            {% else %}
                <a href="{{ path('app_login') }}"
                   class="hidden lg:inline-flex items-center px-4 py-2 rounded-full border text-sm font-medium transition-colors hover:border-copper"
                   style="border-color: rgba(184,134,74,0.4); color: var(--color-ink-deep);">
                    {{ 'ui.common.login'|trans }}
                </a>
                <a href="{{ path('index_register') }}"
                   class="inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold transition-colors hover:opacity-90"
                   style="background: var(--color-paprika-700); color: white;">
                    {{ 'ui.common.register'|trans }}
                </a>
            {% endif %}

        </div>
    </div>
</nav>

{# ════════════════════════════════════════════════════════════════════
   DESKTOP BACKDROP (z-48 — clique en dehors → ferme l'overlay)
   ════════════════════════════════════════════════════════════════════ #}
<div x-show="open"
     x-cloak
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     @click="close()"
     class="nav-backdrop hidden lg:block"
     aria-hidden="true"></div>

{# ════════════════════════════════════════════════════════════════════
   DESKTOP OVERLAY (fixed top-20, z-49 — hidden on mobile via CSS)
   ════════════════════════════════════════════════════════════════════ #}
<div id="nav-overlay"
     x-show="open"
     x-cloak
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 -translate-y-2"
     x-transition:enter-end="opacity-100 translate-y-0"
     x-transition:leave="transition ease-in duration-200"
     x-transition:leave-start="opacity-100 translate-y-0"
     x-transition:leave-end="opacity-0 -translate-y-2"
     class="nav-overlay hidden lg:block"
     role="navigation"
     aria-label="{{ 'ui.navbar.main_menu'|trans }}">

    <div class="max-w-7xl mx-auto px-8 lg:px-16 py-12">
        {# Hero Search #}
        <div class="max-w-xl mx-auto mb-12">
            {{ component('Search') }}
        </div>

        {# 3 Pôles ─────────────────────────────────────────────────── #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 max-w-5xl mx-auto">

            {# ── I · Exploration ── #}
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="font-mono text-[9px] tracking-[0.3em] uppercase"
                          style="color: var(--color-copper-text)">{{ 'ui.navbar.section_exploration'|trans }}</span>
                    <div class="flex-1 h-px"
                         style="background: linear-gradient(90deg, rgba(184,134,74,0.55), transparent)"></div>
                </div>
                <p class="font-display italic text-[14px] mb-5"
                   style="color: var(--color-copper-text)">{{ 'ui.navbar.exploration_subtitle'|trans }}</p>
                <ul class="space-y-4">
                    <li>
                        <a href="{{ path('index_spices') }}" @click="close()"
                           class="pole-item items-baseline justify-between group/item">
                            <div>
                                <div class="pole-name font-display text-[24px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.navbar.catalog_title'|trans }}</div>
                                <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                     style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.catalog_sub'|trans }}</div>
                            </div>
                            <span class="pole-arrow font-display text-[18px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('index_spicy_match') }}" @click="close()"
                           class="pole-item items-baseline justify-between group/item">
                            <div>
                                <div class="pole-name font-display text-[24px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.navbar.alchemy_title'|trans }}</div>
                                <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                     style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.alchemy_sub'|trans }}</div>
                            </div>
                            <span class="pole-arrow font-display text-[18px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                </ul>
            </div>

            {# ── II · Apprentissage ── #}
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="font-mono text-[9px] tracking-[0.3em] uppercase"
                          style="color: var(--color-copper-text)">{{ 'ui.navbar.section_learning'|trans }}</span>
                    <div class="flex-1 h-px"
                         style="background: linear-gradient(90deg, rgba(184,134,74,0.55), transparent)"></div>
                </div>
                <p class="font-display italic text-[14px] mb-5"
                   style="color: var(--color-copper-text)">{{ 'ui.navbar.learning_subtitle'|trans }}</p>
                <ul class="space-y-4">
                    <li>
                        <a href="{{ path('education_index') }}" @click="close()"
                           class="pole-item items-baseline justify-between">
                            <div>
                                <div class="pole-name font-display text-[24px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.common.academy'|trans }}</div>
                                <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                     style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.academy_sub'|trans }}</div>
                            </div>
                            <span class="pole-arrow font-display text-[18px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('education_play_live', {'mode': 'survival'}) }}" @click="close()"
                           class="pole-item items-baseline justify-between">
                            <div>
                                <div class="pole-name font-display text-[24px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.navbar.scoville_title'|trans }}</div>
                                <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                     style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.scoville_sub'|trans }}</div>
                            </div>
                            <span class="pole-arrow font-display text-[18px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('education_play_live', {'mode': 'intrus'}) }}" @click="close()"
                           class="pole-item items-baseline justify-between">
                            <div>
                                <div class="pole-name font-display text-[24px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.navbar.intrus_title'|trans }}</div>
                                <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                     style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.intrus_sub'|trans }}</div>
                            </div>
                            <span class="pole-arrow font-display text-[18px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                </ul>
            </div>

            {# ── III · Atelier ── #}
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <span class="font-mono text-[9px] tracking-[0.3em] uppercase"
                          style="color: var(--color-copper-text)">{{ 'ui.navbar.section_atelier'|trans }}</span>
                    <div class="flex-1 h-px"
                         style="background: linear-gradient(90deg, rgba(184,134,74,0.55), transparent)"></div>
                </div>
                {% if is_granted('ROLE_USER') %}
                    <p class="font-display italic text-[14px] mb-5"
                       style="color: var(--color-copper-text)">{{ 'ui.navbar.atelier_subtitle'|trans }}</p>
                    <ul class="space-y-4">
                        <li>
                            <a href="{{ path('profile_user') }}" @click="close()"
                               class="pole-item items-baseline justify-between">
                                <div>
                                    <div class="pole-name font-display text-[24px] font-medium"
                                         style="color: var(--color-ink-deep)">{{ 'ui.common.my_profile'|trans }}</div>
                                    <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                         style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.profile_sub'|trans }}</div>
                                </div>
                                <span class="pole-arrow font-display text-[18px] ml-3"
                                      style="color: rgba(184,134,74,0.7)">→</span>
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('history_user') }}" @click="close()"
                               class="pole-item items-baseline justify-between">
                                <div>
                                    <div class="pole-name font-display text-[24px] font-medium"
                                         style="color: var(--color-ink-deep)">{{ 'ui.common.my_blends'|trans }}</div>
                                    <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                         style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.blends_sub'|trans }}</div>
                                </div>
                                <span class="pole-arrow font-display text-[18px] ml-3"
                                      style="color: rgba(184,134,74,0.7)">→</span>
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('configuration_user') }}" @click="close()"
                               class="pole-item items-baseline justify-between">
                                <div>
                                    <div class="pole-name font-display text-[24px] font-medium"
                                         style="color: var(--color-ink-deep)">{{ 'ui.common.configuration'|trans }}</div>
                                    <div class="font-mono text-[10px] tracking-[0.15em] uppercase mt-0.5"
                                         style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.config_sub'|trans }}</div>
                                </div>
                                <span class="pole-arrow font-display text-[18px] ml-3"
                                      style="color: rgba(184,134,74,0.7)">→</span>
                            </a>
                        </li>
                    </ul>
                {% else %}
                    <p class="font-display italic text-[14px] mb-5"
                       style="color: var(--color-copper-text)">{{ 'ui.navbar.join_subtitle'|trans }}</p>
                    <a href="{{ path('index_register') }}" @click="close()"
                       class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm font-semibold hover:opacity-90 transition-opacity"
                       style="background: var(--color-paprika-700); color: white;">
                        {{ 'ui.navbar.create_account'|trans }}
                        <span class="pole-arrow">→</span>
                    </a>
                {% endif %}
            </div>

        </div>{# fin grid #}

        {# Footer Menu ─────────────────────────────────── #}
        <div class="mt-12 pt-8 flex items-center justify-between"
             style="border-top: 1px solid rgba(184,134,74,0.35)">
            <div class="flex items-center gap-6 font-mono text-[11px]"
                 style="color: rgba(74,50,37,0.75)">
                <a href="{{ path('new_contact') }}" @click="close()"
                   class="spice-underline hover:text-paprika-700 transition-colors">{{ 'ui.navbar.help'|trans }}</a>
                {% if is_granted('ROLE_USER') %}
                    <a href="{{ path('app_logout') }}"
                       class="spice-underline hover:text-paprika-700 transition-colors">{{ 'ui.common.logout'|trans }}</a>
                {% else %}
                    <a href="{{ path('app_login') }}" @click="close()"
                       class="spice-underline hover:text-paprika-700 transition-colors">{{ 'ui.common.login'|trans }}</a>
                {% endif %}
            </div>

            {# Sélecteur de langue (i18n) #}
            <div class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.15em]">
                {% for loc in ['fr', 'en', 'es'] %}
                    <a href="{{ path('switch_locale', {'locale': loc}) }}"
                       hreflang="{{ loc }}"
                       {# full reload volontaire : Turbo ne réévalue pas les modules JS → sinon libellés JS figés sur l'ancienne langue #}
                       data-turbo="false"
                       class="px-1.5 py-0.5 rounded transition-colors {{ app.request.locale == loc ? 'text-paprika-700 font-semibold' : 'hover:text-paprika-700' }}"
                       style="{{ app.request.locale == loc ? '' : 'color: rgba(74,50,37,0.75)' }}"
                       {{ app.request.locale == loc ? 'aria-current="true"' : '' }}>{{ loc }}</a>
                {% endfor %}
            </div>
        </div>

    </div>
</div>

{# ════════════════════════════════════════════════════════════════════
   MOBILE BACKDROP (z-48 — visible sous le sheet)
   ════════════════════════════════════════════════════════════════════ #}
<div x-show="mobileOpen"
     x-cloak
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     @click="mobileClose()"
     class="nav-backdrop lg:hidden"
     aria-hidden="true"></div>

{# ════════════════════════════════════════════════════════════════════
   MOBILE SHEET (slide from bottom, z-49)
   ════════════════════════════════════════════════════════════════════ #}
<div id="nav-sheet"
     x-show="mobileOpen"
     x-cloak
     x-transition:enter="transition duration-[320ms] ease-[cubic-bezier(.2,.7,.2,1)]"
     x-transition:enter-start="-translate-y-full"
     x-transition:enter-end="translate-y-0"
     x-transition:leave="transition duration-[220ms] ease-in"
     x-transition:leave-start="translate-y-0"
     x-transition:leave-end="-translate-y-full"
     class="nav-sheet lg:hidden"
     role="navigation"
     aria-label="{{ 'ui.navbar.main_menu'|trans }}">

    <div class="p-6">

        {# Hero search #}
        <div class="mb-6">{{ component('Search') }}</div>

        {# Grade card si connecté #}
        {% if is_granted('ROLE_USER') and app.user.progression %}
            <div class="flex items-center gap-3 p-4 rounded-2xl mb-6"
                 style="border: 1px solid rgba(184,134,74,0.3); background: rgba(255,250,235,0.5)">
                {{ _self.herbierLogo('size-10') }}
                <div class="flex-1 min-w-0">
                    <div class="font-display text-[17px] font-medium"
                         style="color: var(--color-ink-deep)">{{ app.user.username }}</div>
                    <div class="font-display italic text-[12px]"
                         style="color: var(--color-paprika-700)">{{ _grade }}</div>
                    <div class="rounded-full mt-1.5 overflow-hidden w-full" style="height: 2px; background: rgba(184,134,74,0.2);">
                        <div class="gauge-bar h-full" style="width: {{ _gaugePct }}%"></div>
                    </div>
                </div>
                {% if _streak > 0 %}
                    <div class="flex flex-col items-center shrink-0">
                        <i class="fa-solid fa-fire" style="color: var(--color-saffron-600)" aria-hidden="true"></i>
                        <span class="font-mono text-[10px] mt-0.5"
                              style="color: var(--color-copper-text)">{{ _streak }}j</span>
                    </div>
                {% endif %}
            </div>
        {% endif %}

        {# 3 Pôles empilés ──────────────────────────────────────── #}
        <div class="space-y-6">

            {# Pôle I — Exploration #}
            <div>
                <div class="flex items-center gap-2 mb-3">
                    <span class="font-mono text-[9px] tracking-[0.3em] uppercase"
                          style="color: var(--color-copper-text)">{{ 'ui.navbar.section_exploration'|trans }}</span>
                    <div class="flex-1 h-px"
                         style="background: linear-gradient(90deg, rgba(184,134,74,0.5), transparent)"></div>
                </div>
                <ul class="space-y-3">
                    <li>
                        <a href="{{ path('index_spices') }}" @click="mobileClose()"
                           class="pole-item items-baseline justify-between">
                            <div class="pole-name font-display text-[20px] font-medium"
                                 style="color: var(--color-ink-deep)">{{ 'ui.navbar.catalog_title'|trans }}</div>
                            <span class="pole-arrow font-display text-[14px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('index_spicy_match') }}" @click="mobileClose()"
                           class="pole-item items-baseline justify-between">
                            <div class="pole-name font-display text-[20px] font-medium"
                                 style="color: var(--color-ink-deep)">{{ 'ui.navbar.alchemy_title'|trans }}</div>
                            <span class="pole-arrow font-display text-[14px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                </ul>
            </div>

            {# Pôle II — Apprentissage #}
            <div>
                <div class="flex items-center gap-2 mb-3">
                    <span class="font-mono text-[9px] tracking-[0.3em] uppercase"
                          style="color: var(--color-copper-text)">{{ 'ui.navbar.section_learning'|trans }}</span>
                    <div class="flex-1 h-px"
                         style="background: linear-gradient(90deg, rgba(184,134,74,0.5), transparent)"></div>
                </div>
                <ul class="space-y-3">
                    <li>
                        <a href="{{ path('education_index') }}" @click="mobileClose()"
                           class="pole-item items-baseline justify-between">
                            <div class="pole-name font-display text-[20px] font-medium"
                                 style="color: var(--color-ink-deep)">{{ 'ui.common.academy'|trans }}</div>
                            <span class="pole-arrow font-display text-[14px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('education_play_live', {'mode': 'survival'}) }}" @click="mobileClose()"
                           class="pole-item items-baseline justify-between">
                            <div class="pole-name font-display text-[20px] font-medium"
                                 style="color: var(--color-ink-deep)">{{ 'ui.navbar.scoville_title'|trans }}</div>
                            <span class="pole-arrow font-display text-[14px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('education_play_live', {'mode': 'intrus'}) }}" @click="mobileClose()"
                           class="pole-item items-baseline justify-between">
                            <div class="pole-name font-display text-[20px] font-medium"
                                 style="color: var(--color-ink-deep)">{{ 'ui.navbar.intrus_title'|trans }}</div>
                            <span class="pole-arrow font-display text-[14px] ml-3"
                                  style="color: rgba(184,134,74,0.7)">→</span>
                        </a>
                    </li>
                </ul>
            </div>

            {# Pôle III — Atelier #}
            <div>
                <div class="flex items-center gap-2 mb-3">
                    <span class="font-mono text-[9px] tracking-[0.3em] uppercase"
                          style="color: var(--color-copper-text)">{{ 'ui.navbar.section_atelier'|trans }}</span>
                    <div class="flex-1 h-px"
                         style="background: linear-gradient(90deg, rgba(184,134,74,0.5), transparent)"></div>
                </div>
                {% if is_granted('ROLE_USER') %}
                    <ul class="space-y-3">
                        <li>
                            <a href="{{ path('profile_user') }}" @click="mobileClose()"
                               class="pole-item items-baseline justify-between">
                                <div class="pole-name font-display text-[20px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.common.my_profile'|trans }}</div>
                                <span class="pole-arrow font-display text-[14px] ml-3"
                                      style="color: rgba(184,134,74,0.7)">→</span>
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('history_user') }}" @click="mobileClose()"
                               class="pole-item items-baseline justify-between">
                                <div class="pole-name font-display text-[20px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.common.my_blends'|trans }}</div>
                                <span class="pole-arrow font-display text-[14px] ml-3"
                                      style="color: rgba(184,134,74,0.7)">→</span>
                            </a>
                        </li>
                        <li>
                            <a href="{{ path('configuration_user') }}" @click="mobileClose()"
                               class="pole-item items-baseline justify-between">
                                <div class="pole-name font-display text-[20px] font-medium"
                                     style="color: var(--color-ink-deep)">{{ 'ui.common.configuration'|trans }}</div>
                                <span class="pole-arrow font-display text-[14px] ml-3"
                                      style="color: rgba(184,134,74,0.7)">→</span>
                            </a>
                        </li>
                    </ul>
                {% else %}
                    <a href="{{ path('index_register') }}" @click="mobileClose()"
                       class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm font-semibold hover:opacity-90 transition-opacity"
                       style="background: var(--color-paprika-700); color: white;">
                        {{ 'ui.navbar.create_account'|trans }} →
                    </a>
                {% endif %}
            </div>

        </div>

        {# Footer sheet #}
        <div class="mt-8 pt-6 flex items-center justify-between"
             style="border-top: 1px solid rgba(184,134,74,0.3)">
            <a href="{{ path('new_contact') }}" @click="mobileClose()"
               class="font-mono text-[11px] transition-colors hover:text-paprika-700"
               style="color: rgba(74,50,37,0.75)">{{ 'ui.navbar.help'|trans }}</a>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_logout') }}"
                   class="font-mono text-[11px] transition-colors hover:text-paprika-700"
                   style="color: rgba(74,50,37,0.75)">{{ 'ui.common.logout'|trans }}</a>
            {% else %}
                <a href="{{ path('app_login') }}" @click="mobileClose()"
                   class="font-mono text-[11px] transition-colors hover:text-paprika-700"
                   style="color: rgba(74,50,37,0.75)">{{ 'ui.common.login'|trans }}</a>
            {% endif %}

            {# Sélecteur de langue (i18n) #}
            <div class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.15em]">
                {% for loc in ['fr', 'en', 'es'] %}
                    <a href="{{ path('switch_locale', {'locale': loc}) }}"
                       hreflang="{{ loc }}"
                       {# full reload volontaire : Turbo ne réévalue pas les modules JS → sinon libellés JS figés sur l'ancienne langue #}
                       data-turbo="false"
                       class="px-1.5 py-0.5 rounded transition-colors {{ app.request.locale == loc ? 'text-paprika-700 font-semibold' : 'hover:text-paprika-700' }}"
                       style="{{ app.request.locale == loc ? '' : 'color: rgba(74,50,37,0.75)' }}"
                       {{ app.request.locale == loc ? 'aria-current="true"' : '' }}>{{ loc }}</a>
                {% endfor %}
            </div>
        </div>

    </div>
</div>

</div>{# end x-data="navMenu" #}
