{#
    Onboarding guidé — 2 couches :
    1. Modale de bienvenue (accueil uniquement)
    2. Spotlight tour contextuel (pages cibles : épices, lab, académie)

    State localStorage 'sm_onboarding' :
      absent  → modale de bienvenue
      spices  → tour catalogue
      lab     → tour lab
      academy → tour académie
      done    → ne plus rien afficher

    IFTTD #89  Benoit Freslon : équilibrer guidage et découverte
    IFTTD #305 Alex Delivet   : mettre rapidement en situation concrète
    IFTTD #231 Frederic Bouchery : l'expérience s'acquiert en pratique
    IFTTD #329 Frédéric Barthelet : hints contextuels > tutoriels linéaires
#}
{% if is_granted('ROLE_USER') %}

{# ═══════════════════════════════════════════════════════════ #}
{# COUCHE 1 — Modale de bienvenue (accueil uniquement)        #}
{# ═══════════════════════════════════════════════════════════ #}
<div x-data="onboardingWelcome()"
     x-init="init()"
     x-show="visible"
     x-cloak
     x-effect="document.querySelectorAll('main, nav, footer').forEach(el => { el.inert = visible; });"
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     @keydown.escape="skip()"
     @keydown.tab="handleTab($event)"
     class="fixed inset-0 z-60 flex items-end sm:items-center justify-center p-4 sm:p-8"
     role="dialog" aria-modal="true" aria-labelledby="onboarding-welcome-title">

    {# Overlay #}
    <div class="absolute inset-0 bg-stone-900/60 backdrop-blur-sm"
         @click="skip()"></div>

    {# Carte #}
    <div class="relative z-10 w-full max-w-sm bg-cream rounded-2xl shadow-2xl border border-saffron-200/60 overflow-hidden">

        {# Bouton fermeture #}
        <button @click="skip()"
                class="absolute top-4 right-4 w-7 h-7 flex items-center justify-center rounded-full
                       text-stone-400 hover:text-stone-600 hover:bg-stone-100 transition-colors z-10"
                aria-label="Passer l'introduction">
            <i class="fa-solid fa-xmark text-xs"></i>
        </button>

        <div class="px-7 pt-8 pb-7">
            <div class="text-center mb-6">
                <div class="w-20 h-20 bg-saffron-100 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-saffron-200">
                    <i class="fa-solid fa-hand-sparkles text-4xl text-saffron-600"></i>
                </div>
                <h2 id="onboarding-welcome-title" class="text-xl font-bold text-stone-800 mb-3 leading-tight">
                    Bienvenue sur SpicyMatch !
                </h2>
                <p class="text-stone-500 text-sm leading-relaxed">
                    On va te faire découvrir <strong class="text-stone-700">3 espaces clés</strong> du site en quelques secondes.
                    Promis, c'est rapide.
                </p>
            </div>
            <a href="{{ path('index_spices') }}"
               @click="start()"
               class="flex items-center justify-center gap-2 w-full px-5 py-3.5 bg-paprika-800
                      text-white text-sm font-bold rounded-xl hover:bg-paprika-900
                      transition-colors shadow-sm shadow-paprika-900/20 mb-3">
                <i class="fa-solid fa-arrow-right"></i>
                C'est parti !
            </a>
            <button @click="skip()"
                    class="w-full text-center text-xs text-stone-500 hover:text-stone-600 py-1 transition-colors">
                Je connais déjà, passer →
            </button>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════════════ #}
{# COUCHE 2 — Spotlight tour (pages cibles)                    #}
{# ═══════════════════════════════════════════════════════════ #}
<div x-data="spotlightTour()"
     x-init="init()"
     x-cloak>

    {# Overlay avec trou (box-shadow) #}
    <div x-show="active"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="spotlight-overlay"
         :style="spotlightStyle"
         @click="next()">
    </div>

    {# Tooltip #}
    <div x-show="active"
         x-transition:enter="transition ease-out duration-200 delay-100"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed z-60 max-w-xs bg-white rounded-xl shadow-2xl border border-saffron-200/60 p-5"
         :style="tooltipStyle"
         role="tooltip"
         @keydown.escape.window="skip()">

        <p class="text-sm font-semibold text-stone-800 mb-1" x-text="currentTitle"></p>
        <p class="text-xs text-stone-600 leading-relaxed mb-4" x-text="currentText"></p>

        <div class="flex items-center justify-between">
            <div class="flex gap-1.5">
                <template x-for="i in totalSteps" :key="i">
                    <div :class="i <= currentStep + 1
                        ? 'w-5 h-1.5 bg-saffron-500 rounded-full'
                        : 'w-1.5 h-1.5 bg-stone-300 rounded-full'"
                         class="transition-all duration-300"></div>
                </template>
            </div>
            <div class="flex gap-2">
                <button @click="skip()" class="text-xs text-stone-500 hover:text-stone-600 transition-colors">Passer</button>
                <button @click="next()"
                        class="text-xs font-semibold text-white bg-paprika-800 hover:bg-paprika-900 px-3 py-1.5 rounded-full transition-colors">
                    <span x-text="isLastStep ? 'Terminé !' : 'Suivant →'"></span>
                </button>
            </div>
        </div>
    </div>

    {# Toast de transition entre pages #}
    <div x-show="showTransition"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-4"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0 translate-y-4"
         class="fixed bottom-8 left-1/2 -translate-x-1/2 z-60 bg-white rounded-xl shadow-2xl border border-saffron-200/60 px-6 py-4 max-w-sm">
        <p class="text-sm font-semibold text-stone-800 mb-2" x-text="transitionTitle"></p>
        <div class="flex gap-2 justify-end">
            <button @click="skipTransition()" class="text-xs text-stone-500 hover:text-stone-600">Plus tard</button>
            <a :href="transitionUrl"
               @click="acceptTransition()"
               class="text-xs font-semibold text-white bg-paprika-800 hover:bg-paprika-900 px-3 py-1.5 rounded-full transition-colors">
                Allons-y →
            </a>
        </div>
    </div>
</div>

<script>
/* ── Couche 1 : Modale de bienvenue ── */
function onboardingWelcome() {
    return {
        visible: false,
        previouslyFocused: null,

        init() {
            const check = () => {
                const state = localStorage.getItem('sm_onboarding');
                if (!state && window.location.pathname === '/') {
                    setTimeout(() => {
                        this.previouslyFocused = document.activeElement;
                        this.visible = true;
                        this.$nextTick(() => this.trapFocus());
                    }, 600);
                }
            };
            check();
            document.addEventListener('turbo:load', () => check());
        },

        trapFocus() {
            const focusable = this.$el.querySelectorAll(
                'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
            );
            if (focusable.length) focusable[0].focus();
        },

        handleTab(e) {
            const focusable = [...this.$el.querySelectorAll(
                'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'
            )];
            if (!focusable.length) return;
            const first = focusable[0];
            const last = focusable[focusable.length - 1];
            if (e.shiftKey && document.activeElement === first) {
                e.preventDefault(); last.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault(); first.focus();
            }
        },

        start() {
            localStorage.setItem('sm_onboarding', 'spices');
            this.visible = false;
            if (this.previouslyFocused) this.previouslyFocused.focus();
        },

        skip() {
            localStorage.setItem('sm_onboarding', 'done');
            this.visible = false;
            if (this.previouslyFocused) this.previouslyFocused.focus();
        },
    };
}

/* ── Couche 2 : Spotlight tour ── */
const TOURS = {
    spices: {
        path: '/epices',
        nextState: 'lab',
        nextUrl: '{{ path("index_spicy_match") }}',
        transitionTitle: 'Bien joué ! Prêt à créer ton premier mélange ?',
        steps: [
            {
                target: 'input[name="search"]',
                title: 'Cherche une épice',
                text: 'Tape un nom pour trouver ton épice. Cumin, paprika, curcuma… tout y est.',
                position: 'bottom',
            },
            {
                target: '.card-warm',
                title: 'Découvre les fiches',
                text: 'Clique sur une épice pour voir sa fiche : saveurs, composés aromatiques, accords gourmands.',
                position: 'bottom',
            },
            {
                target: '[data-tour="cta-lab"]',
                title: 'Prêt à créer ?',
                text: 'Quand une épice te plaît, viens créer un mélange dans le Lab !',
                position: 'bottom',
            },
        ],
    },
    lab: {
        path: '/spicymatch',
        nextState: 'academy',
        nextUrl: '{{ path("education_index") }}',
        transitionTitle: 'Super ! Dernier arrêt : l\'Académie des épices.',
        steps: [
            {
                target: '[data-tour="mode-toggle"]',
                title: 'Choisis ton mode',
                text: 'Auto : l\'algorithme trouve les meilleurs accords. Manuel : compose librement.',
                position: 'bottom',
            },
            {
                target: '[data-tour="lab-search"]',
                title: 'Sélectionne et mélange',
                text: 'Cherche une épice, clique dessus, et regarde la magie des accords aromatiques opérer.',
                position: 'bottom',
            },
        ],
    },
    academy: {
        path: '/education',
        nextState: 'done',
        nextUrl: null,
        transitionTitle: null,
        steps: [
            {
                target: '[data-tour="game-grid"]',
                title: '6 mini-jeux t\'attendent',
                text: 'Choisis un mode, une difficulté, et prouve ce que tu sais sur les épices !',
                position: 'bottom',
            },
            {
                target: '.tag-secondary',
                title: 'Gagne de l\'XP',
                text: 'Chaque bonne réponse rapporte de l\'XP. Monte en niveau et débloque des succès exclusifs !',
                position: 'left',
            },
        ],
    },
};

function spotlightTour() {
    return {
        active: false,
        paused: false,
        currentStep: 0,
        steps: [],
        totalSteps: 0,
        tourKey: null,
        targetEl: null,
        spotlightStyle: {},
        tooltipStyle: {},
        currentTitle: '',
        currentText: '',
        showTransition: false,
        transitionTitle: '',
        transitionUrl: '',
        _observer: null,
        _resizeHandler: null,
        _targetClickHandler: null,
        _modalObserver: null,

        init() {
            const check = () => this.checkTour();
            check();
            document.addEventListener('turbo:load', () => setTimeout(check, 100));
        },

        checkTour() {
            // Ne pas relancer si en pause (modal ouvert) ou si modale bienvenue active
            if (this.paused) return;
            if (!localStorage.getItem('sm_onboarding')) return;

            const state = localStorage.getItem('sm_onboarding');
            if (!state || state === 'done') return;

            const tour = TOURS[state];
            if (!tour) return;

            // Vérifier que le path matche
            if (!window.location.pathname.startsWith(tour.path)) return;

            this.tourKey = state;
            this.steps = tour.steps;
            this.totalSteps = tour.steps.length;
            this.currentStep = 0;
            this.showTransition = false;

            // Délai pour laisser Turbo/LC stabiliser le DOM
            setTimeout(() => this.showStep(), 600);
        },

        showStep() {
            const step = this.steps[this.currentStep];
            if (!step) return this.completeTour();

            this.currentTitle = step.title;
            this.currentText = step.text;

            const el = document.querySelector(step.target);
            if (el) {
                this.activateStep(el, step);
            } else {
                // Attendre que l'élément apparaisse (LiveComponent, Turbo Frame)
                this.waitForElement(step.target, (found) => {
                    this.activateStep(found, step);
                });
            }
        },

        activateStep(el, step) {
            this.targetEl = el;
            this.targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(() => {
                this.positionSpotlight();
                this.positionTooltip(step.position);
                this.active = true;
                // Rendre l'élément cible cliquable au-dessus de l'overlay
                this.targetEl.style.position = this.targetEl.style.position || 'relative';
                this.targetEl.style.zIndex = '56';
                this.targetEl.style.pointerEvents = 'auto';
                this.setupResize();
                this.listenTargetClick();
            }, 300);
        },

        // Quand l'utilisateur clique sur l'élément mis en valeur :
        // - Lien qui navigue → persiste nextState avant la navigation
        // - Interaction locale (quick view, etc.) → pause le tour,
        //   attend la fin de l'interaction, puis reprend à l'étape suivante
        listenTargetClick() {
            this.cleanupTargetClick();
            if (!this.targetEl) return;

            this._targetClickHandler = () => {
                const link = this.targetEl.tagName === 'A' ? this.targetEl
                    : this.targetEl.closest('a') || this.targetEl.querySelector('a');
                const willNavigate = link && link.href
                    && !link.href.includes('#')
                    && !link.hasAttribute('data-turbo-frame');

                if (willNavigate) {
                    const tour = TOURS[this.tourKey];
                    localStorage.setItem('sm_onboarding', tour.nextState);
                    this.active = false;
                    this.cleanupResize();
                } else {
                    this.pauseForInteraction();
                }
            };

            this.targetEl.addEventListener('click', this._targetClickHandler, { once: true });
        },

        // Masque le tour et attend qu'un modal/overlay se ferme avant de reprendre
        pauseForInteraction() {
            this.active = false;
            this.paused = true;
            this.cleanupResize();
            this.waitForModalClose(() => {
                this.paused = false;
                this.currentStep++;
                if (this.currentStep >= this.steps.length) {
                    this.completeTour();
                } else {
                    setTimeout(() => this.showStep(), 300);
                }
            });
        },

        // Observe le DOM pour détecter quand le quick view modal (z-50 .fixed.inset-0)
        // disparaît, puis appelle le callback
        waitForModalClose(callback) {
            this.cleanupModalObserver();

            // Petite attente pour laisser le modal s'ouvrir
            setTimeout(() => {
                const checkClosed = () => {
                    // Le quick view modal : div.fixed.inset-0.z-50 visible
                    const modal = document.querySelector('.fixed.inset-0.z-50');
                    return !modal || modal.style.display === 'none'
                        || modal.offsetParent === null;
                };

                // Si le modal n'est même pas ouvert, reprendre directement
                if (checkClosed()) return callback();

                // Observer les changements de style du modal
                const modalEl = document.querySelector('.fixed.inset-0.z-50');
                if (!modalEl) return callback();

                this._modalObserver = new MutationObserver(() => {
                    if (checkClosed()) {
                        this.cleanupModalObserver();
                        callback();
                    }
                });
                this._modalObserver.observe(modalEl, {
                    attributes: true,
                    attributeFilter: ['style', 'class'],
                });
                // Aussi observer le parent au cas où Alpine retire l'élément
                this._modalObserver.observe(modalEl.parentElement, {
                    childList: true,
                });

                // Safety timeout : si le modal ne se ferme jamais, reprendre après 30s
                setTimeout(() => {
                    if (this.paused) {
                        this.cleanupModalObserver();
                        this.paused = false;
                        callback();
                    }
                }, 30000);
            }, 500);
        },

        cleanupModalObserver() {
            if (this._modalObserver) {
                this._modalObserver.disconnect();
                this._modalObserver = null;
            }
        },

        cleanupTargetClick() {
            if (this.targetEl) {
                this.targetEl.style.zIndex = '';
                this.targetEl.style.pointerEvents = '';
            }
            if (this._targetClickHandler && this.targetEl) {
                this.targetEl.removeEventListener('click', this._targetClickHandler);
                this._targetClickHandler = null;
            }
        },

        positionSpotlight() {
            if (!this.targetEl) return;
            const rect = this.targetEl.getBoundingClientRect();
            const pad = 8;
            this.spotlightStyle = {
                position: 'fixed',
                top: (rect.top - pad) + 'px',
                left: (rect.left - pad) + 'px',
                width: (rect.width + pad * 2) + 'px',
                height: (rect.height + pad * 2) + 'px',
            };
        },

        positionTooltip(position) {
            if (!this.targetEl) return;
            const rect = this.targetEl.getBoundingClientRect();
            const gap = 16;
            const tooltipW = 280;

            let top, left;
            switch (position) {
                case 'bottom':
                    top = rect.bottom + gap;
                    left = rect.left + (rect.width / 2) - (tooltipW / 2);
                    break;
                case 'top':
                    top = rect.top - gap - 140;
                    left = rect.left + (rect.width / 2) - (tooltipW / 2);
                    break;
                case 'left':
                    top = rect.top + (rect.height / 2) - 60;
                    left = rect.left - tooltipW - gap;
                    break;
                case 'right':
                    top = rect.top + (rect.height / 2) - 60;
                    left = rect.right + gap;
                    break;
                default:
                    top = rect.bottom + gap;
                    left = rect.left;
            }

            // Garder dans le viewport
            const vw = window.innerWidth;
            const vh = window.innerHeight;
            if (left < 12) left = 12;
            if (left + tooltipW > vw - 12) left = vw - tooltipW - 12;
            if (top < 12) top = 12;
            if (top > vh - 160) top = vh - 160;

            this.tooltipStyle = {
                top: top + 'px',
                left: left + 'px',
                width: tooltipW + 'px',
            };
        },

        setupResize() {
            this.cleanupResize();
            this._resizeHandler = () => {
                this.positionSpotlight();
                this.positionTooltip(this.steps[this.currentStep]?.position || 'bottom');
            };
            window.addEventListener('resize', this._resizeHandler);
        },

        cleanupResize() {
            if (this._resizeHandler) {
                window.removeEventListener('resize', this._resizeHandler);
                this._resizeHandler = null;
            }
        },

        get isLastStep() {
            return this.currentStep >= this.steps.length - 1;
        },

        next() {
            this.active = false;
            this.cleanupResize();
            this.cleanupTargetClick();
            this.currentStep++;
            if (this.currentStep >= this.steps.length) {
                this.completeTour();
            } else {
                setTimeout(() => this.showStep(), 200);
            }
        },

        completeTour() {
            const tour = TOURS[this.tourKey];
            localStorage.setItem('sm_onboarding', tour.nextState);
            this.active = false;
            this.paused = false;
            this.cleanupResize();
            this.cleanupTargetClick();
            this.cleanupModalObserver();

            // Afficher le toast de transition si page suivante
            if (tour.nextUrl && tour.transitionTitle) {
                this.transitionTitle = tour.transitionTitle;
                this.transitionUrl = tour.nextUrl;
                this.showTransition = true;
                // Auto-hide après 8s
                setTimeout(() => { this.showTransition = false; }, 8000);
            }
        },

        acceptTransition() {
            this.showTransition = false;
        },

        skipTransition() {
            this.showTransition = false;
        },

        skip() {
            localStorage.setItem('sm_onboarding', 'done');
            this.active = false;
            this.paused = false;
            this.showTransition = false;
            this.cleanupResize();
            this.cleanupTargetClick();
            this.cleanupModalObserver();
        },

        waitForElement(selector, callback, timeout = 3000) {
            if (this._observer) this._observer.disconnect();
            const found = document.querySelector(selector);
            if (found) return callback(found);
            this._observer = new MutationObserver(() => {
                const el = document.querySelector(selector);
                if (el) {
                    this._observer.disconnect();
                    this._observer = null;
                    callback(el);
                }
            });
            this._observer.observe(document.body, { childList: true, subtree: true });
            setTimeout(() => {
                if (this._observer) {
                    this._observer.disconnect();
                    this._observer = null;
                    // Élément introuvable — skip cette étape
                    this.next();
                }
            }, timeout);
        },
    };
}
</script>

{% endif %}
