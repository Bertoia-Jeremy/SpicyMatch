{#
    Onboarding gamifié — 3 étapes pour les nouveaux utilisateurs.

    Déclencheur : affiché si utilisateur connecté + localStorage 'sm_onboarding_done' absent.
    (Le localStorage gère intégralement le "déjà vu" — pas de condition sur l'activité,
     ce qui permet la réactivation via le bouton dans Configuration sans colonne DB.)

    IFTTD #13 Katia Himeur : séquencer, pas surcharger → 3 étapes max.
    IFTTD #231 Frederic Bouchery : l'expérience s'acquiert en pratique → CTAs directs vers l'action.
#}
{% if is_granted('ROLE_USER') %}

<div x-data="onboardingWizard()"
     x-init="init()"
     x-show="visible"
     x-cloak
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     class="fixed inset-0 z-60 flex items-end sm:items-center justify-center p-4 sm:p-8"
     role="dialog" aria-modal="true" aria-labelledby="onboarding-title">

    {# Overlay #}
    <div class="absolute inset-0 bg-stone-900/60 backdrop-blur-sm"
         @click="skip()"></div>

    {# Carte principale #}
    <div class="relative z-10 w-full max-w-sm bg-cream rounded-2xl shadow-2xl border border-saffron-200/60 overflow-hidden">

        {# Barre de progression fine #}
        <div class="h-0.5 bg-stone-200">
            <div class="h-full bg-linear-to-r from-saffron-500 to-turmeric-500 transition-all duration-500"
                 :style="`width: ${(step / totalSteps) * 100}%`"></div>
        </div>

        {# Bouton fermeture #}
        <button @click="skip()"
                class="absolute top-4 right-4 w-7 h-7 flex items-center justify-center rounded-full
                       text-stone-400 hover:text-stone-600 hover:bg-stone-100 transition-colors z-10"
                aria-label="Passer l'introduction">
            <i class="fa-solid fa-xmark text-xs"></i>
        </button>

        {# Étape 1 — Explorer les épices #}
        <template x-if="step === 1">
            <div class="px-7 pt-8 pb-7">
                <div class="text-center mb-6">
                    <div class="w-20 h-20 bg-turmeric-300/20 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-turmeric-400/30">
                        <i class="fa-solid fa-pepper-hot text-4xl text-turmeric-600"></i>
                    </div>
                    <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-saffron-100 rounded-full mb-3">
                        <span class="text-saffron-700 text-[11px] font-bold uppercase tracking-wider">Défi 1 sur 3</span>
                    </div>
                    <h2 id="onboarding-title" class="text-xl font-bold text-stone-800 mb-3 leading-tight">
                        Rencontre ta première épice
                    </h2>
                    <p class="text-stone-500 text-sm leading-relaxed">
                        Plus de <strong class="text-stone-700">120 épices</strong> t'attendent — chacune avec ses saveurs, ses accords gourmands et ses secrets de cuisine.
                    </p>
                </div>
                <a href="{{ path('index_spices') }}"
                   @click="next()"
                   class="flex items-center justify-center gap-2 w-full px-5 py-3.5 bg-paprika-800
                          text-white text-sm font-bold rounded-xl hover:bg-paprika-900
                          transition-colors shadow-sm shadow-paprika-900/20 mb-3">
                    <i class="fa-solid fa-arrow-right"></i>
                    Explore les épices
                </a>
                <button @click="next()"
                        class="w-full text-center text-xs text-stone-400 hover:text-stone-600 py-1 transition-colors">
                    Je le ferai plus tard →
                </button>
            </div>
        </template>

        {# Étape 2 — Créer un mélange #}
        <template x-if="step === 2">
            <div class="px-7 pt-8 pb-7">
                <div class="text-center mb-6">
                    <div class="w-20 h-20 bg-saffron-100 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-saffron-200">
                        <i class="fa-solid fa-flask text-4xl text-saffron-600"></i>
                    </div>
                    <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-saffron-100 rounded-full mb-3">
                        <span class="text-saffron-700 text-[11px] font-bold uppercase tracking-wider">Défi 2 sur 3</span>
                    </div>
                    <h2 id="onboarding-title" class="text-xl font-bold text-stone-800 mb-3 leading-tight">
                        Crée ton premier mélange
                    </h2>
                    <p class="text-stone-500 text-sm leading-relaxed">
                        Dans <strong class="text-stone-700">Le Lab</strong>, choisis une épice et l'algorithme trouve ses meilleurs accords. Sauvegarde ta recette et gagne <strong class="text-saffron-700">+10 XP</strong>.
                    </p>
                </div>
                <a href="{{ path('index_spicy_match') }}"
                   @click="next()"
                   class="flex items-center justify-center gap-2 w-full px-5 py-3.5 bg-paprika-800
                          text-white text-sm font-bold rounded-xl hover:bg-paprika-900
                          transition-colors shadow-sm shadow-paprika-900/20 mb-3">
                    <i class="fa-solid fa-fire text-saffron-400"></i>
                    Aller au Lab
                </a>
                <button @click="next()"
                        class="w-full text-center text-xs text-stone-400 hover:text-stone-600 py-1 transition-colors">
                    Je le ferai plus tard →
                </button>
            </div>
        </template>

        {# Étape 3 — L'Académie #}
        <template x-if="step === 3">
            <div class="px-7 pt-8 pb-7">
                <div class="text-center mb-6">
                    <div class="w-20 h-20 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-purple-200">
                        <i class="fa-solid fa-graduation-cap text-4xl text-purple-600"></i>
                    </div>
                    <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-saffron-100 rounded-full mb-3">
                        <span class="text-saffron-700 text-[11px] font-bold uppercase tracking-wider">Défi 3 sur 3</span>
                    </div>
                    <h2 id="onboarding-title" class="text-xl font-bold text-stone-800 mb-3 leading-tight">
                        Prouve ce que tu vaux
                    </h2>
                    <p class="text-stone-500 text-sm leading-relaxed">
                        <strong class="text-stone-700">6 mini-jeux</strong> sur les épices t'attendent. Réponds juste, gagne de l'XP, monte en niveau et débloque des succès exclusifs.
                    </p>
                </div>
                <a href="{{ path('education_index') }}"
                   @click="complete()"
                   class="flex items-center justify-center gap-2 w-full px-5 py-3.5 bg-paprika-800
                          text-white text-sm font-bold rounded-xl hover:bg-paprika-900
                          transition-colors shadow-sm shadow-paprika-900/20 mb-3">
                    <i class="fa-solid fa-gamepad"></i>
                    Relever le défi
                </a>
                <button @click="complete()"
                        class="w-full text-center text-xs text-stone-400 hover:text-stone-600 py-1 transition-colors">
                    C'est parti, je vais explorer →
                </button>
            </div>
        </template>

        {# Dots de navigation #}
        <div class="flex justify-center gap-2 pb-5">
            <template x-for="i in totalSteps" :key="i">
                <button @click="step = i"
                        :class="step === i
                            ? 'w-6 h-2 bg-saffron-600 rounded-full'
                            : 'w-2 h-2 bg-stone-300 hover:bg-stone-400 rounded-full'"
                        class="transition-all duration-300"
                        :aria-label="`Étape ${i}`">
                </button>
            </template>
        </div>

    </div>
</div>

<script>
function onboardingWizard() {
    return {
        visible: false,
        step: 1,
        totalSteps: 3,

        init() {
            if (!localStorage.getItem('sm_onboarding_done')) {
                // Petit délai pour laisser la page se charger avant d'afficher la modale
                setTimeout(() => { this.visible = true; }, 600);
            }
        },

        next() {
            if (this.step < this.totalSteps) {
                this.step++;
            } else {
                this.complete();
            }
        },

        complete() {
            localStorage.setItem('sm_onboarding_done', '1');
            this.visible = false;
        },

        skip() {
            localStorage.setItem('sm_onboarding_done', '1');
            this.visible = false;
        },
    };
}
</script>

{% endif %}
