{% if is_granted('ROLE_USER') %}

{% set tourMeta = {
    spices: { path: '/epices', nextState: 'lab', nextUrl: path('index_spicy_match'), transitionKey: 'transition_spices' },
    lab: { path: '/spicymatch', nextState: 'academy', nextUrl: path('education_index'), transitionKey: 'transition_lab' },
    academy: { path: '/education', nextState: 'done', nextUrl: null, transitionKey: null }
} %}

{% set tourSteps = {
    spices: [
        { target: 'input[name="search"]', key: 'search', position: 'bottom', noClickAdvance: true },
        { target: '.card-warm', key: 'cards', position: 'bottom' },
        { target: '[data-tour="cta-lab"]', key: 'cta', position: 'bottom' }
    ],
    lab: [
        { target: '[data-tour="mode-toggle"]', key: 'mode', position: 'bottom', noClickAdvance: true },
        { target: '.card-warm', key: 'score', position: 'bottom', noClickAdvance: true },
        { target: '[data-tour="lab-workspace"]', key: 'blend', position: 'left', noClickAdvance: true },
        { target: '[data-tour="lab-context"]', key: 'context', position: 'bottom', noClickAdvance: true },
        { target: '[data-tour="lab-compose"]', key: 'compose', position: 'left', noClickAdvance: true }
    ],
    academy: [
        { target: '[data-tour="game-grid"]', key: 'games', position: 'bottom' },
        { target: '.tag-secondary', key: 'xp', position: 'left' }
    ]
} %}

{% set tours = {} %}
{% for name, meta in tourMeta %}
    {% set steps = [] %}
    {% for step in tourSteps[name] %}
        {% set steps = steps|merge([step|merge({
            title: ('ui.onboarding.tours.' ~ name ~ '.' ~ step.key ~ '.title')|trans,
            text: ('ui.onboarding.tours.' ~ name ~ '.' ~ step.key ~ '.text')|trans
        })]) %}
    {% endfor %}
    {% set tours = tours|merge({ (name): {
        path: meta.path,
        nextState: meta.nextState,
        nextUrl: meta.nextUrl,
        transitionTitle: meta.transitionKey ? ('ui.onboarding.' ~ meta.transitionKey)|trans : null,
        steps: steps
    } }) %}
{% endfor %}

<div x-data="onboardingWelcome"
     x-show="visible"
     x-cloak
     x-transition:enter="transition ease-out duration-300"
     x-transition:enter-start="opacity-0 scale-95"
     x-transition:enter-end="opacity-100 scale-100"
     @keydown.escape="skip"
     @keydown.tab="handleTab($event)"
     class="fixed inset-0 z-60 flex items-end sm:items-center justify-center p-4 sm:p-8"
     role="dialog" aria-modal="true" aria-labelledby="onboarding-welcome-title">

    <div class="absolute inset-0 bg-stone-900/60 backdrop-blur-sm"
         @click="skip"></div>

    <div class="relative z-10 w-full max-w-md bg-cream rounded-2xl shadow-2xl border border-saffron-200/60 overflow-hidden">

        <twig:Button
            label="{{ 'ui.onboarding.skip_intro'|trans }}"
            iconOnly
            icon="fa-solid fa-xmark"
            variant="ghost"
            @click="skip"
            extra="absolute top-4 right-4 z-10"
        />

        <div class="px-7 pt-8 pb-7">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-saffron-100 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-saffron-200">
                    <i class="fa-solid fa-hand-sparkles text-3xl text-saffron-600" aria-hidden="true"></i>
                </div>
                <h2 id="onboarding-welcome-title" class="text-xl font-bold text-stone-800 mb-2 leading-tight">
                    {{ 'ui.onboarding.welcome_title'|trans }}
                </h2>
                <p class="text-stone-500 text-sm leading-relaxed">
                    {{ 'ui.onboarding.welcome_text'|trans }}
                </p>
            </div>

            <ul class="flex flex-col gap-2.5 mb-5">
                <li class="flex items-center gap-3 bg-spice-surface border border-spice-border rounded-xl px-4 py-3">
                    <span class="size-9 shrink-0 rounded-lg bg-saffron-100 border border-saffron-200 flex items-center justify-center">
                        <i class="fa-solid fa-pepper-hot text-saffron-600" aria-hidden="true"></i>
                    </span>
                    <span class="text-sm text-stone-700 leading-snug">{{ 'ui.onboarding.preview.spices'|trans }}</span>
                </li>
                <li class="flex items-center gap-3 bg-spice-surface border border-spice-border rounded-xl px-4 py-3">
                    <span class="size-9 shrink-0 rounded-lg bg-saffron-100 border border-saffron-200 flex items-center justify-center">
                        <i class="fa-solid fa-mortar-pestle text-saffron-600" aria-hidden="true"></i>
                    </span>
                    <span class="text-sm text-stone-700 leading-snug">{{ 'ui.onboarding.preview.lab'|trans }}</span>
                </li>
                <li class="flex items-center gap-3 bg-spice-surface border border-spice-border rounded-xl px-4 py-3">
                    <span class="size-9 shrink-0 rounded-lg bg-saffron-100 border border-saffron-200 flex items-center justify-center">
                        <i class="fa-solid fa-graduation-cap text-saffron-600" aria-hidden="true"></i>
                    </span>
                    <span class="text-sm text-stone-700 leading-snug">{{ 'ui.onboarding.preview.academy'|trans }}</span>
                </li>
            </ul>

            <p class="flex items-center justify-center gap-1.5 text-[11px] font-mono uppercase tracking-widest text-stone-400 mb-5">
                <i class="fa-regular fa-clock" aria-hidden="true"></i>
                {{ 'ui.onboarding.duration'|trans }}
            </p>

            <twig:Button
                label="{{ 'ui.onboarding.lets_go'|trans }}"
                href="{{ path('index_spices') }}"
                variant="primary"
                icon="fa-solid fa-arrow-right"
                @click="start"
                extra="w-full justify-center mb-3"
            />
            <twig:Button
                label="{{ 'ui.onboarding.already_know'|trans }}"
                variant="ghost"
                @click="skip"
                extra="w-full justify-center"
            />
        </div>
    </div>
</div>

<div x-data="spotlightTour"
     data-tours-json="{{ tours|json_encode|e('html_attr') }}"
     x-cloak>

    <div x-show="active"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="spotlight-overlay"
         :style="spotlightStyle"
         aria-hidden="true">
    </div>

    <div x-show="tooltipActive"
         x-transition:enter="transition ease-out duration-200 delay-100"
         x-transition:enter-start="opacity-0 translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed z-60 bg-white shadow-2xl border border-saffron-200/60 focus:outline-none"
         :class="tooltipClass()"
         :style="tooltipStyle"
         role="dialog"
         aria-label="{{ 'ui.onboarding.tour_dialog_aria'|trans }}"
         tabindex="-1"
         x-ref="tooltip"
         @keydown.escape.window="skip">

        <div class="flex items-center justify-between mb-2">
            <span class="font-mono text-[10px] uppercase tracking-widest text-stone-500" x-text="stepCounter()"></span>
            <button @click="skip"
                    class="text-[11px] font-medium text-stone-500 hover:text-stone-700 transition-colors">
                {{ 'ui.onboarding.skip'|trans }}
            </button>
        </div>

        <div aria-live="polite">
            <p class="text-sm font-semibold text-stone-800 mb-1" x-text="currentTitle"></p>
            <p class="text-xs text-stone-600 leading-relaxed mb-4" x-text="currentText"></p>
        </div>

        <div class="flex items-center justify-between gap-3">
            <div class="flex gap-1.5" aria-hidden="true">
                <template x-for="i in totalSteps" :key="i">
                    <div :class="stepDotClass(i)"
                         class="transition-all duration-300"></div>
                </template>
            </div>
            <div class="flex gap-2">
                <button @click="prev"
                        x-show="hasPrev"
                        aria-label="{{ 'ui.onboarding.prev_step_aria'|trans }}"
                        class="text-xs font-semibold text-stone-500 hover:text-stone-700 border border-stone-200 hover:border-stone-300 px-3 py-1.5 rounded-full transition-colors">
                    ← {{ 'ui.onboarding.prev'|trans }}
                </button>
                <button @click="next"
                        aria-label="{{ 'ui.onboarding.next_step_aria'|trans }}"
                        class="text-xs font-semibold text-white bg-paprika-800 hover:bg-paprika-900 px-3 py-1.5 rounded-full transition-colors">
                    <span x-text="nextLabel()"></span>
                </button>
            </div>
        </div>
    </div>

    <div x-show="showTransition"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-4"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0 translate-y-4"
         class="fixed bottom-8 left-1/2 -translate-x-1/2 z-60 bg-white rounded-xl shadow-2xl border border-saffron-200/60 px-6 py-4 max-w-sm"
         role="status">
        <p class="text-sm font-semibold text-stone-800 mb-2" x-text="transitionTitle"></p>
        <div class="flex gap-2 justify-end">
            <twig:Button label="{{ 'ui.onboarding.later'|trans }}" variant="ghost" size="xs" @click="skipTransition" />
            <a :href="transitionUrl"
               @click="acceptTransition"
               class="text-xs font-semibold text-white bg-paprika-800 hover:bg-paprika-900 px-3 py-1.5 rounded-full transition-colors">
                {{ 'ui.onboarding.go'|trans }}
            </a>
        </div>
    </div>
</div>

{% endif %}
