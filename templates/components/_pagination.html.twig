{# templates/components/_pagination.html.twig #}
{% if pageCount > 1 %}
    <nav aria-label="Page navigation" class="flex flex-col sm:flex-row items-center justify-center sm:justify-between gap-4 mt-10">
        <ul class="flex -space-x-px text-sm list-none p-0 m-0">
            {# Previous Button #}
            {% if previous is defined %}
                <li>
                    <a href="{{ path(route, query|merge({(pageParameterName): previous})) }}" 
                       class="flex items-center justify-center text-stone-600 bg-white border border-stone-200 hover:bg-spice-surface hover:text-saffron-700 shadow-xs font-medium rounded-s-xl text-sm px-4 h-10 transition-colors">
                        Précédent
                    </a>
                </li>
            {% else %}
                <li>
                    <span class="flex items-center justify-center text-stone-300 bg-stone-50 border border-stone-200 font-medium rounded-s-xl text-sm px-4 h-10 cursor-not-allowed">
                        Précédent
                    </span>
                </li>
            {% endif %}

            {# Pages #}
            {% for page in pagesInRange %}
                {% if page != current %}
                    <li>
                        <a href="{{ path(route, query|merge({(pageParameterName): page})) }}" 
                           class="flex items-center justify-center text-stone-600 bg-white border border-stone-200 hover:bg-spice-surface hover:text-saffron-700 shadow-xs font-medium text-sm w-10 h-10 transition-colors">
                            {{ page }}
                        </a>
                    </li>
                {% else %}
                    <li>
                        <span aria-current="page" 
                              class="flex items-center justify-center text-white bg-saffron-600 border border-saffron-600 font-bold text-sm w-10 h-10 shadow-lg shadow-saffron-600/20 z-10 relative">
                            {{ page }}
                        </span>
                    </li>
                {% endif %}
            {% endfor %}

            {# Next Button #}
            {% if next is defined %}
                <li>
                    <a href="{{ path(route, query|merge({(pageParameterName): next})) }}" 
                       class="flex items-center justify-center text-stone-600 bg-white border border-stone-200 hover:bg-spice-surface hover:text-saffron-700 shadow-xs font-medium rounded-e-xl text-sm px-4 h-10 transition-colors">
                        Suivant
                    </a>
                </li>
            {% else %}
                <li>
                    <span class="flex items-center justify-center text-stone-300 bg-stone-50 border border-stone-200 font-medium rounded-e-xl text-sm px-4 h-10 cursor-not-allowed">
                        Suivant
                    </span>
                </li>
            {% endif %}
        </ul>

        {# Items per page select #}
        <form method="GET" action="{{ path(route) }}" class="flex items-center gap-2" x-data x-ref="limitForm">
            {# Keep existing query params except page and limit #}
            {% for key, value in query %}
                {% if key != pageParameterName and key != 'limit' %}
                    <input type="hidden" name="{{ key }}" value="{{ value }}">
                {% endif %}
            {% endfor %}
            
            <label for="limit" class="sr-only">Nombre d'épices par page</label>
            <select id="limit" 
                    name="limit" 
                    @change="$event.target.form.submit()"
                    class="block w-36 px-3 py-2 bg-white border border-stone-200 text-stone-700 text-sm rounded-xl focus:ring-saffron-500 focus:border-saffron-500 shadow-xs cursor-pointer transition-all">
                {% set currentLimit = app.request.query.get('limit', 12) %}
                <option value="12" {{ currentLimit == 12 ? 'selected' : '' }}>12 par page</option>
                <option value="24" {{ currentLimit == 24 ? 'selected' : '' }}>24 par page</option>
                <option value="48" {{ currentLimit == 48 ? 'selected' : '' }}>48 par page</option>
                <option value="96" {{ currentLimit == 96 ? 'selected' : '' }}>96 par page</option>
            </select>
        </form>
    </nav>
{% endif %}
