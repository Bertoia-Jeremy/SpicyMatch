{#
  Quick View modal — Alpine.js + Symfony Turbo Frame.

  Usage :
    Inclure ce composant UNE FOIS dans la page qui contient la grille de cartes.
    Les cartes émettent un event custom "open-spice-modal" avec { url, fullUrl }.
    Ce composant l'attrape et charge le contenu via Turbo Frame.

  Dépendances :
    - Alpine.js (quickSpiceView dans alpine_components.js)
    - @hotwired/turbo (turbo-frame)
    - Le template _quick_view.html.twig fournit la structure 2-col
#}
<div
    x-data="quickSpiceView"
    @open-spice-modal.window="openSpice($event)"
    @keydown.escape.window="close"
    @keydown.tab="handleTab($event)">

    <div
        x-show="modalOpen"
        x-cloak
        class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0">

        {# Backdrop #}
        <div class="absolute inset-0 bg-stone-900/40 backdrop-blur-[6px]"
             @click="close" aria-hidden="true"></div>

        {# Panel #}
        <div
            role="dialog"
            aria-modal="true"
            aria-label="{{ 'ui.modal.quick_view_label'|trans }}"
            class="relative w-full max-w-[880px] max-h-[90vh] overflow-hidden
                   bg-cream rounded-[18px] shadow-2xl"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-5 scale-[0.98]"
            x-transition:enter-end="opacity-100 translate-y-0 scale-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100 translate-y-0 scale-100"
            x-transition:leave-end="opacity-0 translate-y-3 scale-[0.98]">

            {# Bouton fermer #}
            <button
                @click="close"
                aria-label="{{ 'ui.modal.close'|trans }}"
                class="absolute top-4 right-4 z-20 size-8 flex items-center justify-center
                       bg-cream/90 backdrop-blur-sm border border-stone-200 rounded-full
                       text-stone-500 hover:text-saffron-600 hover:bg-white transition-colors shadow-sm">
                <i class="fa-solid fa-xmark text-sm" aria-hidden="true"></i>
            </button>

            {# Turbo Frame — charge _quick_view.html.twig (structure 2-col) #}
            <turbo-frame
                id="spice_quick_view"
                x-bind:src="modalOpen ? selectedUrl : null"
                loading="lazy"
                class="block">

                {# Skeleton pendant chargement Turbo #}
                <div class="grid sm:grid-cols-[300px_1fr]">
                    <div class="skeleton-pulse min-h-[220px] sm:min-h-[400px]"></div>
                    <div class="p-7 space-y-4">
                        <div class="skeleton-pulse h-3 w-28 rounded"></div>
                        <div class="skeleton-pulse h-9 w-3/4 rounded"></div>
                        <div class="flex gap-2 pt-1">
                            <div class="skeleton-pulse h-6 w-20 rounded-full"></div>
                            <div class="skeleton-pulse h-6 w-16 rounded-full"></div>
                        </div>
                        <div class="skeleton-pulse h-3 w-full rounded mt-2"></div>
                        <div class="skeleton-pulse h-3 w-5/6 rounded"></div>
                        <div class="skeleton-pulse h-3 w-4/5 rounded"></div>
                        <div class="flex gap-2 pt-3">
                            <div class="skeleton-pulse h-7 w-24 rounded-full"></div>
                            <div class="skeleton-pulse h-7 w-20 rounded-full"></div>
                            <div class="skeleton-pulse h-7 w-28 rounded-full"></div>
                        </div>
                    </div>
                    <div class="sm:col-span-2 h-14 border-t border-stone-200 skeleton-pulse"></div>
                </div>
            </turbo-frame>

        </div>
    </div>
</div>
