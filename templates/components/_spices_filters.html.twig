{#
  Filtres du catalogue épices.
  Variables attendues : aromaticGroups, spicyTypes, activeAgId, activeStId
  Soumission via form GET → Turbo Frame #spices_frame_id.
#}
{% set activeAgId = activeAgId|default(null) %}
{% set activeStId = activeStId|default(null) %}
{% set aromaticGroups = aromaticGroups|default([]) %}
{% set spicyTypes = spicyTypes|default([]) %}
{% set activeCount = (activeAgId ? 1 : 0) + (activeStId ? 1 : 0) %}

<div x-data="{
    filtersOpen: {{ activeCount > 0 ? 'true' : 'false' }},
    activeCount: {{ activeCount }},
    reset() {
        this.activeCount = 0;
        this.$refs.filterForm.reset();
        this.$refs.filterForm.submit();
    }
}" class="mb-6">

    {# ── Barre d'en-tête filtres ── #}
    <div class="flex items-center justify-between mb-3">
        <button
            type="button"
            @click="filtersOpen = !filtersOpen"
            class="flex items-center gap-2 px-4 py-2 bg-white border border-spice-border rounded-xl text-sm font-medium text-stone-700 hover:border-saffron-600/40 hover:text-saffron-700 transition-colors shadow-sm">
            <i class="fa-solid fa-sliders text-saffron-600"></i>
            Filtrer
            <span
                x-show="activeCount > 0"
                x-cloak
                class="inline-flex items-center justify-center w-5 h-5 bg-saffron-600 text-white text-xs font-bold rounded-full">
                <span x-text="activeCount"></span>
            </span>
            <i class="fa-solid fa-chevron-down text-xs transition-transform duration-200" :class="filtersOpen ? 'rotate-180' : ''"></i>
        </button>

        <button
            x-show="activeCount > 0"
            x-cloak
            type="button"
            @click="reset()"
            class="flex items-center gap-1.5 text-sm text-stone-400 hover:text-red-700 transition-colors">
            <i class="fa-solid fa-xmark"></i>
            Réinitialiser
        </button>
    </div>

    {# ── Panneau filtres (collapsible) ── #}
    <div
        x-show="filtersOpen"
        x-transition:enter="transition ease-out duration-150"
        x-transition:enter-start="opacity-0 -translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-cloak>
        <form
            x-ref="filterForm"
            method="GET"
            action="{{ path('index_spices') }}"
            data-turbo-frame="spices_frame_id"
            class="bg-white border border-spice-border rounded-2xl p-5 shadow-sm grid grid-cols-1 sm:grid-cols-2 gap-4">

            {# Groupe aromatique #}
            <div class="flex flex-col gap-1.5">
                <label for="filter_aromatic_group" class="text-xs font-semibold text-stone-500 uppercase tracking-wider">
                    <i class="fa-solid fa-circle-nodes text-saffron-600 mr-1"></i>
                    Groupe aromatique
                </label>
                <select
                    id="filter_aromatic_group"
                    name="aromatic_group"
                    @change="$el.closest('form').submit()"
                    class="w-full px-3 py-2 border rounded-xl text-sm text-stone-700 bg-white focus:outline-none focus:ring-2 focus:ring-saffron-600/30 focus:border-saffron-600/40 transition-colors {{ activeAgId ? 'border-saffron-600/40 bg-spice-surface' : 'border-stone-200' }}">
                    <option value="">Tous les groupes</option>
                    {% for group in aromaticGroups %}
                        <option value="{{ group.id }}" {{ activeAgId == group.id ? 'selected' : '' }}>
                            {{ group.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Type d'épice #}
            <div class="flex flex-col gap-1.5">
                <label for="filter_spicy_type" class="text-xs font-semibold text-stone-500 uppercase tracking-wider">
                    <i class="fa-solid fa-tag text-saffron-600 mr-1"></i>
                    Type d'épice
                </label>
                <select
                    id="filter_spicy_type"
                    name="spicy_type"
                    @change="$el.closest('form').submit()"
                    class="w-full px-3 py-2 border rounded-xl text-sm text-stone-700 bg-white focus:outline-none focus:ring-2 focus:ring-saffron-600/30 focus:border-saffron-600/40 transition-colors {{ activeStId ? 'border-saffron-600/40 bg-spice-surface' : 'border-stone-200' }}">
                    <option value="">Tous les types</option>
                    {% for type in spicyTypes %}
                        <option value="{{ type.id }}" {{ activeStId == type.id ? 'selected' : '' }}>
                            {{ type.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>
        </form>
    </div>

    {# ── Chips filtres actifs ── #}
    {% if activeAgId or activeStId %}
        <div class="flex flex-wrap gap-2 mt-3">
            {% if activeAgId %}
                {% for group in aromaticGroups %}{% if group.id == activeAgId %}
                    <a href="{{ path('index_spices', activeStId ? { spicy_type: activeStId } : {}) }}"
                       class="inline-flex items-center gap-1.5 bg-saffron-600/10 border border-saffron-600/30 text-saffron-800 text-xs font-medium px-3 py-1.5 rounded-full hover:bg-saffron-600/20 transition-colors">
                        <i class="fa-solid fa-circle-nodes text-xs"></i>{{ group.name }}
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                {% endif %}{% endfor %}
            {% endif %}
            {% if activeStId %}
                {% for type in spicyTypes %}{% if type.id == activeStId %}
                    <a href="{{ path('index_spices', activeAgId ? { aromatic_group: activeAgId } : {}) }}"
                       class="inline-flex items-center gap-1.5 bg-saffron-600/10 border border-saffron-600/30 text-saffron-800 text-xs font-medium px-3 py-1.5 rounded-full hover:bg-saffron-600/20 transition-colors">
                        <i class="fa-solid fa-tag text-xs"></i>{{ type.name }}
                        <i class="fa-solid fa-xmark"></i>
                    </a>
                {% endif %}{% endfor %}
            {% endif %}
        </div>
    {% endif %}
</div>
