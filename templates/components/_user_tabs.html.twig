{% set tabs = [
    { route: 'profile_user',       label: 'ui.tabs.profile'|trans },
    { route: 'favorites_user',     label: 'ui.tabs.favorites'|trans, icon: 'fa-solid fa-star text-xs mr-1' },
    { route: 'achievements_user',  label: 'ui.tabs.achievements'|trans, icon: 'fa-solid fa-trophy text-xs mr-1' },
    { route: 'configuration_user', label: 'ui.tabs.configuration'|trans },
    { route: 'history_user',       label: 'ui.tabs.history'|trans },
    { route: 'security_user',      label: 'ui.tabs.security'|trans },
] %}
<div class="flex flex-wrap border-b border-spice-border mt-6">
    {% for tab in tabs %}
        <a href="{{ path(tab.route) }}"
           class="px-4 py-2 text-sm font-medium
                  {{ app.request.attributes.get('_route') == tab.route
                     ? 'text-saffron-700 border-b-2 border-saffron-700'
                     : 'text-stone-500 hover:text-stone-800 hover:border-b-2 hover:border-stone-300' }}">
            {% if tab.icon is defined %}<i class="{{ tab.icon }}"></i>{% endif %}
            {{ tab.label }}
        </a>
    {% endfor %}
</div>
