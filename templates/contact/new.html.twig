{% extends 'base.html.twig' %}
{% block title %}SpicyMatch — Nous contacter{% endblock %}

{% block body %}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        {# Colonne gauche — descriptif #}
        <div class="lg:pt-4">
            <span class="tag-primary mb-4 inline-block">Contact</span>
            <h1 class="text-4xl font-bold text-stone-900 mb-4">Nous contacter</h1>
            <p class="text-stone-500 text-lg leading-relaxed mb-8">
                Une question sur nos épices, un retour sur l'application ou une idée d'association aromatique ? On vous lit.
            </p>

            <div class="space-y-5">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-spice-surface flex items-center justify-center shrink-0 border border-spice-border">
                        <i class="fa-solid fa-envelope text-saffron-600 text-sm"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-stone-800 text-sm">Réponse rapide</p>
                        <p class="text-stone-500 text-sm">Nous répondons sous 48h ouvrées.</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-spice-surface flex items-center justify-center shrink-0 border border-spice-border">
                        <i class="fa-solid fa-lightbulb text-saffron-600 text-sm"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-stone-800 text-sm">Suggestions bienvenues</p>
                        <p class="text-stone-500 text-sm">Votre feedback améliore SpicyMatch.</p>
                    </div>
                </div>
            </div>
        </div>

        {# Colonne droite — formulaire #}
        <div class="bg-white border border-stone-200 rounded-2xl p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}

            <div>
                {{ form_label(form.name, 'Nom', {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors'}}) }}
            </div>

            <div>
                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors'}}) }}
            </div>

            <div>
                {{ form_label(form.subject, 'Sujet', {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.subject, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors'}}) }}
            </div>

            <div>
                {{ form_label(form.message, 'Message', {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.message, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors', 'rows': 5}}) }}
            </div>

            <div>
                {{ form_widget(form.Valider, {
                    'label': 'Envoyer le message',
                    'attr': {'class': 'btn-pill-primary w-full justify-center py-3'}
                }) }}
            </div>

            {{ form_end(form) }}
        </div>

    </div>
</section>
{% endblock %}
