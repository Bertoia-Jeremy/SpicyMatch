{% extends 'base.html.twig' %}
{% block title %}{{ 'ui.contact.page_title'|trans }}{% endblock %}

{% block body %}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        {# Colonne gauche — descriptif #}
        <div class="lg:pt-4">
            <span class="tag-primary mb-4 inline-block">{{ 'ui.contact.tag'|trans }}</span>
            <h1 class="text-4xl font-bold text-stone-900 mb-4">{{ 'ui.contact.title'|trans }}</h1>
            <p class="text-stone-500 text-lg leading-relaxed mb-8">
                {{ 'ui.contact.intro'|trans }}
            </p>

            <div class="space-y-5">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-spice-surface flex items-center justify-center shrink-0 border border-spice-border">
                        <i class="fa-solid fa-envelope text-saffron-600 text-sm" aria-hidden="true"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-stone-800 text-sm">{{ 'ui.contact.quick_reply'|trans }}</p>
                        <p class="text-stone-500 text-sm">{{ 'ui.contact.quick_reply_text'|trans }}</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-spice-surface flex items-center justify-center shrink-0 border border-spice-border">
                        <i class="fa-solid fa-lightbulb text-saffron-600 text-sm" aria-hidden="true"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-stone-800 text-sm">{{ 'ui.contact.suggestions'|trans }}</p>
                        <p class="text-stone-500 text-sm">{{ 'ui.contact.suggestions_text'|trans }}</p>
                    </div>
                </div>
            </div>
        </div>

        {# Colonne droite — formulaire #}
        <div class="bg-white border border-stone-200 rounded-2xl p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}
            <p class="text-xs text-stone-500">{{ 'ui.form.required_legend'|trans }}</p>

            <div>
                {{ form_label(form.name, 'form.contact.name'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors'}}) }}
            </div>

            <div>
                {{ form_label(form.email, 'form.contact.email'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.email, {'attr': {'autocomplete': 'email', 'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors'}}) }}
            </div>

            <div>
                {{ form_label(form.subject, 'form.contact.subject'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.subject, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors'}}) }}
            </div>

            <div>
                {{ form_label(form.message, 'form.contact.message'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.message, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors', 'rows': 5}}) }}
            </div>

            <div>
                <twig:Button
                    label="{{ 'ui.contact.send'|trans }}"
                    type="submit"
                    variant="primary"
                    icon="fa-solid fa-paper-plane text-xs"
                />
                {# On rend le bouton original caché pour que Symfony Form ne râle pas ou on utilise form_rest #}
                <div class="hidden">{{ form_widget(form.Valider) }}</div>
            </div>

            {{ form_end(form) }}
        </div>

    </div>
</section>
{% endblock %}
