{% extends 'base.html.twig' %}
{% block title %}SpicyMatch — Message envoyé{% endblock %}

{% block body %}
<section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <div class="bg-white border border-stone-200 rounded-2xl p-10">
        <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-check text-green-600 text-2xl"></i>
        </div>
        <h1 class="text-3xl font-bold text-stone-900 mb-3">Merci pour votre message !</h1>
        <p class="text-stone-500 text-lg mb-2">Nous l'avons bien reçu et ferons de notre mieux pour vous répondre rapidement.</p>
        <p class="text-stone-500 mb-8">
            Bonne
            {% if "now"|date("H") < 18 %}journée{% else %}soirée{% endif %} !
        </p>
        <a href="{{ path('home') }}" class="btn-pill-primary">
            <i class="fa-solid fa-house"></i> Retour à l'accueil
        </a>
    </div>
</section>
{% endblock %}
