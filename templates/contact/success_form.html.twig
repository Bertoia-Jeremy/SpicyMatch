{% extends 'base.html.twig' %}
{% block title %}{{ 'ui.contact_success.page_title'|trans }}{% endblock %}

{% block body %}
{% import 'macros/buttons.html.twig' as buttons %}

<section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <div class="bg-white border border-stone-200 rounded-2xl p-10">
        <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-check text-green-600 text-2xl"></i>
        </div>
        <h1 class="text-3xl font-bold text-stone-900 mb-3">{{ 'ui.contact_success.title'|trans }}</h1>
        <p class="text-stone-500 text-lg mb-2">{{ 'ui.contact_success.text'|trans }}</p>
        <p class="text-stone-500 mb-8">
            {% if "now"|date("H") < 18 %}{{ 'ui.contact_success.good_day'|trans }}{% else %}{{ 'ui.contact_success.good_evening'|trans }}{% endif %}
        </p>
        {{ buttons.button('ui.common.back_home'|trans, {
            href: path('home'),
            variant: 'primary',
            icon: 'fa-solid fa-house'
        }) }}
    </div>
</section>
{% endblock %}
