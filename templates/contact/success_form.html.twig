{% extends 'base.html.twig' %}
{% block title %}Formulaire de contact{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8">
        <div class="bg-white shadow-md rounded-lg p-8 text-center">
            <h1 class="text-4xl font-bold text-gray-800 mb-4">Merci pour votre intérêt !</h1>

            <p class="text-lg text-gray-700 mb-4">Dès que nous aurons lu votre mail, nous ferons de notre mieux pour vous répondre.</p>

            <p class="text-lg text-gray-700 mb-8">
                D'ici là, nous vous souhaitons une bonne 
                {% if "now"|date("H") < 18 %}
                    journée
                {% else %}
                    soirée
                {% endif %}
                !
            </p>

            <a class="inline-block px-6 py-3 text-white bg-blue-600 rounded-md hover:bg-blue-700" href="{{ path('home') }}">Retour à l'accueil</a>
        </div>
    </div>
{% endblock %}