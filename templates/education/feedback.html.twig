{% extends 'base.html.twig' %}

{% block title %}Quiz — Résultat{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-6 text-center">

    {% if correct %}
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
        <i class="fa-solid fa-check text-2xl text-green-600"></i>
      </div>
      <h2 class="text-2xl font-bold text-green-700 mb-2">Bonne réponse !</h2>
      <p class="text-stone-600">
        <span class="font-semibold text-stone-800">{{ correctAnswer }}</span> est la bonne réponse.
      </p>
    {% else %}
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 flex items-center justify-center">
        <i class="fa-solid fa-xmark text-2xl text-red-600"></i>
      </div>
      <h2 class="text-2xl font-bold text-red-700 mb-2">Mauvaise réponse</h2>
      <p class="text-stone-600 mb-1">
        Tu as répondu <span class="font-semibold text-stone-800">{{ answer }}</span>
      </p>
      <p class="text-stone-600">
        La bonne réponse était <span class="font-semibold text-green-700">{{ correctAnswer }}</span>
      </p>
    {% endif %}

    <a href="{{ path('education_play', { id: session.id }) }}"
       class="btn-pill-primary mt-6 inline-flex items-center gap-2">
      <i class="fa-solid fa-arrow-right"></i>
      Question suivante
    </a>
  </div>
</div>
{% endblock %}
