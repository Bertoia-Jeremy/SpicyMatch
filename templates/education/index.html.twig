{% extends 'base.html.twig' %}

{% block title %}Académie des Épices{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <h1 class="text-3xl font-bold text-stone-800 mb-2">Académie des Épices</h1>
  <p class="text-stone-600 mb-8">Teste tes connaissances sur les épices et leurs compatibilités aromatiques.</p>

  {# Flash messages #}
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="mb-4 px-4 py-3 rounded-lg text-sm
        {{ label == 'warning' ? 'bg-turmeric-100 text-turmeric-800 border border-turmeric-300' : '' }}
        {{ label == 'error' ? 'bg-red-100 text-red-800 border border-red-300' : '' }}
        {{ label == 'success' ? 'bg-green-100 text-green-800 border border-green-300' : '' }}">
        {{ message }}
      </div>
    {% endfor %}
  {% endfor %}

  {# Mode selection cards #}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10"
       data-tour="game-grid"
       x-data="{ selectedMode: '{{ app.request.query.get('mode') ?? '' }}', selectedDifficulty: 'easy' }">

    {% for mode in modes %}
      <button type="button"
              @click="selectedMode = '{{ mode.value }}'"
              :class="selectedMode === '{{ mode.value }}'
                ? 'ring-2 ring-saffron-500 border-saffron-400 bg-spice-surface'
                : 'border-stone-200 bg-white hover:bg-cream'"
              class="relative text-left p-5 rounded-2xl border shadow-sm transition-all cursor-pointer group">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-saffron-100 text-saffron-600 group-hover:bg-saffron-200 transition-colors">
            <i class="{{ mode.icon }}"></i>
          </div>
          <h3 class="font-semibold text-stone-800">{{ mode.label }}</h3>
        </div>
        <p class="text-sm text-stone-600 leading-relaxed">{{ mode.description }}</p>
        <div class="mt-3 flex items-center gap-2 text-xs text-stone-500">
          <span class="tag-secondary">{{ mode.xpPerCorrect }} XP/correct</span>
          {% if mode.totalQuestions %}
            <span class="tag-secondary">{{ mode.totalQuestions }} questions</span>
          {% else %}
            <span class="tag-secondary">∞ questions</span>
          {% endif %}
        </div>
      </button>
    {% endfor %}

    {# Difficulty + Start section #}
    <div x-show="selectedMode" x-cloak
         class="sm:col-span-2 lg:col-span-3 bg-white border border-stone-200 rounded-2xl shadow-sm p-6 mt-2">
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex-1">
          <label class="block text-sm font-medium text-stone-700 mb-2">Difficulté</label>
          <div class="flex gap-2">
            {% for difficulty in difficulties %}
              <button type="button"
                      @click="selectedDifficulty = '{{ difficulty.value }}'"
                      :class="selectedDifficulty === '{{ difficulty.value }}'
                        ? 'bg-saffron-600 text-white'
                        : 'bg-stone-100 text-stone-700 hover:bg-stone-200'"
                      class="px-4 py-2 rounded-full text-sm font-medium transition-colors">
                {{ difficulty.label }}
                <span class="text-xs opacity-75">(×{{ difficulty.xpMultiplier }})</span>
              </button>
            {% endfor %}
          </div>
        </div>

        {# QCM uses the form POST flow, Live Component modes use GET link #}
        <template x-if="selectedMode === 'qcm'">
          <form method="post" action="{{ path('education_start') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('education_start') }}">
            <input type="hidden" name="mode" :value="selectedMode">
            <input type="hidden" name="difficulty" :value="selectedDifficulty">
            <button type="submit" class="btn-pill-primary whitespace-nowrap">
              <i class="fa-solid fa-play mr-2"></i>Commencer
            </button>
          </form>
        </template>

        <template x-if="selectedMode && selectedMode !== 'qcm'">
          <a :href="'/education/play-live/' + selectedMode + '?difficulty=' + selectedDifficulty"
             class="btn-pill-primary inline-flex items-center whitespace-nowrap">
            <i class="fa-solid fa-play mr-2"></i>Commencer
          </a>
        </template>
      </div>
    </div>
  </div>

  {# Recent sessions #}
  {% if recentSessions is not empty %}
    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-6">
      <h2 class="text-xl font-semibold text-stone-800 mb-4">Parties récentes</h2>
      <div class="space-y-3">
        {% for session in recentSessions %}
          <a href="{{ path(session.isFinished ? 'education_result' : 'education_play', { id: session.id }) }}"
             class="flex items-center justify-between px-4 py-3 rounded-lg border border-stone-200 hover:bg-cream transition-colors group">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-stone-100 text-stone-500">
                <i class="{{ session.gameMode.icon }} text-sm"></i>
              </div>
              <span class="text-sm font-medium text-stone-800">{{ session.gameMode.label }}</span>
              <span class="tag-secondary text-xs">{{ session.difficulty.label }}</span>
            </div>
            <div class="flex items-center gap-4 text-sm text-stone-600">
              {% if session.isFinished %}
                <span>{{ session.correctAnswers }}/{{ session.totalQuestions }} correct</span>
                <span class="font-semibold text-saffron-600">+{{ session.score }} XP</span>
              {% else %}
                <span class="text-turmeric-600 font-medium">En cours</span>
              {% endif %}
              <span class="text-xs text-stone-400">{{ session.startedAt|date('d/m H:i') }}</span>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>
{% endblock %}
