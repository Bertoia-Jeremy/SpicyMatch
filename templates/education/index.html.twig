{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.edu.academy_title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <h1 class="text-3xl font-bold text-stone-800 mb-2">{{ 'ui.edu.academy_title'|trans }}</h1>
  <p class="text-stone-600 mb-8">{{ 'ui.edu.academy_intro'|trans }}</p>

  {# Flash messages #}
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="mb-4 px-4 py-3 rounded-lg text-sm
        {{ label == 'warning' ? 'bg-turmeric-100 text-turmeric-800 border border-turmeric-300' : '' }}
        {{ label == 'error' ? 'bg-red-100 text-red-800 border border-red-300' : '' }}
        {{ label == 'success' ? 'bg-green-100 text-green-800 border border-green-300' : '' }}">
        {{ message }}
      </div>
    {% endfor %}
  {% endfor %}

  {# Mode selection cards #}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
    {% for mode in modes %}
      {% set count = dailyCounts[mode.value] ?? 0 %}
      {% set remaining = maxDailySessions - count %}
      {% set cardUrl = path('education_briefing', { mode: mode.value, difficulty: userDifficulty }) %}
      {% if remaining <= 0 %}
      <a href="{{ cardUrl }}"
         aria-disabled="true"
         tabindex="-1"
         class="relative block p-5 rounded-2xl border shadow-sm opacity-60 pointer-events-none bg-white border-stone-200">
      {% else %}
      <a href="{{ cardUrl }}"
         class="relative block p-5 rounded-2xl border shadow-sm transition-all cursor-pointer group hover:border-saffron-300 hover:shadow-md hover:bg-cream bg-white border-stone-200">
      {% endif %}
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-saffron-100 text-saffron-600 group-hover:bg-saffron-200 transition-colors">
            <i class="{{ mode.icon }}" aria-hidden="true"></i>
          </div>
          <h2 class="font-semibold text-stone-800 pr-6">{{ mode.label|trans }}</h2>
        </div>
        <p class="text-sm text-stone-600 leading-relaxed">{{ mode.description|trans }}</p>
        <div class="mt-3 flex items-center gap-2 text-xs text-stone-500 flex-wrap">
          <span class="tag-secondary">{{ 'ui.edu.xp_per_correct'|trans({'%xp%': mode.xpPerCorrect}) }}</span>
          {% if mode.totalQuestions %}
            <span class="tag-secondary">{{ 'ui.edu.questions'|trans({'%count%': mode.totalQuestions}) }}</span>
          {% elseif mode.value == 'chrono' %}
            <span class="tag-secondary"><i class="fa-solid fa-clock mr-1" aria-hidden="true"></i>{{ 'ui.edu.timed_mode'|trans }}</span>
          {% elseif mode.value == 'survival' %}
            <span class="tag-secondary"><i class="fa-solid fa-link mr-1" aria-hidden="true"></i>{{ 'ui.edu.survival_mode'|trans }}</span>
          {% else %}
            <span class="tag-secondary">{{ 'ui.edu.unlimited_questions'|trans }}</span>
          {% endif %}
          {% if is_granted('ROLE_USER') %}
            {% if remaining <= 0 %}
              <span class="tag-secondary bg-paprika-100 text-paprika-700 border-paprika-300 font-medium">
                  <i class="fa-solid fa-clock-rotate-left mr-1" aria-hidden="true"></i>{{ 'ui.edu.come_back_tomorrow'|trans }}
              </span>
            {% elseif count >= reducedXpThreshold %}
              <span class="tag-secondary bg-turmeric-100 text-turmeric-700 border-turmeric-300"
                    title="{{ 'ui.edu.reduced_xp_tooltip'|trans({'%threshold%': reducedXpThreshold}) }}">
                {{ 'ui.edu.remaining_xp'|trans({'%count%': remaining}) }}
              </span>
            {% else %}
              <span class="tag-secondary">{{ 'ui.edu.remaining_today'|trans({'%remaining%': remaining, '%max%': maxDailySessions}) }}</span>
            {% endif %}
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>

  {# Recent sessions #}
  {% if recentSessions is not empty %}
    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-6">
      <h2 class="text-xl font-semibold text-stone-800 mb-4">{{ 'ui.edu.recent_games'|trans }}</h2>
      <div class="space-y-3">
        {% for session in recentSessions %}
          <div class="flex items-center justify-between px-4 py-3 rounded-lg border border-stone-200">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-stone-100 text-stone-500">
                <i class="{{ session.gameMode.icon }} text-sm"></i>
              </div>
              <span class="text-sm font-medium text-stone-800">{{ session.gameMode.label|trans }}</span>
            </div>
            <div class="flex items-center gap-4 text-sm text-stone-600">
              {% if session.isFinished %}
                <span>{{ 'ui.edu.correct_count'|trans({'%correct%': session.correctAnswers, '%total%': session.totalQuestions}) }}</span>
                <span class="font-semibold text-saffron-600">+{{ session.score }} XP</span>
              {% else %}
                <span class="text-turmeric-600 font-medium">{{ 'ui.edu.in_progress'|trans }}</span>
              {% endif %}
              <span class="text-xs text-stone-400">{{ session.startedAt|format_date('short') }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="mt-12">
    {% include 'partials/_ads_banner.html.twig' %}
  </div>
</div>
{% endblock %}
