{% extends 'base.html.twig' %}
{% import 'components/Education/_game_header.html.twig' as game_header %}

{% block title %}{{ session.gameMode.label|trans }} — {{ 'ui.edu.question'|trans({'%num%': questionNumber}) }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10" x-data="qcmForm">

  {{ game_header.header(
      icon     = session.gameMode.icon,
      title    = session.gameMode.label|trans,
      subtitle = session.gameMode.description|trans,
      current  = questionNumber,
      total    = session.totalQuestions,
      scoreLabel = 'ui.edu.pts'|trans({'%score%': session.score}),
      quitUrl  = path('education_briefing', { mode: session.gameMode.value, difficulty: session.difficulty.value }),
  ) }}

  {# Question card #}
  <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-6 mb-6">
    {# Base spice info #}
    <div class="text-center mb-6">
      <p class="text-lg font-semibold text-stone-800">{{ question.prompt }}</p>
    </div>

    {% if showFeedback ?? false %}
      {# Mode feedback — options non-interactives colorées #}
      <div class="space-y-3 mb-6">
        {% for option in question.options %}
          <div class="flex items-center gap-3 px-4 py-3 rounded-xl border-2
            {% if option.name == correctAnswer %}border-green-500 bg-green-50
            {% elseif option.name == selectedAnswer %}border-red-500 bg-red-50
            {% else %}border-stone-200 bg-white{% endif %}">
            {% if option.name == correctAnswer %}
              <i class="fa-solid fa-check text-green-600 shrink-0" aria-hidden="true"></i>
            {% elseif option.name == selectedAnswer %}
              <i class="fa-solid fa-xmark text-red-600 shrink-0" aria-hidden="true"></i>
            {% else %}
              <div class="w-4 shrink-0"></div>
            {% endif %}
            <span class="font-medium text-stone-800">{{ option.name }}</span>
          </div>
        {% endfor %}
      </div>

      <div class="text-center mb-6 py-3 rounded-xl {{ isCorrect ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' }}">
        <i class="fa-solid {{ isCorrect ? 'fa-circle-check' : 'fa-circle-xmark' }} mr-2" aria-hidden="true"></i>
        <span class="font-semibold">{{ isCorrect ? 'ui.edu.correct_answer'|trans : 'ui.edu.wrong_answer'|trans }}</span>
      </div>

      <twig:Button
          label="{{ 'ui.edu.next_question'|trans }}"
          variant="primary"
          icon="fa-solid fa-arrow-right"
          href="{{ path('education_play', { id: session.id }) }}"
          data-turbo="false"
          extra="w-full justify-center" />

    {% else %}
      {# Mode normal — formulaire interactif #}
      <form method="post" action="{{ path('education_answer', { id: session.id }) }}" id="answerForm" @submit="submit" data-turbo="false">
        <div class="space-y-3 mb-6">
          {% for option in question.options %}
            <label class="flex items-center gap-3 px-4 py-3 rounded-xl border-2 cursor-pointer transition-all duration-200"
                   :class="optionSelectedClass('{{ option.name|e('js') }}')"
                   @click="pick('{{ option.name|e('js') }}')">
              <input type="radio" name="answer" value="{{ option.name }}"
                     class="text-saffron-600 focus:ring-saffron-500"
                     x-model="selected">
              <span class="text-stone-800 font-medium">{{ option.name }}</span>
            </label>
          {% endfor %}
        </div>

        <input type="hidden" name="_token" value="{{ csrf_token('education_answer') }}">
        <input type="hidden" name="timeSpentMs" x-bind:value="elapsed()">

        <twig:Button
            label="{{ 'ui.edu.submit'|trans }}"
            variant="primary"
            type="submit"
            x-bind:disabled="canSubmit()"
            extra="w-full disabled:opacity-50 disabled:cursor-not-allowed" />
      </form>
    {% endif %}
  </div>
</div>
{% endblock %}
