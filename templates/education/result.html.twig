{% extends 'base.html.twig' %}

{% block title %}{{ session.gameMode.label }} — Résultats{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  {# Score card #}
  <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-8 text-center mb-8">
    <div class="flex items-center justify-center gap-3 mb-6">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center bg-saffron-100 text-saffron-600">
        <i class="{{ session.gameMode.icon }}"></i>
      </div>
      <h1 class="text-2xl font-bold text-stone-800">{{ session.gameMode.label }}</h1>
    </div>

    {# Circular score display #}
    <div class="w-32 h-32 mx-auto mb-6 rounded-full border-8 flex items-center justify-center
      {{ session.accuracy >= 80 ? 'border-green-400 text-green-700' : (session.accuracy >= 50 ? 'border-turmeric-400 text-turmeric-700' : 'border-red-400 text-red-700') }}">
      <div>
        <div class="text-3xl font-bold">{{ session.accuracy|round }}%</div>
        <div class="text-xs">précision</div>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-4 mb-6">
      <div class="text-center">
        <div class="text-2xl font-bold text-stone-800">{{ session.correctAnswers }}</div>
        <div class="text-xs text-stone-500">Bonnes réponses</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-stone-800">{{ session.totalQuestions - session.correctAnswers }}</div>
        <div class="text-xs text-stone-500">Erreurs</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold text-saffron-600">+{{ session.score }}</div>
        <div class="text-xs text-stone-500">XP gagnés</div>
      </div>
    </div>

    <div class="flex flex-wrap justify-center gap-2 text-sm text-stone-500 mb-6">
      <span class="tag-secondary">{{ session.difficulty.label }}</span>
      {% if session.durationSeconds %}
        <span class="tag-secondary">
          <i class="fa-solid fa-clock mr-1"></i>{{ (session.durationSeconds / 60)|round(0, 'floor') }}min {{ session.durationSeconds % 60 }}s
        </span>
      {% endif %}
    </div>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      {% if session.gameMode.isLiveComponent %}
        <a href="{{ path('education_play_live', { mode: session.gameMode.value, difficulty: session.difficulty.value }) }}"
           class="btn-pill-primary inline-flex items-center gap-2">
          <i class="fa-solid fa-rotate-right"></i>
          Rejouer
        </a>
      {% endif %}
      <a href="{{ path('education_index') }}" class="btn-pill-outline inline-flex items-center gap-2">
        <i class="fa-solid fa-gamepad"></i>
        Tous les modes
      </a>
      <a href="{{ path('dashboard_user') }}" class="btn-pill-outline inline-flex items-center gap-2">
        <i class="fa-solid fa-house"></i>
        Tableau de bord
      </a>
    </div>
  </div>

  {# Question review (QCM only — LC modes don't store GameQuestion rows) #}
  {% if session.questions is not empty %}
    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-6">
      <h2 class="text-lg font-semibold text-stone-800 mb-4">Détail des questions</h2>
      <div class="space-y-3">
        {% for question in session.questions %}
          {% set qData = question.questionData %}
          <div class="flex items-center gap-3 px-4 py-3 rounded-lg border border-stone-200
            {{ question.correct ? 'bg-green-50 border-green-200' : 'bg-red-50 border-red-200' }}">
            <div class="shrink-0">
              {% if question.correct %}
                <i class="fa-solid fa-circle-check text-green-500"></i>
              {% else %}
                <i class="fa-solid fa-circle-xmark text-red-500"></i>
              {% endif %}
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-stone-800 font-medium truncate">
                {{ qData.prompt ?? ('Question ' ~ (question.questionIndex + 1)) }}
              </p>
              {% if not question.correct and qData.correctAnswer is defined %}
                <p class="text-xs text-stone-500">
                  Répondu : {{ question.answerGiven }} — Correct : {{ qData.correctAnswer }}
                </p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>
{% endblock %}
