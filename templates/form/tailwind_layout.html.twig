{% use "form_div_layout.html.twig" %}

{# Row wrapper: label + widget + errors in a flex column #}
{% block form_row -%}
    <div class="mb-4">
        {{- form_label(form) -}}
        {{- form_errors(form) -}}
        {{- form_widget(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock %}

{# Label #}
{% block form_label -%}
    {% if label is not same as(false) -%}
        {% if not compound -%}
            {% set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' block text-sm font-medium text-gray-700 mb-1')|trim}) %}
        {%- endif %}
        {{- parent() -}}
    {%- endif %}
{%- endblock %}

{% block form_label_content -%}
    {{- parent() -}}
    {%- if required is defined and required -%}
        <span aria-hidden="true" class="text-red-600"> *</span>
    {%- endif -%}
{%- endblock %}

{# Ici (et pas dans form_row) pour couvrir aussi les appels form_widget() directs #}
{% block widget_attributes -%}
    {%- set aria_describedby = attr['aria-describedby']|default('') ? [attr['aria-describedby']] : [] -%}
    {%- if help -%}
        {%- set aria_describedby = aria_describedby|merge([id ~ '_help']) -%}
    {%- endif -%}
    {%- if errors|length > 0 -%}
        {%- set aria_describedby = aria_describedby|merge(errors|map((_, index) => id ~ '_error' ~ (index + 1))) -%}
        {%- set attr = attr|merge({'aria-invalid': 'true'}) -%}
    {%- endif -%}
    {%- if aria_describedby|length > 0 -%}
        {%- set attr = attr|merge({'aria-describedby': aria_describedby|join(' ')}) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock %}

{# Input, select (single), number, email, password, url, search #}
{% block form_widget_simple -%}
    {%- set attr = attr|merge({class: (
        'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm '
        ~ 'focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 '
        ~ (attr.class|default(''))
    )|trim}) -%}
    {{- parent() -}}
{%- endblock %}

{# Textarea #}
{% block textarea_widget -%}
    {%- set attr = attr|merge({class: (
        'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm '
        ~ 'focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 '
        ~ (attr.class|default(''))
    )|trim}) -%}
    {{- parent() -}}
{%- endblock %}

{# Select (collapsed choice) #}
{% block choice_widget_collapsed -%}
    {%- set attr = attr|merge({class: (
        'w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm bg-white '
        ~ 'focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 '
        ~ (attr.class|default(''))
    )|trim}) -%}
    {{- parent() -}}
{%- endblock %}

{# Submit / button #}
{% block button_widget -%}
    {%- set attr = attr|merge({class: (
        'btn-pill-base btn-pill-primary px-5 py-2 text-sm '
        ~ (attr.class|default(''))
    )|trim}) -%}
    {{- parent() -}}
{%- endblock %}

{# Errors #}
{% block form_errors -%}
    {%- if errors|length > 0 -%}
        <ul class="mt-1 text-sm text-red-600 space-y-0.5 list-none p-0">
            {%- for error in errors -%}
                <li{% if id is defined and id %} id="{{ id ~ '_error' ~ loop.index }}"{% endif %}>{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif %}
{%- endblock %}

{# Checkbox row #}
{% block checkbox_row -%}
    <div class="flex items-start mb-4">
        {{- form_widget(form) -}}
        <div class="ml-2">
            {{- form_label(form) -}}
            {{- form_errors(form) -}}
        </div>
    </div>
{%- endblock %}

{# Checkbox widget #}
{% block checkbox_widget -%}
    {%- set attr = attr|merge({class: ('h-4 w-4 text-blue-600 border-gray-300 rounded ' ~ (attr.class|default('')))|trim}) -%}
    {{- parent() -}}
{%- endblock %}
