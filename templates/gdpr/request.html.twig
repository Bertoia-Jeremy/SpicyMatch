{% extends 'base.html.twig' %}
{% block title %}{{ 'ui.gdpr.page_title'|trans }}{% endblock %}

{% block body %}
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <div class="lg:pt-4">
            <span class="tag-primary mb-4 inline-block">{{ 'ui.gdpr.tag'|trans }}</span>
            <h1 class="text-4xl font-bold text-stone-900 mb-4">{{ 'ui.gdpr.title'|trans }}</h1>
            <p class="text-stone-500 text-lg leading-relaxed mb-8">
                {{ 'ui.gdpr.intro'|trans }}
            </p>

            <div class="space-y-5">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-spice-surface flex items-center justify-center shrink-0 border border-spice-border">
                        <i class="fa-solid fa-scale-balanced text-saffron-600 text-sm" aria-hidden="true"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-stone-800 text-sm">{{ 'ui.gdpr.deadline'|trans }}</p>
                        <p class="text-stone-500 text-sm">{{ 'ui.gdpr.deadline_text'|trans }}</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-spice-surface flex items-center justify-center shrink-0 border border-spice-border">
                        <i class="fa-solid fa-id-card text-saffron-600 text-sm" aria-hidden="true"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-stone-800 text-sm">{{ 'ui.gdpr.identity'|trans }}</p>
                        <p class="text-stone-500 text-sm">{{ 'ui.gdpr.identity_text'|trans }}</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-spice-surface flex items-center justify-center shrink-0 border border-spice-border">
                        <i class="fa-solid fa-user-gear text-saffron-600 text-sm" aria-hidden="true"></i>
                    </div>
                    <div>
                        <p class="font-semibold text-stone-800 text-sm">{{ 'ui.gdpr.self_service'|trans }}</p>
                        <p class="text-stone-500 text-sm">{{ 'ui.gdpr.self_service_text'|trans }}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white border border-stone-200 rounded-2xl p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}
            <p class="text-xs text-stone-500">{{ 'ui.form.required_legend'|trans }}</p>

            <div>
                {{ form_label(form.email, 'form.gdpr.email'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_errors(form.email) }}
                {{ form_widget(form.email, {'attr': {'autocomplete': 'email', 'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors'}}) }}
                <p class="text-xs text-stone-500 mt-1">{{ 'form.gdpr.email_help'|trans }}</p>
            </div>

            <div>
                {{ form_label(form.requestType, 'form.gdpr.request_type'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_errors(form.requestType) }}
                {{ form_widget(form.requestType, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors bg-white'}}) }}
            </div>

            <div>
                {{ form_label(form.message, 'form.gdpr.message'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_errors(form.message) }}
                {{ form_widget(form.message, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 transition-colors', 'rows': 4}}) }}
            </div>

            <div>
                {{ form_errors(form.altcha) }}
                {% do form.altcha.setRendered() %}
                {% include 'components/_altcha.html.twig' with {name: field_name(form.altcha)} only %}
            </div>

            <p class="text-xs text-stone-500">{{ 'ui.gdpr.form_notice'|trans }}</p>

            <div>
                <twig:Button
                    label="{{ 'ui.gdpr.send'|trans }}"
                    type="submit"
                    variant="primary"
                    icon="fa-solid fa-paper-plane text-xs"
                />
            </div>

            {{ form_end(form) }}
        </div>

    </div>
</section>
{% endblock %}
