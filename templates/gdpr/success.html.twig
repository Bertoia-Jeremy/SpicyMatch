{% extends 'base.html.twig' %}
{% block title %}{{ 'ui.gdpr_success.page_title'|trans }}{% endblock %}

{% block body %}
<section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <div class="bg-white border border-stone-200 rounded-2xl p-10">
        <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-check text-green-600 text-2xl" aria-hidden="true"></i>
        </div>
        <h1 class="text-3xl font-bold text-stone-900 mb-3">{{ 'ui.gdpr_success.title'|trans }}</h1>
        <p class="text-stone-500 text-lg mb-8">{{ 'ui.gdpr_success.text'|trans }}</p>
        <twig:Button
            label="{{ 'ui.common.back_home'|trans }}"
            href="{{ path('home') }}"
            variant="primary"
            icon="fa-solid fa-house"
        />
    </div>
</section>
{% endblock %}
