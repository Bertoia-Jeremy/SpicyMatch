{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.help.eggs_page_title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-sm text-stone-500 mb-4">
        <a href="{{ path('help_index') }}" class="hover:text-saffron-600">{{ 'ui.help.back_to_help'|trans }}</a>
    </nav>

    <h1 class="text-3xl font-bold text-stone-800 mb-6">{{ 'ui.help.easter_eggs'|trans }}</h1>

    <section class="prose prose-stone max-w-none">
        <p>{{ 'ui.help.eggs_intro_html'|trans|raw }}</p>

        {{ 'ui.help.eggs_body_html'|trans|raw }}

        <p class="text-sm text-stone-500 italic mt-8">
            {{ 'ui.help.eggs_outro'|trans }}
        </p>
    </section>
</div>
{% endblock %}
