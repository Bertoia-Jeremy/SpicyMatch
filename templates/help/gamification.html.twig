{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.help.gamification_page_title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-sm text-stone-500 mb-4">
        <a href="{{ path('help_index') }}" class="hover:text-saffron-600">{{ 'ui.help.back_to_help'|trans }}</a>
    </nav>

    <h1 class="text-3xl font-bold text-stone-800 mb-6">{{ 'ui.help.gamification_h1'|trans }}</h1>

    <section class="prose prose-stone max-w-none mb-8">
        {{ 'ui.help.gamification_body_html'|trans|raw }}

        <h2>{{ 'ui.help.gamification_disable_h2'|trans }}</h2>
        <p>
            {{ 'ui.help.gamification_disable_html'|trans({'%url%': path('configuration_user')})|raw }}
        </p>
    </section>
</div>
{% endblock %}
