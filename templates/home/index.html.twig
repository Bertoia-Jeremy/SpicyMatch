{% extends 'base.html.twig' %}

{% block title %}SpicyMatch - Créez des mélanges d'épices parfaits{% endblock %}

{% block body %}

{# ===== HERO ===== #}
<section class="relative overflow-hidden bg-cream-dark min-h-[80vh] flex items-center">

    {# Texture papier kraft #}
    <div class="absolute inset-0 bg-noise opacity-20 pointer-events-none"></div>

    {# Halos ambiants (Tailwind uniquement) #}
    <div class="absolute top-1/4 right-1/3 w-96 h-96 rounded-full bg-saffron-500/10 blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-1/3 left-1/4 w-72 h-72 rounded-full bg-turmeric-400/10 blur-3xl pointer-events-none"></div>
    <div class="absolute top-1/2 right-1/4 w-48 h-48 rounded-full bg-saffron-600/8 blur-2xl pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            {# ── Gauche : Texte ── #}
            <div>
                {# Badge #}
                <div class="inline-flex items-center gap-2 bg-saffron-600/8 border border-saffron-600/20
                            text-saffron-700 text-xs font-semibold px-4 py-2 rounded-full mb-8 tracking-widest uppercase">
                    <i class="fa-solid fa-flask-vial text-saffron-600 text-xs"></i>
                    Moteur de compatibilité aromatique
                </div>

                <h1 class="font-display text-5xl lg:text-7xl font-bold text-stone-900 leading-tight mb-6">
                    Créez des<br>
                    mélanges<br>
                    <span class="italic text-saffron-700">parfaits.</span>
                </h1>

                <p class="text-lg text-stone-600 max-w-md leading-relaxed mb-10">
                    Découvrez les associations aromatiques entre les épices grâce à la science des composés.
                    Fini les mélanges au hasard.
                </p>

                <div class="flex flex-col sm:flex-row gap-3">
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('index_spicy_match') }}" class="btn-pill-primary" data-haptic="medium">
                            <i class="fa-solid fa-flask text-sm"></i>
                            Lancer un mélange
                        </a>
                        <a href="{{ path('index_spices') }}" class="btn-pill-outline" data-haptic="light">
                            Explorer les épices
                        </a>
                    {% else %}
                        <a href="{{ path('index_register') }}" class="btn-pill-primary" data-haptic="medium">
                            <i class="fa-solid fa-user-plus text-sm"></i>
                            Commencer gratuitement
                        </a>
                        <a href="{{ path('index_spices') }}" class="btn-pill-outline" data-haptic="light">
                            Explorer les épices
                        </a>
                    {% endif %}
                </div>

                {# Proof line #}
                <div class="flex items-center gap-3 mt-10 text-sm text-stone-500">
                    <div class="flex -space-x-2">
                        <div class="w-8 h-8 rounded-full bg-saffron-200 border-2 border-cream-dark
                                    flex items-center justify-center text-xs font-bold text-saffron-800">A</div>
                        <div class="w-8 h-8 rounded-full bg-turmeric-300 border-2 border-cream-dark
                                    flex items-center justify-center text-xs font-bold text-stone-800">B</div>
                        <div class="w-8 h-8 rounded-full bg-saffron-300 border-2 border-cream-dark
                                    flex items-center justify-center text-xs font-bold text-saffron-900">C</div>
                    </div>
                    <span>Des centaines de passionnés composent déjà</span>
                </div>
            </div>

            {# ── Droite : Composition visuelle ── #}
            <div class="hidden lg:flex items-center justify-center">
                <div class="relative w-[420px] h-[420px]">

                    {# Anneaux décoratifs #}
                    <div class="absolute inset-0 rounded-full border border-saffron-700/10"></div>
                    <div class="absolute inset-8 rounded-full border border-dashed border-saffron-700/10"></div>

                    {# Cercle central #}
                    <div class="absolute inset-16 rounded-full bg-saffron-600/5 border border-saffron-600/15
                                flex items-center justify-center">
                        <i class="fa-solid fa-mortar-pestle text-5xl text-saffron-700/40"></i>
                    </div>

                    {# Pills orbitales — utilise tag-primary / tag-secondary de app.scss #}
                    <div class="tag-primary absolute top-4 left-1/2 -translate-x-1/2 shadow-sm">
                        Curcuma
                    </div>
                    <div class="tag-primary absolute top-1/2 right-2 -translate-y-1/2 shadow-sm">
                        Gingembre
                    </div>
                    <div class="tag-secondary absolute bottom-4 left-1/2 -translate-x-1/2 shadow-sm">
                        Cardamome
                    </div>
                    <div class="tag-secondary absolute top-1/2 left-2 -translate-y-1/2 shadow-sm">
                        Cannelle
                    </div>
                    <div class="tag-primary absolute top-14 right-10 shadow-sm text-[11px]">
                        Poivre noir
                    </div>
                    <div class="tag-secondary absolute bottom-14 left-8 shadow-sm text-[11px]">
                        Anis étoilé
                    </div>

                    {# Carte score flottante #}
                    <div class="absolute -bottom-6 -right-6 bg-white rounded-2xl px-5 py-4
                                shadow-xl border border-spice-border">
                        <div class="font-display text-3xl font-bold text-saffron-700 leading-none">94%</div>
                        <div class="text-xs text-stone-500 mt-1">Score de compatibilité</div>
                    </div>

                    {# Badge associations #}
                    <div class="absolute -top-4 -left-4 bg-turmeric-400 rounded-xl px-4 py-2.5 shadow-lg">
                        <div class="text-xs font-bold text-stone-900 leading-none">+1 200</div>
                        <div class="text-xs text-stone-700 mt-0.5">associations</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{# ===== FEATURES (3 cartes) ===== #}
<section class="bg-[#FFF7ED] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <h2 class="text-3xl font-bold text-stone-800 mb-3">Tout ce qu'il vous faut pour composer</h2>
            <p class="text-stone-500 max-w-xl mx-auto">De la sélection d'épices à la recette finalisée, SpicyMatch vous guide à chaque étape.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-white rounded-xl shadow-sm p-8 border border-stone-100 text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-orange-100 rounded-full mb-5">
                    <i class="fa-solid fa-mortar-pestle text-2xl text-orange-600"></i>
                </div>
                <h3 class="text-xl font-bold text-stone-800 mb-3">Créez</h3>
                <p class="text-stone-500 text-sm leading-relaxed">Composez vos propres mélanges d'épices en quelques clics. L'algorithme trouve les épices compatibles grâce aux composés aromatiques communs.</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-8 border border-stone-100 text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-amber-100 rounded-full mb-5">
                    <i class="fa-solid fa-magnifying-glass text-2xl text-amber-600"></i>
                </div>
                <h3 class="text-xl font-bold text-stone-800 mb-3">Découvrez</h3>
                <p class="text-stone-500 text-sm leading-relaxed">Explorez une vaste bibliothèque d'épices, de composés aromatiques et de familles de saveurs. La science au service de votre cuisine.</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-8 border border-stone-100 text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-orange-100 rounded-full mb-5">
                    <i class="fa-solid fa-bookmark text-2xl text-orange-600"></i>
                </div>
                <h3 class="text-xl font-bold text-stone-800 mb-3">Sauvegardez</h3>
                <p class="text-stone-500 text-sm leading-relaxed">Enregistrez vos créations, choisissez les méthodes de préparation et les moments d'insertion. Votre carnet de recettes personnalisé.</p>
            </div>
        </div>
    </div>
</section>

{# ===== TEASER (aperçu pour non-connectés) ===== #}
{% if not is_granted('ROLE_USER') %}
<section class="bg-[#F9F5F0] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <h2 class="text-3xl font-bold text-stone-800 mb-3">Comment ça marche ?</h2>
            <p class="text-stone-500 max-w-xl mx-auto">Voici un aperçu d'un mélange typique. Créez un compte pour accéder à l'expérience complète.</p>
        </div>

        <div class="max-w-3xl mx-auto">
            {# Étape 1 : sélection #}
            <div class="mb-6">
                <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-3">
                    <i class="fa-solid fa-1 mr-1.5 text-orange-500"></i>Épices sélectionnées
                </p>
                <div class="flex flex-wrap gap-2">
                    <span class="inline-flex items-center gap-1.5 bg-orange-100 border border-orange-200 text-orange-800 text-sm font-medium px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-circle-check text-orange-500 text-xs"></i>Curcuma
                    </span>
                    <span class="inline-flex items-center gap-1.5 bg-orange-100 border border-orange-200 text-orange-800 text-sm font-medium px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-circle-check text-orange-500 text-xs"></i>Gingembre
                    </span>
                    <span class="inline-flex items-center gap-1.5 bg-orange-100 border border-orange-200 text-orange-800 text-sm font-medium px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-circle-check text-orange-500 text-xs"></i>Cardamome
                    </span>
                </div>
            </div>

            <div class="flex items-center gap-3 mb-6 text-stone-400">
                <div class="flex-1 border-t border-dashed border-stone-300"></div>
                <div class="flex items-center gap-1.5 text-xs font-medium text-stone-500">
                    <i class="fa-solid fa-angles-down text-orange-500"></i>
                    Composés aromatiques communs trouvés
                </div>
                <div class="flex-1 border-t border-dashed border-stone-300"></div>
            </div>

            {# Étape 2 : résultats visibles #}
            <div class="mb-4">
                <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-3">
                    <i class="fa-solid fa-2 mr-1.5 text-orange-500"></i>Épices compatibles
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">Poivre noir</p>
                        <p class="text-xs text-stone-400">Groupe : Épices piquantes</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">Cannelle</p>
                        <p class="text-xs text-stone-400">Groupe : Épices douces</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">Anis étoilé</p>
                        <p class="text-xs text-stone-400">Groupe : Épices anisées</p>
                    </div>
                </div>
            </div>

            {# Étape 3 : locked #}
            <div class="relative">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 blur-sm pointer-events-none select-none" aria-hidden="true">
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">█████████</p>
                        <p class="text-xs text-stone-400">Groupe : ██████████</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">████████</p>
                        <p class="text-xs text-stone-400">Groupe : █████████</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">███████████</p>
                        <p class="text-xs text-stone-400">Groupe : ███████</p>
                    </div>
                </div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="bg-white/90 backdrop-blur-sm border border-stone-200 rounded-xl px-6 py-4 text-center shadow-lg">
                        <i class="fa-solid fa-lock text-orange-500 text-xl mb-2 block"></i>
                        <p class="text-stone-700 text-sm font-medium mb-3">+ 8 autres épices compatibles</p>
                        <a href="{{ path('index_register') }}"
                           class="inline-flex items-center gap-1.5 bg-orange-600 hover:bg-orange-700 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors">
                            Créer un compte pour voir
                            <i class="fa-solid fa-arrow-right text-xs"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% else %}
{# CTA pour utilisateurs connectés #}
<section class="bg-[#F9F5F0] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-stone-800 mb-3">Prêt à composer un nouveau mélange ?</h2>
        <p class="text-stone-500 mb-8">Sélectionnez vos épices et laissez l'algorithme trouver les meilleures associations.</p>
        <a href="{{ path('index_spicy_match') }}"
           class="inline-flex items-center gap-2 bg-orange-600 hover:bg-orange-700 text-white px-8 py-3.5 rounded-lg text-lg font-semibold transition-colors shadow-lg">
            <i class="fa-solid fa-flask"></i>Lancer un mélange
        </a>
    </div>
</section>
{% endif %}

{% endblock %}
