{% extends 'base.html.twig' %}

{% block title %}SpicyMatch - Créez des mélanges d'épices parfaits{% endblock %}

{% block body %}


{# ===== HERO SECTION PREMIUM ===== #}
<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-cream py-20">
    
    {# Éléments de décor en arrière-plan #}
    <div class="absolute top-0 right-0 w-1/3 h-full bg-cream-dark/50 -skew-x-12 translate-x-1/4 pointer-events-none"></div>
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-saffron-500/10 rounded-full blur-[120px] pointer-events-none animate-pulse"></div>
    <div class="absolute bottom-1/4 left-1/4 w-64 h-64 bg-paprika-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
        <div class="grid grid-cols-12 gap-12 items-center">
            
            {# ── Côté Gauche : Contenu (cols 1-7) ── #}
            <div class="col-span-12 lg:col-span-7 space-y-12">
                
                {# Petit badge raffiné #}
                <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white border border-stone-100 shadow-sm">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-saffron-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-saffron-500"></span>
                    </span>
                    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-stone-500">Alchimie Culinaire Moderne</span>
                </div>

                {# Titre Imposant #}
                <h1 class="font-display text-7xl md:text-8xl lg:text-9xl font-bold leading-[0.85] tracking-tight text-stone-900">
                    L'art de<br>
                    l'accord <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-saffron-600 to-paprika-800 italic">
                        épicé.
                    </span>
                </h1>

                {# Description #}
                <p class="text-xl text-stone-600 max-w-xl leading-relaxed font-light">
                    Découvrez une approche scientifique et sensorielle pour créer des mélanges d'épices d'exception. 
                    <span class="font-medium text-stone-900">SpicyMatch</span> analyse les molécules aromatiques pour sublimer vos créations.
                </p>

                {# CTAs #}
                <div class="flex flex-wrap gap-6 pt-4">
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('index_spicy_match') }}" 
                           class="group relative inline-flex items-center gap-3 bg-paprika-900 text-cream px-10 py-5 rounded-full text-lg font-bold transition-all hover:bg-paprika-800 shadow-2xl shadow-paprika-900/30 hover:-translate-y-1">
                            <span>Lancer un mélange</span>
                            <i class="fa-solid fa-arrow-right text-sm transition-transform group-hover:translate-x-1"></i>
                        </a>
                        <a href="{{ path('index_spices') }}" 
                           class="inline-flex items-center gap-3 bg-white border border-stone-200 text-stone-800 px-10 py-5 rounded-full text-lg font-bold transition-all hover:bg-stone-50 hover:border-stone-300">
                            Explorer la bibliothèque
                        </a>
                    {% else %}
                        <a href="{{ path('index_register') }}" 
                           class="group relative inline-flex items-center gap-3 bg-paprika-900 text-cream px-10 py-5 rounded-full text-lg font-bold transition-all hover:bg-paprika-800 shadow-2xl shadow-paprika-900/30 hover:-translate-y-1">
                            <span>Commencer l'expérience</span>
                            <i class="fa-solid fa-sparkles text-saffron-400"></i>
                        </a>
                        <a href="{{ path('index_spices') }}" 
                           class="inline-flex items-center gap-3 bg-white border border-stone-200 text-stone-800 px-10 py-5 rounded-full text-lg font-bold transition-all hover:bg-stone-50 hover:border-stone-300">
                            Explorer les épices
                        </a>
                    {% endif %}
                </div>

                {# Chips de valeur #}
                <div class="flex flex-wrap items-center gap-3 pt-10 border-t border-stone-200/60">
                    <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-stone-100 rounded-full text-xs font-semibold text-stone-600 shadow-sm">
                        <i class="fa-solid fa-atom text-saffron-500"></i>Analyse moléculaire
                    </span>
                    <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-stone-100 rounded-full text-xs font-semibold text-stone-600 shadow-sm">
                        <i class="fa-solid fa-pepper-hot text-paprika-700"></i>120+ épices répertoriées
                    </span>
                    <span class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-stone-100 rounded-full text-xs font-semibold text-stone-600 shadow-sm">
                        <i class="fa-solid fa-bookmark text-turmeric-600"></i>Recettes personnalisées
                    </span>
                </div>
            </div>

            {# ── Côté Droit : Visuel Dynamique (cols 8-12) ── #}
            <div class="hidden md:col-span-5 md:flex flex-col items-center justify-center relative">
                
                {# Cercle décoratif principal avec effet de grain #}
                <div class="relative w-full aspect-square max-w-[500px] flex items-center justify-center">
                    
                    {# Orbes tournants (déco) #}
                    <div class="absolute inset-0 rounded-full border border-stone-200/60 scale-110 animate-[spin_20s_linear_infinite]"></div>
                    <div class="absolute inset-0 rounded-full border border-dashed border-saffron-500/20 scale-125"></div>
                    
                    {# Fond du visuel #}
                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-stone-100 to-cream-dark shadow-inner overflow-hidden border border-stone-200">
                        <div class="absolute inset-0 bg-noise opacity-[0.03]"></div>
                        
                        {# Motif abstrait (Alchimie) #}
                        <div class="absolute inset-0 flex items-center justify-center opacity-10">
                            <i class="fa-solid fa-atom text-[300px] rotate-12"></i>
                        </div>
                    </div>

                    {# Contenu central : Mortier stylisé #}
                    <div class="relative z-20 flex flex-col items-center group">
                        <div class="w-48 h-48 bg-white rounded-full shadow-2xl flex items-center justify-center border border-stone-100 transition-transform group-hover:scale-105 duration-500">
                            <i class="fa-solid fa-mortar-pestle text-7xl text-paprika-900"></i>
                        </div>
                        
                        {# Tags flottants #}
                        <div class="absolute -top-12 -right-8 bg-saffron-500 text-white px-5 py-2 rounded-full text-xs font-bold shadow-xl shadow-saffron-500/20 rotate-12">
                            Curcumine
                        </div>
                        <div class="absolute top-1/2 -left-16 bg-white border border-stone-100 text-stone-800 px-5 py-2 rounded-full text-xs font-bold shadow-xl -rotate-6">
                            Pipérine
                        </div>
                        <div class="absolute -bottom-6 right-10 bg-paprika-800 text-white px-5 py-2 rounded-full text-xs font-bold shadow-xl shadow-paprika-900/20 -rotate-3">
                            Capsaïcine
                        </div>
                    </div>

                    {# Carte de score flottante #}
                    <div class="absolute bottom-10 -left-10 bg-white/80 backdrop-blur-md border border-stone-200 rounded-2xl p-6 shadow-2xl animate-bounce-slow">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-full bg-turmeric-300/20 flex items-center justify-center text-turmeric-700">
                                <i class="fa-solid fa-check-double text-xl"></i>
                            </div>
                            <div>
                                <div class="text-sm font-bold text-stone-400 uppercase tracking-tighter">Accord Parfait</div>
                                <div class="text-3xl font-display font-bold text-stone-900 leading-none">98%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


{# ===== FEATURES (3 cartes) ===== #}
<section class="bg-[#FFF7ED] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <h2 class="text-3xl font-bold text-stone-800 mb-3">Tout ce qu'il vous faut pour composer</h2>
            <p class="text-stone-500 max-w-xl mx-auto">De la sélection d'épices à la recette finalisée, SpicyMatch vous guide à chaque étape.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-white rounded-xl shadow-sm p-8 border border-stone-100 text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-spice-surface rounded-full mb-5 border border-spice-border">
                    <i class="fa-solid fa-mortar-pestle text-2xl text-saffron-600"></i>
                </div>
                <h3 class="text-xl font-bold text-stone-800 mb-3">Créez</h3>
                <p class="text-stone-500 text-sm leading-relaxed">Composez vos propres mélanges d'épices en quelques clics. L'algorithme trouve les épices compatibles grâce aux composés aromatiques communs.</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-8 border border-stone-100 text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-turmeric-300/20 rounded-full mb-5 border border-turmeric-400/30">
                    <i class="fa-solid fa-magnifying-glass text-2xl text-turmeric-600"></i>
                </div>
                <h3 class="text-xl font-bold text-stone-800 mb-3">Découvrez</h3>
                <p class="text-stone-500 text-sm leading-relaxed">Explorez une vaste bibliothèque d'épices, de composés aromatiques et de familles de saveurs. La science au service de votre cuisine.</p>
            </div>
            <div class="bg-white rounded-xl shadow-sm p-8 border border-stone-100 text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-spice-surface rounded-full mb-5 border border-spice-border">
                    <i class="fa-solid fa-bookmark text-2xl text-saffron-600"></i>
                </div>
                <h3 class="text-xl font-bold text-stone-800 mb-3">Sauvegardez</h3>
                <p class="text-stone-500 text-sm leading-relaxed">Enregistrez vos créations, choisissez les méthodes de préparation et les moments d'insertion. Votre carnet de recettes personnalisé.</p>
            </div>
        </div>
    </div>
</section>

{# ===== TEASER (aperçu pour non-connectés) ===== #}
{% if not is_granted('ROLE_USER') %}
<section class="bg-[#F9F5F0] py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <h2 class="text-3xl font-bold text-stone-800 mb-3">Comment ça marche ?</h2>
            <p class="text-stone-500 max-w-xl mx-auto">Voici un aperçu d'un mélange typique. Créez un compte pour accéder à l'expérience complète.</p>
        </div>

        <div class="max-w-3xl mx-auto">
            {# Étape 1 : sélection #}
            <div class="mb-6">
                <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-3">
                    <i class="fa-solid fa-1 mr-1.5 text-saffron-500"></i>Épices sélectionnées
                </p>
                <div class="flex flex-wrap gap-2">
                    <span class="inline-flex items-center gap-1.5 bg-spice-surface border border-spice-border text-stone-800 text-sm font-medium px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-circle-check text-saffron-500 text-xs"></i>Curcuma
                    </span>
                    <span class="inline-flex items-center gap-1.5 bg-spice-surface border border-spice-border text-stone-800 text-sm font-medium px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-circle-check text-saffron-500 text-xs"></i>Gingembre
                    </span>
                    <span class="inline-flex items-center gap-1.5 bg-spice-surface border border-spice-border text-stone-800 text-sm font-medium px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-circle-check text-saffron-500 text-xs"></i>Cardamome
                    </span>
                </div>
            </div>

            <div class="flex items-center gap-3 mb-6 text-stone-400">
                <div class="flex-1 border-t border-dashed border-stone-300"></div>
                <div class="flex items-center gap-1.5 text-xs font-medium text-stone-500">
                    <i class="fa-solid fa-angles-down text-saffron-500"></i>
                    Composés aromatiques communs trouvés
                </div>
                <div class="flex-1 border-t border-dashed border-stone-300"></div>
            </div>

            {# Étape 2 : résultats visibles #}
            <div class="mb-4">
                <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-3">
                    <i class="fa-solid fa-2 mr-1.5 text-saffron-500"></i>Épices compatibles
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">Poivre noir</p>
                        <p class="text-xs text-stone-400">Groupe : Épices piquantes</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">Cannelle</p>
                        <p class="text-xs text-stone-400">Groupe : Épices douces</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">Anis étoilé</p>
                        <p class="text-xs text-stone-400">Groupe : Épices anisées</p>
                    </div>
                </div>
            </div>

            {# Étape 3 : locked #}
            <div class="relative">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 blur-sm pointer-events-none select-none" aria-hidden="true">
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">█████████</p>
                        <p class="text-xs text-stone-400">Groupe : ██████████</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">████████</p>
                        <p class="text-xs text-stone-400">Groupe : █████████</p>
                    </div>
                    <div class="bg-white border border-stone-200 rounded-xl p-4 shadow-sm">
                        <p class="font-semibold text-stone-800 text-sm mb-1">███████████</p>
                        <p class="text-xs text-stone-400">Groupe : ███████</p>
                    </div>
                </div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="bg-white/90 backdrop-blur-sm border border-stone-200 rounded-xl px-6 py-4 text-center shadow-lg">
                        <i class="fa-solid fa-lock text-saffron-500 text-xl mb-2 block"></i>
                        <p class="text-stone-700 text-sm font-medium mb-3">+ 8 autres épices compatibles</p>
                        <a href="{{ path('index_register') }}"
                           class="inline-flex items-center gap-1.5 bg-paprika-900 hover:bg-paprika-800 text-cream text-sm font-semibold px-5 py-2.5 rounded-full transition-colors">
                            Créer un compte pour voir
                            <i class="fa-solid fa-arrow-right text-xs"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% else %}
{# CTA pour utilisateurs connectés #}
<section class="bg-[#F9F5F0] py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-stone-800 mb-3">Prêt à composer un nouveau mélange ?</h2>
        <p class="text-stone-500 mb-8">Sélectionnez vos épices et laissez l'algorithme trouver les meilleures associations.</p>
        <a href="{{ path('index_spicy_match') }}"
           class="inline-flex items-center gap-2 bg-paprika-900 hover:bg-paprika-800 text-cream px-8 py-3.5 rounded-full text-lg font-semibold transition-colors shadow-lg shadow-paprika-900/20">
            <i class="fa-solid fa-flask"></i>Lancer un mélange
        </a>
    </div>
</section>
{% endif %}

{% endblock %}
