{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.legal.notice.title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-stone-800 mb-6">{{ 'ui.legal.notice.title'|trans }}</h1>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.notice.publisher_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.notice.publisher_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.notice.director_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.notice.director_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.notice.host_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.notice.host_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.notice.contact_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">
            {{ 'ui.legal.notice.contact_text'|trans }}
            <a href="{{ path('new_contact') }}" class="text-saffron-800 hover:text-saffron-700 font-medium underline">{{ 'ui.common.contact'|trans }}</a>.
        </p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.notice.ip_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.notice.ip_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.notice.liability_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.notice.liability_text'|trans }}</p>
    </section>

    <p class="text-sm text-stone-600">{{ 'ui.legal.notice.privacy_link_text'|trans }}
        <a href="{{ path('privacy_policy') }}" class="text-saffron-800 hover:text-saffron-700 font-medium underline">{{ 'ui.legal.privacy.title'|trans }}</a>.
    </p>
</div>
{% endblock %}
