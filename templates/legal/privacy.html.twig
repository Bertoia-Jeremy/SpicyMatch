{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.legal.privacy.title'|trans }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-stone-800 mb-6">{{ 'ui.legal.privacy.title'|trans }}</h1>

    <p class="text-stone-700 leading-relaxed mb-8">{{ 'ui.legal.privacy.intro'|trans }}</p>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.controller_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.privacy.controller_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.data_title'|trans }}</h2>
        <ul class="list-disc pl-6 text-stone-700 leading-relaxed space-y-2">
            <li>{{ 'ui.legal.privacy.data_account'|trans }}</li>
            <li>{{ 'ui.legal.privacy.data_contact'|trans }}</li>
            <li>{{ 'ui.legal.privacy.data_newsletter'|trans }}</li>
            <li>{{ 'ui.legal.privacy.data_consent'|trans }}</li>
            <li>{{ 'ui.legal.privacy.data_monitoring'|trans }}</li>
        </ul>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.purposes_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.privacy.purposes_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.ads_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.privacy.ads_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.retention_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.privacy.retention_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.cookies_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.privacy.cookies_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.rights_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.privacy.rights_text'|trans }}</p>
    </section>

    <section class="mb-8">
        <h2 class="text-xl font-semibold text-stone-800 mb-3">{{ 'ui.legal.privacy.complaint_title'|trans }}</h2>
        <p class="text-stone-700 leading-relaxed">{{ 'ui.legal.privacy.complaint_text'|trans }}</p>
    </section>

    <p class="text-sm text-stone-600">{{ 'ui.legal.privacy.updated_text'|trans }}</p>
</div>
{% endblock %}
