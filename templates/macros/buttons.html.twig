{# templates/macros/buttons.html.twig #}

{% macro button(label, options = {}) %}
    {# Choix du tag : a si href est présent, sinon button #}
    {% set tag = options.href is defined ? 'a' : 'button' %}
    
    {# Configuration des variantes #}
    {% set variants = {
        'primary': 'btn-pill-primary',
        'outline': 'btn-pill-outline',
        'paprika': 'btn-pill-base bg-paprika-100 text-paprika-800 hover:bg-paprika-200',
        'turmeric': 'btn-pill-base bg-turmeric-100 text-turmeric-800 hover:bg-turmeric-200',
        'ghost': 'btn-pill-base bg-transparent text-stone-600 hover:bg-stone-100 border-transparent',
        'danger': 'btn-pill-base bg-red-100 text-red-700 hover:bg-red-200',
        'white': 'btn-pill-base bg-white text-stone-900 hover:bg-stone-50 border-spice-border'
    } %}

    {# Tailles personnalisées #}
    {% set sizes = {
        'xs': 'px-2.5 py-0.5 text-xs gap-1.5',
        'sm': 'px-3.5 py-1 text-sm gap-2',
        'md': 'px-5 py-2 text-sm gap-2',
        'lg': 'px-7 py-3 text-base gap-2.5',
        'xl': 'px-9 py-4 text-lg gap-3'
    } %}

    {# Extraction des options #}
    {% set variant = options.variant|default('primary') %}
    {% set size = options.size|default('md') %}
    {% set icon = options.icon|default(null) %}
    {% set icon_pos = options.icon_pos|default('left') %}
    {% set attr = options.attr|default([]) %}

    {# Construction des classes finales #}
    {# On retire le padding par défaut si une taille spécifique est demandée, mais ici on gère via l'ordre des classes #}
    {% set final_class = [
        variants[variant]|default(variants.primary),
        sizes[size]|default(''),
        'shadow-lg font-bold px-10'
    ]|join(' ')|trim %}

    <{{ tag }}
        {% if tag == 'a' %}
            href="{{ options.href }}"
        {% else %}
            type="{{ options.type|default('button') }}"
        {% endif %}
        class="{{ final_class }}"
        {% for name, value in attr %}
            {{ name }}="{{ value }}"
        {% endfor %}
    >
        {% if icon and icon_pos == 'left' %}
            {{ _self.render_icon(icon) }}
        {% endif %}

        {% if label %}
            <span>{{ label }}</span>
        {% endif %}

        {% if icon and icon_pos == 'right' %}
            {{ _self.render_icon(icon) }}
        {% endif %}
    </{{ tag }}>
{% endmacro %}

{# Macro interne pour le rendu des icônes (FontAwesome ou SVG) #}
{% macro render_icon(icon) %}
    {% if '<svg' in icon %}
        <span class="w-4 h-4 flex items-center justify-center shrink-0">
            {{ icon|raw }}
        </span>
    {% else %}
        <i class="{{ icon }} flex items-center justify-center shrink-0" aria-hidden="true"></i>
    {% endif %}
{% endmacro %}
