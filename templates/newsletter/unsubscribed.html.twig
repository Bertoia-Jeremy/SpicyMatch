{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.newsletter.unsub_title'|trans }}{% endblock %}

{% block body %}
    <div class="max-w-lg mx-auto px-4 py-24 text-center">
        <div class="bg-white border border-spice-border rounded-2xl shadow-sm p-8">
            <div class="w-16 h-16 mx-auto mb-6 bg-saffron-100 rounded-full flex items-center justify-center">
                <i class="fa-solid fa-envelope-open text-2xl text-saffron-600" aria-hidden="true"></i>
            </div>

            <h1 class="text-2xl font-display font-semibold text-stone-800 mb-3">{{ 'ui.newsletter.unsub_confirmed'|trans }}</h1>

            <p class="text-stone-600 mb-6">
                {{ 'ui.newsletter.unsub_text_html'|trans({'%email%': email})|raw }}
            </p>

            <p class="text-sm text-stone-500 mb-6">
                {{ 'ui.newsletter.unsub_changed_mind'|trans }}
            </p>

            <a href="{{ path('app_home') }}" class="btn-pill-primary">
                {{ 'ui.common.back_home'|trans }}
            </a>
        </div>
    </div>
{% endblock %}
