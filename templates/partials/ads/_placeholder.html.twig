        <i class="fa-solid fa-mortar-pestle text-3xl" aria-hidden="true"></i>
    </div>
    <div class="min-w-0 flex-1">
        <p class="font-semibold text-stone-800 text-base">{{ 'ui.ads.placeholder_title'|trans }}</p>
        <p class="text-stone-500 text-sm mt-1 leading-snug">{{ 'ui.ads.placeholder_body'|trans }}</p>
        <div class="mt-3 flex items-center gap-3 flex-wrap">
            <span class="inline-flex items-center rounded-full bg-saffron-600 text-white text-xs font-medium px-4 py-1.5">{{ 'ui.ads.placeholder_cta'|trans }}</span>
            <span class="font-mono text-[10px] uppercase tracking-widest text-stone-400">{{ 'ui.ads.placeholder_sponsor'|trans }}</span>
        </div>
