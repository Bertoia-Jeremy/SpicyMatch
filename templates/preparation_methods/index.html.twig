{% extends 'base.html.twig' %}

{% block title %}Méthodes de préparation{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8">
        <h1 class="text-4xl font-bold text-gray-800 text-center mb-8">Méthodes de préparation</h1>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for preparation_method in preparation_methods %}
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-2xl font-semibold text-gray-800 mb-2">{{ preparation_method.name }}</h2>
                    <p class="text-gray-600 mb-4">{{ preparation_method.description|nl2br }}</p>
                    <a href="{{ path('view_preparation_methods', {'id': preparation_method.id}) }}" class="inline-block px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700">Voir les détails</a>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
