{% extends 'base.html.twig' %}
{% block title %}Méthode de préparation - Présentation{% endblock %}

{% block body %}
    <turbo-frame id="preparation_methode_frame_id">
        <div class="container mx-auto px-4 py-8">
            <div class="text-center mb-8">
                <h1 class="text-4xl font-bold text-gray-800">{{ preparationMethod.name }}</h1>
                <p class="mt-4 text-lg text-gray-600">{{ preparationMethod.description }}</p>
            </div>

            <div class="bg-white shadow-md rounded-lg p-6">
                <h2 class="text-2xl font-bold text-gray-800 mb-4">Conseils d'utilisation</h2>
                <p class="text-gray-700">{{ preparationMethod.name }}</p>
                <p class="text-gray-700 mt-2">{{ preparationMethod.description }}</p>
            </div>
        </div>
    </turbo-frame>
{% endblock %}

