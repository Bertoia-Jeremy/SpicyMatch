{% extends 'base.html.twig' %}

{% block title %}Création de compte{% endblock %}

{% block body %}
<div class="flex flex-col items-center justify-center min-h-screen bg-gray-100">
    <div class="w-full max-w-md p-8 space-y-6 bg-white rounded-lg shadow-md">
        <h2 class="text-3xl font-bold text-center text-gray-800">Création de compte</h2>
        {{ form_start(form, {
            'attr': {'class': 'space-y-6'}
        }) }}

        <div>
            {{ form_label(form.username, 'Pseudo', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.username, {'attr': {'class': 'w-full px-4 py-2 mt-1 border rounded-md focus:outline-none focus:ring-1 focus:ring-blue-600'}}) }}
        </div>

        <div>
            {{ form_label(form.mail, 'Email (facultatif mais utile pour récupérer ton mot de passe)', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.mail, {'attr': {'class': 'w-full px-4 py-2 mt-1 border rounded-md focus:outline-none focus:ring-1 focus:ring-blue-600'}}) }}
        </div>

        <div>
            {{ form_label(form.plainPassword, 'Mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
            {{ form_widget(form.plainPassword, {'attr': {'class': 'w-full px-4 py-2 mt-1 border rounded-md focus:outline-none focus:ring-1 focus:ring-blue-600'}}) }}
        </div>

        <div>
            {{ form_widget(form.Valider, {
                'label': 'Créer mon compte',
                'attr': {'class': 'w-full px-4 py-2 text-white bg-blue-600 rounded-md hover:bg-blue-700'}
            }) }}
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
