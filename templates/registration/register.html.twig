{% extends 'base.html.twig' %}

{% import 'macros/buttons.html.twig' as buttons %}

{% block title %}{{ 'ui.register.page_title'|trans }}{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[calc(100vh-4rem)] bg-cream-dark py-12 px-4">
    <div class="w-full max-w-md">
        <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-8 space-y-6">
            <div class="text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-spice-surface rounded-full mb-4 border border-spice-border">
                    <i class="fa-solid fa-user-plus text-2xl text-saffron-600"></i>
                </div>
                <h2 class="text-3xl font-bold text-stone-800">{{ 'ui.register.title'|trans }}</h2>
                <p class="text-stone-500 text-sm mt-1">{{ 'ui.register.subtitle'|trans }}</p>
            </div>

            {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}

            {% if form.vars.errors|length > 0 %}
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg text-sm">
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            <div>
                {{ form_label(form.username, 'ui.register.username'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.username, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 bg-white text-stone-800'}}) }}
                {{ form_errors(form.username) }}
            </div>

            <div>
                {{ form_label(form.mail, 'ui.register.mail'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                {{ form_widget(form.mail, {'attr': {'class': 'w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 bg-white text-stone-800'}}) }}
                {{ form_errors(form.mail) }}
            </div>

            <div>
                {{ form_label(form.plainPassword, 'ui.register.password'|trans, {'label_attr': {'class': 'block text-sm font-medium text-stone-700 mb-1'}}) }}
                <div class="relative" x-data="passwordVisibility">
                    {{ form_widget(form.plainPassword, {'attr': {
                        ':type': 'inputType()',
                        'class': 'w-full px-4 py-2.5 pr-24 border border-stone-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 bg-white text-stone-800'
                    }}) }}
                    <button type="button" @click="show = !show"
                            aria-label="{{ 'ui.register.toggle_visibility'|trans }}"
                            class="absolute inset-y-0 right-0 px-3 flex items-center text-sm text-stone-500 hover:text-stone-700">
                        <span x-text="label()">{{ 'password.show'|trans({}, 'js') }}</span>
                    </button>
                </div>
                {{ form_errors(form.plainPassword) }}
            </div>

            <div>
                {{ buttons.button('ui.register.submit'|trans, {
                    variant: 'primary',
                    type: 'submit',
                    attr: {
                        'name': form.Valider.vars.full_name,
                        'class': 'w-full justify-center cursor-pointer py-3'
                    }
                }) }}
            </div>

            {{ form_end(form) }}

            <p class="text-center text-sm text-stone-500">
                {{ 'ui.register.already_account'|trans }} <a href="{{ path('app_login') }}" class="text-saffron-700 hover:text-saffron-600 font-medium">{{ 'ui.register.sign_in'|trans }}</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
