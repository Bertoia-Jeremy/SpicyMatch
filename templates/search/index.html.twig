{% extends 'base.html.twig' %}

{% block title %}Recherche{% if query %} — {{ query }}{% endif %} — SpicyMatch{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    {# En-tête #}
    <div class="mb-10">
        <h1 class="text-3xl font-bold text-stone-900 mb-6">
            <i class="fa-solid fa-magnifying-glass text-saffron-600 mr-2"></i>Recherche
        </h1>

        {# Barre de recherche pleine page #}
        <form action="{{ path('search_results') }}" method="GET" class="flex gap-3">
            <input
                type="text"
                name="q"
                value="{{ query }}"
                placeholder="Épice, composé aromatique..."
                autofocus
                class="flex-1 px-5 py-3 border border-spice-border rounded-full bg-white text-stone-700
                       placeholder-stone-400 text-base
                       focus:outline-none focus:ring-2 focus:ring-saffron-600/30 focus:border-saffron-600/40
                       transition-colors shadow-sm"
            >
            <button type="submit"
                    class="btn-pill-primary px-6 py-3">
                Rechercher
            </button>
        </form>
    </div>

    {% if query is not empty %}
        {% if results is not empty %}
            {# Résultats #}
            <p class="text-sm text-stone-400 mb-6">
                {{ results|length }} résultat{{ results|length > 1 ? 's' : '' }} pour
                <span class="text-stone-700 font-medium">« {{ query }} »</span>
            </p>

            {# Séparer épices et composés #}
            {% set spiceResults = results|filter(r => r.type == 'spice') %}
            {% set compoundResults = results|filter(r => r.type == 'aromatic_compound') %}

            {% if spiceResults is not empty %}
                <section class="mb-10">
                    <h2 class="text-sm font-bold text-stone-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-pepper-hot text-paprika-700"></i> Épices
                    </h2>
                    <div class="space-y-2">
                        {% for result in spiceResults %}
                            <a href="{{ path('view_spice', {id: result.id}) }}"
                               class="flex items-center gap-3 px-5 py-3.5 bg-white border border-stone-200 rounded-xl hover:border-saffron-400/60 hover:shadow-sm transition-all group">
                                <i class="fa-solid fa-leaf text-saffron-500 text-sm shrink-0"></i>
                                <span class="font-medium text-stone-800 group-hover:text-saffron-700 transition-colors">{{ result.name }}</span>
                                <span class="ml-auto text-xs text-saffron-600 bg-saffron-50 border border-saffron-200 px-2 py-0.5 rounded-full">Épice</span>
                            </a>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if compoundResults is not empty %}
                <section>
                    <h2 class="text-sm font-bold text-stone-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-atom text-turmeric-500"></i> Composés aromatiques
                    </h2>
                    <div class="space-y-2">
                        {% for result in compoundResults %}
                            <a href="{{ path('view_aromatic_compound', {id: result.id}) }}"
                               class="flex items-center gap-3 px-5 py-3.5 bg-white border border-stone-200 rounded-xl hover:border-turmeric-400/60 hover:shadow-sm transition-all group">
                                <i class="fa-solid fa-atom text-turmeric-500 text-sm shrink-0"></i>
                                <span class="font-medium text-stone-800 group-hover:text-turmeric-700 transition-colors">{{ result.name }}</span>
                                <span class="ml-auto text-xs text-turmeric-600 bg-turmeric-50 border border-turmeric-200 px-2 py-0.5 rounded-full">Composé</span>
                            </a>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

        {% else %}
            {# Aucun résultat #}
            <div class="text-center py-16">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-stone-100 mb-5">
                    <i class="fa-solid fa-magnifying-glass text-stone-300 text-2xl"></i>
                </div>
                <h2 class="text-xl font-semibold text-stone-700 mb-2">Aucun résultat</h2>
                <p class="text-stone-400 mb-1">
                    Aucune épice ni composé aromatique ne correspond à
                    <span class="text-stone-600 font-medium">« {{ query }} »</span>.
                </p>
                <p class="text-stone-400 text-sm">Essayez un autre terme ou vérifiez l'orthographe.</p>
            </div>
        {% endif %}

    {% else %}
        {# Pas encore de recherche #}
        <div class="text-center py-16">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-saffron-50 border border-saffron-200 mb-5">
                <i class="fa-solid fa-magnifying-glass text-saffron-500 text-2xl"></i>
            </div>
            <p class="text-stone-500">Saisissez un terme pour explorer épices et composés aromatiques.</p>
        </div>
    {% endif %}

</div>
{% endblock %}
