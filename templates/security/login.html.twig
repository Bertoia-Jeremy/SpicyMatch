{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.auth.login_title'|trans }}{% endblock %}

{% block body %}
<div class="flex min-h-[calc(100vh-4rem)]">
    <div class="w-1/2 hidden md:block">
        <img src="{{ asset('images/login.png') }}" alt="" class="w-full h-full object-cover" loading="lazy" decoding="async">
    </div>
    <div class="w-full md:w-1/2 flex justify-center items-center bg-cream-dark">
        <div class="w-full max-w-md p-8">

            <twig:Button label="{{ 'ui.common.back_home'|trans }}" href="{{ path('home') }}" variant="back" size="sm" extra="mb-8" />

            <div class="text-center mb-8">
                <div class="inline-flex items-center gap-2 mb-5 no-underline">
                    <div class="w-9 h-9 bg-paprika-900 flex items-center justify-center rounded-lg shadow-sm">
                        <i class="fa-solid fa-mortar-pestle text-cream text-sm" aria-hidden="true"></i>
                    </div>
                    <span class="font-display text-2xl font-bold tracking-tight text-paprika-900">Spicy<span class="text-saffron-700 italic">Match</span></span>
                </div>
                <h1 class="text-3xl font-bold text-stone-800">{{ 'ui.auth.login_title'|trans }}</h1>
                <p class="text-stone-600 mt-2 text-sm">
                    <a href="{{ path('index_register') }}" class="text-saffron-800 hover:text-saffron-700 font-medium">{{ 'ui.auth.no_account'|trans }}</a>
                </p>
            </div>

            <form action="{{ path('app_login') }}" method="post" class="space-y-5">
                <p class="text-xs text-stone-600">{{ 'ui.form.required_legend'|trans }}</p>
                <div>
                    <label for="username" class="block text-sm font-medium text-stone-700 mb-1">{{ 'ui.auth.username'|trans }}<span aria-hidden="true" class="text-red-600"> *</span></label>
                    <input type="text" id="username" name="username" value="{{ last_username }}" autocomplete="username"
                           class="w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 bg-white text-stone-800"
                           required autofocus>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-stone-700 mb-1">{{ 'ui.auth.password'|trans }}<span aria-hidden="true" class="text-red-600"> *</span></label>
                    <div class="relative" x-data="passwordVisibility">
                        <input :type="inputType()" id="password" name="password" autocomplete="current-password"
                               class="w-full px-4 py-2.5 pr-24 border border-stone-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 bg-white text-stone-800"
                               required>
                        <button type="button" @click="show = !show"
                                class="absolute inset-y-0 right-0 px-3 flex items-center text-sm text-stone-600 hover:text-stone-700">
                            <span x-text="label()">{{ 'password.show'|trans({}, 'js') }}</span>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <input type="hidden" name="_target_path" value="{{ path('home') }}">

                {% if error is not empty %}
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg text-sm" role="alert">
                        <i class="fa-solid fa-triangle-exclamation mr-1.5" aria-hidden="true"></i>{{ 'ui.auth.bad_credentials'|trans }}
                    </div>
                {% endif %}

                <twig:Button
                    label="{{ 'ui.auth.login_cta'|trans }}"
                    type="submit"
                    variant="primary"
                    icon="fa-solid fa-right-to-bracket text-xs"
                />
            </form>
        </div>
    </div>
</div>
{% endblock %}
