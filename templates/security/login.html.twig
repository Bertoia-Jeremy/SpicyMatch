{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="flex min-h-[calc(100vh-4rem)]">
    <div class="w-1/2 hidden md:block">
        <img src="{{ asset('assets/images/login.png') }}" alt="Épices" class="w-full h-full object-cover">
    </div>
    <div class="w-full md:w-1/2 flex justify-center items-center bg-cream-dark">
        <div class="w-full max-w-md p-8">

            <a href="{{ path('home') }}" class="inline-flex items-center gap-1.5 text-stone-600 hover:text-stone-800 text-xs mb-8 transition-colors no-underline">
                <i class="fa-solid fa-arrow-left text-[10px]"></i>Retour à l'accueil
            </a>

            <div class="text-center mb-8">
                <div class="inline-flex items-center gap-2 mb-5 no-underline">
                    <div class="w-9 h-9 bg-paprika-900 flex items-center justify-center rounded-lg shadow-sm">
                        <i class="fa-solid fa-mortar-pestle text-cream text-sm"></i>
                    </div>
                    <span class="font-display text-2xl font-bold tracking-tight text-paprika-900">Spicy<span class="text-saffron-600 italic">Match</span></span>
                </div>
                <h2 class="text-3xl font-bold text-stone-800">Connexion</h2>
                <p class="text-stone-500 mt-2 text-sm">
                    <a href="{{ path('index_register') }}" class="text-saffron-700 hover:text-saffron-600 font-medium">Pas de compte ? En créer un (même pas besoin de mail !)</a>
                </p>
            </div>

            <form action="{{ path('app_login') }}" method="post" class="space-y-5">
                <div>
                    <label for="username" class="block text-sm font-medium text-stone-700 mb-1">Pseudo</label>
                    <input type="text" id="username" name="username" value="{{ last_username }}"
                           class="w-full px-4 py-2.5 border border-stone-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 bg-white text-stone-800"
                           required autofocus>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-stone-700 mb-1">Mot de passe</label>
                    <div class="relative" x-data="passwordVisibility">
                        <input :type="show ? 'text' : 'password'" id="password" name="password"
                               class="w-full px-4 py-2.5 pr-24 border border-stone-300 rounded-lg focus:outline-none focus:ring-1 focus:ring-saffron-600/30 focus:border-saffron-500 bg-white text-stone-800"
                               required>
                        <button type="button" @click="show = !show"
                                class="absolute inset-y-0 right-0 px-3 flex items-center text-sm text-stone-500 hover:text-stone-700">
                            <span x-text="show ? 'Masquer' : 'Afficher'">Afficher</span>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <input type="hidden" name="_target_path" value="{{ path('home') }}">

                {% if error is not empty %}
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg text-sm" role="alert">
                        <i class="fa-solid fa-triangle-exclamation mr-1.5"></i>Identifiants incorrects.
                    </div>
                {% endif %}

                {% import 'macros/buttons.html.twig' as buttons %}
                {{ buttons.button('Se connecter', {
                    type: 'submit',
                    variant: 'primary',
                    class: 'w-full justify-center py-4 mt-2',
                    icon: 'fa-solid fa-right-to-bracket text-xs'
                }) }}
            </form>
        </div>
    </div>
</div>
{% endblock %}
