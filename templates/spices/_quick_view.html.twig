<turbo-frame id="spice_quick_view">
    {% set loc = app.request.locale %}
    {% set color = spice.aromaticGroups ? spice.aromaticGroups.color : '#78716C' %}
    {% set groupName = spice.aromaticGroups ? spice.aromaticGroups.getLocalizedName(loc) : null %}
    {% set typeName = spice.spicyType ? spice.spicyType.name : null %}
    {% set spiceName = spice.getLocalizedName(loc) %}
    {% set imageUrl = vich_uploader_asset(spice, 'imageFile') %}

    {# Grille 2 colonnes : image | contenu — footer col-span-2 #}
    <div class="grid sm:grid-cols-[300px_1fr]">

        {# ── Col 1 : Image ── #}
        <div class="relative min-h-[220px] sm:min-h-[400px]"
             style="background: linear-gradient(135deg, {{ color }}33, {{ color }}11)">
            {% if imageUrl %}
                <img src="{{ imageUrl|imagine_filter('spice_hero') }}" alt="{{ spiceName }}"
                     decoding="async" width="800" height="800"
                     class="absolute inset-0 w-full h-full object-cover">
            {% else %}
                <span class="absolute inset-0 flex items-center justify-center" aria-hidden="true"
                      style="color: {{ color }}66">
                    <i class="fa-solid fa-seedling text-6xl"></i>
                </span>
            {% endif %}
            {# Gradient overlay bas #}
            <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/25 pointer-events-none"></div>
        </div>

        {# ── Col 2 : Contenu scrollable ── #}
        <div class="overflow-y-auto sm:max-h-[calc(90vh-57px)] p-7 flex flex-col gap-5
                    scrollbar-thin scrollbar-thumb-spice-border scrollbar-track-transparent">

            {# Eyebrow mono : groupe · type #}
            {% if groupName or typeName %}
                <div class="flex items-center gap-2 font-mono text-[10.5px] tracking-[0.12em] uppercase text-stone-500">
                    {% if groupName %}
                        <span class="size-2.5 rounded-full flex-none" style="background: {{ color }}"></span>
                        <span>{{ groupName }}</span>
                    {% endif %}
                    {% if groupName and typeName %}
                        <span class="text-stone-300">·</span>
                    {% endif %}
                    {% if typeName %}
                        <span>{{ typeName }}</span>
                    {% endif %}
                </div>
            {% endif %}

            {# Titre — Fraunces #}
            <h2 class="font-display font-normal text-[2.1rem] leading-[1.05] tracking-tight text-stone-900 -mt-1">
                {{ spiceName }}
            </h2>

            {# Tags groupe + type #}
            <div class="flex flex-wrap gap-1.5">
                {% if groupName %}
                    <span class="inline-flex items-center gap-1.5 text-[11.5px] font-medium px-2.5 py-1.5 rounded-full border"
                          style="background: {{ color }}15; color: {{ color }}; border-color: {{ color }}40">
                        <span class="size-2 rounded-full flex-none" style="background: {{ color }}"></span>
                        {{ groupName }}
                    </span>
                {% endif %}
                {% if typeName %}
                    <span class="inline-flex items-center text-[11.5px] font-medium px-2.5 py-1.5 rounded-full
                                 bg-stone-100 border border-stone-200 text-stone-500">
                        {{ typeName }}
                    </span>
                {% endif %}
            </div>

            {# Description — serif italic avec bordure accent #}
            {% if spice.getLocalizedDescription(loc) %}
                <p class="font-display italic font-normal text-[15.5px] leading-relaxed text-stone-600
                          border-l-[2px] pl-4 -ml-0.5"
                   style="border-color: {{ color }}">
                    {{ spice.getLocalizedDescription(loc) }}
                </p>
            {% endif %}

            {# Saveurs dominantes #}
            {% set flavors = [] %}
            {% for ac in spice.aromaticsCompounds %}
                {% for f in ac.AlchemyFlavors %}
                    {% set flavors = flavors|merge([f]) %}
                {% endfor %}
            {% endfor %}
            {% if flavors|length > 0 %}
                <div class="flex flex-col gap-2.5">
                    <h4 class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-stone-400 flex items-center gap-2">
                        <i class="fa-solid fa-droplet text-[10px]" style="color: {{ color }}" aria-hidden="true"></i>
                        {{ 'ui.modal.dominant_flavors'|trans }}
                    </h4>
                    <div class="flex flex-wrap gap-1.5">
                        {% for flavor in flavors|slice(0, 8) %}
                            <span class="inline-flex items-center text-[12.5px] font-medium px-2.5 py-1 rounded-full border"
                                  style="background: {{ color }}12; color: {{ color }}; border-color: {{ color }}30">
                                {{ flavor.name }}
                            </span>
                        {% endfor %}
                        {% if flavors|length > 8 %}
                            <span class="text-[11px] text-stone-400 self-center">+{{ flavors|length - 8 }}</span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {# Composés aromatiques #}
            {% if spice.aromaticsCompounds|length > 0 %}
                <div class="flex flex-col gap-2.5">
                    <h4 class="font-mono text-[10.5px] tracking-[0.14em] uppercase text-stone-400 flex items-center gap-2">
                        <i class="fa-solid fa-atom text-stone-400 text-[10px]" aria-hidden="true"></i>
                        {{ 'ui.modal.aromatic_compounds'|trans }}
                    </h4>
                    <div class="flex flex-wrap gap-1.5">
                        {% for ac in spice.aromaticsCompounds|slice(0, 6) %}
                            <span class="inline-flex items-center text-[12px] font-mono font-medium px-2.5 py-1 rounded-full
                                         bg-stone-100 border border-stone-200 text-stone-600 tracking-[0.03em]">
                                {{ ac.getLocalizedName(loc) }}
                            </span>
                        {% endfor %}
                        {% if spice.aromaticsCompounds|length > 6 %}
                            <span class="text-[11px] text-stone-400 self-center">+{{ spice.aromaticsCompounds|length - 6 }}</span>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

        </div>

        {# ── Footer — pleine largeur (col-span-2) ── #}
        <div class="sm:col-span-2 border-t border-stone-200 px-7 py-4 flex items-center justify-between
                    bg-cream/80">
            <span class="font-mono text-[11px] text-stone-400 tracking-[0.04em]">{{ 'ui.modal.quick_preview'|trans }}</span>
            <a href="{{ path('view_spice', {slug: spice.getLocalizedSlug(app.request.locale)}) }}"
               data-turbo-frame="_top"
               class="inline-flex items-center gap-1.5 text-[13.5px] font-semibold
                      hover:opacity-80 transition-opacity group/link"
               style="color: var(--color-copper-text)">
                {{ 'ui.modal.view_full'|trans }}
                <i class="fa-solid fa-arrow-right text-xs transition-transform group-hover/link:translate-x-0.5" aria-hidden="true"></i>
            </a>
        </div>

    </div>
</turbo-frame>
