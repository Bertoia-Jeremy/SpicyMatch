{% extends 'base.html.twig' %}
{% import "components/_macro_modal_preparation_method.html.twig" as macroModalPreparationMethod %}

{% block title %}SpicyMatch — {{ spice.name }}{% endblock %}

{% block body %}

{#
  Quick View frame — rendu quand la modale Alpine charge /epices/{id}.
  Le contenu complet de la page est en dehors de ce frame (Turbo l'ignore).
#}
<turbo-frame id="spice_quick_view">
    {% set color = spice.aromaticGroups ? spice.aromaticGroups.color : '#78716C' %}
    {% set imageUrl = vich_uploader_asset(spice, 'imageFile') %}

    <div class="p-6">
        {# En-tête : image + nom + groupe #}
        <div class="flex gap-4 mb-5">
            {% if imageUrl %}
                <img src="{{ imageUrl }}" alt="{{ spice.name }}"
                     class="w-24 h-24 rounded-2xl object-cover shrink-0 shadow-sm">
            {% else %}
                <img src="https://loremflickr.com/96/96/spice"
                     alt="{{ spice.name }}"
                     class="w-24 h-24 rounded-2xl object-cover shrink-0 shadow-sm">
            {% endif %}
            <div class="flex-1 min-w-0">
                <h2 class="text-xl font-bold text-stone-900 mb-1">{{ spice.name }}</h2>
                {% if spice.aromaticGroups %}
                    <span class="inline-flex items-center text-xs font-medium px-2.5 py-1 rounded-full"
                          style="background-color: {{ color }}22; color: {{ color }}; border: 1px solid {{ color }}44">
                        {{ spice.aromaticGroups.name }}
                    </span>
                {% endif %}
            </div>
        </div>

        {# Description #}
        {% if spice.description %}
            <p class="text-stone-600 text-sm leading-relaxed mb-5">{{ spice.description }}</p>
        {% endif %}

        {# Saveurs principales #}
        {% set flavors = [] %}
        {% for ac in spice.aromaticsCompounds %}
            {% for f in ac.AlchemyFlavors %}
                {% set flavors = flavors|merge([f]) %}
            {% endfor %}
        {% endfor %}
        {% if flavors|length > 0 %}
            <div class="mb-4">
                <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-2">
                    <i class="fa-solid fa-droplet text-turmeric-500 mr-1"></i>Saveurs
                </p>
                <div class="flex flex-wrap gap-1.5">
                    {% for flavor in flavors|slice(0, 6) %}
                        <span class="tag-primary text-xs">{{ flavor.name }}</span>
                    {% endfor %}
                    {% if flavors|length > 6 %}
                        <span class="tag-secondary text-xs">+{{ flavors|length - 6 }}</span>
                    {% endif %}
                </div>
            </div>
        {% endif %}

        {# Composés aromatiques #}
        {% if spice.aromaticsCompounds|length > 0 %}
            <div>
                <p class="text-xs font-semibold text-stone-400 uppercase tracking-wider mb-2">
                    <i class="fa-solid fa-atom text-saffron-600 mr-1"></i>Composés aromatiques
                </p>
                <div class="flex flex-wrap gap-1.5">
                    {% for ac in spice.aromaticsCompounds|slice(0, 5) %}
                        <span class="tag-secondary text-xs">{{ ac.name }}</span>
                    {% endfor %}
                    {% if spice.aromaticsCompounds|length > 5 %}
                        <span class="tag-secondary text-xs">+{{ spice.aromaticsCompounds|length - 5 }}</span>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    </div>
</turbo-frame>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <div class="mb-6">
        <a href="{{ path('index_spices') }}" class="inline-flex items-center gap-1.5 text-stone-500 hover:text-saffron-700 text-sm transition-colors">
            <i class="fa-solid fa-arrow-left text-[10px]"></i>Retour aux épices
        </a>
    </div>

    {# Hero épice #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
        <div class="md:col-span-2">
            {% if spice.aromaticGroups %}
                <span class="tag-secondary mb-3 inline-block">{{ spice.aromaticGroups.name }}</span>
            {% endif %}
            <h1 class="text-4xl font-bold text-stone-900 mb-3">{{ spice.name }}</h1>
            <p class="text-stone-600 text-lg leading-relaxed">{{ spice.description }}</p>
        </div>

        <div class="card-warm p-5">
            <h3 class="text-lg font-semibold text-stone-800 mb-3">
                <i class="fa-solid fa-fire-flame-curved text-saffron-600 mr-2"></i>Conseils de cuisine
            </h3>
            <p class="text-stone-600 text-sm leading-relaxed">{{ spice.cooking|nl2br }}</p>
        </div>
    </div>

    {# Tips de cuisson #}
    {% if spice.cookingTips is not empty %}
        <div class="mb-10">
            <h2 class="text-2xl font-bold text-stone-900 mb-2">Incorporation de l'épice</h2>
            <p class="text-stone-500 mb-5 text-sm">Quand incorporer cette épice selon l'étape de cuisson — intensité, tolérance à la chaleur.</p>
            <div class="space-y-3">
                {% for cookingTip in spice.cookingTips %}
                    <div class="card-warm p-4">
                        <p class="text-sm font-semibold text-stone-700 mb-1">
                            <span class="text-saffron-700">Étape :</span> {{ cookingTip.cookingStep }}
                        </p>
                        <p class="text-stone-600 text-sm">{{ cookingTip.text }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# Tips de préparation #}
    {% if spice.preparationTips is not empty %}
        <div class="mb-10">
            <h2 class="text-2xl font-bold text-stone-900 mb-2">Conseils de préparation</h2>
            <p class="text-stone-500 mb-5 text-sm">Différentes préparations permettent de moduler l'intensité ou la mise en valeur des saveurs.</p>
            <div class="space-y-4">
                {% for preparationTip in spice.preparationTips %}
                    <article class="card-warm p-5">
                        <h4 class="font-semibold text-stone-800 mb-2">{{ preparationTip.title }}</h4>
                        <div class="w-12 h-0.5 mb-3 rounded" style="background-color: {{ preparationTip.spice.aromaticGroups.color ?? '#C2410C' }}"></div>
                        <p class="text-stone-600 text-sm leading-relaxed">{{ preparationTip.text|nl2br }}</p>
                        {% if preparationTip.preparationMethod is not null %}
                            <div class="mt-3 flex justify-end">
                                {{ macroModalPreparationMethod.modal(
                                    preparationTip.preparationMethod.id,
                                    preparationTip.preparationMethod.name,
                                    true
                                )}}
                            </div>
                        {% endif %}
                    </article>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# Saveurs & composés #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        <div class="card-warm p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-4">
                <i class="fa-solid fa-droplet text-turmeric-500 mr-2"></i>Saveurs
            </h3>
            <div class="flex flex-wrap gap-2">
                {% for aromaticCompound in spice.aromaticsCompounds %}
                    {% for flavor in aromaticCompound.AlchemyFlavors %}
                        <a href="{{ path('view_alchemy_flavors', {"id": flavor.id}) }}" class="tag-primary hover:opacity-80 transition-opacity">{{ flavor.name }}</a>
                    {% endfor %}
                {% endfor %}
                {% for aromaticCompound in spice.secondaryAromaticsCompounds %}
                    {% for flavor in aromaticCompound.AlchemyFlavors %}
                        <a href="{{ path('view_alchemy_flavors', {"id": flavor.id}) }}" class="tag-secondary hover:opacity-80 transition-opacity">{{ flavor.name }}</a>
                    {% endfor %}
                {% endfor %}
            </div>
        </div>

        <div class="card-warm p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-4">
                <i class="fa-solid fa-atom text-saffron-600 mr-2"></i>Composés aromatiques
            </h3>
            <div class="flex flex-wrap gap-2">
                {% for aromaticCompound in spice.aromaticsCompounds %}
                    <a href="{{ path('view_aromatic_compound', {"id": aromaticCompound.id}) }}" class="tag-primary hover:opacity-80 transition-opacity">{{ aromaticCompound.name }}</a>
                {% endfor %}
                {% for aromaticCompound in spice.secondaryAromaticsCompounds %}
                    <a href="{{ path('view_aromatic_compound', {"id": aromaticCompound.id}) }}" class="tag-secondary hover:opacity-80 transition-opacity">{{ aromaticCompound.name }}</a>
                {% endfor %}
            </div>
        </div>
    </div>

    {# En savoir plus #}
    {% if spice.informations %}
        <div class="bg-spice-surface border border-spice-border rounded-2xl p-6">
            <h3 class="text-lg font-semibold text-stone-800 mb-3">
                <i class="fa-solid fa-book-open text-saffron-600 mr-2"></i>En savoir plus
            </h3>
            <p class="text-stone-600 text-sm leading-relaxed">{{ spice.informations }}</p>
        </div>
    {% endif %}

</div>
{% endblock %}
