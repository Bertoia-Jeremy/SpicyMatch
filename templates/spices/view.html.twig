{% extends 'base.html.twig' %}
{% import "components/_macro_modal_preparation_method.html.twig" as macroModalPreparationMethod %}

{% block title %}SpicyMatch — {{ spice.getLocalizedName(app.request.locale) }}{% endblock %}

{% block metas %}
    {% set _heroImg = vich_uploader_asset(spice, 'imageFile') %}
    {% if _heroImg %}
        <link rel="preload" as="image" type="image/webp" href="{{ _heroImg|imagine_filter('spice_hero') }}" fetchpriority="high">
    {% endif %}
{% endblock %}

{% block body %}

{% set loc = app.request.locale %}
{% set color = spice.aromaticGroups ? spice.aromaticGroups.color : '#C2410C' %}
{% set colorAttr = color|e('html_attr') %}

{# Palettes pour les piles du bowl #}
{% set pileConfig = [
    {cx: 50, cy: 48, size: 46},
    {cx: 27, cy: 32, size: 28},
    {cx: 72, cy: 30, size: 26},
    {cx: 30, cy: 70, size: 22},
    {cx: 73, cy: 70, size: 20},
] %}
{% set pileColors = [
    {light: '#FDBA74', dark: '#C2410C'},
    {light: '#FDE68A', dark: '#D97706'},
    {light: '#FCA5A5', dark: '#B91C1C'},
    {light: '#86EFAC', dark: '#15803D'},
    {light: '#C4B5FD', dark: '#7C3AED'},
] %}

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {# Breadcrumb #}
    <nav class="flex items-center gap-2.5 font-mono text-[11px] uppercase tracking-widest mb-7"
         style="color: rgba(42,24,16,0.4)">
        <a href="{{ path('index_spices') }}" class="transition-colors hover:opacity-70">{{ 'ui.catalog.breadcrumb_spices'|trans }}</a>
        <span class="opacity-40">/</span>
        {% if spice.aromaticGroups %}
            <span class="cursor-default">{{ spice.aromaticGroups.getLocalizedName(loc) }}</span>
            <span class="opacity-40">/</span>
        {% endif %}
        <span style="color: {{ color }}">{{ spice.getLocalizedName(loc) }}</span>
    </nav>

    {# ─────────── 01 — HERO ─────────── #}
    <section class="reveal is-in mb-16">
        <div class="relative rounded-3xl overflow-hidden shadow-sm"
             style="background: linear-gradient(180deg, {{ color }}08 0%, {{ color }}14 100%);
                    border: 1px solid rgba(184,134,74,0.25)">
            {# Halos décoratifs #}
            <div class="absolute w-96 h-96 rounded-full pointer-events-none"
                 style="background: radial-gradient(circle, {{ color }}20, transparent 65%); top:-180px; right:-120px; filter:blur(20px)"></div>
            <div class="absolute w-80 h-80 rounded-full pointer-events-none"
                 style="background: radial-gradient(circle, {{ color }}12, transparent 65%); bottom:-160px; left:-100px; filter:blur(20px)"></div>

            <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-10 items-center p-10 md:p-14">
                {# Texte gauche #}
                <div>
                    {# Eyebrow : groupe + type #}
                    <div class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest
                                rounded-full px-3 py-1.5 mb-5 shadow-sm"
                         style="background: var(--color-parchment); border: 1px solid rgba(184,134,74,0.3);
                                color: rgba(42,24,16,0.5)">
                        {% if spice.aromaticGroups %}
                            <span class="size-2.5 rounded-full flex-none" style="background: {{ color }}"></span>
                            {{ spice.aromaticGroups.getLocalizedName(loc) }}
                            {% if spice.spicyType %} · {{ spice.spicyType.name }}{% endif %}
                        {% else %}
                            <i class="fa-solid fa-seedling" style="color: {{ color }}" aria-hidden="true"></i>
                            {% if spice.spicyType %}{{ spice.spicyType.name }}{% else %}{{ 'ui.catalog.spice_fallback'|trans }}{% endif %}
                        {% endif %}
                    </div>

                    <h1 class="font-display font-normal mb-3 leading-none"
                        style="font-size: clamp(2.5rem, 6vw, 4.5rem); letter-spacing: -0.025em; color: var(--color-ink-deep)">
                        {{ spice.getLocalizedName(loc) }}
                    </h1>

                    {% if spice.getLocalizedDescription(loc) %}
                        <p class="font-display text-lg leading-relaxed max-w-lg mb-7"
                           style="color: rgba(42,24,16,0.5)">
                            {{ spice.getLocalizedDescription(loc) }}
                        </p>
                    {% endif %}

                    {# Stat : type #}
                    {% if spice.spicyType %}
                        <div class="flex flex-wrap gap-3">
                            <div class="inline-flex items-center gap-3 rounded-xl px-3.5 py-2.5 shadow-sm"
                                 style="background: var(--color-parchment); border: 1px solid rgba(184,134,74,0.25)">
                                <span class="size-8 rounded-lg grid place-items-center flex-none"
                                      style="background: {{ color }}18">
                                    <i class="fa-solid fa-tag text-sm" style="color: {{ color }}" aria-hidden="true"></i>
                                </span>
                                <span class="flex flex-col gap-0.5">
                                    <span class="font-mono text-[9.5px] uppercase tracking-widest"
                                          style="color: rgba(42,24,16,0.4)">{{ 'ui.catalog.type'|trans }}</span>
                                    <span class="font-display text-[15px] font-medium leading-none"
                                          style="color: var(--color-ink-deep)">{{ spice.spicyType.name }}</span>
                                </span>
                            </div>
                        </div>
                    {% endif %}
                </div>

                {# Image droite — blob morphing #}
                <div class="relative aspect-square max-w-xs md:max-w-none w-full mx-auto md:justify-self-end">
                    <div class="hero-img-blob relative">
                        {% set heroImg = vich_uploader_asset(spice, 'imageFile') %}
                        {% if heroImg %}
                            <img src="{{ heroImg|imagine_filter('spice_hero') }}" alt="{{ spice.getLocalizedName(loc) }}"
                                 fetchpriority="high" decoding="async" width="800" height="800"
                                 class="absolute inset-0 w-full h-full object-cover">
                        {% endif %}
                        {# Highlight #}
                        <div class="absolute inset-0 pointer-events-none"
                             style="background: radial-gradient(circle at 28% 22%, rgba(255,255,255,.25), transparent 35%)"></div>
                    </div>
                    {# Tags flottants (CSS pur, Lora italic) #}
                    {% if spice.aromaticGroups %}
                        <span class="hero-tag hero-tag-1">{{ spice.aromaticGroups.getLocalizedName(loc)|lower }}</span>
                    {% endif %}
                    {% if spice.spicyType %}
                        <span class="hero-tag hero-tag-2">{{ spice.spicyType.name|lower }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    {# ─────────── 02+ — SECTIONS CONDITIONNELLES ─────────── #}
    {% set sectionNum = 1 %}

    {# ─────────── Saveurs (composés aromatiques) ─────────── #}
    {% if spice.aromaticsCompounds is not empty %}
    {% set sectionNum = sectionNum + 1 %}
    <section class="section reveal is-in mb-16">
        <div class="flex items-baseline justify-between gap-4 mb-7 flex-wrap">
            <h2 class="font-display font-normal text-3xl leading-tight" style="letter-spacing: -0.02em; color: var(--color-ink-deep)">
                <span class="font-mono text-sm mr-3" style="color: rgba(42,24,16,0.35)">0{{ sectionNum }} — {{ 'ui.catalog.profile'|trans }}</span>
                {{ 'ui.catalog.flavors_heading_html'|trans({'%color%': colorAttr})|raw }}
            </h2>
        </div>
        <p class="font-display text-lg mb-8 max-w-xl" style="color: rgba(42,24,16,0.4)">
            {{ 'ui.catalog.flavors_intro'|trans }}
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
            {# Bowl #}
            <div class="bowl">
                <div class="bowl-rim"></div>
                {% for compound in spice.aromaticsCompounds|slice(0, 5) %}
                    {% set cfg = pileConfig[loop.index0] ?? {cx: 50, cy: 50, size: 20} %}
                    {% set clr = pileColors[loop.index0] ?? {light: '#FDBA74', dark: '#C2410C'} %}
                    {% set half = cfg.size / 2 %}
                    <div class="pile" style="
                        left: calc({{ cfg.cx }}% - {{ half }}%);
                        top: calc({{ cfg.cy }}% - {{ half }}%);
                        width: {{ cfg.size }}%;
                        height: {{ cfg.size }}%;
                        background: radial-gradient(circle at 30% 30%, {{ clr.light }}, {{ clr.dark }});
                    ">
                        <span style="color:white; font-size: {{ loop.index0 == 0 ? '13' : '10' }}px; font-family: var(--font-display); text-align: center; padding: 0 8px; line-height: 1.15; font-weight: 500">
                            {{ compound.getLocalizedName(loc) }}
                        </span>
                    </div>
                {% endfor %}
            </div>

            {# Légende + composés secondaires #}
            <div>
                <h3 class="font-display text-xl font-medium mb-2" style="color: var(--color-ink-deep)">
                    {{ 'ui.catalog.primary_compounds_heading_html'|trans({'%color%': colorAttr})|raw }}
                </h3>
                <p class="font-display mb-5" style="color: rgba(42,24,16,0.4)">{{ 'ui.catalog.primary_compounds_intro'|trans }}</p>

                {# Légende #}
                <div class="rounded-2xl overflow-hidden shadow-sm mb-4"
                     style="background: var(--color-parchment); border: 1px solid rgba(184,134,74,0.25)">
                    {% for compound in spice.aromaticsCompounds|slice(0, 5) %}
                        {% set clr = pileColors[loop.index0] ?? {light: '#FDBA74', dark: '#C2410C'} %}
                        <div class="flex items-center gap-3 px-4 py-3 {{ not loop.last ? 'border-b' : '' }}"
                             style="{{ not loop.last ? 'border-color: rgba(184,134,74,0.15)' : '' }}">
                            <span class="size-5 rounded-full flex-none shadow-sm"
                                  style="background: radial-gradient(circle at 30% 30%, {{ clr.light }}, {{ clr.dark }})"></span>
                            <a href="{{ path('view_aromatic_compound', {slug: compound.getLocalizedSlug(loc)}) }}"
                               class="font-display text-[15px] font-medium flex-1 hover:underline transition-opacity hover:opacity-70"
                               style="color: var(--color-ink-deep)">{{ compound.getLocalizedName(loc) }}</a>
                            {% if compound.AlchemyFlavors is not empty %}
                                <span class="font-mono text-[9.5px] uppercase tracking-wide"
                                      style="color: rgba(42,24,16,0.4)">
                                    {{ compound.AlchemyFlavors|map(f => f.name)|join(' · ') }}
                                </span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

                {# Composés secondaires #}
                {% if spice.secondaryAromaticsCompounds is not empty %}
                    <div class="rounded-xl p-4"
                         style="background: var(--color-parchment-deep); border: 1px solid rgba(184,134,74,0.2)">
                        <p class="font-mono text-[10px] uppercase tracking-widest mb-2 flex items-center gap-2"
                           style="color: rgba(42,24,16,0.4)">
                            <i class="fa-solid fa-flask-vial text-[10px]" style="color: {{ color }}" aria-hidden="true"></i>
                            {{ 'ui.catalog.secondary_compounds'|trans }}
                        </p>
                        <div class="grid grid-cols-2 gap-x-4">
                            {% for compound in spice.secondaryAromaticsCompounds %}
                                <div class="flex items-baseline justify-between gap-2 py-1.5 border-b border-dotted last:border-0"
                                     style="border-color: rgba(184,134,74,0.2)">
                                    <a href="{{ path('view_aromatic_compound', {slug: compound.getLocalizedSlug(loc)}) }}"
                                       class="font-display text-sm hover:underline transition-opacity hover:opacity-70"
                                       style="color: rgba(42,24,16,0.7)">{{ compound.getLocalizedName(loc) }}</a>
                                    {% if compound.AlchemyFlavors is not empty %}
                                        <span class="font-mono text-[9px] shrink-0"
                                              style="color: rgba(42,24,16,0.4)">{{ compound.AlchemyFlavors|first ? compound.AlchemyFlavors|first.name : '' }}</span>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# Tags flaveurs — primaires + secondaires, avec liens #}
                {% set allFlavors = [] %}
                {% for compound in spice.aromaticsCompounds %}
                    {% for flavor in compound.AlchemyFlavors %}
                        {% if flavor.id not in allFlavors|map(f => f.id) %}
                            {% set allFlavors = allFlavors|merge([flavor]) %}
                        {% endif %}
                    {% endfor %}
                {% endfor %}
                {% for compound in spice.secondaryAromaticsCompounds %}
                    {% for flavor in compound.AlchemyFlavors %}
                        {% if flavor.id not in allFlavors|map(f => f.id) %}
                            {% set allFlavors = allFlavors|merge([flavor]) %}
                        {% endif %}
                    {% endfor %}
                {% endfor %}
                {% if allFlavors is not empty %}
                    <div class="flex flex-wrap gap-2 mt-4">
                        {% for flavor in allFlavors %}
                            <a href="{{ path('view_alchemy_flavors', {slug: flavor.getLocalizedSlug(loc)}) }}"
                               class="tag-primary hover:opacity-75 transition-opacity">{{ flavor.getLocalizedName(loc) }}</a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
    {% endif %}

    <div class="my-12">
        {% include 'partials/_ads_banner.html.twig' %}
    </div>

    {# ─────────── En Cuisine (marmites) ─────────── #}
    {% if spice.cookingTips is not empty %}
    {% set sectionNum = sectionNum + 1 %}
    <section class="section reveal is-in mb-16">
        <div class="flex items-baseline justify-between gap-4 mb-3 flex-wrap">
            <h2 class="font-display font-normal text-3xl leading-tight" style="letter-spacing: -0.02em; color: var(--color-ink-deep)">
                <span class="font-mono text-sm mr-3" style="color: rgba(42,24,16,0.35)">0{{ sectionNum }} — {{ 'ui.catalog.in_kitchen'|trans }}</span>
                {{ 'ui.catalog.in_kitchen_heading_html'|trans({'%color%': colorAttr})|raw }}
            </h2>
            <span class="font-mono text-[11px]" style="color: rgba(42,24,16,0.4)">{{ 'ui.catalog.moments'|trans({'%count%': spice.cookingTips|length}) }}</span>
        </div>

        {% set marmiteLabels = ['ui.catalog.marmite_before'|trans, 'ui.catalog.marmite_during'|trans, 'ui.catalog.marmite_after'|trans, 'ui.catalog.marmite_last'|trans, 'ui.catalog.marmite_marinade'|trans] %}
        {% set marmiteIcons = ['fa-fire-flame-curved', 'fa-bowl-hot', 'fa-sparkles', 'fa-clock', 'fa-droplet'] %}

        <div class="marmites">
            {% for tip in spice.cookingTips|slice(0, 3) %}
                <article class="marmite">
                    <div class="marmite-top">
                        <div class="marmite-glyph">
                            <i class="fa-solid {{ marmiteIcons[loop.index0] ?? 'fa-fire' }} text-2xl" aria-hidden="true"></i>
                        </div>
                        <div class="marmite-step">{{ loop.index }}</div>
                    </div>
                    <div class="marmite-when">{{ marmiteLabels[loop.index0] ?? 'ui.catalog.marmite_default'|trans }}</div>
                    <h4 class="font-display text-xl font-medium mb-3 leading-tight" style="text-wrap: balance; color: var(--color-ink-deep)">
                        {{ tip.getLocalizedCookingStep(loc) }}
                    </h4>
                    <p class="font-display text-[15px] leading-relaxed flex-1 mb-4" style="color: rgba(42,24,16,0.5)">{{ tip.getLocalizedText(loc) }}</p>
                    <span class="marmite-foot">
                        <i class="fa-solid fa-clock text-[10px]" style="color: {{ color }}" aria-hidden="true"></i>
                        {{ 'ui.catalog.step'|trans }} {{ loop.index }}
                    </span>
                </article>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {# ─────────── Le Carnet (préparation + vertus) ─────────── #}
    {% if spice.cooking or spice.preparationTips is not empty %}
    {% set sectionNum = sectionNum + 1 %}
    <section class="section reveal is-in mb-16">
        <div class="flex items-baseline justify-between gap-4 mb-7">
            <h2 class="font-display font-normal text-3xl leading-tight" style="letter-spacing: -0.02em; color: var(--color-ink-deep)">
                <span class="font-mono text-sm mr-3" style="color: rgba(42,24,16,0.35)">0{{ sectionNum }} — {{ 'ui.catalog.notebook'|trans }}</span>
                {{ 'ui.catalog.notebook_heading_html'|trans({'%color%': colorAttr})|raw }}
            </h2>
        </div>

        <div class="carnet-layout">
            {# Colonne gauche : texte narratif #}
            <div>
                <h3 class="font-display text-xl font-medium mb-3 leading-tight" style="color: var(--color-ink-deep)">
                    {{ 'ui.catalog.tame_heading_html'|trans({'%color%': colorAttr})|raw }}
                </h3>

                {% if spice.getLocalizedCooking(loc) %}
                    <p class="font-display text-[16.5px] leading-relaxed mb-4" style="color: rgba(42,24,16,0.5)">
                        {{ spice.getLocalizedCooking(loc) }}
                    </p>
                {% endif %}

                {% if spice.getLocalizedInformations(loc) %}
                    <div class="carnet-tip">
                        <span class="carnet-tip-ic">
                            <i class="fa-solid fa-lightbulb text-lg" aria-hidden="true"></i>
                        </span>
                        <div>
                            <strong class="block font-display text-[15px] font-medium mb-1" style="color: var(--color-ink-deep)">{{ 'ui.catalog.good_to_know'|trans }}</strong>
                            <span class="text-sm leading-relaxed" style="color: rgba(42,24,16,0.5)">{{ spice.getLocalizedInformations(loc) }}</span>
                        </div>
                    </div>
                {% endif %}

                {# Préparations avec modal #}
                {% if spice.preparationTips is not empty %}
                    <div class="mt-5 space-y-3">
                        {% for prep in spice.preparationTips %}
                            <article class="card-warm p-4">
                                <h4 class="font-semibold mb-1.5 text-sm" style="color: var(--color-ink-deep)">{{ prep.getLocalizedTitle(loc) }}</h4>
                                <div class="w-10 h-0.5 mb-3 rounded" style="background-color: {{ color }}"></div>
                                <p class="text-sm leading-relaxed" style="color: rgba(42,24,16,0.5)">{{ prep.getLocalizedText(loc)|nl2br }}</p>
                                {% if prep.preparationMethod is not null %}
                                    <div class="mt-2 flex justify-end">
                                        {{ macroModalPreparationMethod.modal(
                                            prep.preparationMethod.id,
                                            prep.preparationMethod.getLocalizedName(loc),
                                            true,
                                            prep.preparationMethod.getLocalizedSlug(loc)
                                        )}}
                                    </div>
                                {% endif %}
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            {# Colonne droite : vertus / préparations comme liste #}
            <div class="vertus-list">
                <h4 class="font-mono text-[10.5px] uppercase tracking-widest mb-3"
                    style="color: rgba(42,24,16,0.4)">
                    — {{ 'ui.catalog.its_assets'|trans }}
                </h4>

                {% set vertuIcons = ['fa-leaf', 'fa-heart', 'fa-star', 'fa-shield-halved', 'fa-circle-check'] %}

                {% for prep in spice.preparationTips|slice(0, 4) %}
                    <div class="vertu">
                        <span class="vertu-ic">
                            <i class="fa-solid {{ vertuIcons[loop.index0] ?? 'fa-leaf' }} text-lg" aria-hidden="true"></i>
                        </span>
                        <div class="min-w-0">
                            <div class="font-display text-[16px] font-medium leading-tight mb-1"
                                 style="color: var(--color-ink-deep)">
                                {{ prep.getLocalizedTitle(loc) }}
                            </div>
                            <p class="text-[12.5px] leading-relaxed m-0"
                               style="color: rgba(42,24,16,0.4)">
                                {% set prepText = prep.getLocalizedText(loc) %}{{ prepText|slice(0, 120) }}{% if prepText|length > 120 %}…{% endif %}
                            </p>
                        </div>
                    </div>
                {% else %}
                    {# Fallback si pas de preparationTips : afficher les composés #}
                    {% for compound in spice.aromaticsCompounds|slice(0, 3) %}
                        <div class="vertu">
                            <span class="vertu-ic">
                                <i class="fa-solid fa-flask text-lg" aria-hidden="true"></i>
                            </span>
                            <div class="min-w-0">
                                <div class="font-display text-[16px] font-medium leading-tight mb-1"
                                     style="color: var(--color-ink-deep)">
                                    {{ compound.getLocalizedName(loc) }}
                                </div>
                                {% if compound.AlchemyFlavors is not empty %}
                                    <p class="text-[12.5px] m-0" style="color: rgba(42,24,16,0.4)">
                                        {{ 'ui.catalog.note_of'|trans({'%flavors%': compound.AlchemyFlavors|map(f => f.name)|join(', ')}) }}
                                    </p>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}

    {# ─────────── Le Fil des Épices ─────────── #}
    {% if relatedSpices is defined and relatedSpices is not empty %}
    <section class="reveal is-in mt-4 pt-10 mb-8" style="border-top: 1px dashed rgba(184,134,74,0.3)">
        <p class="text-center font-mono text-[11px] uppercase tracking-widest mb-1.5"
           style="color: rgba(42,24,16,0.4)">
            — {{ 'ui.catalog.spice_thread'|trans }} —
        </p>
        <p class="text-center font-display italic text-xl mb-8 max-w-md mx-auto"
           style="color: rgba(42,24,16,0.4); text-wrap: balance">
            {{ 'ui.catalog.spice_thread_text'|trans }}
        </p>
        <div class="fil-grid">
            {% for related in relatedSpices %}
                {% set relColor = related.aromaticGroups ? related.aromaticGroups.color : '#888' %}
                {% set relImg = vich_uploader_asset(related, 'imageFile') %}
                <a href="{{ path('view_spice', {slug: related.getLocalizedSlug(loc)}) }}" class="fil-card group">
                    <div class="fc-img" style="background: {{ relColor }}20">
                        <span class="absolute top-2.5 left-2.5 z-10 inline-flex items-center gap-1.5
                                     rounded-full px-2 py-1
                                     text-[9.5px] font-semibold uppercase tracking-wide"
                              style="background: rgba(241,231,206,0.9); backdrop-filter: blur(4px);
                                     color: rgba(42,24,16,0.6)">
                            <span class="size-1.5 rounded-full" style="background: {{ relColor }}"></span>
                            {{ related.aromaticGroups ? related.aromaticGroups.getLocalizedName(loc) : 'ui.catalog.spice_fallback'|trans }}
                        </span>
                        {% if relImg %}
                            <img src="{{ relImg|imagine_filter('spice_card') }}"
                                 srcset="{{ relImg|imagine_filter('spice_card') }} 1x, {{ relImg|imagine_filter('spice_card_2x') }} 2x"
                                 alt="{{ related.getLocalizedName(loc) }}"
                                 loading="lazy" decoding="async" width="400" height="400"
                                 class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        {% else %}
                            <div class="absolute inset-0 flex items-center justify-center"
                                 style="color: rgba(42,24,16,0.2)">
                                <i class="fa-solid fa-seedling text-4xl" aria-hidden="true"></i>
                            </div>
                        {% endif %}
                    </div>
                    <h3 class="font-display text-xl font-medium leading-tight mb-1" style="color: var(--color-ink-deep)">{{ related.getLocalizedName(loc) }}</h3>
                    {% if related.spicyType %}
                        <p class="font-display italic text-sm" style="color: {{ relColor }}">{{ related.spicyType.name }}</p>
                    {% endif %}
                </a>
            {% endfor %}
        </div>
    </section>
    {% endif %}

</div>

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            function initReveal() {
                var els = document.querySelectorAll('.reveal');
                if (!els.length) return;
                var io = new IntersectionObserver(function (entries) {
                    entries.forEach(function (e) {
                        if (e.isIntersecting) {
                            e.target.classList.add('is-in');
                            io.unobserve(e.target);
                        }
                    });
                }, { threshold: 0, rootMargin: '0px 0px 200px 0px' });
                els.forEach(function (el) { io.observe(el); });
            }
            document.addEventListener('DOMContentLoaded', initReveal);
            document.addEventListener('turbo:load', initReveal);
        })();
    </script>
{% endblock %}

