{% extends 'base.html.twig' %}
{% import "components/_macro_modal_preparation_method.html.twig" as macroModalPreparationMethod %}

{% block title %}SpiceMatch - {{ spice.name }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
        <div class="md:col-span-2">
            <h1 class="text-4xl font-bold text-gray-800">{{ spice.name }}</h1>
            <h2 class="text-2xl text-gray-600">{{ spice.aromaticGroups.name }}</h2>
            <p class="mt-4 text-gray-600">{{ spice.description }}</p>
        </div>

        <div class="my-3">
            <h3>Conseils de cuisine</h3>
            <p>{{ spice.cooking|nl2br }}</p>
            <p>{{ spice.informations|nl2br }}</p>
        </div>

        {% if spice.cookingTips is not null %}
            <div class="my-3">
                <h3 class="mb-3">Incorporation de l'épice</h3>
                <p>
                    Voici des indications sur le moment où incorporer l'épice. 
                    Que ce soit pour l'intensité du goût ou bien la tolérance de la chaleur de l'épice, celle-ci peut être mise à une des étapes décrite ci dessous.
                </p>
                {% for cookingTip in spice.cookingTips %}
                    <div class="my-1">
                        <p class="mb-1"><u>Etape de la cuisson :</u> <b>{{ cookingTip.cookingStep }}</b></p>
                        <p class="mb-0">{{ cookingTip.text }}</p>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        
        {% if spice.preparationTips is not null %}
            <div class="my-3">
                <h3 class="mb-3">Conseils de préparation</h3>
                <p>
                    Différentes préparations permettent différentes intensité de goût ou de mise en valeur de telle ou telle saveur.
                </p>
                {% for preparationTip in spice.preparationTips %}
                    <article class="flex flex-col w-full bg-gray-50 shadow rounded my-3 p-3">
                        <h4 class="mb-1">{{ preparationTip.title }}</h4>
                        <div class="w-1/4 h-1 mb-2 rounded" style="background-color: {{ preparationTip.spice.aromaticGroups.color ?? '#888' }}"></div>
                        <p>{{ preparationTip.text|nl2br }}</p>
                        <div class="self-end text-right w-1/2">
                            {% if preparationTip.preparationMethod is not null %}
                                {{ macroModalPreparationMethod.modal(
                                    preparationTip.preparationMethod.id,
                                    preparationTip.preparationMethod.name,
                                    true
                                )}}
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}

        <div class="my-3">
            <h3 class="mb-3">En savoir plus</h3>
            <p>{{ spice.informations }}</p>
        </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-4 bg-white rounded-lg shadow-md">
            <h3 class="text-2xl font-bold text-gray-800 mb-4">Saveurs</h3>
            <div class="flex flex-wrap gap-2">
                {% for aromaticCompound in spice.aromaticsCompounds %}
                    {% for flavor in aromaticCompound.AlchemyFlavors %}
                        <a href="{{ path('view_alchemy_flavors', {"id" : flavor.id}) }}" class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">{{ flavor.name }}</a>
                    {% endfor %}
                {% endfor %}
                {% for aromaticCompound in spice.secondaryAromaticsCompounds %}
                    {% for flavor in aromaticCompound.AlchemyFlavors %}
                        <a href="{{ path('view_alchemy_flavors', {"id" : flavor.id}) }}" class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-sm">{{ flavor.name }}</a>
                    {% endfor %}
                {% endfor %}
            </div>
        </div>
        <div class="p-4 bg-white rounded-lg shadow-md">
            <h3 class="text-2xl font-bold text-gray-800 mb-4">Composés aromatiques</h3>
            <div class="flex flex-wrap gap-2">
                {% for aromaticCompound in spice.aromaticsCompounds %}
                    <a href="{{ path('view_aromatic_compound', {"id" : aromaticCompound.id}) }}" class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-sm">{{ aromaticCompound.name }}</a>
                {% endfor %}
                {% for aromaticCompound in spice.secondaryAromaticsCompounds %}
                    <a href="{{ path('view_aromatic_compound', {"id" : aromaticCompound.id}) }}" class="px-3 py-1 bg-gray-100 text-gray-800 rounded-full text-sm">{{ aromaticCompound.name }}</a>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

