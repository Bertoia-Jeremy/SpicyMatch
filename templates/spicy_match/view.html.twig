{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.lab.finalize_title'|trans }}{% endblock %}

{% block body %}
{% set loc = app.request.locale %}
<div
  x-data="finalisationMelange(
    '{{ spices|map(s => s.id)|join(',') }}',
    '{{ path('edit_spicy_match_history', {id: spicyMatchHistory.id}) }}',
    '{{ csrf_token('history_edit_' ~ spicyMatchHistory.id) }}'
  )"
  {% for spice in spices %}data-spice-name{{ loop.index0 }}="{{ spice.getLocalizedName(loc) }}" {% endfor %}
  class="min-h-screen etamine-paper"
  style="background-color: #F5ECDB;"
>

  {# ===== TOP BAR ===== #}
  <header class="max-w-[1180px] mx-auto px-6 pt-6 pb-3 flex items-center justify-between">
    <a href="{{ path('index_spicy_match') }}"
       class="flex items-center gap-2 text-sm transition-colors"
       style="color: #5A4A38;"
       onmouseover="this.style.color='#2A1F14'" onmouseout="this.style.color='#5A4A38'">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M14 6l-6 6 6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {{ 'ui.lab.back_to_lab'|trans }}
    </a>
    <span class="smallcaps">{{ 'ui.lab.finalize'|trans }}</span>
  </header>

  {# ===== HERO ===== #}
  <section class="max-w-[1180px] mx-auto px-6 pt-2 pb-8 text-center">
    <span class="relative inline-block mb-4">
      <span class="block hex w-9 h-10" style="background: linear-gradient(180deg, #D2773A, #9A4720);"></span>
      <svg class="absolute inset-0 m-auto" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 3h6M10 3v5L5 19a2 2 0 0 0 1.8 2.9h10.4A2 2 0 0 0 19 19l-5-11V3" stroke="#FBF5E9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <h1 class="font-display leading-[1.05]" style="font-size: clamp(32px, 5vw, 52px); color: #2A1F14;">
      {{ 'ui.lab.blend_takes_shape_html'|trans|raw }}
    </h1>
  </section>

  {# ===== STATIONS ===== #}
  <section class="max-w-[1180px] mx-auto px-6 mb-10">
    <div class="stepper">
      {% for spice in spices %}
        <button
          type="button"
          class="station"
          :class="stationClass('{{ spice.id }}')"
          @click="current = '{{ spice.id }}'"
          :aria-current="isCurrentSpice('{{ spice.id }}') ? 'step' : false"
        >
          <div class="station-hex">{{ '%02d'|format(loop.index) }}</div>
          <div class="flex-1 text-left">
            <div class="station-name">{{ spice.getLocalizedName(loc) }}</div>
            <div class="station-sub">
              <span class="pip" :class="pipClass('{{ spice.id }}', 'cooking')"></span>
              <span class="pip" :class="pipClass('{{ spice.id }}', 'preparation')"></span>
            </div>
          </div>
          <div class="station-link" x-text="statusLabel('{{ spice.id }}')">{{ 'ui.lab.status_upcoming'|trans }}</div>
        </button>
        {% if not loop.last %}<div class="between-rule"></div>{% endif %}
      {% endfor %}
    </div>
  </section>

  {# ===== ÉTAPES PAR ÉPICE ===== #}
  <main class="max-w-[1180px] mx-auto px-6 pb-48">
    {% for spice in spices %}
      {% set cookingTips = spice.cookingTips|sort((a, b) => a.step <=> b.step) %}

      <div x-show="isCurrentSpice('{{ spice.id }}')"
           x-transition:enter="transition ease-out duration-[200ms]"
           x-transition:enter-start="opacity-0"
           x-transition:enter-end="opacity-100"
           x-transition:leave="transition ease-in duration-[100ms]"
           x-transition:leave-start="opacity-100"
           x-transition:leave-end="opacity-0">

        {# ÉTAPE I — LE TEMPS (moment d'insertion) #}
        <section class="step-block">
          <div class="smallcaps mb-2">{{ 'ui.lab.step_time'|trans }}</div>
          <h2 class="font-display leading-tight" style="font-size: clamp(22px, 4vw, 34px); color: #2A1F14;">
            {{ 'ui.lab.step_time_q_html'|trans({'%name%': spice.getLocalizedName(loc)|e})|raw }}
          </h2>
          <div class="rule-dots my-6"></div>

          <div class="tiles grid grid-cols-2 md:grid-cols-4 gap-5 max-w-4xl mx-auto">
            {% for cookingTip in cookingTips %}
              <button
                type="button"
                class="timing"
                :class="timingTileClass('{{ spice.id }}', {{ cookingTip.id }})"
                @click="toggleCooking('{{ spice.id }}', {{ cookingTip.id }})"
              >
                <div class="hex-num-wrap">{{ '%02d'|format(loop.index) }}</div>
                <div class="timing-label">{{ cookingTip.getLocalizedCookingStep(loc) }}</div>
                {% if cookingTip.getLocalizedAdvantages(loc) %}
                  <div class="timing-blurb">{{ cookingTip.getLocalizedAdvantages(loc) }}</div>
                {% endif %}
              </button>
            {% endfor %}
          </div>
        </section>

        {# ÉTAPE II — LA MAIN (méthode de préparation) #}
        <section class="step-block" data-step-method-spice="{{ spice.id }}">
          <div class="smallcaps mb-2">{{ 'ui.lab.step_hand'|trans }}</div>
          <h2 class="font-display leading-tight" style="font-size: clamp(22px, 4vw, 34px); color: #2A1F14;">
            {{ 'ui.lab.step_hand_q_html'|trans({'%name%': spice.getLocalizedName(loc)|e})|raw }}
          </h2>
          <div class="rule-dots my-6"></div>

          <div class="tiles grid grid-cols-2 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
            {% for prepTip in spice.preparationTips %}
              <button
                type="button"
                class="method"
                :class="methodTileClass('{{ spice.id }}', {{ prepTip.id }})"
                @click="togglePreparation('{{ spice.id }}', {{ prepTip.id }})"
              >
                <div class="icon-wrap">
                  {{ include('components/_etamine_icons.html.twig', { name: prepTip.title }) }}
                </div>
                <div class="method-label">{{ prepTip.getLocalizedTitle(loc) }}</div>
                {% if prepTip.getLocalizedAdvantages(loc) %}
                  <div class="method-blurb">{{ prepTip.getLocalizedAdvantages(loc) }}</div>
                {% endif %}
              </button>
            {% endfor %}
          </div>
        </section>

      </div>
    {% endfor %}
  </main>

  {# ===== TOAST ===== #}
  <div class="toast"
       x-show="toast.visible"
       x-cloak
       x-transition:enter="transition ease-out duration-[250ms]"
       x-transition:enter-start="opacity-0 -translate-y-3"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-[150ms]"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 -translate-y-3"
       role="status"
       aria-live="polite">
    <span class="hex w-6 h-7 grid place-items-center" style="background: #D2773A; flex-shrink: 0;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M5 12l5 5L20 7" stroke="#FBF5E9" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
    <span x-text="toast.text"></span>
  </div>

  {# ===== STICKY CTA ===== #}
  <div class="fixed inset-x-0 bottom-0 cta-bar pt-7 sm:pt-10 pb-4 sm:pb-6 pointer-events-none"
       style="z-index: 30;">
    <div class="max-w-[1180px] mx-auto px-6 flex flex-col items-center gap-2">
      <button
        type="button"
        class="btn-seal pointer-events-auto w-full md:w-auto md:min-w-[420px] px-8 py-4 rounded-full flex items-center justify-center gap-3 text-base sm:text-lg font-medium"
        :disabled="!allSealed"
        @click="goToHistory('{{ path('view_spicy_match_history', {id: spicyMatchHistory.id}) }}')"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 2l2.5 5 5.5.8-4 3.9.9 5.5L12 14.8 7.1 17.2 8 11.7 4 7.8l5.5-.8L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <span x-text="ctaLabel"></span>
      </button>
    </div>
  </div>

</div>
{% endblock %}
