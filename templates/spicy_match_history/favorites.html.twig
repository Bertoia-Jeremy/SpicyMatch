{% extends 'base.html.twig' %}

{% block title %}Mes mélanges favoris{% endblock %}

{% block body %}
    {% import 'macros/buttons.html.twig' as buttons %}
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="mb-6">
            <a href="{{ path('index_spicy_match_history') }}" class="inline-flex items-center gap-1.5 text-stone-500 hover:text-saffron-700 text-sm transition-colors">
                <i class="fa-solid fa-arrow-left text-[10px]"></i>Retour à l'historique
            </a>
        </div>

        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-stone-800">
                <i class="fa-solid fa-star text-turmeric-500 mr-2"></i>Mes mélanges favoris
            </h1>
            <p class="mt-2 text-stone-500">Les recettes que vous avez marquées comme favorites.</p>
        </div>

        {% if spicymatch_histories is empty %}
            <div class="text-center py-16">
                <i class="fa-regular fa-star text-stone-300 text-5xl mb-4 block"></i>
                <p class="text-stone-500 text-lg mb-2">Aucun mélange favori pour l'instant.</p>
                <p class="text-stone-400 text-sm mb-6">Cliquez sur l'étoile d'un mélange pour l'ajouter à vos favoris.</p>
                {{ buttons.button('Voir mon historique', {
                    href: path('index_spicy_match_history'),
                    variant: 'outline',
                    icon: 'fa-solid fa-clock-rotate-left'
                }) }}
            </div>
        {% else %}
            <div class="space-y-3">
                {% for history in spicymatch_histories %}
                    <div class="bg-white border border-stone-200 rounded-xl shadow-sm hover:shadow-md hover:border-turmeric-400/50 transition-all p-5"
                         x-data="historyItem(
                            {{ history.id }},
                            '{{ path('rename_spicy_match_history', {id: history.id}) }}',
                            '{{ path('toggle_favorite_spicy_match_history', {id: history.id}) }}',
                            '{{ csrf_token('history_action_' ~ history.id) }}',
                            '{{ history.title ? history.title|e('js') : '' }}',
                            {{ history.isFavorite ? 'true' : 'false' }},
                            '{{ ('Recette du ' ~ history.createdAt|date('d/m/Y à H:i'))|e('js') }}'
                         )">
                        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                            <div class="flex-1 min-w-0">
                                {# Titre inline-éditable (double-clic ou clic icône crayon) #}
                                <div class="mb-2 group" @dblclick.stop="startEdit">
                                    <h2 x-show="!editing"
                                        class="inline-flex items-center gap-1.5 text-lg font-semibold text-stone-800 cursor-pointer hover:text-saffron-700 transition-colors"
                                        title="Double-cliquez pour renommer">
                                        <span x-text="displayTitle()"></span>
                                        <button type="button"
                                                @click.stop="startEdit"
                                                class="opacity-0 group-hover:opacity-100 transition-opacity text-stone-300 hover:text-saffron-600 text-[11px] leading-none"
                                                title="Renommer">
                                            <i class="fa-solid fa-pencil"></i>
                                        </button>
                                    </h2>
                                    <input x-show="editing"
                                           x-model="title"
                                           x-ref="titleInput"
                                           x-effect="editing && $nextTick(() => $refs.titleInput?.focus())"
                                           @blur="saveTitle"
                                           @keydown.enter="saveTitle"
                                           @keydown.escape="cancelEdit"
                                           @click.stop
                                           class="w-full text-lg font-semibold text-stone-800 border border-saffron-300 rounded-lg px-2 py-0.5 focus:outline-none focus:ring-2 focus:ring-saffron-600/30"
                                           :placeholder="fallbackTitle">
                                </div>
                                <div class="flex flex-wrap gap-1.5 items-center">
                                    {% for spice in history.spicyMatch.spices %}
                                        <span class="inline-flex items-center gap-1.5 bg-spice-surface border border-spice-border text-stone-700 text-xs font-medium px-2.5 py-1 rounded-full">
                                            {{ spice.name }}
                                        </span>
                                    {% endfor %}
                                    {% if history.spicyMatch.isManual %}
                                        <span class="inline-flex items-center gap-1 text-[11px] font-medium text-stone-500 bg-stone-100 border border-stone-200 px-2 py-0.5 rounded-full" title="Mélange créé manuellement — compatibilité non garantie">
                                            <i class="fa-solid fa-hand text-[9px]"></i>Manuel
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="flex items-center gap-4 shrink-0">
                                {# Étoile favori cliquable — retire des favoris #}
                                <button type="button"
                                        @click.stop="toggleFavorite"
                                        x-show="favorite"
                                        class="text-xl transition-colors focus:outline-none text-turmeric-500 hover:text-stone-300"
                                        title="Retirer des favoris">
                                    <i class="fa-solid fa-star"></i>
                                </button>
                                <span class="text-sm text-stone-400">{{ history.createdAt|date('d/m/Y') }}</span>
                                <a href="{{ path('view_spicy_match_history', {'id': history.id}) }}"
                                   class="text-stone-300 hover:text-saffron-600 transition-colors"
                                   @click.stop>
                                    <i class="fa-solid fa-chevron-right text-sm"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
