{% extends 'base.html.twig' %}

{% block title %}Historique des mélanges{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-stone-800">
                <i class="fa-solid fa-clock-rotate-left text-saffron-600 mr-2"></i>Historique des mélanges
            </h1>
            <p class="mt-2 text-stone-500">Retrouvez toutes vos recettes sauvegardées.</p>
        </div>

        <turbo-frame id="history_frame_id">
            {% import "components/_macro_card_spicy_match_history.html.twig" as macroCardSpicyMatchHistory %}

            {% if spicymatch_histories is empty %}
                <div class="text-center py-16">
                    <i class="fa-solid fa-flask text-stone-300 text-5xl mb-4 block"></i>
                    <p class="text-stone-500 text-lg mb-6">Vous n'avez pas encore de mélange sauvegardé.</p>
                    <a href="{{ path('index_spicy_match') }}"
                       class="btn-pill-primary mt-2">
                        <i class="fa-solid fa-fire"></i>Créer mon premier mélange
                    </a>
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for history in spicymatch_histories %}
                        <a class="block bg-white border border-stone-200 rounded-xl shadow-sm hover:shadow-md hover:border-saffron-400/50 transition-all p-5"
                           href="{{ path('view_spicy_match_history', {'id': history.id}) }}">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <div class="flex-1">
                                    <h2 class="text-lg font-semibold text-stone-800 mb-2">
                                        {% if history.title is null %}
                                            Recette du {{ history.createdAt|date('d/m/Y à H:i') }}
                                        {% else %}
                                            {{ history.title }}
                                        {% endif %}
                                    </h2>
                                    <div class="flex flex-wrap gap-1.5">
                                        {% for spice in history.spicyMatch.spices %}
                                            {{ macroCardSpicyMatchHistory.cardSpicyMatch(spice) }}
                                        {% endfor %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-4 shrink-0">
                                    {% if history.isFavorite %}
                                        <i class="fa-solid fa-star text-turmeric-500 text-xl" aria-label="Favori" role="img"></i>
                                    {% else %}
                                        <i class="fa-regular fa-star text-stone-300 text-xl" aria-hidden="true"></i>
                                    {% endif %}
                                    <span class="text-sm text-stone-400">{{ history.createdAt|date('d/m/Y') }}</span>
                                    <i class="fa-solid fa-chevron-right text-stone-300 text-sm"></i>
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% endif %}
        </turbo-frame>
    </div>
{% endblock %}
