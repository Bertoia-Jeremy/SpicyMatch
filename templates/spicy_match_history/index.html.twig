{% extends 'base.html.twig' %}

{% block title %}Historique des mélanges{% endblock %}

{% block body %}
    {% import 'macros/buttons.html.twig' as buttons %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-stone-800">
                <i class="fa-solid fa-clock-rotate-left text-saffron-600 mr-2"></i>Historique des mélanges
            </h1>
            <p class="mt-2 text-stone-500">Retrouvez toutes vos recettes sauvegardées.</p>
            {% if favoriteCount > 0 %}
                <a href="{{ path('favorites_spicy_match_history') }}"
                   class="inline-flex items-center gap-2 mt-4 text-sm text-turmeric-600 hover:text-turmeric-500 font-medium transition-colors">
                    <i class="fa-solid fa-star text-xs"></i>
                    Voir mes favoris
                    <span class="bg-turmeric-100 text-turmeric-700 text-xs font-bold px-2 py-0.5 rounded-full">{{ favoriteCount }}</span>
                </a>
            {% endif %}
        </div>

        <turbo-frame id="history_frame_id">
            {% import "components/_macro_card_spicy_match_history.html.twig" as macroCardSpicyMatchHistory %}

            {% if spicymatch_histories is empty %}
                <div class="text-center py-16">
                    <i class="fa-solid fa-flask text-stone-300 text-5xl mb-4 block"></i>
                    <p class="text-stone-500 text-lg mb-6">Vous n'avez pas encore de mélange sauvegardé.</p>
                    {{ buttons.button('Créer mon premier mélange', {
                        href: path('index_spicy_match'),
                        variant: 'primary',
                        class: 'mt-2',
                        icon: 'fa-solid fa-fire'
                    }) }}
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for history in spicymatch_histories %}
                        <div class="bg-white border border-stone-200 rounded-xl shadow-sm hover:shadow-md hover:border-saffron-400/50 transition-all p-5"
                             x-data="{
                                 editing: false,
                                 title: '{{ history.title ? history.title|e('js') : '' }}',
                                 favorite: {{ history.isFavorite ? 'true' : 'false' }},
                                 fallbackTitle: '{{ ('Recette du ' ~ history.createdAt|date('d/m/Y à H:i'))|e('js') }}',
                                 async saveTitle() {
                                     this.editing = false;
                                     const t = this.title.trim();
                                     try {
                                         const res = await fetch('{{ path('rename_spicy_match_history', {id: history.id}) }}', {
                                             method: 'POST',
                                             headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                                             body: JSON.stringify({ title: t, _token: '{{ csrf_token('history_action_' ~ history.id) }}' })
                                         });
                                         if (!res.ok) { console.error('Rename failed', res.status); }
                                     } catch (e) { console.error('Rename error', e); }
                                 },
                                 async toggleFavorite() {
                                     try {
                                         const res = await fetch('{{ path('toggle_favorite_spicy_match_history', {id: history.id}) }}', {
                                             method: 'POST',
                                             headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': '{{ csrf_token('history_action_' ~ history.id) }}' }
                                         });
                                         if (!res.ok) { console.error('Toggle failed', res.status); return; }
                                         const data = await res.json();
                                         this.favorite = data.favorite;
                                     } catch (e) { console.error('Toggle error', e); }
                                 }
                             }">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <div class="flex-1 min-w-0">
                                    {# Titre inline-éditable (double-clic ou clic icône crayon) #}
                                    <div class="mb-2 group" @dblclick.stop="editing = true">
                                        <h2 x-show="!editing"
                                            class="inline-flex items-center gap-1.5 text-lg font-semibold text-stone-800 cursor-pointer hover:text-saffron-700 transition-colors"
                                            title="Double-cliquez pour renommer">
                                            <span x-text="title || fallbackTitle"></span>
                                            <button type="button"
                                                    @click.stop="editing = true"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity text-stone-300 hover:text-saffron-600 text-[11px] leading-none"
                                                    title="Renommer">
                                                <i class="fa-solid fa-pencil"></i>
                                            </button>
                                        </h2>
                                        <input x-show="editing"
                                               x-model="title"
                                               x-ref="titleInput"
                                               x-init="$watch('editing', v => v && $nextTick(() => $refs.titleInput.focus()))"
                                               @blur="saveTitle()"
                                               @keydown.enter="saveTitle()"
                                               @keydown.escape="editing = false"
                                               @click.stop
                                               class="w-full text-lg font-semibold text-stone-800 border border-saffron-300 rounded-lg px-2 py-0.5 focus:outline-none focus:ring-2 focus:ring-saffron-600/30"
                                               :placeholder="fallbackTitle">
                                    </div>
                                    <div class="flex flex-wrap gap-1.5">
                                        {% for spice in history.spicyMatch.spices %}
                                            {{ macroCardSpicyMatchHistory.cardSpicyMatch(spice) }}
                                        {% endfor %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-4 shrink-0">
                                    {# Étoile favori cliquable #}
                                    <button type="button"
                                            @click.stop="toggleFavorite()"
                                            class="text-xl transition-colors focus:outline-none"
                                            :class="favorite ? 'text-turmeric-500 hover:text-turmeric-400' : 'text-stone-300 hover:text-turmeric-400'"
                                            :title="favorite ? 'Retirer des favoris' : 'Ajouter aux favoris'">
                                        <i :class="favorite ? 'fa-solid fa-star' : 'fa-regular fa-star'"></i>
                                    </button>
                                    <span class="text-sm text-stone-400">{{ history.createdAt|date('d/m/Y') }}</span>
                                    <a href="{{ path('view_spicy_match_history', {'id': history.id}) }}"
                                       class="text-stone-300 hover:text-saffron-600 transition-colors"
                                       @click.stop>
                                        <i class="fa-solid fa-chevron-right text-sm"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </turbo-frame>
    </div>
{% endblock %}
