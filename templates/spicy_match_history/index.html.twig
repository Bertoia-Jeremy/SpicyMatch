{% extends 'base.html.twig' %}

{% block title %}Historique des mélanges{% endblock %}

{% block body %}
    {% import 'macros/buttons.html.twig' as buttons %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="text-center mb-10">
            <h1 class="text-4xl font-bold text-stone-800">
                <i class="fa-solid fa-clock-rotate-left text-saffron-600 mr-2" aria-hidden="true"></i>{{ 'ui.history.title'|trans }}
            </h1>
            <p class="mt-2 text-stone-500">{{ 'ui.history.subtitle'|trans }}</p>
            <div x-data="favoriteCount({{ favoriteCount }})"
                 @toast.window="onToast($event)"
                 x-show="count > 0"
                 x-transition>
                <a href="{{ path('favorites_spicy_match_history') }}"
                   class="inline-flex items-center gap-2 mt-4 text-sm text-turmeric-600 hover:text-turmeric-500 font-medium transition-colors">
                    <i class="fa-solid fa-star text-xs" aria-hidden="true"></i>
                    {{ 'ui.history.see_favorites'|trans }}
                    <span class="bg-turmeric-100 text-turmeric-700 text-xs font-bold px-2 py-0.5 rounded-full" x-text="count"></span>
                </a>
            </div>
        </div>

        <turbo-frame id="history_frame_id">

            {% if spicymatch_histories is empty %}
                <div class="text-center py-16">
                    <i class="fa-solid fa-flask text-stone-300 text-5xl mb-4 block" aria-hidden="true"></i>
                    <p class="text-stone-500 text-lg mb-6">{{ 'ui.history.none_yet'|trans }}</p>
                    {{ buttons.button('ui.history.create_first'|trans, {
                        href: path('index_spicy_match'),
                        variant: 'primary',
                        class: 'mt-2',
                        icon: 'fa-solid fa-fire'
                    }) }}
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for history in spicymatch_histories %}
                        <div class="bg-white border border-stone-200 rounded-xl shadow-sm hover:shadow-md hover:border-saffron-400/50 transition-all p-5"
                             x-data="historyItem(
                                {{ history.id }},
                                '{{ path('rename_spicy_match_history', {id: history.id}) }}',
                                '{{ path('toggle_favorite_spicy_match_history', {id: history.id}) }}',
                                '{{ csrf_token('history_action_' ~ history.id) }}',
                                '{{ history.title ? history.title|e('js') : '' }}',
                                {{ history.isFavorite ? 'true' : 'false' }},
                                '{{ ('ui.common.recipe_of'|trans({'%date%': history.createdAt|format_datetime('medium', 'short')}))|e('js') }}'
                             )">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <div class="flex-1 min-w-0">
                                    {# Titre inline-éditable (double-clic ou clic icône crayon) #}
                                    <div class="mb-2 group" @dblclick.stop="startEdit">
                                        <h2 x-show="!editing"
                                            class="inline-flex items-center gap-1.5 text-lg font-semibold text-stone-800 cursor-pointer hover:text-saffron-700 transition-colors"
                                            title="{{ 'ui.history.rename_hint'|trans }}">
                                            <span x-text="displayTitle()"></span>
                                            <button type="button"
                                                    @click.stop="startEdit"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity text-stone-300 hover:text-saffron-600 text-[11px] leading-none"
                                                    title="{{ 'ui.history.rename'|trans }}">
                                                <i class="fa-solid fa-pencil" aria-hidden="true"></i>
                                            </button>
                                        </h2>
                                        <input x-show="editing"
                                               x-model="title"
                                               x-ref="titleInput"
                                               @blur="saveTitle"
                                               @keydown.enter="saveTitle"
                                               @keydown.escape="cancelEdit"
                                               @click.stop
                                               class="w-full text-lg font-semibold text-stone-800 border border-saffron-300 rounded-lg px-2 py-0.5 focus:outline-none focus:ring-2 focus:ring-saffron-600/30"
                                               :placeholder="fallbackTitle">
                                    </div>
                                    <div class="flex flex-wrap gap-1.5 items-center">
                                        {% for spice in history.spicyMatch.spices %}
                                            <span class="inline-flex items-center gap-1.5 bg-spice-surface border border-spice-border text-stone-700 text-xs font-medium px-2.5 py-1 rounded-full">
                                                {{ spice.getLocalizedName(app.request.locale) }}
                                            </span>
                                        {% endfor %}
                                        {% if history.spicyMatch.isManual %}
                                            <span class="inline-flex items-center gap-1 text-[11px] font-medium text-stone-500 bg-stone-100 border border-stone-200 px-2 py-0.5 rounded-full" title="{{ 'ui.history.manual_tooltip'|trans }}">
                                                <i class="fa-solid fa-hand text-[9px]" aria-hidden="true"></i>{{ 'ui.history.manual'|trans }}
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-4 shrink-0">
                                    {# Étoile favori cliquable #}
                                    <button type="button"
                                            @click.stop="toggleFavorite"
                                            class="text-xl transition-colors focus:outline-none"
                                            :class="starButtonClass()"
                                            :title="starTitle()">
                                        <i :class="starIconClass()"></i>
                                    </button>
                                    <span class="text-sm text-stone-400">{{ history.createdAt|format_date('medium') }}</span>
                                    <a href="{{ path('view_spicy_match_history', {'id': history.id}) }}"
                                       class="text-stone-300 hover:text-saffron-600 transition-colors"
                                       @click.stop>
                                        <i class="fa-solid fa-chevron-right text-sm" aria-hidden="true"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </turbo-frame>
    </div>
{% endblock %}
