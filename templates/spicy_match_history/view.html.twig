{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.common.recipe_label'|trans }} — {{ spicyMatchHistory.title ?? 'ui.common.blend_of'|trans({'%date%': spicyMatchHistory.createdAt|format_date('medium')}) }}{% endblock %}

{% block body %}

{% set loc = app.request.locale %}

{# ─── Maps de données ─────────────────────────────────────────────────── #}
{% set cookingStepBySpice = {} %}
{% for step, cookings in cookingsByStep %}
  {% for cooking in cookings %}
    {% set cookingStepBySpice = cookingStepBySpice|merge({(cooking.spice.id): cooking.cookingStep}) %}
  {% endfor %}
{% endfor %}

{% set prepTitleBySpice = {} %}
{% for prep in preparations %}
  {% set prepTitleBySpice = prepTitleBySpice|merge({(prep.spice.id): prep.title}) %}
{% endfor %}

{% set shownGroups = [] %}
{% set shownGroupIds = [] %}
{% for prep in preparations %}
  {% if prep.spice.aromaticGroups is defined and prep.spice.aromaticGroups.id not in shownGroupIds %}
    {% set shownGroups = shownGroups|merge([prep.spice.aromaticGroups]) %}
    {% set shownGroupIds = shownGroupIds|merge([prep.spice.aromaticGroups.id]) %}
  {% endif %}
{% endfor %}

{% set filledMomentsCount = cookingsByStep|filter(v => v is not empty)|length %}
{% set uniqueMethods = [] %}
{% for prep in preparations %}
  {% if prep.title not in uniqueMethods %}
    {% set uniqueMethods = uniqueMethods|merge([prep.title]) %}
  {% endif %}
{% endfor %}

{% set defaultTitle = 'ui.common.recipe_of'|trans({'%date%': spicyMatchHistory.createdAt|format_datetime('medium', 'short')}) %}
{% set displayTitle = spicyMatchHistory.title ?? defaultTitle %}

<div
  x-data="recetteView(
    {{ spicyMatchHistory.id }},
    '{{ path('rename_spicy_match_history', {id: spicyMatchHistory.id}) }}',
    '{{ path('toggle_favorite_spicy_match_history', {id: spicyMatchHistory.id}) }}',
    '{{ csrf_token('history_action_' ~ spicyMatchHistory.id) }}',
    '{{ displayTitle|e('js') }}',
    {{ spicyMatchHistory.isFavorite ? 'true' : 'false' }}
  )"
  class="min-h-screen etamine-paper"
  style="background-color: #F5ECDB; color: #2A1F14;"
>

  {# ===== TOP BAR ===== #}
  <header class="max-w-[1180px] mx-auto px-6 pt-6 pb-3 flex items-center justify-between">
    <a href="{{ path('index_spicy_match') }}"
       class="flex items-center gap-2 text-sm transition-colors"
       style="color: #5A4A38;"
       onmouseover="this.style.color='#2A1F14'" onmouseout="this.style.color='#5A4A38'">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M14 6l-6 6 6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Retour au Lab
    </a>
    <div class="flex items-center gap-2"></div>
  </header>

  {# ===== HERO / FOLIO ===== #}
  <section class="max-w-[1180px] mx-auto px-6 pt-3 pb-6">
    <div class="flex items-start gap-4 mb-2">
      <span class="hex flex-shrink-0 mt-1 grid place-items-center"
            style="width:48px; height:54px; background: linear-gradient(180deg,#D2773A,#9A4720);">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 5h7a3 3 0 0 1 3 3v12M20 5h-7a3 3 0 0 0-3 3v12M4 5v15h7M20 5v15h-7" stroke="#FBF5E9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>

      <div class="flex-1 min-w-0">
        <div class="smallcaps mb-2">
          {{ 'ui.recipe.folio'|trans({'%id%': '%04d'|format(spicyMatchHistory.id)}) }}
        </div>

        <div class="flex items-baseline gap-3 flex-wrap">
          <h1 class="font-display leading-[1] text-ink-900" style="font-size: clamp(32px, 5vw, 52px);">
            <span
              x-ref="titleEl"
              contenteditable="true"
              spellcheck="false"
              role="textbox"
              aria-label="{{ 'ui.recipe.rename_aria'|trans }}"
              class="outline-none rounded px-1 -mx-1 cursor-text"
              @blur="saveTitle($event.target)"
              @keydown.enter.prevent="$event.target.blur()"
              x-text="title"
            >{{ displayTitle }}</span>
          </h1>
          <button class="icon-btn" @click="$refs.titleEl.focus()" title="{{ 'ui.recipe.rename'|trans }}" aria-label="{{ 'ui.recipe.rename_aria'|trans }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M16 4l4 4-12 12H4v-4L16 4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

        <div class="mt-3 flex items-center gap-4 flex-wrap">
          <button
            class="fav"
            :class="favClass()"
            @click="toggleFavorite()"
            :aria-pressed="favorite"
            aria-label="{{ 'ui.recipe.add_favorite'|trans }}"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2l2.5 5 5.5.8-4 3.9.9 5.5L12 14.8 7.1 17.2 8 11.7 4 7.8l5.5-.8L12 2z"/>
            </svg>
            <span x-text="favLabel()">{{ spicyMatchHistory.isFavorite ? 'ui.recipe.in_favorites'|trans : 'ui.recipe.add_favorite'|trans }}</span>
          </button>

          <div class="hidden md:flex items-center gap-6 ml-2">
            <div class="stat">
              <span class="stat-num">{{ spicyMatch.spices|length }}</span>
              <span class="stat-label">{{ 'ui.recipe.spices'|trans({'%count%': spicyMatch.spices|length}) }}</span>
            </div>
            <div class="stat">
              <span class="stat-num">{{ filledMomentsCount }}</span>
              <span class="stat-label">{{ 'ui.recipe.moments'|trans({'%count%': filledMomentsCount}) }}</span>
            </div>
            <div class="stat">
              <span class="stat-num">{{ uniqueMethods|length }}</span>
              <span class="stat-label">{{ 'ui.recipe.methods'|trans({'%count%': uniqueMethods|length}) }}</span>
            </div>
            <div class="stat">
              <span class="stat-num">{{ sharedCompounds|length > 0 ? sharedCompounds|length : '∅' }}</span>
              <span class="stat-label">{{ 'ui.recipe.shared_compound'|trans }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-[1180px] mx-auto px-6">
    <div class="rule-dots my-2"></div>
  </div>

  {# ===== CARTE DU MOMENT (contexte culinaire persisté — Étape 3E-3) ===== #}
  <section class="max-w-[1180px] mx-auto px-6 pt-6 pb-2">
    <div class="flex flex-wrap items-center gap-4 px-5 py-4 rounded-2xl border"
         style="border-color: rgba(154,71,32,0.18); background: linear-gradient(180deg, #FBF5E9 0%, #F5ECDB 100%);">
      <span class="hex grid place-items-center"
            style="width:40px; height:46px; background: linear-gradient(180deg,#D2773A,#9A4720);">
        <i class="fa-solid {{ culinaryContext.icon }} text-[14px]" style="color:#FBF5E9;" aria-hidden="true"></i>
      </span>
      <div class="flex-1 min-w-0">
        <div class="smallcaps mb-0.5" style="color:#7A6A55;">{{ 'ui.recipe.moment_card'|trans }}</div>
        <div class="flex items-baseline gap-2 flex-wrap">
          <span class="font-display text-lg" style="color:#2A1F14;">{{ culinaryContext.label }}</span>
          <span class="smallcaps" style="color:#9A4720;">{{ culinaryContext.matrix.label|trans }}</span>
        </div>
        {% if culinaryContext.isCustom %}
          <p class="text-[12px] mt-1 tabular-nums" style="color:#5A4A38;">
            {% if culinaryContext.fatRatio > 0 %}
              <span>{{ (culinaryContext.fatRatio * 100)|round }}&nbsp;{{ 'ui.recipe.fat'|trans }}</span>
              <span style="color:#7A6A55;">·</span>
              <span>{{ (culinaryContext.waterRatio * 100)|round }}&nbsp;{{ 'ui.recipe.aqueous'|trans }}</span>
            {% endif %}
            {% if culinaryContext.cookingTimeMin > 0 %}
              {% if culinaryContext.fatRatio > 0 %}<span style="color:#7A6A55;">·</span>{% endif %}
              <span>{{ culinaryContext.cookingTimeMin }}&nbsp;min @ {{ culinaryContext.temperatureCelsius }}&nbsp;°C</span>
            {% endif %}
          </p>
        {% else %}
          <p class="text-[12px] mt-1" style="color:#7A6A55;">{{ 'ui.recipe.dry_profile'|trans }}</p>
        {% endif %}
      </div>
    </div>
  </section>

  {# ===== PRÉPARATION DES ÉPICES ===== #}
  <section class="max-w-[1180px] mx-auto px-6 pt-8 pb-6">
    <div class="flex items-center gap-3 mb-5">
      <span class="section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 11h16M5 11c0 4 3 7 7 7s7-3 7-7M9 7l2-3m3 3l-2-3M16 6l1-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <div>
        <h2 class="font-display leading-tight" style="font-size: clamp(22px, 3vw, 30px); color: #2A1F14;">{{ 'ui.recipe.prep_title'|trans }}</h2>
        <div class="smallcaps mt-1">{{ 'ui.recipe.prep_sub'|trans({'%count%': preparations|length}) }}</div>
      </div>
    </div>

    <div class="space-y-4">
      {% for prep in preparations %}
        {% set prepMatrix = prep.applicableMatrix %}
        {% set prepApplicable = prepMatrix is null or prepMatrix == culinaryContext.matrix %}
        <article class="card prep {{ prepApplicable ? '' : 'opacity-60' }}" role="article">
          {# Colonne 1 — Thumb hexagonal #}
          <div class="prep-thumb stripes" aria-hidden="true">
            <span class="placeholder-label">{{ prep.spice.name|split(' ')|first|slice(0,4)|upper }}</span>
          </div>

          {# Colonne 2 — Narration #}
          <div class="min-w-0">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="prep-name {{ prepApplicable ? '' : 'line-through' }}">{{ prep.spice.getLocalizedName(loc) }}</span>
              <span class="prep-form">— {{ prep.getLocalizedTitle(loc) }}</span>
              {% if not prepApplicable %}
                {# UX-4 : tooltip explicatif + contraste plus visible (turmeric-50/saffron-900). #}
                <span class="smallcaps px-2 py-0.5 rounded-full inline-flex items-center gap-1 cursor-help"
                      style="background:#FEF3C7; color:#78350F; border:1px solid #FCD34D;"
                      role="note"
                      aria-label="{{ 'ui.recipe.out_of_matrix_aria'|trans({'%label%': prepMatrix.label|trans}) }}"
                      title="{{ 'ui.recipe.out_of_matrix_title'|trans({'%label%': prepMatrix.label|trans}) }}">
                  <i class="fa-solid fa-triangle-exclamation text-[9px]" aria-hidden="true"></i>
                  {{ 'ui.recipe.out_of_matrix'|trans({'%label%': prepMatrix.label|trans}) }}
                </span>
              {% endif %}
            </div>
            <div class="family-mark mt-2" style="color: {{ prep.spice.aromaticGroups.color ?? '#7A6A55' }}">
              {{ prep.spice.aromaticGroups.getLocalizedName(loc) }}
            </div>
            {% if prep.getLocalizedText(loc) %}
              <p class="mt-2 text-[14px] leading-relaxed" style="color: #5A4A38;">{{ prep.getLocalizedText(loc) }}</p>
            {% endif %}
          </div>

          {# Colonne 3 — Méthode #}
          <div class="method-panel">
            <span class="method-tag">{{ 'ui.recipe.method'|trans }}</span>
            <div class="method-row">
              <div class="method-icon">
                {{ include('components/_etamine_icons.html.twig', { name: prep.title }) }}
              </div>
              <div>
                <div class="method-name">{{ prep.getLocalizedTitle(loc) }}</div>
                {% if prep.getLocalizedAdvantages(loc) %}
                  <div class="method-hint">{{ prep.getLocalizedAdvantages(loc) }}</div>
                {% endif %}
              </div>
            </div>
            {% set spiceStep = cookingStepBySpice[prep.spice.id] ?? null %}
            {% if spiceStep %}
              <div class="method-step">
                <span class="pip-tiny"></span>{{ spiceStep }}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </section>

  {# ===== MOMENTS D'INSERTION ===== #}
  <section class="max-w-[1180px] mx-auto px-6 pt-8 pb-6">
    <div class="flex items-center gap-3 mb-5">
      <span class="section-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M5 12l4-4M5 12l4 4M19 12l-4-4M19 12l-4 4M12 4v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <div>
        <h2 class="font-display leading-tight" style="font-size: clamp(22px, 3vw, 30px); color: #2A1F14;">{{ 'ui.recipe.moments_title'|trans }}</h2>
        <div class="smallcaps mt-1">{{ 'ui.recipe.moments_sub'|trans }}</div>
      </div>
    </div>

    <div class="hidden md:flex items-center gap-3 mb-3 smallcaps">
      <span>{{ 'ui.recipe.earlier'|trans }}</span>
      <span class="rule-dots flex-1"></span>
      <span>{{ 'ui.recipe.later'|trans }}</span>
    </div>

    {% set momentNames = {0: 'ui.recipe.moment_before'|trans, 1: 'ui.recipe.moment_start'|trans, 2: 'ui.recipe.moment_middle'|trans, 3: 'ui.recipe.moment_end'|trans, 4: 'ui.recipe.moment_after'|trans} %}
    {% set momentNums  = {0: '01',    1: '02',    2: '03',    3: '04',    4: '05'} %}

    <div class="timeline">
      {% for step in 0..4 %}
        {% set cookings = cookingsByStep[step] ?? [] %}
        <div class="moment {{ cookings|length ? 'filled' }}">
          <div class="moment-step">
            <div class="moment-num">{{ momentNums[step] }}</div>
            <div class="moment-name">{{ momentNames[step] }}</div>
          </div>
          {% if cookings|length %}
            {% for cooking in cookings %}
              <div class="moment-medallion">
                <div class="medallion-thumb stripes" aria-hidden="true">
                  <span class="tiny">{{ cooking.spice.name|slice(0,2)|upper }}</span>
                </div>
                <div>
                  <div class="medallion-text">{{ cooking.spice.name }}</div>
                  <div class="medallion-method">{{ prepTitleBySpice[cooking.spice.id] ?? '' }}</div>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="moment-empty"><span>{{ 'ui.recipe.moment_free'|trans }}</span></div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </section>

  {# ===== TIMELINE CINÉTIQUE (Étape 3E-3) ===== #}
  {% set kineticsTotal = cookingTimeline.head|length + cookingTimeline.heart|length + cookingTimeline.base|length %}
  {% if kineticsTotal > 0 %}
    <section class="max-w-[1180px] mx-auto px-6 pt-8 pb-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="section-icon">
          <i class="fa-solid fa-wave-square text-[16px]" aria-hidden="true"></i>
        </span>
        <div>
          <h2 class="font-display leading-tight" style="font-size: clamp(22px, 3vw, 30px); color: #2A1F14;">{{ 'ui.recipe.kinetics_title'|trans }}</h2>
          <div class="smallcaps mt-1">
            {{ 'ui.recipe.kinetics_sub'|trans }}
            {% if culinaryContext.cookingTimeMin > 0 %}
              <span style="color:#9A4720;">{{ 'ui.recipe.kinetics_retention'|trans({'%temp%': culinaryContext.temperatureCelsius, '%time%': culinaryContext.cookingTimeMin}) }}</span>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {% set kineticsConfig = {
          head:  {label: 'enum.kinetics.head'|trans,  icon: '💨', blurb: 'ui.recipe.kinetics_head_blurb'|trans,  accent: '#D2773A'},
          heart: {label: 'enum.kinetics.heart'|trans, icon: '❤️', blurb: 'ui.recipe.kinetics_heart_blurb'|trans, accent: '#9A4720'},
          base:  {label: 'enum.kinetics.base'|trans,  icon: '🪨', blurb: 'ui.recipe.kinetics_base_blurb'|trans,  accent: '#5A4A38'}
        } %}
        {% for kineticsKey in ['head', 'heart', 'base'] %}
          {% set bucket = cookingTimeline[kineticsKey] %}
          {% set cfg = kineticsConfig[kineticsKey] %}
          <div class="rounded-2xl border px-5 py-4"
               style="border-color: rgba(122,106,85,0.25); background:#FBF5E9;">
            <div class="flex items-baseline justify-between mb-2">
              <span class="font-display text-base" style="color: {{ cfg.accent }};">
                <span aria-hidden="true">{{ cfg.icon }}</span> {{ cfg.label }}
              </span>
              <span class="smallcaps tabular-nums" style="color:#7A6A55;">{{ bucket|length }} {{ 'ui.recipe.compounds'|trans({'%count%': bucket|length}) }}</span>
            </div>
            <p class="text-[11px] mb-3" style="color:#7A6A55;">{{ cfg.blurb }}</p>
            {% if bucket|length == 0 %}
              <p class="text-[12px] italic" style="color:#7A6A55;">{{ 'ui.recipe.no_compound_cat'|trans }}</p>
            {% else %}
              <ul class="flex flex-col gap-1.5">
                {% for entry in bucket %}
                  <li class="flex items-center justify-between gap-2 text-[13px]">
                    <span style="color:#2A1F14;">{{ entry.name }}</span>
                    {% if entry.retention is not null and culinaryContext.cookingTimeMin > 0 %}
                      {% set retentionPct = (entry.retention * 100)|round %}
                      {% set retentionColor = retentionPct >= 70 ? '#5A8A4A' : (retentionPct >= 30 ? '#9A6A20' : '#9A4720') %}
                      <span class="smallcaps tabular-nums"
                            style="color: {{ retentionColor }};"
                            title="{{ 'ui.recipe.retention_title'|trans }}">
                        {{ retentionPct }}&nbsp;%
                      </span>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if cookingTimeline.unknown|length > 0 %}
        <p class="text-[11px] mt-3" style="color:#7A6A55;">
          <i class="fa-solid fa-circle-info text-[10px] mr-1" aria-hidden="true"></i>
          {{ 'ui.recipe.no_physchem'|trans({'%count%': cookingTimeline.unknown|length, '%names%': cookingTimeline.unknown|map(e => e.name)|join(', ')}) }}
        </p>
      {% endif %}
    </section>
  {% endif %}

  {# ===== COMPARATIF MATRICIEL (Étape 3E-3 — Phase B/E) ===== #}
  {% if matrixGrid|length > 0 %}
    <section class="max-w-[1180px] mx-auto px-6 pt-8 pb-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="section-icon">
          <i class="fa-solid fa-grip-vertical text-[16px]" aria-hidden="true"></i>
        </span>
        <div>
          <h2 class="font-display leading-tight" style="font-size: clamp(22px, 3vw, 30px); color: #2A1F14;">{{ 'ui.recipe.matrix_title'|trans }}</h2>
          <div class="smallcaps mt-1">{{ 'ui.recipe.matrix_sub'|trans|raw }}</div>
        </div>
      </div>

      <div class="rounded-2xl border overflow-hidden"
           style="border-color: rgba(122,106,85,0.25); background:#FBF5E9;">
        <table class="w-full text-[13px]">
          <caption class="sr-only">{{ 'ui.recipe.matrix_caption'|trans }}</caption>
          <thead>
            <tr style="background: rgba(122,106,85,0.08);">
              <th scope="col" class="text-left px-4 py-3 smallcaps" style="color:#5A4A38;">{{ 'ui.recipe.col_spice'|trans }}</th>
              {% for matrixKey in ['air', 'water', 'oil'] %}
                {% set matrixLabel = ('enum.matrix.' ~ matrixKey)|trans %}
                {% set isCurrent = culinaryContext.matrix.value == matrixKey %}
                <th scope="col" class="px-3 py-3 text-center smallcaps"
                    style="color: {{ isCurrent ? '#9A4720' : '#5A4A38' }};">
                  {{ matrixLabel }}
                  {% if isCurrent %}
                    <i class="fa-solid fa-star text-[8px] ml-1" style="color:#D2773A;" title="{{ 'ui.recipe.current_matrix'|trans }}" aria-hidden="true"></i><span class="sr-only">{{ 'ui.recipe.current_matrix'|trans }}</span>
                  {% endif %}
                </th>
              {% endfor %}
            </tr>
          </thead>
          <tbody>
            {% for row in matrixGrid %}
              <tr style="border-top: 1px solid rgba(122,106,85,0.15);">
                <th scope="row" class="px-4 py-2.5 text-left font-normal" style="color:#2A1F14;">{{ row.name }}</th>
                {% for matrixKey in ['air', 'water', 'oil'] %}
                  {% set score = row.scores[matrixKey] %}
                  {% set isCurrent = culinaryContext.matrix.value == matrixKey %}
                  {% set isBest = score == max(row.scores) and score > 0 %}
                  <td class="px-3 py-2.5 text-center tabular-nums"
                      style="color: {{ score == 0 ? '#7A6A55' : (isCurrent ? '#9A4720' : '#2A1F14') }};
                             font-weight: {{ isBest ? '600' : '400' }};
                             background: {{ isCurrent ? 'rgba(210,119,58,0.06)' : 'transparent' }};"
                      title="{{ score == 0 ? 'ui.recipe.out_of_top5'|trans : 'ui.recipe.tanimoto_title'|trans }}">
                    {{ score == 0 ? '—' : score }}
                  </td>
                {% endfor %}
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <p class="text-[11px] mt-3" style="color:#7A6A55;">
        <i class="fa-solid fa-flask text-[10px] mr-1" style="color:#9A4720;" aria-hidden="true"></i>
        {{ 'ui.recipe.tanimoto_note'|trans }}
      </p>
    </section>
  {% endif %}

  {# ===== NOTE DE L'ALCHIMISTE ===== #}
  <section class="max-w-[1180px] mx-auto px-6 pt-4 pb-2">
    <div class="note-slip">
      <div class="note-mark">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 19l4-4L17 6a2 2 0 1 1 3 3l-9 9-4 4-3-3z" stroke="#FBF5E9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div>
        <div class="smallcaps mb-1">{{ 'ui.recipe.alchemist_note'|trans }}</div>
        <p class="font-display italic" style="font-size: clamp(18px, 2vw, 22px); line-height: 1.35; color: #2A1F14;">
          {% if sharedCompounds is not empty %}
            {{ 'ui.recipe.note_shared'|trans({'%count%': sharedCompounds|length}) }}
          {% elseif spicyMatch.isManual %}
            {{ 'ui.recipe.note_manual'|trans }}
          {% else %}
            {{ 'ui.recipe.note_contrast'|trans }}
          {% endif %}
        </p>
        {% if sharedCompounds is not empty %}
          <div class="mt-3 flex flex-wrap gap-2">
            {% for compound in sharedCompounds %}
              <a href="{{ path('view_aromatic_compound', {id: compound.id}) }}"
                 class="smallcaps hover:opacity-75 transition-opacity"
                 style="color: #9A4720;">
                {{ compound.getLocalizedName(loc) }}
              </a>
              {% if not loop.last %}<span style="color: #7A6A55;">·</span>{% endif %}
            {% endfor %}
          </div>
        {% elseif shownGroups|length %}
          <div class="mt-3 flex items-center gap-2 flex-wrap">
            {% for group in shownGroups %}
              <span class="family-mark" style="color: {{ group.color ?? '#7A6A55' }}">{{ group.getLocalizedName(loc) }}</span>
              {% if not loop.last %}<span style="color: #7A6A55;">·</span>{% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </section>

  {# ===== CTA BAS DE PAGE ===== #}
  <section class="max-w-[1180px] mx-auto px-6 pt-10 pb-20">
    <div class="flex justify-center">
      <a href="{{ path('index_spicy_match') }}"
         class="btn-primary px-8 py-3.5 rounded-full inline-flex items-center gap-3 text-base w-full md:w-auto justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 3h6M10 3v5L5 19a2 2 0 0 0 1.8 2.9h10.4A2 2 0 0 0 19 19l-5-11V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Créer un nouveau mélange
      </a>
    </div>
  </section>

</div>
{% endblock %}
