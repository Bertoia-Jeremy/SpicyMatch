{% extends 'base.html.twig' %}

{% block title %}SpicyMatch — Types d'épices{% endblock %}

{% block body %}
{% import 'macros/buttons.html.twig' as buttons %}

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-12">
        <span class="tag-primary mb-4 inline-block">Botanique</span>
        <h1 class="text-4xl font-bold text-stone-900 mb-3">Types d'épices</h1>
        <p class="text-stone-500 text-lg max-w-2xl mx-auto">Classification des épices selon leur origine végétale et leur nature biologique.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for type in spicyTypes %}
            <article class="card-warm p-6 flex flex-col h-full">
                <div class="w-12 h-12 rounded-xl bg-saffron-100 flex items-center justify-center mb-4">
                    <i class="fa-solid fa-tags text-saffron-600"></i>
                </div>
                <h2 class="text-xl font-bold text-stone-900 mb-2">{{ type.name }}</h2>
                {% if type.description %}
                    <p class="text-stone-500 text-sm line-clamp-3 mb-6 flex-1">{{ type.description }}</p>
                {% else %}
                    <p class="text-stone-400 text-sm italic mb-6 flex-1">Aucune description disponible.</p>
                {% endif %}
                
                {{ buttons.button('Voir les épices', {
                    href: path('view_spicy_type', {id: type.id}),
                    variant: 'outline',
                    size: 'sm',
                    icon: 'fa-solid fa-arrow-right',
                    icon_pos: 'right'
                }) }}
            </article>
        {% else %}
            <div class="col-span-full text-center py-12">
                <p class="text-stone-400">Aucun type répertorié pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</section>
{% endblock %}
