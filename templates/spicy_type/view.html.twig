{% extends 'base.html.twig' %}

{% block title %}{{ spicyType.name }} — SpicyMatch{% endblock %}

{% block body %}
{% import 'macros/buttons.html.twig' as buttons %}
{% import "components/_macro_card_spice.html.twig" as macroCardSpice %}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    {# Fil d'Ariane #}
    <nav class="mb-8">
        <a href="{{ path('index_spicy_type') }}" class="text-stone-500 hover:text-saffron-700 text-sm flex items-center gap-2 transition-colors">
            <i class="fa-solid fa-arrow-left text-xs" aria-hidden="true"></i>
            {{ 'ui.catalog.back_to_types'|trans }}
        </a>
    </nav>

    {# En-tête #}
    <header class="mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-saffron-100 text-saffron-700 text-xs font-bold uppercase tracking-wider mb-4">
            <i class="fa-solid fa-tags" aria-hidden="true"></i> {{ 'ui.catalog.type_badge'|trans }}
        </div>
        <h1 class="text-5xl font-display font-bold text-stone-900">{{ spicyType.name }}</h1>
    </header>

    {# Grille principale #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 mb-16">
        <div class="lg:col-span-2 space-y-8">
            <section class="card-warm p-8">
                <h2 class="text-xl font-bold text-stone-900 mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-circle-info text-saffron-500" aria-hidden="true"></i> {{ 'ui.catalog.definition'|trans }}
                </h2>
                <div class="text-stone-600 leading-relaxed space-y-4">
                    {{ spicyType.description|default('ui.catalog.no_definition_detailed'|trans)|nl2br }}
                </div>
            </section>

            {% if spicyType.cooking %}
                <section class="card-warm p-8">
                    <h2 class="text-xl font-bold text-stone-900 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-mortar-pestle text-saffron-500" aria-hidden="true"></i> {{ 'ui.catalog.general_usage'|trans }}
                    </h2>
                    <div class="text-stone-600 leading-relaxed">
                        {{ spicyType.cooking|nl2br }}
                    </div>
                </section>
            {% endif %}
        </div>

        <aside class="space-y-8">
            {% if spicyType.informations %}
                <section class="card-warm p-8">
                    <h2 class="text-lg font-bold text-stone-900 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-flask text-saffron-500" aria-hidden="true"></i> {{ 'ui.catalog.botanical_note'|trans }}
                    </h2>
                    <div class="text-sm text-stone-600 leading-relaxed">
                        {{ spicyType.informations|nl2br }}
                    </div>
                </section>
            {% endif %}
        </aside>
    </div>

    {# Zone Épices liées #}
    {% set allSpices = spicyType.spices %}
    <section class="pt-10 border-t border-stone-200" x-data="spicesLimit({{ allSpices|length }})">
        
        <div class="flex items-center justify-between mb-8">
            <h3 class="text-2xl font-bold text-stone-900 flex items-center gap-3">
                <i class="fa-solid fa-pepper-hot text-paprika-600" aria-hidden="true"></i> {{ 'ui.catalog.spices_of_type'|trans }}
                <span class="text-sm font-normal text-stone-400">({{ allSpices|length }})</span>
            </h3>

            {% if allSpices|length > 8 %}
                <div class="flex items-center bg-stone-100 p-1 rounded-xl">
                    <button @click="setGrid" :class="sliderToggleClass()" class="px-4 py-1.5 rounded-lg text-xs font-bold transition-all">{{ 'ui.catalog.view_slider'|trans }}</button>
                    <button @click="setList" :class="gridToggleClass()" class="px-4 py-1.5 rounded-lg text-xs font-bold transition-all">{{ 'ui.catalog.view_grid'|trans }}</button>
                </div>
            {% endif %}
        </div>
        
        {% if allSpices is not empty %}
            
            {# --- MODE SLIDER (8 épices max) --- #}
            <div x-show="!gridMode" class="space-y-6">
                <div class="embla" data-controller="carousel"
                     role="group" aria-roledescription="{{ 'ui.carousel.roledescription'|trans }}"
                     aria-label="{{ 'ui.carousel.label'|trans }}">
                    <div class="embla__viewport" data-carousel-target="viewport">
                        <div class="embla__container">
                            {% for spice in allSpices|slice(0, 8) %}
                                <div class="embla__slide">
                                    {{ macroCardSpice.cardSpice(spice, { compact: true }) }}
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    {% if allSpices|length > 1 %}
                    <div class="flex justify-end gap-2 mt-6">
                        <button type="button" class="embla__button" data-carousel-target="prev" data-action="carousel#prev"
                                aria-label="{{ 'ui.carousel.prev'|trans }}">
                            <i class="fa-solid fa-chevron-left text-xs" aria-hidden="true"></i>
                        </button>
                        <button type="button" class="embla__button" data-carousel-target="next" data-action="carousel#next"
                                aria-label="{{ 'ui.carousel.next'|trans }}">
                            <i class="fa-solid fa-chevron-right text-xs" aria-hidden="true"></i>
                        </button>
                    </div>
                    {% endif %}
                </div>
            </div>

            {# --- MODE GRILLE (Progressif) --- #}
            <div x-show="gridMode" x-cloak class="space-y-10">
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5">
                    {% for spice in allSpices %}
                        <div x-show="{{ loop.index }} <= limit" 
                             x-transition:enter="transition ease-out duration-300"
                             x-transition:enter-start="opacity-0 translate-y-4"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             class="h-full">
                            {{ macroCardSpice.cardSpice(spice, { compact: true }) }}
                        </div>
                    {% endfor %}
                </div>

                {% if allSpices|length > 8 %}
                <div class="flex justify-center" x-show="hasMore()">
                    {{ buttons.button('ui.catalog.load_more_spices'|trans, {
                        variant: 'outline',
                        icon: 'fa-solid fa-plus',
                        attr: { '@click': 'showMore' }
                    }) }}
                </div>
                {% endif %}
            </div>

        {% else %}
            <div class="card-warm p-10 text-center">
                <p class="text-stone-400 italic">{{ 'ui.catalog.no_linked_spices'|trans }}</p>
            </div>
        {% endif %}
    </section>
</div>
{% endblock %}
