{% extends 'users/dashboard.html.twig' %}

{% block content %}
<turbo-frame id="user_frame_id">

    {# Nav tabs dynamique #}
    {% set tabs = [
        { route: 'profile_user',       label: 'Profil' },
        { route: 'achievements_user',  label: 'Succès', icon: 'fa-solid fa-trophy text-xs mr-1' },
        { route: 'configuration_user', label: 'Configuration' },
        { route: 'history_user',       label: 'Historique' },
        { route: 'security_user',      label: 'Sécurité' },
    ] %}
    <div class="flex flex-wrap border-b border-stone-200 mt-6">
        {% for tab in tabs %}
            <a href="{{ path(tab.route) }}"
               class="px-4 py-2 text-sm font-medium {{ app.request.attributes.get('_route') == tab.route ? 'text-orange-600 border-b-2 border-orange-600' : 'text-stone-500 hover:text-stone-800 hover:border-b-2 hover:border-stone-300' }}">
                {% if tab.icon is defined %}<i class="{{ tab.icon }}"></i>{% endif %}
                {{ tab.label }}
            </a>
        {% endfor %}
    </div>

    <div class="p-4">
        {% if progression %}

            {# ── Construire le lookup slug → UserAchievement ─────────────── #}
            {% set unlockedMap = {} %}
            {% for ua in progression.userAchievements %}
                {% set unlockedMap = unlockedMap|merge({ (ua.achievement.slug): ua }) %}
            {% endfor %}

            {# ── Stats globales ──────────────────────────────────────────── #}
            {% set unlockedCount = progression.userAchievements|length %}
            {% set totalCount = allAchievements|length %}
            {% set xpFromAchievements = 0 %}
            {% for ua in progression.userAchievements %}
                {% set xpFromAchievements = xpFromAchievements + ua.achievement.xpReward %}
            {% endfor %}
            {% set globalPct = totalCount > 0 ? (unlockedCount / totalCount * 100)|round(0) : 0 %}

            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 mt-4">
                <div>
                    <h2 class="text-xl font-bold text-stone-800">
                        <i class="fa-solid fa-trophy text-amber-500 mr-2"></i>
                        {{ unlockedCount }} / {{ totalCount }} succès débloqués
                    </h2>
                    <p class="text-sm text-stone-500 mt-0.5">
                        +{{ xpFromAchievements }} XP gagnés via les succès
                    </p>
                </div>
                <div class="sm:w-52">
                    <div class="flex justify-between text-xs text-stone-500 mb-1">
                        <span>Progression globale</span>
                        <span>{{ globalPct }}%</span>
                    </div>
                    <div class="w-full bg-stone-200 rounded-full h-2">
                        <div class="h-2 rounded-full bg-amber-500 transition-all" style="width: {{ globalPct }}%"></div>
                    </div>
                </div>
            </div>

            {# ── Maps de classes par rarity ───────────────────────────────── #}
            {% set cardClasses = {
                'common':    'border-stone-300 bg-stone-50',
                'rare':      'border-blue-300 bg-blue-50',
                'epic':      'border-purple-300 bg-purple-50',
                'legendary': 'border-amber-400 bg-amber-50',
            } %}
            {% set badgeClasses = {
                'common':    'bg-stone-200 text-stone-700',
                'rare':      'bg-blue-100 text-blue-700',
                'epic':      'bg-purple-100 text-purple-700',
                'legendary': 'bg-amber-100 text-amber-700',
            } %}
            {% set rarityLabels = {
                'common':    'Commun',
                'rare':      'Rare',
                'epic':      'Épique',
                'legendary': 'Légendaire',
            } %}
            {% set iconCircleClasses = {
                'common':    'bg-stone-200 text-stone-600',
                'rare':      'bg-blue-100 text-blue-600',
                'epic':      'bg-purple-100 text-purple-600',
                'legendary': 'bg-amber-100 text-amber-600',
            } %}

            {# ── Grille achievements ──────────────────────────────────────── #}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for achievement in allAchievements %}
                    {% set rarity = achievement.rarity.value %}
                    {% set trigger = achievement.trigger.value %}
                    {% set isUnlocked = unlockedMap[achievement.slug] is defined %}
                    {% set ua = isUnlocked ? unlockedMap[achievement.slug] : null %}

                    {# Calcul progression pour cards verrouillées #}
                    {% set progressCurrent = 0 %}
                    {% set progressMax = achievement.triggerValue %}
                    {% set progressLabel = 'À venir' %}
                    {% if not isUnlocked %}
                        {% if trigger == 'first_match' %}
                            {% set progressCurrent = min(progression.totalMatches, 1) %}
                            {% set progressLabel = progressCurrent ~ ' / 1 mélange' %}
                        {% elseif trigger == 'n_matches' %}
                            {% set progressCurrent = min(progression.totalMatches, achievement.triggerValue) %}
                            {% set progressLabel = progressCurrent ~ ' / ' ~ achievement.triggerValue ~ ' mélanges' %}
                        {% elseif trigger == 'n_spices_used' %}
                            {% set progressCurrent = min(progression.uniqueSpicesUsed, achievement.triggerValue) %}
                            {% set progressLabel = progressCurrent ~ ' / ' ~ achievement.triggerValue ~ ' épices max' %}
                        {% endif %}
                    {% endif %}
                    {% set progressPct = progressMax > 0 ? (progressCurrent / progressMax * 100)|round(0) : 0 %}

                    <div class="relative border rounded-2xl p-5 flex flex-col gap-3
                                {{ cardClasses[rarity] ?? 'border-stone-200 bg-white' }}
                                {{ not isUnlocked ? 'opacity-60 grayscale' : '' }}
                                transition-all duration-200">

                        {# Indicateur en haut à droite #}
                        <div class="absolute top-3 right-3">
                            {% if isUnlocked %}
                                <i class="fa-solid fa-circle-check text-amber-500 text-sm"></i>
                            {% else %}
                                <i class="fa-solid fa-lock text-stone-400 text-sm"></i>
                            {% endif %}
                        </div>

                        {# Icône centrée dans un cercle coloré #}
                        <div class="flex justify-center">
                            <div class="w-14 h-14 rounded-full flex items-center justify-center text-2xl
                                        {{ isUnlocked ? (iconCircleClasses[rarity] ?? 'bg-amber-100 text-amber-600') : 'bg-stone-200 text-stone-500' }}">
                                <i class="{{ achievement.icon }}"></i>
                            </div>
                        </div>

                        {# Nom + description #}
                        <div class="text-center">
                            <div class="font-bold text-stone-800 text-sm mb-1">{{ achievement.name }}</div>
                            <div class="text-xs text-stone-500 leading-relaxed">{{ achievement.description }}</div>
                        </div>

                        {# Badges rarity + XP #}
                        <div class="flex items-center justify-center gap-2 flex-wrap">
                            <span class="text-xs px-2 py-0.5 rounded-full font-medium {{ badgeClasses[rarity] ?? 'bg-stone-100 text-stone-600' }}">
                                {{ rarityLabels[rarity] ?? rarity }}
                            </span>
                            <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-medium">
                                +{{ achievement.xpReward }} XP
                            </span>
                        </div>

                        {# Section basse : date ou barre de progression #}
                        <div class="mt-auto pt-1">
                            {% if isUnlocked %}
                                <p class="text-center text-xs text-stone-400">
                                    <i class="fa-solid fa-calendar-check mr-1"></i>
                                    Débloqué le {{ ua.unlockedAt|date('d/m/Y') }}
                                </p>
                            {% elseif progressLabel == 'À venir' %}
                                <p class="text-center text-xs text-stone-400 italic">
                                    <i class="fa-solid fa-hourglass-half mr-1"></i>Fonctionnalité à venir
                                </p>
                            {% else %}
                                <div class="flex justify-between text-xs text-stone-500 mb-1">
                                    <span>Progression</span>
                                    <span>{{ progressLabel }}</span>
                                </div>
                                <div class="w-full bg-stone-200 rounded-full h-1.5">
                                    <div class="h-1.5 rounded-full bg-orange-400 transition-all"
                                         style="width: {{ progressPct }}%"></div>
                                </div>
                            {% endif %}
                        </div>

                    </div>
                {% endfor %}
            </div>

        {% else %}
            <div class="text-center text-stone-500 py-16">
                <i class="fa-solid fa-trophy text-5xl text-stone-300 mb-4 block"></i>
                <p class="text-lg font-medium text-stone-700">Aucun succès pour l'instant</p>
                <p class="text-sm mt-1">Créez votre premier mélange pour débloquer des succès et gagner de l'XP !</p>
                <a href="{{ path('index_spicy_match') }}" data-haptic="medium" class="btn-pill-primary mt-6 inline-flex">
                    <i class="fa-solid fa-flask"></i> Créer mon premier mélange
                </a>
            </div>
        {% endif %}
    </div>

</turbo-frame>
{% endblock %}
