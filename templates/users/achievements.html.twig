{% extends 'users/dashboard.html.twig' %}

{% block content %}
{% import 'macros/buttons.html.twig' as buttons %}
<turbo-frame id="user_frame_id">

    {% include 'components/_user_tabs.html.twig' %}

    <div class="p-4">
        {% if progression %}

            {# ── Construire le lookup slug → UserAchievement ─────────────── #}
            {% set unlockedMap = {} %}
            {% for ua in userAchievements %}
                {% set unlockedMap = unlockedMap|merge({ (ua.achievement.slug): ua }) %}
            {% endfor %}

            {# ── Stats globales ──────────────────────────────────────────── #}
            {% set unlockedCount = userAchievements|length %}
            {% set totalCount = allAchievements|length %}
            {% set xpFromAchievements = 0 %}
            {% for ua in userAchievements %}
                {% set xpFromAchievements = xpFromAchievements + ua.achievement.xpReward %}
            {% endfor %}
            {% set globalPct = totalCount > 0 ? (unlockedCount / totalCount * 100)|round(0) : 0 %}

            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 mt-4">
                <div>
                    <h2 class="text-xl font-bold text-stone-800">
                        <i class="fa-solid fa-trophy text-turmeric-500 mr-2"></i>
                        {{ 'ui.achievements.unlocked_count'|trans({'%count%': unlockedCount, '%total%': totalCount}) }}
                    </h2>
                    <p class="text-sm text-stone-500 mt-0.5">
                        {{ 'ui.achievements.xp_from_achievements'|trans({'%xp%': xpFromAchievements}) }}
                    </p>
                </div>
                <div class="sm:w-52">
                    <div class="flex justify-between text-xs text-stone-500 mb-1">
                        <span>{{ 'ui.achievements.global_progress'|trans }}</span>
                        <span>{{ globalPct }}%</span>
                    </div>
                    <div class="w-full bg-stone-200 rounded-full h-2">
                        <div class="h-2 rounded-full bg-saffron-600 transition-all" style="width: {{ globalPct }}%"></div>
                    </div>
                </div>
            </div>

            {# ── Grille achievements ──────────────────────────────────────── #}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for achievement in allAchievements %}
                    {% set rarity = achievement.rarity.value %}
                    {% set rarityColors = rarity_colors(achievement.rarity) %}
                    {% set trigger = achievement.trigger.value %}
                    {% set isUnlocked = unlockedMap[achievement.slug] is defined %}
                    {% set ua = isUnlocked ? unlockedMap[achievement.slug] : null %}

                    {# Generic progress lookup — driven by AchievementProgress rows persisted
                       by the gamification manager (ProgressTrackableEvaluator::currentValue). #}
                    {% set progressCurrent = 0 %}
                    {% set progressMax = achievement.triggerValue %}
                    {% set progressLabel = 'ui.achievements.not_started'|trans %}
                    {% set storedProgress = progressByAchievementId[achievement.id] ?? null %}
                    {% if not isUnlocked %}
                        {% if trigger == 'easter_egg_found' %}
                            {% set progressLabel = 'ui.achievements.to_discover'|trans %}
                        {% elseif storedProgress %}
                            {% set progressCurrent = min(storedProgress.progress, achievement.triggerValue) %}
                            {% set progressLabel = progressCurrent ~ ' / ' ~ achievement.triggerValue %}
                        {% endif %}
                    {% endif %}
                    {% set progressPct = progressMax > 0 ? (progressCurrent / progressMax * 100)|round(0) : 0 %}

                    {% set isEquipped = isUnlocked and progression.equippedBadge and progression.equippedBadge.id == ua.id %}
                    <div class="relative rounded-2xl p-5 flex flex-col gap-3
                                {{ isEquipped ? 'border-2 border-stone-800 shadow-md' : 'border' }}
                                {{ not isUnlocked ? 'opacity-60 grayscale' : '' }}
                                transition-all duration-200"
                         style="{% if isUnlocked and not isEquipped %}border-color: {{ rarityColors.ring }}50; background-color: {{ rarityColors.bg }}40;{% else %}background-color: white;{% endif %}"
                         x-data="equipButton">

                        {# Indicateur en haut à droite #}
                        <div class="absolute top-3 right-3">
                            {% if isUnlocked %}
                                <i class="fa-solid fa-circle-check text-turmeric-500 text-sm"></i>
                            {% else %}
                                <i class="fa-solid fa-lock text-stone-400 text-sm"></i>
                            {% endif %}
                        </div>

                        {# Icône centrée dans un cercle coloré — driven by RarityExtension hex palette #}
                        <div class="flex justify-center">
                            <div class="w-14 h-14 rounded-full flex items-center justify-center text-2xl"
                                 style="{% if isUnlocked %}background-color: {{ rarityColors.bg }}; color: {{ rarityColors.text }};{% else %}background-color: #e7e5e4; color: #78716c;{% endif %}">
                                <i class="{{ achievement.icon }}"></i>
                            </div>
                        </div>

                        {# Nom + description #}
                        <div class="text-center">
                            <div class="font-bold text-stone-800 text-sm mb-1">{{ achievement.getLocalizedName(app.request.locale) }}</div>
                            <div class="text-xs text-stone-500 leading-relaxed">{{ achievement.getLocalizedDescription(app.request.locale) }}</div>
                        </div>

                        {# Badges rarity + XP #}
                        <div class="flex items-center justify-center gap-2 flex-wrap">
                            <span class="text-xs px-2 py-0.5 rounded-full font-medium"
                                  style="background-color: {{ rarityColors.bg }}; color: {{ rarityColors.text }}">
                                    {{ achievement.rarity.label()|trans }}
                            </span>
                            <span class="text-xs px-2 py-0.5 rounded-full bg-turmeric-300/20 text-turmeric-700 font-medium">
                                +{{ achievement.xpReward }} XP
                            </span>
                        </div>

                        {# Section basse : date ou barre de progression #}
                        <div class="mt-auto pt-1">
                            {% if isUnlocked %}
                                <p class="text-center text-xs text-stone-400 mb-2">
                                    <i class="fa-solid fa-calendar-check mr-1"></i>
                                    {{ 'ui.common.unlocked_on'|trans({'%date%': ua.unlockedAt|format_date('medium')}) }}
                                </p>
                                {% if isEquipped %}
                                    <p class="text-center text-xs font-semibold text-saffron-600">
                                        <i class="fa-solid fa-shield-halved mr-1"></i>{{ 'ui.achievements.equipped_badge'|trans }}
                                    </p>
                                {% else %}
                                    <div class="text-center">
                                        <button type="button"
                                                :disabled="equipping"
                                                @click="equip"
                                                data-equip-url="{{ path('equip_badge_user', {id: ua.id}) }}"
                                                data-equip-token="{{ csrf_token('equip_badge_' ~ ua.id) }}"
                                                data-equip-redirect="{{ path('achievements_user') }}"
                                                class="text-xs px-3 py-1 rounded-full border border-saffron-400 text-saffron-700 hover:bg-saffron-50 transition-colors cursor-pointer">
                                            <span x-show="!equipping"><i class="fa-solid fa-shield-halved mr-1"></i>{{ 'ui.achievements.equip'|trans }}</span>
                                            <span x-show="equipping" x-cloak><i class="fa-solid fa-spinner fa-spin mr-1"></i>…</span>
                                        </button>
                                    </div>
                                {% endif %}
                            {% elseif progressLabel == 'ui.achievements.not_started'|trans %}
                                <p class="text-center text-xs text-stone-400 italic">
                                    <i class="fa-solid fa-hourglass-half mr-1"></i>{{ 'ui.achievements.not_started'|trans }}
                                </p>
                            {% else %}
                                <div class="flex justify-between text-xs text-stone-500 mb-1">
                                    <span>{{ 'ui.achievements.progress'|trans }}</span>
                                    <span>{{ progressLabel }}</span>
                                </div>
                                <div class="w-full bg-stone-200 rounded-full h-1.5">
                                    <div class="h-1.5 rounded-full bg-saffron-600 transition-all"
                                         style="width: {{ progressPct }}%"></div>
                                </div>
                            {% endif %}
                        </div>

                    </div>
                {% endfor %}
            </div>

        {% else %}
            <div class="text-center text-stone-500 py-16">
                <i class="fa-solid fa-trophy text-5xl text-stone-300 mb-4 block"></i>
                <p class="text-lg font-medium text-stone-700">{{ 'ui.achievements.none_yet'|trans }}</p>
                <p class="text-sm mt-1">{{ 'ui.achievements.none_yet_text'|trans }}</p>
                {{ buttons.button('ui.achievements.create_first'|trans, {
                    href: path('index_spicy_match'),
                    variant: 'primary',
                    class: 'mt-6 inline-flex',
                    icon: 'fa-solid fa-flask',
                    attr: {'data-haptic': 'medium'}
                }) }}
            </div>
        {% endif %}
    </div>

</turbo-frame>
{% endblock %}
