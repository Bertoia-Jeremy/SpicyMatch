{% extends 'users/dashboard.html.twig' %}

{% block content %}
    <turbo-frame id="user_frame_id">
        {% include 'components/_user_tabs.html.twig' %}

        {# Mail #}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-envelope text-saffron-600 text-base"></i>Adresse mail
            </h2>
            <turbo-frame id="userMail_frame_id" class="block">
                <div class="card-warm p-5">
                    <p class="text-stone-700 text-sm">
                        Mail actuellement utilisé :
                        {% if user.mail is null %}
                            Aucun (<a href="{{ path('mail_user') }}" class="text-saffron-700 hover:text-saffron-600 underline">Ajouter un mail</a>)
                        {% else %}
                            <span class="font-medium">{{ user.mail }}</span>
                            (<a href="{{ path('mail_user') }}" class="text-saffron-700 hover:text-saffron-600 underline">Changer le mail</a>)
                        {% endif %}
                    </p>
                </div>
            </turbo-frame>
        </div>

        {# Gamification opt-out #}
        {% if app.user.progression %}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-shield-halved text-saffron-600 text-base"></i>Gamification & Vie privée
            </h2>
            <div class="card-warm p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-sm font-medium text-stone-800">Système de progression (XP, niveaux, succès)</p>
                        <p class="text-xs text-stone-500 mt-1">
                            {% if app.user.progression.gamificationEnabled %}
                                Activé — tes actions donnent de l'XP et débloquent des succès.
                            {% else %}
                                Désactivé — aucune donnée de progression n'est collectée.
                            {% endif %}
                        </p>
                    </div>
                    <form action="{{ path('toggle_gamification_user') }}" method="POST" class="shrink-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_gamification') }}">
                        <button type="submit"
                                class="text-sm px-4 py-1.5 rounded-full border transition-colors
                                       {% if app.user.progression.gamificationEnabled %}
                                           border-stone-300 text-stone-600 hover:bg-stone-50
                                       {% else %}
                                           border-saffron-400 text-saffron-700 hover:bg-saffron-50
                                       {% endif %}">
                            {{ app.user.progression.gamificationEnabled ? 'Désactiver' : 'Activer' }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% endif %}

    </turbo-frame>
{% endblock %}
