{% extends 'users/dashboard.html.twig' %}

{% block content %}
    <turbo-frame id="user_frame_id">
        {% set tabs = [
            { route: 'profile_user',       label: 'Profil' },
            { route: 'achievements_user',  label: 'Succès', icon: 'fa-solid fa-trophy text-xs mr-1' },
            { route: 'configuration_user', label: 'Configuration' },
            { route: 'history_user',       label: 'Historique' },
            { route: 'security_user',      label: 'Sécurité' },
        ] %}
        <div class="flex flex-wrap border-b border-stone-200 mt-6">
            {% for tab in tabs %}
                <a href="{{ path(tab.route) }}"
                   class="px-4 py-2 text-sm font-medium {{ app.request.attributes.get('_route') == tab.route ? 'text-orange-600 border-b-2 border-orange-600' : 'text-stone-500 hover:text-stone-800 hover:border-b-2 hover:border-stone-300' }}">
                    {% if tab.icon is defined %}<i class="{{ tab.icon }}"></i>{% endif %}
                    {{ tab.label }}
                </a>
            {% endfor %}
        </div>

        <div class="flex flex-col items-center justify-center p-4">
            <div class="w-full bg-stone-800 text-amber-100 text-center p-3 rounded-t-lg">
                <h5 class="m-0 text-lg font-semibold">Adresse mail</h5>
            </div>

            <turbo-frame id="userMail_frame_id" class="w-full p-4 border border-t-0 border-stone-200 rounded-b-lg">
                <p class="m-0 text-stone-700">
                    Mail actuellement utilisé :
                    {% if user.mail is null %}
                        Aucun (<a href="{{ path('mail_user') }}" class="text-orange-600 hover:underline">Ajouter un mail</a>)
                    {% else %}
                        {{ user.mail }} (<a href="{{ path('mail_user') }}" class="text-orange-600 hover:underline">Changer le mail</a>)
                    {% endif %}
                </p>
            </turbo-frame>
        </div>
    </turbo-frame>
{% endblock %}
