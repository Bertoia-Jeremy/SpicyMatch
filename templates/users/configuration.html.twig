{% extends 'users/dashboard.html.twig' %}

{% block content %}
    <turbo-frame id="user_frame_id">
        {% include 'components/_user_tabs.html.twig' %}

        {# Mail #}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-envelope text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.email_address'|trans }}
            </h2>
            <turbo-frame id="userMail_frame_id" class="block">
                <div class="card-warm p-5">
                    <p class="text-stone-700 text-sm">
                        {{ 'ui.config.current_mail'|trans }}
                        {% if user.mail is null %}
                            {{ 'ui.config.none'|trans }} (<a href="{{ path('mail_user') }}" class="text-saffron-700 hover:text-saffron-600 underline">{{ 'ui.config.add_mail'|trans }}</a>)
                        {% else %}
                            <span class="font-medium">{{ user.mail }}</span>
                            (<a href="{{ path('mail_user') }}" class="text-saffron-700 hover:text-saffron-600 underline">{{ 'ui.config.change_mail'|trans }}</a>)
                        {% endif %}
                    </p>
                </div>
            </turbo-frame>
        </div>

        {# Réactiver l'onboarding #}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-compass text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.discovery_path'|trans }}
            </h2>
            <div class="card-warm p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-sm font-medium text-stone-800">{{ 'ui.config.replay_intro'|trans }}</p>
                        <p class="text-xs text-stone-500 mt-1">
                            {{ 'ui.config.replay_intro_text'|trans }}
                        </p>
                    </div>
                    <twig:Button
                        label="{{ 'ui.config.replay'|trans }}"
                        variant="secondary"
                        size="sm"
                        icon="fa-solid fa-rotate-left"
                        x-data
                        @click="localStorage.removeItem('sm_onboarding'); window.location.href = '{{ path('home') }}';"
                        extra="shrink-0"
                    />
                </div>
            </div>
        </div>

        {# Difficulté / Posture #}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-gauge-high text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.game_posture'|trans }}
            </h2>
            <div class="card-warm p-5">
                <p class="text-sm text-stone-600 mb-3">
                    {{ 'ui.config.posture_intro'|trans }}
                </p>
                <form action="{{ path('update_difficulty_user') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('update_difficulty') }}">
                    {% set difficulties = [
                        { value: 'easy', label: 'ui.config.commis'|trans, multiplier: '1' },
                        { value: 'medium', label: 'ui.config.cuisinier'|trans, multiplier: '1.5' },
                        { value: 'hard', label: 'ui.config.chef_partie'|trans, multiplier: '2' }
                    ] %}
                    <div class="flex flex-wrap gap-2 mb-3">
                        {% for d in difficulties %}
                            <label class="cursor-pointer">
                                <input type="radio" name="difficulty" value="{{ d.value }}"
                                       class="peer sr-only"
                                       {{ app.user.preferredDifficulty.value == d.value ? 'checked' : '' }}>
                                <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-colors
                                    peer-checked:bg-saffron-600 peer-checked:text-white peer-checked:border-saffron-600
                                    bg-stone-100 text-stone-700 border-stone-200 hover:bg-stone-200">
                                    {{ d.label }}
                                    <span class="text-xs opacity-75">(x{{ d.multiplier }})</span>
                                </span>
                            </label>
                        {% endfor %}
                    </div>
                    <div class="text-xs text-stone-500 mb-3">
                        {% if app.user.preferredDifficulty.value == 'hard' %}
                            {{ 'ui.config.posture_hard_html'|trans|raw }}
                        {% elseif app.user.preferredDifficulty.value == 'medium' %}
                            {{ 'ui.config.posture_medium_html'|trans|raw }}
                        {% else %}
                            {{ 'ui.config.posture_easy_html'|trans|raw }}
                        {% endif %}
                    </div>
                    <twig:Button label="{{ 'common.actions.save'|trans }}" variant="secondary" size="sm" type="submit" />
                </form>
            </div>
        </div>

        {# Gamification opt-out #}
        {% if app.user.progression %}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-shield-halved text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.gamification_privacy'|trans }}
            </h2>
            <div class="card-warm p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-sm font-medium text-stone-800">{{ 'ui.config.progression_system'|trans }}</p>
                        <p class="text-xs text-stone-500 mt-1">
                            {% if app.user.progression.gamificationEnabled %}
                                {{ 'ui.config.gamification_on'|trans }}
                            {% else %}
                                {{ 'ui.config.gamification_off'|trans }}
                            {% endif %}
                        </p>
                    </div>
                    <form action="{{ path('toggle_gamification_user') }}" method="POST" class="shrink-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_gamification') }}">
                        <twig:Button
                            label="{{ app.user.progression.gamificationEnabled ? 'ui.config.disable'|trans : 'ui.config.enable'|trans }}"
                            variant="secondary"
                            size="sm"
                            type="submit"
                        />
                    </form>
                </div>
            </div>
        </div>
        {% endif %}

    </turbo-frame>
{% endblock %}
