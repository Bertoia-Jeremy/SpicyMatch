{% extends 'users/dashboard.html.twig' %}

{% block content %}
    <turbo-frame id="user_frame_id">
        {% include 'components/_user_tabs.html.twig' %}

        {# Mail #}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-envelope text-saffron-600 text-base"></i>Adresse mail
            </h2>
            <turbo-frame id="userMail_frame_id" class="block">
                <div class="card-warm p-5">
                    <p class="text-stone-700 text-sm">
                        Mail actuellement utilisé :
                        {% if user.mail is null %}
                            Aucun (<a href="{{ path('mail_user') }}" class="text-saffron-700 hover:text-saffron-600 underline">Ajouter un mail</a>)
                        {% else %}
                            <span class="font-medium">{{ user.mail }}</span>
                            (<a href="{{ path('mail_user') }}" class="text-saffron-700 hover:text-saffron-600 underline">Changer le mail</a>)
                        {% endif %}
                    </p>
                </div>
            </turbo-frame>
        </div>

        {# Réactiver l'onboarding #}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-compass text-saffron-600 text-base"></i>Parcours de découverte
            </h2>
            <div class="card-warm p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-sm font-medium text-stone-800">Revoir l'introduction</p>
                        <p class="text-xs text-stone-500 mt-1">
                            Relance le guide de démarrage pour redécouvrir les fonctionnalités principales.
                        </p>
                    </div>
                    <button type="button"
                            x-data
                            @click="
                                localStorage.removeItem('sm_onboarding');
                                window.location.href = '{{ path('home') }}';
                            "
                            class="shrink-0 text-sm px-4 py-1.5 rounded-full border border-saffron-400
                                   text-saffron-700 hover:bg-saffron-50 transition-colors">
                        <i class="fa-solid fa-rotate-left mr-1.5"></i>Relancer
                    </button>
                </div>
            </div>
        </div>

        {# Difficulté / Posture #}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-gauge-high text-saffron-600 text-base"></i>Posture de jeu
            </h2>
            <div class="card-warm p-5">
                <p class="text-sm text-stone-600 mb-3">
                    Ta posture détermine la difficulté par défaut des jeux et modifie certains éléments visuels.
                </p>
                <form action="{{ path('update_difficulty_user') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('update_difficulty') }}">
                    {% set difficulties = [
                        { value: 'easy', label: 'Commis', multiplier: '1' },
                        { value: 'medium', label: 'Cuisinier', multiplier: '1.5' },
                        { value: 'hard', label: 'Chef de Partie', multiplier: '2' }
                    ] %}
                    <div class="flex flex-wrap gap-2 mb-3">
                        {% for d in difficulties %}
                            <label class="cursor-pointer">
                                <input type="radio" name="difficulty" value="{{ d.value }}"
                                       class="peer sr-only"
                                       {{ app.user.preferredDifficulty.value == d.value ? 'checked' : '' }}>
                                <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-colors
                                    peer-checked:bg-saffron-600 peer-checked:text-white peer-checked:border-saffron-600
                                    bg-stone-100 text-stone-700 border-stone-200 hover:bg-stone-200">
                                    {{ d.label }}
                                    <span class="text-xs opacity-75">(x{{ d.multiplier }})</span>
                                </span>
                            </label>
                        {% endfor %}
                    </div>
                    <div class="text-xs text-stone-500 mb-3">
                        {% if app.user.preferredDifficulty.value == 'hard' %}
                            <strong>Chef de Partie :</strong> couleurs des groupes aromatiques masquées, chrono réduit au Pendu, intrus plus subtils.
                        {% elseif app.user.preferredDifficulty.value == 'medium' %}
                            <strong>Cuisinier :</strong> difficulté intermédiaire, comportement standard.
                        {% else %}
                            <strong>Commis :</strong> aides visuelles complètes, plus de temps, indices supplémentaires.
                        {% endif %}
                    </div>
                    <button type="submit" class="text-sm px-4 py-1.5 rounded-full border border-saffron-400 text-saffron-700 hover:bg-saffron-50 transition-colors">
                        Enregistrer
                    </button>
                </form>
            </div>
        </div>

        {# Gamification opt-out #}
        {% if app.user.progression %}
        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-shield-halved text-saffron-600 text-base"></i>Gamification & Vie privée
            </h2>
            <div class="card-warm p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-sm font-medium text-stone-800">Système de progression (XP, niveaux, succès)</p>
                        <p class="text-xs text-stone-500 mt-1">
                            {% if app.user.progression.gamificationEnabled %}
                                Activé — tes actions donnent de l'XP et débloquent des succès.
                            {% else %}
                                Désactivé — aucune donnée de progression n'est collectée.
                            {% endif %}
                        </p>
                    </div>
                    <form action="{{ path('toggle_gamification_user') }}" method="POST" class="shrink-0">
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_gamification') }}">
                        <button type="submit"
                                class="text-sm px-4 py-1.5 rounded-full border transition-colors
                                       {% if app.user.progression.gamificationEnabled %}
                                           border-stone-300 text-stone-600 hover:bg-stone-50
                                       {% else %}
                                           border-saffron-400 text-saffron-700 hover:bg-saffron-50
                                       {% endif %}">
                            {{ app.user.progression.gamificationEnabled ? 'Désactiver' : 'Activer' }}
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {% endif %}

    </turbo-frame>
{% endblock %}
