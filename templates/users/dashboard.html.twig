{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-8">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="shrink-0 flex justify-center">
          {% include 'components/_avatar.html.twig' with { slug: app.user.avatar, sizeClass: 'w-24 h-24 text-3xl', equippedBadge: progression is defined and progression is not empty ? progression.equippedBadge : null } %}
        </div>
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl font-bold text-stone-800 mb-1 flex items-center gap-2 flex-wrap">
            {{ app.user.username|capitalize }}
            {% if progression is defined and progression is not empty and progression.equippedBadge %}
              <i class="{{ progression.equippedBadge.achievement.icon }} text-saffron-500 text-xl"></i>
            {% endif %}
          </h1>

          {% if progression is defined and progression is not empty %}
            {# Badge niveau #}
            <span class="inline-flex items-center gap-1.5 bg-turmeric-300/30 text-turmeric-700 text-sm font-medium px-3 py-1 rounded-full mb-2">
              <i class="fa-solid fa-star text-turmeric-500 text-xs"></i>
              Niveau {{ progression.level }} — {{ progression.xp }} XP
            </span>
            {# Badge équipé #}
            {% if progression.equippedBadge %}
              <p class="text-sm font-medium text-saffron-700 mb-1">
                <i class="{{ progression.equippedBadge.achievement.icon }} mr-1"></i>{{ progression.equippedBadge.achievement.name }}
              </p>
            {% endif %}
          {% endif %}
          <p class="text-stone-400 text-sm">Membre depuis le {{ app.user.createdAt|date('d/m/Y') }}</p>
        </div>
      </div>

      {% block content %}
      {% endblock %}
    </div>
  </div>
{% endblock %}
