{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-8">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="shrink-0 flex justify-center">
          {% if app.user.avatar is defined and app.user.avatar is not empty %}
            <img src="{{ asset(app.user.avatar) }}"
                 class="rounded-full w-24 h-24 object-cover border-2 border-saffron-400/30"
                 alt="Avatar de {{ app.user.username|capitalize }}"
                 loading="lazy" width="96" height="96">
          {% else %}
            <div class="w-24 h-24 rounded-full bg-spice-surface border-2 border-saffron-400/30 flex items-center justify-center">
              <i class="fa-solid fa-user text-3xl text-saffron-400"></i>
            </div>
          {% endif %}
        </div>
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl font-bold text-stone-800 mb-1">{{ app.user.username|capitalize }}</h1>

          {% if progression is defined and progression is not empty %}
            {# Badge niveau #}
            <span class="inline-flex items-center gap-1.5 bg-turmeric-300/30 text-turmeric-700 text-sm font-medium px-3 py-1 rounded-full mb-2">
              <i class="fa-solid fa-star text-turmeric-500 text-xs"></i>
              Niveau {{ progression.level }} — {{ progression.xp }} XP
            </span>
          {% endif %}
          <p class="text-stone-400 text-sm">Membre depuis le {{ app.user.createdAt|date('d/m/Y') }}</p>
        </div>
      </div>

      {% block content %}
      {% endblock %}
    </div>
  </div>
{% endblock %}
