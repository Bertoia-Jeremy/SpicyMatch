{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-8">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="shrink-0 flex justify-center">
          {% if app.user.avatar is not empty %}
            <img src="{{ asset(app.user.avatar) }}"
                 class="rounded-full w-24 h-24 object-cover border-2 border-saffron-400/30"
                 alt="Avatar de {{ app.user.username|capitalize }}">
          {% else %}
            <div class="w-24 h-24 rounded-full bg-spice-surface border-2 border-saffron-400/30 flex items-center justify-center">
              <i class="fa-solid fa-user text-3xl text-saffron-400"></i>
            </div>
          {% endif %}
        </div>
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl font-bold text-stone-800 mb-1">{{ app.user.username|capitalize }}</h1>

          {% if progression %}
            {# Badge niveau #}
            <span class="inline-flex items-center gap-1.5 bg-turmeric-300/30 text-turmeric-700 text-sm font-medium px-3 py-1 rounded-full mb-3">
              <i class="fa-solid fa-star text-turmeric-500 text-xs"></i>
              Niveau {{ progression.level }} — {{ progression.xp }} XP
            </span>

            {# XP progress bar #}
            {% set lvl = progression.level %}
            {% set xpMin = (lvl - 1) * (lvl - 1) * 100 %}
            {% set xpMax = lvl * lvl * 100 %}
            {% set range = xpMax - xpMin %}
            {% set pct = range > 0 ? ((progression.xp - xpMin) / range * 100)|round(1) : 100 %}
            <div class="mb-1 flex justify-between text-xs text-stone-500">
              <span>Niv. {{ lvl }}</span>
              <span>{{ pct }}% — encore {{ progression.xpToNextLevel }} XP</span>
              <span>Niv. {{ lvl + 1 }}</span>
            </div>
            <div class="w-full bg-stone-200 rounded-full h-2 mb-4">
              <div class="h-2 rounded-full bg-linear-to-r from-saffron-600 to-turmeric-400 transition-all"
                   style="width: {{ pct }}%"></div>
            </div>

            {# Stats strip 3 colonnes #}
            <div class="grid grid-cols-3 gap-2 text-center">
              <div class="bg-spice-surface border border-spice-border rounded-xl py-2 px-3">
                <div class="text-xl font-bold text-saffron-700">{{ progression.totalMatches }}</div>
                <div class="text-xs text-stone-500 mt-0.5">Mélanges</div>
              </div>
              <div class="bg-spice-surface border border-spice-border rounded-xl py-2 px-3">
                <div class="text-xl font-bold text-saffron-700">{{ progression.uniqueSpicesUsed }}</div>
                <div class="text-xs text-stone-500 mt-0.5">Épices max</div>
              </div>
              <div class="bg-spice-surface border border-spice-border rounded-xl py-2 px-3">
                <div class="text-xl font-bold text-saffron-700">{{ progression.userAchievements|length }}</div>
                <div class="text-xs text-stone-500 mt-0.5">Succès</div>
              </div>
            </div>
          {% else %}
            <p class="text-stone-400 text-sm">Membre depuis le {{ app.user.createdAt|date('d/m/Y') }}</p>
          {% endif %}
        </div>
      </div>

      {% block content %}
      {% endblock %}
    </div>
  </div>
{% endblock %}
