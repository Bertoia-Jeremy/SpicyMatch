{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
  {# Utilise app.user.progression directement — fiable sur toutes les pages, indépendamment des vars de contrôleur #}
  {% set _prog = app.user.progression %}
  {% set _badge = _prog ? _prog.equippedBadge : null %}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-8">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6">

        {# Avatar #}
        <div class="shrink-0 flex justify-center">
          {% include 'components/_avatar.html.twig' with { slug: app.user.avatar, sizeClass: 'w-24 h-24 text-3xl', equippedBadge: _badge } %}
        </div>

        {# Infos utilisateur #}
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl font-bold text-stone-800 mb-2 flex items-center gap-2.5 flex-wrap justify-center md:justify-start">
            {{ app.user.username|capitalize }}
            {% if _badge %}
              {% set _rarity = _badge.achievement.rarity.value %}
              {% set _iconColor = { 'common': '#16a34a', 'rare': '#1d4ed8', 'epic': '#7e22ce', 'legendary': '#a16207' } %}
              <i class="{{ _badge.achievement.icon }}" style="color: {{ _iconColor[_rarity] ?? '#f59e0b' }}"></i>
            {% endif %}
          </h1>

          {% if _prog %}
            {# Niveau XP #}
            <div class="flex items-center gap-2 mb-2 justify-center md:justify-start flex-wrap">
              <span class="inline-flex items-center gap-1.5 bg-turmeric-300/30 text-turmeric-700 text-sm font-medium px-3 py-1 rounded-full">
                <i class="fa-solid fa-star text-turmeric-500 text-xs"></i>
                Niveau {{ _prog.level }} — {{ _prog.xp }} XP
              </span>
            </div>

            {# Succès équipé #}
            {% if _badge %}
              {% set _rarity = _badge.achievement.rarity.value %}
              {% set _rarityPill = {
                'common':    ['bg-green-50',  'text-green-700',  'border-green-200',  'text-green-400'],
                'rare':      ['bg-blue-50',   'text-blue-700',   'border-blue-200',   'text-blue-400'],
                'epic':      ['bg-purple-50', 'text-purple-700', 'border-purple-200', 'text-purple-400'],
                'legendary': ['bg-yellow-50', 'text-yellow-700', 'border-yellow-200', 'text-yellow-400'],
              } %}
              {% set _colors = _rarityPill[_rarity] ?? ['bg-stone-50', 'text-stone-600', 'border-stone-200', 'text-stone-400'] %}
              <div class="flex items-center gap-2 mb-2 justify-center md:justify-start flex-wrap">
                <span class="text-[10px] text-stone-400 font-semibold uppercase tracking-widest">Succès équipé</span>
                <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full border text-xs font-semibold {{ _colors[0] }} {{ _colors[1] }} {{ _colors[2] }}">
                  <i class="{{ _badge.achievement.icon }} {{ _colors[3] }} text-[10px]"></i>
                  {{ _badge.achievement.name }}
                  <span class="font-normal opacity-60">· {{ _badge.achievement.rarity.label }}</span>
                </span>
              </div>
            {% endif %}
          {% endif %}

          <p class="text-stone-400 text-sm">Membre depuis le {{ app.user.createdAt|date('d/m/Y') }}</p>
        </div>
      </div>

      {% block content %}
      {% endblock %}
    </div>
  </div>
{% endblock %}
