{% extends 'users/dashboard.html.twig' %}

{% block content %}
    {% import 'macros/buttons.html.twig' as buttons %}
    <turbo-frame id="user_frame_id">
        {% include 'components/_user_tabs.html.twig' %}

        <div class="mt-6">
            <h2 class="text-xl font-semibold text-stone-800 flex items-center gap-2 mb-6">
                <i class="fa-solid fa-star text-turmeric-500 text-base"></i>{{ 'ui.history.my_favorites'|trans }}
            </h2>

            {% if favorites|length > 0 %}
                <div class="space-y-4">
                    {% for history in favorites %}
                        <div x-data="favoriteRemover(
                                '{{ path('toggle_favorite_spicy_match_history', {id: history.id}) }}',
                                '{{ csrf_token('history_action_' ~ history.id) }}'
                             )"
                             x-show="!removed"
                             x-transition:leave="transition ease-in duration-200"
                             x-transition:leave-start="opacity-100 translate-x-0"
                             x-transition:leave-end="opacity-0 -translate-x-4"
                             class="bg-white border border-stone-200 rounded-xl shadow-sm hover:shadow-md hover:border-saffron-400/50 transition-all p-5">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <a href="{{ path('view_spicy_match_history', {'id': history.id}) }}"
                                   class="flex-1 min-w-0"
                                   data-turbo-frame="_top">
                                    <h3 class="text-lg font-semibold text-stone-800 mb-2">
                                        {{ history.title ?: 'ui.common.recipe_of'|trans({'%date%': history.createdAt|format_datetime('medium', 'short')}) }}
                                    </h3>
                                    <div class="flex flex-wrap gap-2">
                                        {% for spice in history.spicyMatch.spices %}
                                            <span class="inline-flex items-center gap-1.5 bg-spice-surface border border-spice-border text-stone-700 text-xs font-medium px-2.5 py-1 rounded-full">
                                                {{ spice.getLocalizedName(app.request.locale) }}
                                            </span>
                                        {% endfor %}
                                    </div>
                                </a>
                                <div class="flex items-center gap-4 shrink-0">
                                    <span class="text-sm text-stone-400">{{ history.createdAt|format_date('medium') }}</span>
                                    <button type="button"
                                            @click="removeFavorite"
                                            class="text-xl transition-colors focus:outline-none text-turmeric-500 hover:text-stone-300"
                                            title="{{ 'ui.history.remove_favorite'|trans }}">
                                        <i class="fa-solid fa-star"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="card-warm p-10 text-center">
                    <i class="fa-solid fa-star text-stone-300 text-5xl mb-4 block"></i>
                    <p class="text-stone-500 text-lg mb-6">{{ 'ui.history.no_favorites'|trans }}</p>
                    {{ buttons.button('ui.history.see_my_blends'|trans, {
                        href: path('index_spicy_match_history'),
                        variant: 'primary',
                        icon: 'fa-solid fa-flask',
                        attr: {'data-turbo-frame': '_top'}
                    }) }}
                </div>
            {% endif %}
        </div>
    </turbo-frame>
{% endblock %}
