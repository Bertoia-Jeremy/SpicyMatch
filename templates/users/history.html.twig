{% extends 'users/dashboard.html.twig' %}

{% block content %}
    {% import 'macros/buttons.html.twig' as buttons %}
    <turbo-frame id="user_frame_id">
        {% include 'components/_user_tabs.html.twig' %}

        <div class="mt-6">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-semibold text-stone-800 flex items-center gap-2">
                    <i class="fa-solid fa-clock-rotate-left text-saffron-600 text-base"></i>Historique des mélanges
                </h2>
                {{ buttons.button("Tout voir", {
                    href: path('index_spicy_match_history'),
                    variant: 'outline',
                    size: 'xs'
                }) }}
            </div>

            {% if pagination|length > 0 %}
                <div class="space-y-4">
                    {% for history in pagination %}
                        <a class="block bg-white border border-stone-200 rounded-xl shadow-sm hover:shadow-md hover:border-saffron-400/50 transition-all p-5"
                           href="{{ path('view_spicy_match_history', {'id': history.id}) }}"
                           data-turbo-frame="_top">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <div class="flex-1">
                                    <h3 class="text-lg font-semibold text-stone-800 mb-2">
                                        {{ history.title ?: 'Recette du ' ~ history.createdAt|date('d/m/Y à H:i') }}
                                    </h3>
                                    <div class="flex flex-wrap gap-2">
                                        {% for spice in history.spicyMatch.spices %}
                                            <span class="inline-flex items-center gap-1.5 bg-spice-surface border border-spice-border text-stone-700 text-xs font-medium px-2.5 py-1 rounded-full">
                                                {{ spice.name }}
                                            </span>
                                        {% endfor %}
                                    </div>
                                </div>
                                <div class="flex items-center gap-4 shrink-0">
                                    <span class="text-sm text-stone-400">{{ history.createdAt|date('d/m/Y') }}</span>
                                    <i class="fa-solid fa-chevron-right text-stone-300 text-sm"></i>
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>

                {# Pagination #}
                {% if pagination.pageCount > 1 %}
                    <div class="mt-8 flex justify-center">
                        {{ knp_pagination_render(pagination) }}
                    </div>
                {% endif %}
            {% else %}
                <div class="card-warm p-10 text-center">
                    <i class="fa-solid fa-flask text-stone-300 text-5xl mb-4 block"></i>
                    <p class="text-stone-500 text-lg mb-6">Vous n'avez pas encore de mélange sauvegardé.</p>
                    {{ buttons.button('Créer mon premier mélange', {
                        href: path('index_spicy_match'),
                        variant: 'primary',
                        icon: 'fa-solid fa-fire'
                    }) }}
                </div>
            {% endif %}
        </div>
    </turbo-frame>
{% endblock %}
