{% extends 'base.html.twig' %}

{% block title %}{{ 'ui.profile.dashboard_title'|trans }}{% endblock %}

{% block body %}
  {% set _prog = app.user.progression %}
  {% set _badge = _prog ? _prog.equippedBadge : null %}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10"
       x-data="profileTabs('{{ activeTab }}')" x-cloak>

    <div class="bg-white border border-stone-200 rounded-2xl shadow-sm p-8">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-6">
        <div class="shrink-0 flex justify-center">
          {% include 'components/_avatar.html.twig' with {sizeClass: 'w-24 h-24 text-3xl', equippedBadge: _badge} %}
        </div>
        <div class="flex-1 text-center md:text-left">
          <h1 class="text-3xl font-bold text-stone-800 mb-2">{{ app.user.username|capitalize }}</h1>
          {% if _prog %}
            <span class="inline-flex items-center gap-1.5 bg-turmeric-300/30 text-turmeric-700 text-sm font-medium px-3 py-1 rounded-full">
              <i class="fa-solid fa-star text-turmeric-500 text-xs" aria-hidden="true"></i>
              {{ 'ui.profile.level_xp'|trans({'%level%': _prog.level, '%xp%': _prog.xp}) }}
            </span>
          {% endif %}
          <p class="text-stone-500 text-sm mt-2">{{ 'ui.common.member_since'|trans({'%date%': app.user.createdAt|format_date('medium')}) }}</p>
        </div>
      </div>

      {% include 'components/_profile_tabs.html.twig' %}

      {% set panels = {
        dashboard: 'frame-dashboard',
        grimoire:  'frame-grimoire',
        history:   'frame-history',
        lab:       'frame-lab',
      } %}
      {% for key, frameId in panels %}
        {% set _frameSrc = (key == 'history' and app.request.query.get('filter'))
          ? path('profile_tab', {tab: key, filter: app.request.query.get('filter')})
          : path('profile_tab', {tab: key}) %}
        <div x-show="isActive('{{ key }}')" role="tabpanel" :aria-labelledby="'tab-' + '{{ key }}'">
          <turbo-frame id="{{ frameId }}" loading="{{ key == activeTab ? 'eager' : 'lazy' }}" src="{{ _frameSrc }}">
            <div class="py-16 text-center text-stone-400" aria-busy="true">
              <i class="fa-solid fa-spinner fa-spin text-2xl" aria-hidden="true"></i>
            </div>
          </turbo-frame>
        </div>
      {% endfor %}
    </div>
  </div>
{% endblock %}
