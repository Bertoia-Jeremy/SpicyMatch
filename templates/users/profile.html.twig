{% extends 'users/dashboard.html.twig' %}

{% block content %}
    <turbo-frame id="user_frame_id">
        {% include 'components/_user_tabs.html.twig' %}

        <div class="p-4">
            {% if progression %}
                {% set lvl = progression.level %}
                {% set pct = progression.progressPercent %}

                <div class="mb-6 p-4 bg-linear-to-r from-turmeric-50 to-saffron-50 border border-saffron-200 rounded-xl">
                    <div class="flex items-center justify-between mb-1">
                        <div class="flex items-center gap-2">
                            <i class="fa-solid fa-star text-turmeric-500 text-lg" aria-hidden="true"></i>
                            <span class="text-2xl font-bold text-saffron-700">Niveau {{ lvl }}</span>
                        </div>
                        {% if progression.equippedBadge %}
                            <div class="flex items-center gap-1.5 text-xs text-stone-500">
                                <i class="{{ progression.equippedBadge.achievement.icon }} text-saffron-500"></i>
                                <span class="font-medium text-stone-700">{{ progression.equippedBadge.achievement.name }}</span>
                            </div>
                        {% endif %}
                    </div>
                    <div class="text-sm text-stone-500 mb-2">{{ progression.xp }} XP — encore {{ progression.xpToNextLevel }} XP pour le niveau suivant</div>
                    <div class="w-full bg-saffron-100 rounded-full h-2.5 overflow-hidden">
                        <div class="h-2.5 rounded-full bg-linear-to-r from-turmeric-400 to-saffron-600 transition-all" style="width: {{ pct }}%"></div>
                    </div>
                    <div class="flex justify-between text-[10px] text-stone-400 mt-1">
                        <span>Niv. {{ lvl }}</span>
                        <span>{{ pct }}%</span>
                        <span>Niv. {{ lvl + 1 }}</span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3 mb-6">
                    <div class="text-center p-3 bg-spice-surface border border-spice-border rounded-xl">
                        <div class="text-2xl font-bold text-saffron-700">{{ stats.totalBlends }}</div>
                        <div class="text-xs text-stone-500 mt-1 flex items-center justify-center gap-1">
                            <i class="fa-solid fa-flask text-saffron-400 text-[10px]" aria-hidden="true"></i>Mélanges créés
                        </div>
                    </div>
                    <div class="text-center p-3 bg-spice-surface border border-spice-border rounded-xl">
                        <div class="text-2xl font-bold text-saffron-700">{{ stats.distinctSpices }}</div>
                        <div class="text-xs text-stone-500 mt-1 flex items-center justify-center gap-1">
                            <i class="fa-solid fa-seedling text-saffron-400 text-[10px]" aria-hidden="true"></i>Épices utilisées
                        </div>
                    </div>
                    <div class="text-center p-3 bg-spice-surface border border-spice-border rounded-xl">
                        <div class="text-2xl font-bold text-turmeric-600">{{ stats.favorites }}</div>
                        <div class="text-xs text-stone-500 mt-1 flex items-center justify-center gap-1">
                            <i class="fa-solid fa-star text-turmeric-400 text-[10px]" aria-hidden="true"></i>Favoris
                        </div>
                    </div>
                    <div class="text-center p-3 bg-spice-surface border border-spice-border rounded-xl">
                        <div class="text-2xl font-bold text-turmeric-600">{{ stats.spicesViewed }}</div>
                        <div class="text-xs text-stone-500 mt-1 flex items-center justify-center gap-1">
                            <i class="fa-solid fa-book-open text-turmeric-400 text-[10px]" aria-hidden="true"></i>Fiches consultées
                        </div>
                    </div>
                </div>

                {# ── Stats avancées (depuis UserStat) ── #}
                {% if userStats %}
                    <div class="grid grid-cols-3 gap-3 mb-6">
                        <div class="text-center p-3 bg-stone-50 border border-stone-200 rounded-xl">
                            <div class="text-xl font-bold text-stone-700">{{ userStats.visitedGroupsCount }}</div>
                            <div class="text-[10px] text-stone-500 mt-1">
                                <i class="fa-solid fa-layer-group text-saffron-400" aria-hidden="true"></i> Groupes visités
                            </div>
                        </div>
                        <div class="text-center p-3 bg-stone-50 border border-stone-200 rounded-xl">
                            <div class="text-xl font-bold text-stone-700">{{ progression.longestReadingStreak }}</div>
                            <div class="text-[10px] text-stone-500 mt-1">
                                <i class="fa-solid fa-fire text-paprika-400" aria-hidden="true"></i> Meilleur streak
                            </div>
                        </div>
                        <div class="text-center p-3 bg-stone-50 border border-stone-200 rounded-xl">
                            <div class="text-xl font-bold text-stone-700">{{ userStats.easterEggsFound }}</div>
                            <div class="text-[10px] text-stone-500 mt-1">
                                <i class="fa-solid fa-egg text-turmeric-400" aria-hidden="true"></i> Secrets trouvés
                            </div>
                        </div>
                    </div>
                {% endif %}

                <div class="mt-8">
                    <h2 class="text-lg font-semibold text-stone-800 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-clock-rotate-left text-saffron-600 text-base" aria-hidden="true"></i>Derniers mélanges
                    </h2>
                    {% if latestHistories is not empty %}
                        {% import "components/_macro_card_spicy_match_history.html.twig" as macroCardSpicyMatchHistory %}
                        <div class="space-y-3">
                            {% for history in latestHistories %}
                                <a class="block bg-stone-50/50 border border-stone-200 rounded-xl hover:shadow-md hover:border-saffron-400/50 transition-all p-4"
                                   href="{{ path('view_spicy_match_history', {'id': history.id}) }}"
                                   data-turbo-frame="_top">
                                    <div class="flex justify-between items-center gap-4">
                                        <div class="flex-1 min-w-0">
                                            <h3 class="text-sm font-semibold text-stone-800 truncate mb-2">
                                                {{ history.title ?: 'ui.common.blend_of'|trans({'%date%': history.createdAt|format_date('medium')}) }}
                                            </h3>
                                            <div class="flex flex-wrap gap-1 items-center">
                                                {% for spice in history.spicyMatch.spices %}
                                                    {% set spiceLocName = spice.getLocalizedName(app.request.locale) %}
                                                    <div class="w-8 h-8 rounded-lg overflow-hidden border border-white shadow-sm" title="{{ spiceLocName }}">
                                                        {% set spiceImg = vich_uploader_asset(spice, 'imageFile') %}
                                                        <img src="{{ spiceImg ?: 'https://loremflickr.com/100/100/spice' }}" alt="{{ spiceLocName }}" class="w-full h-full object-cover">
                                                    </div>
                                                {% endfor %}
                                                {% if history.spicyMatch.isManual %}
                                                    <span class="inline-flex items-center gap-1 text-[10px] font-medium text-stone-500 bg-stone-100 border border-stone-200 px-1.5 py-0.5 rounded-full" title="{{ 'ui.history.manual'|trans }}">
                                                        <i class="fa-solid fa-hand text-[8px]" aria-hidden="true"></i>{{ 'ui.history.manual'|trans }}
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <i class="fa-solid fa-chevron-right text-stone-300 text-xs" aria-hidden="true"></i>
                                    </div>
                                </a>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="card-warm p-6 text-center">
                            <p class="text-stone-400 text-sm">{{ 'ui.profile.no_recent_blend'|trans }}</p>
                        </div>
                    {% endif %}
                </div>

                {% if progression.userAchievements is not empty %}
                    <h2 class="text-lg font-semibold text-stone-800 mb-3 mt-8">{{ 'ui.profile.unlocked_achievements'|trans }}</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {% for ua in progression.userAchievements %}
                            {% set uaColors = rarity_colors(ua.achievement.rarity) %}
                            {% set isEquipped = progression.equippedBadge and progression.equippedBadge.id == ua.id %}
                            <div class="flex items-start gap-3 p-3 rounded-xl {{ isEquipped ? 'border-2 border-stone-800 shadow-md' : 'border' }}"
                                 style="{% if not isEquipped %}border-color: {{ uaColors.ring }}50; background-color: {{ uaColors.bg }}40;{% endif %}"
                                 x-data="equipButton"
                            >
                                <div class="text-2xl w-8 text-center shrink-0">
                                    <i class="{{ ua.achievement.icon }}"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <div class="font-semibold text-stone-800 text-sm flex items-center gap-1.5">
                                        {{ ua.achievement.name }}
                                        {% if isEquipped %}
                                            <i class="fa-solid fa-shield-halved text-saffron-500 text-xs" aria-hidden="true"></i>
                                        {% endif %}
                                    </div>
                                    <div class="text-xs text-stone-500 mt-0.5">{{ ua.achievement.description }}</div>
                                    <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                                        <span class="text-xs px-2 py-0.5 rounded-full"
                                              style="background-color: {{ uaColors.bg }}; color: {{ uaColors.text }}">+{{ ua.achievement.xpReward }} XP</span>
                                        <span class="text-xs text-stone-400">{{ ua.unlockedAt|format_date('medium') }}</span>
                                        {% if isEquipped %}
                                            <span class="text-xs font-semibold text-saffron-600">
                                                <i class="fa-solid fa-check mr-0.5" aria-hidden="true"></i>Équipé
                                            </span>
                                        {% else %}
                                            <button type="button"
                                                    :disabled="equipping"
                                                    @click="equip"
                                                    data-equip-url="{{ path('equip_badge_user', {id: ua.id}) }}"
                                                    data-equip-token="{{ csrf_token('equip_badge_' ~ ua.id) }}"
                                                    data-equip-redirect="{{ path('profile_user') }}"
                                                    class="text-xs px-2.5 py-0.5 rounded-full border border-saffron-400 text-saffron-700 hover:bg-saffron-50 transition-colors cursor-pointer">
                                                <span x-show="!equipping"><i class="fa-solid fa-shield-halved mr-0.5" aria-hidden="true"></i>{{ 'ui.achievements.equip'|trans }}</span>
                                                <span x-show="equipping" x-cloak><i class="fa-solid fa-spinner fa-spin mr-0.5" aria-hidden="true"></i>…</span>
                                            </button>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="mt-4 text-center">
                        <twig:Button
                            label="{{ 'ui.profile.see_all_achievements'|trans }}"
                            href="{{ path('achievements_user') }}"
                            variant="primary"
                            size="sm"
                            icon="fa-solid fa-trophy"
                            data-haptic="light"
                        />
                    </div>
                {% endif %}

            {% else %}
                <div class="text-center text-stone-500 py-12">
                    <i class="fa-solid fa-flask text-5xl text-stone-300 mb-4 block" aria-hidden="true"></i>
                    <p class="text-lg font-medium">{{ 'ui.profile.no_progress'|trans }}</p>
                    <p class="text-sm mt-1">{{ 'ui.profile.no_progress_hint'|trans }}</p>
                    <twig:Button
                        label="{{ 'ui.history.create_first'|trans }}"
                        href="{{ path('index_spicy_match') }}"
                        variant="primary"
                        icon="fa-solid fa-flask text-sm"
                        data-haptic="medium"
                    />
                </div>
            {% endif %}
        </div>
    </turbo-frame>
{% endblock %}
