<turbo-frame id="frame-lab">
    <div class="mt-6 space-y-6">
        <section aria-labelledby="lab-engine-title">
            <h2 id="lab-engine-title" class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-flask text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.lab.prefs.section_engine'|trans }}
            </h2>
            <div class="card-warm p-5">
                <twig:EnginePreferences />
            </div>
        </section>
        <section aria-labelledby="lab-account-title">
            <h2 id="lab-account-title" class="text-xl font-semibold text-stone-800 mb-4 flex items-center gap-2">
                <i class="fa-solid fa-gear text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.lab.prefs.section_account'|trans }}
            </h2>
            <div class="space-y-6">
                <div>
                    <h3 class="text-lg font-semibold text-stone-800 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-envelope text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.email_address'|trans }}
                    </h3>
                    <div class="card-warm p-5">
                        {% if editSection == 'mail' %}
                            {{ form_start(mailForm, {'attr': {'class': 'space-y-4'}}) }}
                                {{ form_errors(mailForm) }}
                                <div>
                                    {{ form_label(mailForm.mail, 'ui.config.email_address'|trans, {'label_attr': {'class': 'sr-only'}}) }}
                                    {{ form_widget(mailForm.mail, {'attr': {'class': 'w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-1 focus:ring-saffron-600/30', 'placeholder': 'form.mail.placeholder'|trans}}) }}
                                </div>
                                <div class="flex items-center gap-3">
                                    <twig:Button label="{{ 'common.actions.save'|trans }}" variant="primary" size="sm" type="submit" />
                                    <a href="{{ path('profile_tab', {tab: 'lab'}) }}" class="text-sm text-stone-500 hover:text-stone-700 underline">{{ 'common.actions.cancel'|trans }}</a>
                                </div>
                            {{ form_end(mailForm) }}
                        {% else %}
                            <div class="flex items-center justify-between gap-4">
                                <p class="text-stone-700 text-sm">
                                    {{ 'ui.config.current_mail'|trans }}
                                    {% if user.mail is null %}
                                        <span class="text-stone-400 italic">{{ 'ui.config.none'|trans }}</span>
                                    {% else %}
                                        <span class="font-medium">{{ user.mail }}</span>
                                    {% endif %}
                                </p>
                                <a href="{{ path('profile_tab', {tab: 'lab', edit: 'mail'}) }}" data-turbo-frame="frame-lab" class="text-sm text-saffron-700 hover:text-saffron-600 underline shrink-0">{{ user.mail is null ? 'ui.config.add_mail'|trans : 'ui.config.change_mail'|trans }}</a>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-semibold text-stone-800 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-key text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.security.password'|trans }}
                    </h3>
                    <div class="card-warm p-5">
                        {% if editSection == 'password' %}
                            <p class="text-sm text-stone-600 mb-3">{{ 'ui.security.password_text'|trans }}</p>
                            {{ form_start(passwordForm, {'attr': {'class': 'space-y-4'}}) }}
                                {{ form_errors(passwordForm) }}
                                <div>
                                    {{ form_label(passwordForm.currentPassword, 'ui.security.current_password'|trans) }}
                                    {{ form_widget(passwordForm.currentPassword, {'attr': {'class': 'w-full px-4 py-2 mt-1 border rounded-md focus:outline-none focus:ring-1 focus:ring-saffron-600/30'}}) }}
                                    {{ form_errors(passwordForm.currentPassword) }}
                                </div>
                                <div>
                                    {{ form_label(passwordForm.plainPassword.first, 'ui.security.new_password'|trans) }}
                                    {{ form_widget(passwordForm.plainPassword.first, {'attr': {'class': 'w-full px-4 py-2 mt-1 border rounded-md focus:outline-none focus:ring-1 focus:ring-saffron-600/30'}}) }}
                                    {{ form_errors(passwordForm.plainPassword.first) }}
                                </div>
                                <div>
                                    {{ form_label(passwordForm.plainPassword.second, 'ui.security.confirm_password'|trans) }}
                                    {{ form_widget(passwordForm.plainPassword.second, {'attr': {'class': 'w-full px-4 py-2 mt-1 border rounded-md focus:outline-none focus:ring-1 focus:ring-saffron-600/30'}}) }}
                                </div>
                                <div class="flex items-center gap-3">
                                    <twig:Button label="{{ 'ui.security.change_password'|trans }}" variant="primary" size="sm" type="submit" />
                                    <a href="{{ path('profile_tab', {tab: 'lab'}) }}" class="text-sm text-stone-500 hover:text-stone-700 underline">{{ 'common.actions.cancel'|trans }}</a>
                                </div>
                            {{ form_end(passwordForm) }}
                        {% else %}
                            <div class="flex items-center justify-between gap-4">
                                <p class="text-stone-700 text-sm">
                                    <span class="font-medium tracking-widest">••••••••</span>
                                    <span class="text-stone-400 ml-2">{{ 'ui.security.password_masked'|trans }}</span>
                                </p>
                                <a href="{{ path('profile_tab', {tab: 'lab', edit: 'password'}) }}" data-turbo-frame="frame-lab" class="text-sm text-saffron-700 hover:text-saffron-600 underline shrink-0">{{ 'ui.security.change_password'|trans }}</a>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-semibold text-stone-800 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-shield-halved text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.security.auth'|trans }}
                    </h3>
                    <div class="card-warm p-5">
                        <div class="flex items-start justify-between gap-4">
                            <p class="text-sm text-stone-600">{{ 'ui.security.auth_text'|trans }}</p>
                            <span class="shrink-0 inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-400 border border-stone-200">{{ 'ui.security.coming_soon'|trans }}</span>
                        </div>
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-semibold text-stone-800 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-compass text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.discovery_path'|trans }}
                    </h3>
                    <div class="card-warm p-5">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-sm font-medium text-stone-800">{{ 'ui.config.replay_intro'|trans }}</p>
                                <p class="text-xs text-stone-500 mt-1">
                                    {{ 'ui.config.replay_intro_text'|trans }}
                                </p>
                            </div>
                            <twig:Button
                                label="{{ 'ui.config.replay'|trans }}"
                                variant="secondary"
                                size="sm"
                                icon="fa-solid fa-rotate-left"
                                x-data
                                @click="localStorage.removeItem('sm_onboarding'); window.location.href = '{{ path('home') }}';"
                                extra="shrink-0"
                            />
                        </div>
                    </div>
                </div>

                <div>
                    <h3 class="text-lg font-semibold text-stone-800 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-gauge-high text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.game_posture'|trans }}
                    </h3>
                    <div class="card-warm p-5">
                        <p class="text-sm text-stone-600 mb-3">
                            {{ 'ui.config.posture_intro'|trans }}
                        </p>
                        <form action="{{ path('update_difficulty_user') }}" method="POST">
                            <input type="hidden" name="_token" value="{{ csrf_token('update_difficulty') }}">
                            {% set difficulties = [
                                { value: 'easy', label: 'ui.config.commis'|trans, multiplier: '1' },
                                { value: 'medium', label: 'ui.config.cuisinier'|trans, multiplier: '1.5' },
                                { value: 'hard', label: 'ui.config.chef_partie'|trans, multiplier: '2' }
                            ] %}
                            <div class="flex flex-wrap gap-2 mb-3">
                                {% for d in difficulties %}
                                    <label class="cursor-pointer">
                                        <input type="radio" name="difficulty" value="{{ d.value }}"
                                               class="peer sr-only"
                                               {{ app.user.preferredDifficulty.value == d.value ? 'checked' : '' }}>
                                        <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-colors
                                            peer-checked:bg-saffron-600 peer-checked:text-white peer-checked:border-saffron-600
                                            bg-stone-100 text-stone-700 border-stone-200 hover:bg-stone-200">
                                            {{ d.label }}
                                            <span class="text-xs opacity-75">(x{{ d.multiplier }})</span>
                                        </span>
                                    </label>
                                {% endfor %}
                            </div>
                            <div class="text-xs text-stone-500 mb-3">
                                {% if app.user.preferredDifficulty.value == 'hard' %}
                                    {{ 'ui.config.posture_hard_html'|trans|raw }}
                                {% elseif app.user.preferredDifficulty.value == 'medium' %}
                                    {{ 'ui.config.posture_medium_html'|trans|raw }}
                                {% else %}
                                    {{ 'ui.config.posture_easy_html'|trans|raw }}
                                {% endif %}
                            </div>
                            <twig:Button label="{{ 'common.actions.save'|trans }}" variant="secondary" size="sm" type="submit" />
                        </form>
                    </div>
                </div>

                {% if app.user.progression %}
                <div>
                    <h3 class="text-lg font-semibold text-stone-800 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-shield-halved text-saffron-600 text-base" aria-hidden="true"></i>{{ 'ui.config.gamification_privacy'|trans }}
                    </h3>
                    <div class="card-warm p-5">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <p class="text-sm font-medium text-stone-800">{{ 'ui.config.progression_system'|trans }}</p>
                                <p class="text-xs text-stone-500 mt-1">
                                    {% if app.user.progression.gamificationEnabled %}
                                        {{ 'ui.config.gamification_on'|trans }}
                                    {% else %}
                                        {{ 'ui.config.gamification_off'|trans }}
                                    {% endif %}
                                </p>
                            </div>
                            <form action="{{ path('toggle_gamification_user') }}" method="POST" class="shrink-0">
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle_gamification') }}">
                                <twig:Button
                                    label="{{ app.user.progression.gamificationEnabled ? 'ui.config.disable'|trans : 'ui.config.enable'|trans }}"
                                    variant="secondary"
                                    size="sm"
                                    type="submit"
                                />
                            </form>
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>
        </section>
    </div>
</turbo-frame>
